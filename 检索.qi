// 检索 — 混合检索（向量 + BM25，RRF 融合）+ LLM 重排 + 一站式 RAG 入口
//
// 单路检索各有盲区：
//   - 纯向量：语义相近强，但「精确关键词/代号/型号」（QX-9000）语义平淡时常漏；
//   - 纯 BM25：关键词必中，但同义不同词（"提升吞吐" vs "跑得更快"）召不回。
// 混合 = 两路各取 top-K，用 **RRF（reciprocal rank fusion, k=60）** 融合：
//   分 = Σ 1/(60 + rank + 1)。只看名次不看分值，对两路分数量纲天然免疫、无需调权。
//
// ID 对齐约定（贴合 向量记忆.qi 的句柄/ID 体系）：
//   - 向量路复用 向量记忆 的 SQLite 表 + 向量索引（键 = 库句柄，id = 表自增 id）；
//   - 词法路是 标准库.词法索引（BM25，键任选——惯例直接用同一个库句柄）；
//   - 同一篇文档必须以 **同一个 id** 进两个索引：用 索引文档()（内部先 语义记住
//     拿 id，再以该 id 进词法索引）即可自动对齐。
//
// 嵌入配置走模块级 配置检索（同 文件工具/代理服务 的模块全局模式），
// 避免每个检索调用都拖 端点/密钥/模型 三个参数。
//
// 用法：
//   导入 Harness.检索::{配置检索, 索引文档, 混合检索, 重排, 检索};
//   配置检索(嵌入端点, 密钥, "text-embedding-v4");
//   变量 库: 整数 = 打开向量库("/tmp/知识库.db");
//   词法索引.重置(库);
//   索引文档(库, 库, 长文本, 600, 120);
//   变量 命中表: 整数 = 检索(库, 库, 会话, "如何减少慢查询", 8, 3);  // 字符串列表句柄

包 Harness;

导入 标准库.数据库;
导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 标准库.JSON 作为 J;
导入 标准库.向量索引 作为 向量索引;
导入 标准库.词法索引 作为 词法索引;
导入 标准库.大模型 作为 底层模型;
导入 Harness.向量记忆::{嵌入, 语义记住};
导入 Harness.文档::{分块, 最后出现};
导入 Harness.追踪::{事件};

// ── 模块级嵌入配置（配置检索 设置；索引文档/混合检索/检索 使用）──
变量 检索嵌入端点: 字符串 = "";
变量 检索嵌入密钥: 字符串 = "";
变量 检索嵌入模型: 字符串 = "";

公开 函数 配置检索(嵌入端点: 字符串, 密钥: 字符串, 嵌入模型: 字符串) : 整数 {
    检索嵌入端点 = 嵌入端点;
    检索嵌入密钥 = 密钥;
    检索嵌入模型 = 嵌入模型;
    返回 1;
}

// 清空模块级配置（owned 串放回字面量，进程退出前调用可保 RC 清零）。
// 之后 混合检索/检索 退化为纯 BM25；再用需重新 配置检索。
公开 函数 关闭检索() : 整数 {
    检索嵌入端点 = "";
    检索嵌入密钥 = "";
    检索嵌入模型 = "";
    返回 1;
}

// 按 id 取回文档内容（向量记忆 表）。没有返回 ""。
公开 函数 取文档内容(向量库: 整数, id: 整数) : 字符串 {
    变量 行JSON: 字符串 = 数据库.查询(向量库,
        "SELECT 内容 FROM 向量记忆 WHERE id = " + 整数转字符串(id));
    变量 行数组: 整数 = J.解码(行JSON);
    如果 (行数组 <= 0) { 返回 ""; }
    如果 (J.数组长度(行数组) == 0) { 返回 ""; }
    返回 J.获取字符串(J.数组获取对象(行数组, 0), "内容");
}

// 索引一篇文档：分块 → 每块 语义记住（嵌入 + 落库 + 进向量索引，拿 id）→
// 以同一 id 进词法索引（BM25）。返回成功入两路索引的块数。
公开 函数 索引文档(向量库: 整数, 词法句柄: 整数, 文本: 字符串, 块大小: 整数, 重叠: 整数) : 整数 {
    变量 块表: 整数 = 分块(文本, 块大小, 重叠);
    变量 n: 整数 = 列表库::字符串列表大小(块表);
    变量 成: 整数 = 0;
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 块: 字符串 = 列表库::获取字符串(块表, i);
        变量 id: 整数 = 语义记住(向量库, 检索嵌入端点, 检索嵌入密钥, 检索嵌入模型,
                                 "文档", 块, "", 3);
        如果 (id > 0) {
            词法索引.添加(词法句柄, id, 块);
            成 = 成 + 1;
        }
        i = i + 1;
    }
    列表库::删除列表(块表);
    返回 成;
}

// 命中数组（[{"id":..}...] 已按分降序）里 id 的名次（0 起）；不在返回 -1。
函数 排名位置(命中数组: 整数, id: 整数) : 整数 {
    如果 (命中数组 <= 0) { 返回 0 - 1; }
    变量 n: 整数 = J.数组长度(命中数组);
    变量 i: 整数 = 0;
    当 (i < n) {
        如果 (J.获取整数(J.数组获取对象(命中数组, i), "id") == id) { 返回 i; }
        i = i + 1;
    }
    返回 0 - 1;
}

// 把一路命中的 id 去重并入 id表。
函数 收集id(命中数组: 整数, id表: 整数) : 整数 {
    如果 (命中数组 <= 0) { 返回 0; }
    变量 n: 整数 = J.数组长度(命中数组);
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 id: 整数 = J.获取整数(J.数组获取对象(命中数组, i), "id");
        如果 (列表库::查找整数索引(id表, id) < 0) {
            列表库::添加整数(id表, id);
        }
        i = i + 1;
    }
    返回 n;
}

// 混合检索：向量 top-K + BM25 top-K → RRF 融合去重 → top-K。
// 返回 JSON 数组 [{"id":..,"rrf":..}]（按融合分降序）。
// 嵌入未配置或查询嵌入失败时自动退化为纯 BM25（不崩）。
公开 函数 混合检索(向量库: 整数, 词法句柄: 整数, 查询: 字符串, K: 整数) : 字符串 {
    变量 k: 整数 = K;
    如果 (k <= 0) { k = 5; }

    // 向量路（可用才走）
    变量 向量命中: 整数 = 0;
    如果 (字符串::字节长度(检索嵌入端点) > 0) {
        变量 查询向量: 字符串 = 嵌入(检索嵌入端点, 检索嵌入密钥, 检索嵌入模型, 查询);
        如果 (字符串::字节长度(查询向量) > 0) {
            向量命中 = J.解码(向量索引.搜索(向量库, 查询向量, k));
        } 否则 {
            事件("embed_fail", "检索", "查询未能向量化，退化为纯 BM25: " + 查询);
        }
    }
    // 词法路
    变量 词法命中: 整数 = J.解码(词法索引.搜索(词法句柄, 查询, k));

    // 并集 id → 逐 id 算 RRF 分（分 = Σ 1/(60 + rank + 1)，只看名次）
    变量 id表: 整数 = 列表库::创建整数列表();
    收集id(向量命中, id表);
    收集id(词法命中, id表);
    变量 数: 整数 = 列表库::整数列表大小(id表);

    变量 分表: 整数 = 列表库::创建浮点列表();
    变量 i: 整数 = 0;
    当 (i < 数) {
        变量 id: 整数 = 列表库::获取整数(id表, i);
        变量 分: 浮点数 = 0.0;
        变量 rv: 整数 = 排名位置(向量命中, id);
        如果 (rv >= 0) { 分 = 分 + 1.0 / (60.0 + 整数转浮点数(rv) + 1.0); }
        变量 rl: 整数 = 排名位置(词法命中, id);
        如果 (rl >= 0) { 分 = 分 + 1.0 / (60.0 + 整数转浮点数(rl) + 1.0); }
        列表库::添加浮点数(分表, 分);
        i = i + 1;
    }

    // 选出融合分 top-K（重复取最大 + 已用标记，K 小无需真排序）
    变量 已用: 整数 = 列表库::创建整数列表();
    i = 0;
    当 (i < 数) { 列表库::添加整数(已用, 0); i = i + 1; }

    变量 出数组: 整数 = J.创建数组();
    变量 取数: 整数 = k;
    如果 (取数 > 数) { 取数 = 数; }
    变量 r: 整数 = 0;
    当 (r < 取数) {
        变量 最好: 整数 = 0 - 1;
        变量 最好分: 浮点数 = 0.0 - 1.0;
        i = 0;
        当 (i < 数) {
            如果 (列表库::获取整数(已用, i) == 0 && 列表库::获取浮点数(分表, i) > 最好分) {
                最好 = i;
                最好分 = 列表库::获取浮点数(分表, i);
            }
            i = i + 1;
        }
        如果 (最好 < 0) { 跳出; }
        列表库::设置整数(已用, 最好, 1);
        变量 项: 整数 = J.创建对象();
        J.设置整数(项, "id", 列表库::获取整数(id表, 最好));
        J.设置浮点数(项, "rrf", 最好分);
        J.数组添加对象(出数组, 项);
        r = r + 1;
    }
    列表库::删除列表(id表);
    列表库::删除列表(分表);
    列表库::删除列表(已用);
    返回 J.转字符串(出数组);
}

// 从模型回复里抠第一个 [ 到最后一个 ] 的 JSON 数组并解码；失败返回 0。
函数 解析序号数组(回复: 字符串) : 整数 {
    变量 开: 整数 = 字符串::查找(回复, "[");
    如果 (开 < 0) { 返回 0; }
    变量 闭: 整数 = 最后出现(回复, "]");
    如果 (闭 < 开) { 返回 0; }
    返回 J.解码(字符串::子串(回复, 开, 闭 - 开 + 1));
}

// LLM-as-reranker：候选（带序号）一次性拼进提示，让模型按相关性输出序号 JSON 数组，
// 解析后重排取 top-N。批量单次调用（不逐候选打分）。任何解析失败/漏排都按原序补齐，不崩。
// 候选表/返回值均为字符串列表句柄。
公开 函数 重排(会话: 整数, 查询: 字符串, 候选表: 整数, N: 整数) : 整数 {
    变量 数: 整数 = 列表库::字符串列表大小(候选表);
    变量 n: 整数 = N;
    如果 (n <= 0 || n > 数) { n = 数; }
    变量 出表: 整数 = 列表库::创建字符串列表();
    如果 (数 == 0) { 返回 出表; }

    变量 已选: 整数 = 列表库::创建整数列表();
    如果 (会话 > 0 && 数 > 1) {
        变量 提示: 字符串 = "你是检索重排器。给定查询与候选文档，按与查询的相关性从高到低排列候选序号。\n"
            + "只输出一个 JSON 数组（候选序号，0 起，全部候选都要出现），不要输出任何其他文字。例如: [2,0,1]\n\n"
            + "查询: " + 查询 + "\n\n候选:\n";
        变量 i: 整数 = 0;
        当 (i < 数) {
            提示 = 提示 + "[" + 整数转字符串(i) + "] " + 列表库::获取字符串(候选表, i) + "\n";
            i = i + 1;
        }
        变量 回复: 字符串 = 底层模型.对话(会话, 提示);
        变量 序数组: 整数 = 解析序号数组(回复);
        如果 (序数组 > 0) {
            变量 m: 整数 = J.数组长度(序数组);
            i = 0;
            当 (i < m && 列表库::字符串列表大小(出表) < n) {
                变量 序: 整数 = J.数组获取整数(序数组, i);
                如果 (序 >= 0 && 序 < 数 && 列表库::查找整数索引(已选, 序) < 0) {
                    列表库::添加整数(已选, 序);
                    列表库::添加字符串(出表, 列表库::获取字符串(候选表, 序));
                }
                i = i + 1;
            }
        } 否则 {
            事件("rerank_fallback", "检索", "重排输出不可解析，退回原序");
        }
    }

    // 不足 n 条按原序补齐（无会话/单候选/解析失败/模型漏排 全走这里）
    变量 j: 整数 = 0;
    当 (j < 数 && 列表库::字符串列表大小(出表) < n) {
        如果 (列表库::查找整数索引(已选, j) < 0) {
            列表库::添加整数(已选, j);
            列表库::添加字符串(出表, 列表库::获取字符串(候选表, j));
        }
        j = j + 1;
    }
    列表库::删除列表(已选);
    返回 出表;
}

// 一站式检索：混合召回 top-召回K → LLM 重排 → top-精排N 文本列表（字符串列表句柄）。
公开 函数 检索(向量库: 整数, 词法句柄: 整数, 会话: 整数, 查询: 字符串,
              召回K: 整数, 精排N: 整数) : 整数 {
    变量 融合JSON: 字符串 = 混合检索(向量库, 词法句柄, 查询, 召回K);
    变量 候选表: 整数 = 列表库::创建字符串列表();
    变量 融合数组: 整数 = J.解码(融合JSON);
    如果 (融合数组 > 0) {
        变量 n: 整数 = J.数组长度(融合数组);
        变量 i: 整数 = 0;
        当 (i < n) {
            变量 内容: 字符串 = 取文档内容(向量库,
                J.获取整数(J.数组获取对象(融合数组, i), "id"));
            如果 (字符串::字节长度(内容) > 0) {
                列表库::添加字符串(候选表, 内容);
            }
            i = i + 1;
        }
    }
    变量 出表: 整数 = 重排(会话, 查询, 候选表, 精排N);
    列表库::删除列表(候选表);
    返回 出表;
}
