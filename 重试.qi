// 重试 — exponential backoff for LLM 调用
//
// LLM 调用容易遇到 429 限流、5xx、网络抖动。Harness 层在每次模型调用周围
// 套这个 helper：3 次重试、指数 backoff（起 100ms 翻倍），失败照抛。

包 Harness;

导入 标准库.字符串;
导入 标准库.时间;
导入 标准库.列表 作为 列表库;
导入 标准库.JSON 作为 J;
导入 Harness.追踪::{事件, 错误事件};
导入 Harness.事件::{发出当前生命周期事件};

公开 类型 重试策略 {
    最大次数: 整数,         // 总试次次数（含第一次），默认 3
    起始延迟毫秒: 整数,      // 第一次失败后等多久，默认 100
    最大延迟毫秒: 整数,      // 上限，默认 10000
    倍数: 整数,              // backoff 倍数（×10 整数表达，3 = 1.0 ×… 暂 simplify 为整数倍数 2/3/4），默认 2
}

公开 函数 默认策略() : 重试策略 {
    返回 新建 重试策略 {
        最大次数: 3,
        起始延迟毫秒: 100,
        最大延迟毫秒: 10000,
        倍数: 2,
    };
}

函数 重试载荷(试次: 整数, 最大次数: 整数, 延迟毫秒: 整数, 结果值: 字符串, 类别: 整数) : 字符串 {
    变量 根: 整数 = J.创建对象();
    J.设置整数(根, "attempt", 试次);
    J.设置整数(根, "max_attempts", 最大次数);
    J.设置整数(根, "delay_ms", 延迟毫秒);
    如果 (字符串::字节长度(结果值) > 0) { J.设置字符串(根, "result", 结果值); }
    如果 (类别 >= 0) { J.设置整数(根, "category", 类别); }
    变量 文本: 字符串 = J.转字符串(根);
    J.删除(根);
    返回 文本;
}

函数 发出重试开始(代理名: 字符串, 下一试次: 整数, 策略: 重试策略, 延迟毫秒: 整数) {
    发出当前生命周期事件("retry_start", 代理名,
        重试载荷(下一试次, 策略.最大次数, 延迟毫秒, "", 0 - 1));
}

函数 发出重试结束(代理名: 字符串, 试次: 整数, 策略: 重试策略, 类别: 整数) {
    变量 结果值: 字符串 = "failed";
    如果 (类别 == 0) { 结果值 = "success"; }
    否则如果 (类别 == 2) { 结果值 = "fatal"; }
    发出当前生命周期事件("retry_end", 代理名,
        重试载荷(试次, 策略.最大次数, 0, 结果值, 类别));
}

函数 发出重试错误(代理名: 字符串, 原因: 字符串, 试次: 整数, 最大次数: 整数) {
    变量 根: 整数 = J.创建对象();
    J.设置字符串(根, "source", "retry");
    J.设置字符串(根, "reason", 原因);
    J.设置整数(根, "attempt", 试次);
    J.设置整数(根, "max_attempts", 最大次数);
    变量 载荷: 字符串 = J.转字符串(根);
    J.删除(根);
    发出当前生命周期事件("error", 代理名, 载荷);
}

// 判断是否「值得重试」的响应——简单策略：包含 "error" 或空字符串视为失败
// 实际可改成 parse JSON 看 status_code。
公开 函数 是失败(响应: 字符串) : 整数 {
    如果 (字符串::字节长度(响应) == 0) {
        返回 1;
    }
    // harness 自身错误统一以 [harness] 开头；正常 JSON 数组不能误判为失败。
    如果 (字符串::开始于(响应, "[harness]") == 1) {
        返回 1;
    }
    // 底层 LLM 调用失败时返回 "LLM调用失败: ..."（如 401/网络错误），
    // 之前漏判导致真实错误不会触发重试。这里补上。
    如果 (字符串::开始于(响应, "LLM调用失败") == 1) {
        返回 1;
    }
    返回 0;
}

// 调用方传一个零参数 closure，本函数包重试。closure 必须返回 字符串。
公开 函数 重试调用(策略: 重试策略, 代理名: 字符串, 调用: 函数(): 字符串) : 字符串 {
    变量 试次: 整数 = 0;
    变量 延迟: 整数 = 策略.起始延迟毫秒;
    变量 上次响应: 字符串 = "";
    变量 重试进行中: 整数 = 0;

    当 (试次 < 策略.最大次数) {
        上次响应 = 调用();
        如果 (是失败(上次响应) == 0) {
            如果 (重试进行中 == 1) { 发出重试结束(代理名, 试次 + 1, 策略, 0); }
            如果 (试次 > 0) {
                事件("retry_ok", 代理名, "成功于试次 " + 整数转字符串(试次 + 1));
            }
            返回 上次响应;
        }
        如果 (重试进行中 == 1) {
            发出重试结束(代理名, 试次 + 1, 策略, 1);
            重试进行中 = 0;
        }
        试次 = 试次 + 1;
        如果 (试次 < 策略.最大次数) {
            发出重试开始(代理名, 试次 + 1, 策略, 延迟);
            重试进行中 = 1;
            事件("retry", 代理名,
                "试次 " + 整数转字符串(试次) + " 失败，延迟 " + 整数转字符串(延迟) + " ms");
            时间.睡眠毫秒(延迟);
            延迟 = 延迟 * 策略.倍数;
            如果 (延迟 > 策略.最大延迟毫秒) {
                延迟 = 策略.最大延迟毫秒;
            }
        }
    }
    错误事件(代理名, "重试 " + 整数转字符串(策略.最大次数) + " 次全部失败");
    发出重试错误(代理名, "exhausted", 策略.最大次数, 策略.最大次数);
    返回 上次响应;
}

// ===== 错误分类 =====
// 0 = 成功；1 = 可重试（429 / 5xx / 超时 / 网络抖动 / 空响应）；2 = 致命（4xx，别浪费退避）
// LLM 对话只回文本，拿不到 HTTP status，只能按错误串里的特征分类（best-effort）。
公开 函数 错误类别(响应: 字符串) : 整数 {
    如果 (字符串::字节长度(响应) == 0) { 返回 1; }   // 空 = 网络层挂了，值得重试

    // 只对明确的底层/框架错误串解释 HTTP 状态码。正常回答可能包含“400”“503”等数字，
    // 不能因为内容碰巧含状态码就被默认 Agent 重试。
    变量 是错误串: 整数 = 0;
    如果 (字符串::开始于(响应, "LLM调用失败") == 1) { 是错误串 = 1; }
    如果 (字符串::开始于(响应, "工具对话失败") == 1) { 是错误串 = 1; }
    如果 (字符串::开始于(响应, "继续工具对话失败") == 1) { 是错误串 = 1; }
    如果 (字符串::开始于(响应, "HTTP错误") == 1) { 是错误串 = 1; }
    如果 (字符串::开始于(响应, "[harness]") == 1) { 是错误串 = 1; }
    如果 (是错误串 == 0) { 返回 0; }

    // 致命：鉴权 / 请求本身错，重试也没用
    如果 (字符串::包含(响应, "401") == 1) { 返回 2; }
    如果 (字符串::包含(响应, "403") == 1) { 返回 2; }
    如果 (字符串::包含(响应, "400") == 1) { 返回 2; }
    如果 (字符串::包含(响应, "404") == 1) { 返回 2; }
    如果 (字符串::包含(响应, "405") == 1) { 返回 2; }
    如果 (字符串::包含(响应, "422") == 1) { 返回 2; }
    如果 (字符串::包含(响应, "invalid_api_key") == 1) { 返回 2; }
    如果 (字符串::包含(响应, "Unauthorized") == 1) { 返回 2; }
    如果 (字符串::包含(响应, "budget_exceeded") == 1) { 返回 2; }

    // 可重试：限流 / 服务端 / 超时
    如果 (字符串::包含(响应, "429") == 1) { 返回 1; }
    如果 (字符串::包含(响应, "500") == 1) { 返回 1; }
    如果 (字符串::包含(响应, "502") == 1) { 返回 1; }
    如果 (字符串::包含(响应, "503") == 1) { 返回 1; }
    如果 (字符串::包含(响应, "504") == 1) { 返回 1; }
    如果 (字符串::包含(响应, "timeout") == 1) { 返回 1; }
    如果 (字符串::包含(响应, "超时") == 1) { 返回 1; }

    返回 1;   // 已确认是错误串，未知网络错误按可重试处理
}

// ===== 重试资源 =====
// 句柄 0 保留给兼容的进程级 API。新 Agent 各自创建资源，也可显式共享同一句柄。
// 令牌用千分之一枚为单位存储，避免可变浮点状态并保留毫秒级补充精度。
变量 熔断阈值表: 整数 = 0;
变量 熔断冷却表: 整数 = 0;
变量 连续失败表: 整数 = 0;
变量 断路开启表: 整数 = 0;
变量 桶容量表: 整数 = 0;
变量 桶令牌千分表: 整数 = 0;
变量 每秒许可表: 整数 = 0;
变量 上次补充表: 整数 = 0;
变量 资源启用表: 整数 = 0;
变量 资源表已建: 整数 = 0;

函数 添加默认资源() : 整数 {
    变量 句柄: 整数 = 列表库::整数列表大小(熔断阈值表);
    列表库::添加整数(熔断阈值表, 5);
    列表库::添加整数(熔断冷却表, 30000);
    列表库::添加整数(连续失败表, 0);
    列表库::添加整数(断路开启表, 0);
    列表库::添加整数(桶容量表, 0);
    列表库::添加整数(桶令牌千分表, 0);
    列表库::添加整数(每秒许可表, 0);
    列表库::添加整数(上次补充表, 0);
    列表库::添加整数(资源启用表, 1);
    返回 句柄;
}

函数 重置资源(句柄: 整数) {
    列表库::设置整数(熔断阈值表, 句柄, 5);
    列表库::设置整数(熔断冷却表, 句柄, 30000);
    列表库::设置整数(连续失败表, 句柄, 0);
    列表库::设置整数(断路开启表, 句柄, 0);
    列表库::设置整数(桶容量表, 句柄, 0);
    列表库::设置整数(桶令牌千分表, 句柄, 0);
    列表库::设置整数(每秒许可表, 句柄, 0);
    列表库::设置整数(上次补充表, 句柄, 0);
    列表库::设置整数(资源启用表, 句柄, 1);
}

函数 确保资源表() {
    如果 (资源表已建 == 0) {
        熔断阈值表 = 列表库::创建整数列表();
        熔断冷却表 = 列表库::创建整数列表();
        连续失败表 = 列表库::创建整数列表();
        断路开启表 = 列表库::创建整数列表();
        桶容量表 = 列表库::创建整数列表();
        桶令牌千分表 = 列表库::创建整数列表();
        每秒许可表 = 列表库::创建整数列表();
        上次补充表 = 列表库::创建整数列表();
        资源启用表 = 列表库::创建整数列表();
        资源表已建 = 1;
        添加默认资源();
    }
}

公开 函数 创建重试资源() : 整数 {
    确保资源表();
    变量 i: 整数 = 1;
    变量 总数: 整数 = 列表库::整数列表大小(资源启用表);
    当 (i < 总数) {
        如果 (列表库::获取整数(资源启用表, i) == 0) {
            重置资源(i);
            返回 i;
        }
        i = i + 1;
    }
    返回 添加默认资源();
}

公开 函数 重试资源有效(资源句柄: 整数) : 整数 {
    确保资源表();
    如果 (资源句柄 < 0 || 资源句柄 >= 列表库::整数列表大小(资源启用表)) { 返回 0; }
    返回 列表库::获取整数(资源启用表, 资源句柄);
}

// 资源 0 是兼容进程级资源，不允许释放。成功释放返回 1，随后句柄可被创建调用复用。
公开 函数 释放重试资源(资源句柄: 整数) : 整数 {
    如果 (资源句柄 <= 0 || 重试资源有效(资源句柄) == 0) { 返回 0; }
    列表库::设置整数(连续失败表, 资源句柄, 0);
    列表库::设置整数(断路开启表, 资源句柄, 0);
    列表库::设置整数(桶容量表, 资源句柄, 0);
    列表库::设置整数(桶令牌千分表, 资源句柄, 0);
    列表库::设置整数(每秒许可表, 资源句柄, 0);
    列表库::设置整数(上次补充表, 资源句柄, 0);
    列表库::设置整数(资源启用表, 资源句柄, 0);
    返回 1;
}

公开 函数 配置资源熔断(资源句柄: 整数, 阈值: 整数, 冷却毫秒: 整数) : 整数 {
    如果 (重试资源有效(资源句柄) == 0) { 返回 0; }
    列表库::设置整数(熔断阈值表, 资源句柄, 阈值);
    列表库::设置整数(熔断冷却表, 资源句柄, 冷却毫秒);
    返回 1;
}

// 1 = 允许；0 = 断路打开且仍在冷却期。
公开 函数 资源熔断允许(资源句柄: 整数) : 整数 {
    如果 (重试资源有效(资源句柄) == 0) { 返回 0; }
    变量 开启时刻: 整数 = 列表库::获取整数(断路开启表, 资源句柄);
    如果 (开启时刻 == 0) { 返回 1; }
    变量 过去: 整数 = 时间.当前毫秒() - 开启时刻;
    如果 (过去 >= 列表库::获取整数(熔断冷却表, 资源句柄)) {
        列表库::设置整数(断路开启表, 资源句柄, 0);
        列表库::设置整数(连续失败表, 资源句柄, 0);
        事件("circuit_half_open", "熔断", "冷却结束，放行试探");
        返回 1;
    }
    返回 0;
}

公开 函数 资源熔断记成功(资源句柄: 整数) {
    如果 (重试资源有效(资源句柄) == 0) { 返回; }
    列表库::设置整数(连续失败表, 资源句柄, 0);
    列表库::设置整数(断路开启表, 资源句柄, 0);
}

公开 函数 资源熔断记失败(资源句柄: 整数) {
    如果 (重试资源有效(资源句柄) == 0) { 返回; }
    变量 失败数: 整数 = 列表库::获取整数(连续失败表, 资源句柄) + 1;
    列表库::设置整数(连续失败表, 资源句柄, 失败数);
    如果 (失败数 >= 列表库::获取整数(熔断阈值表, 资源句柄)) {
        列表库::设置整数(断路开启表, 资源句柄, 时间.当前毫秒());
        事件("circuit_open", "熔断", "连续失败 " + 整数转字符串(失败数)
            + " 次，断路打开 "
            + 整数转字符串(列表库::获取整数(熔断冷却表, 资源句柄)) + "ms");
    }
}

公开 函数 资源熔断状态(资源句柄: 整数) : 字符串 {
    如果 (重试资源有效(资源句柄) == 0) { 返回 "无效"; }
    如果 (列表库::获取整数(断路开启表, 资源句柄) == 0) { 返回 "闭合"; }
    返回 "打开";
}

函数 补充资源令牌(资源句柄: 整数) {
    变量 现: 整数 = 时间.当前毫秒();
    变量 流逝: 整数 = 现 - 列表库::获取整数(上次补充表, 资源句柄);
    如果 (流逝 > 0) {
        变量 令牌: 整数 = 列表库::获取整数(桶令牌千分表, 资源句柄)
            + 流逝 * 列表库::获取整数(每秒许可表, 资源句柄);
        变量 上限: 整数 = 列表库::获取整数(桶容量表, 资源句柄) * 1000;
        如果 (令牌 > 上限) { 令牌 = 上限; }
        列表库::设置整数(桶令牌千分表, 资源句柄, 令牌);
        列表库::设置整数(上次补充表, 资源句柄, 现);
    }
}

公开 函数 配置资源限流(资源句柄: 整数, 每秒许可: 整数, 容量: 整数) : 整数 {
    如果 (重试资源有效(资源句柄) == 0) { 返回 0; }
    如果 (每秒许可 <= 0 || 容量 <= 0) {
        列表库::设置整数(桶容量表, 资源句柄, 0);
        列表库::设置整数(桶令牌千分表, 资源句柄, 0);
        列表库::设置整数(每秒许可表, 资源句柄, 0);
        返回 0;
    }
    列表库::设置整数(桶容量表, 资源句柄, 容量);
    列表库::设置整数(桶令牌千分表, 资源句柄, 容量 * 1000);
    列表库::设置整数(每秒许可表, 资源句柄, 每秒许可);
    列表库::设置整数(上次补充表, 资源句柄, 时间.当前毫秒());
    返回 1;
}

// 非阻塞取令牌。成功或未启用返回 1，不足返回 0。
公开 函数 资源限流尝试获取(资源句柄: 整数) : 整数 {
    如果 (重试资源有效(资源句柄) == 0) { 返回 0; }
    如果 (列表库::获取整数(桶容量表, 资源句柄) == 0) { 返回 1; }
    补充资源令牌(资源句柄);
    变量 令牌: 整数 = 列表库::获取整数(桶令牌千分表, 资源句柄);
    如果 (令牌 < 1000) { 返回 0; }
    列表库::设置整数(桶令牌千分表, 资源句柄, 令牌 - 1000);
    返回 1;
}

// 阻塞取一个令牌；未启用时立即返回。
公开 函数 资源限流获取(资源句柄: 整数) {
    如果 (重试资源有效(资源句柄) == 0) { 返回; }
    如果 (列表库::获取整数(桶容量表, 资源句柄) == 0) { 返回; }
    当 (资源限流尝试获取(资源句柄) == 0) {
        变量 缺: 整数 = 1000 - 列表库::获取整数(桶令牌千分表, 资源句柄);
        变量 速率: 整数 = 列表库::获取整数(每秒许可表, 资源句柄);
        时间.睡眠毫秒((缺 + 速率 - 1) / 速率);
    }
}

// 兼容 API 继续使用资源 0，保留原来的进程级共享语义。
公开 函数 配置熔断(阈值: 整数, 冷却毫秒: 整数) : 整数 {
    返回 配置资源熔断(0, 阈值, 冷却毫秒);
}

公开 函数 熔断允许() : 整数 { 返回 资源熔断允许(0); }
公开 函数 熔断记成功() { 资源熔断记成功(0); }
公开 函数 熔断记失败() { 资源熔断记失败(0); }
公开 函数 熔断状态() : 字符串 { 返回 资源熔断状态(0); }

公开 函数 配置限流(每秒许可: 整数, 容量: 整数) : 整数 {
    返回 配置资源限流(0, 每秒许可, 容量);
}

公开 函数 限流获取() { 资源限流获取(0); }

// ===== 智能重试 =====
// 比 重试调用 更聪明：先过限流 + 熔断闸；按 错误类别 决定——致命(2)立即返回不重试，
// 可重试(1)才退避。每次结果记进熔断器。断路打开时直接快失败。
公开 函数 智能重试调用(策略: 重试策略, 代理名: 字符串, 调用: 函数(): 字符串) : 字符串 {
    返回 智能重试调用使用资源(0, 策略, 代理名, 调用);
}

// 使用显式重试资源的智能重试；多个调用传同一句柄即可共享熔断和令牌桶。
公开 函数 智能重试调用使用资源(
    资源句柄: 整数,
    策略: 重试策略,
    代理名: 字符串,
    调用: 函数(): 字符串
) : 字符串 {
    变量 试次: 整数 = 0;
    变量 延迟: 整数 = 策略.起始延迟毫秒;
    变量 上次响应: 字符串 = "";
    变量 重试进行中: 整数 = 0;

    当 (试次 < 策略.最大次数) {
        如果 (资源熔断允许(资源句柄) == 0) {
            错误事件(代理名, "熔断打开，快失败（冷却中）");
            如果 (重试进行中 == 1) { 发出重试结束(代理名, 试次 + 1, 策略, 1); }
            发出重试错误(代理名, "circuit_open", 试次 + 1, 策略.最大次数);
            返回 "[harness] 熔断打开，请求被快失败";
        }
        资源限流获取(资源句柄);
        上次响应 = 调用();
        变量 类别: 整数 = 错误类别(上次响应);

        如果 (类别 == 0) {
            资源熔断记成功(资源句柄);
            如果 (重试进行中 == 1) { 发出重试结束(代理名, 试次 + 1, 策略, 0); }
            如果 (试次 > 0) { 事件("retry_ok", 代理名, "成功于试次 " + 整数转字符串(试次 + 1)); }
            返回 上次响应;
        }
        资源熔断记失败(资源句柄);
        如果 (重试进行中 == 1) {
            发出重试结束(代理名, 试次 + 1, 策略, 类别);
            重试进行中 = 0;
        }
        如果 (类别 == 2) {
            错误事件(代理名, "致命错误，不重试: " + 上次响应);
            发出重试错误(代理名, "fatal", 试次 + 1, 策略.最大次数);
            返回 上次响应;
        }

        试次 = 试次 + 1;
        如果 (试次 < 策略.最大次数) {
            发出重试开始(代理名, 试次 + 1, 策略, 延迟);
            重试进行中 = 1;
            事件("retry", 代理名, "试次 " + 整数转字符串(试次) + " 可重试错误，延迟 " + 整数转字符串(延迟) + " ms");
            时间.睡眠毫秒(延迟);
            延迟 = 延迟 * 策略.倍数;
            如果 (延迟 > 策略.最大延迟毫秒) { 延迟 = 策略.最大延迟毫秒; }
        }
    }
    错误事件(代理名, "智能重试 " + 整数转字符串(策略.最大次数) + " 次全部失败");
    发出重试错误(代理名, "exhausted", 策略.最大次数, 策略.最大次数);
    返回 上次响应;
}

// 带两个显式参数的智能重试。用于 Agent 把会话句柄和提示传入底层调用，
// 避免用模块级“当前会话/当前提示”模拟 closure，保证并行 Agent 不串线。
公开 函数 智能重试调用带参数(
    策略: 重试策略,
    代理名: 字符串,
    参数1: 整数,
    参数2: 字符串,
    调用: 函数(整数, 字符串): 字符串
) : 字符串 {
    返回 智能重试调用带参数使用资源(0, 策略, 代理名, 参数1, 参数2, 调用);
}

公开 函数 智能重试调用带参数使用资源(
    资源句柄: 整数,
    策略: 重试策略,
    代理名: 字符串,
    参数1: 整数,
    参数2: 字符串,
    调用: 函数(整数, 字符串): 字符串
) : 字符串 {
    变量 试次: 整数 = 0;
    变量 延迟: 整数 = 策略.起始延迟毫秒;
    变量 上次响应: 字符串 = "";
    变量 重试进行中: 整数 = 0;

    当 (试次 < 策略.最大次数) {
        如果 (资源熔断允许(资源句柄) == 0) {
            错误事件(代理名, "熔断打开，快失败（冷却中）");
            如果 (重试进行中 == 1) { 发出重试结束(代理名, 试次 + 1, 策略, 1); }
            发出重试错误(代理名, "circuit_open", 试次 + 1, 策略.最大次数);
            返回 "[harness] 熔断打开，请求被快失败";
        }
        资源限流获取(资源句柄);
        上次响应 = 调用(参数1, 参数2);
        变量 类别: 整数 = 错误类别(上次响应);

        如果 (类别 == 0) {
            资源熔断记成功(资源句柄);
            如果 (重试进行中 == 1) { 发出重试结束(代理名, 试次 + 1, 策略, 0); }
            如果 (试次 > 0) { 事件("retry_ok", 代理名, "成功于试次 " + 整数转字符串(试次 + 1)); }
            返回 上次响应;
        }
        资源熔断记失败(资源句柄);
        如果 (重试进行中 == 1) {
            发出重试结束(代理名, 试次 + 1, 策略, 类别);
            重试进行中 = 0;
        }
        如果 (类别 == 2) {
            错误事件(代理名, "致命错误，不重试: " + 上次响应);
            发出重试错误(代理名, "fatal", 试次 + 1, 策略.最大次数);
            返回 上次响应;
        }

        试次 = 试次 + 1;
        如果 (试次 < 策略.最大次数) {
            发出重试开始(代理名, 试次 + 1, 策略, 延迟);
            重试进行中 = 1;
            事件("retry", 代理名, "试次 " + 整数转字符串(试次) + " 可重试错误，延迟 " + 整数转字符串(延迟) + " ms");
            时间.睡眠毫秒(延迟);
            延迟 = 延迟 * 策略.倍数;
            如果 (延迟 > 策略.最大延迟毫秒) { 延迟 = 策略.最大延迟毫秒; }
        }
    }
    错误事件(代理名, "智能重试 " + 整数转字符串(策略.最大次数) + " 次全部失败");
    发出重试错误(代理名, "exhausted", 策略.最大次数, 策略.最大次数);
    返回 上次响应;
}
