// 重试 — exponential backoff for LLM 调用
//
// LLM 调用容易遇到 429 限流、5xx、网络抖动。Harness 层在每次模型调用周围
// 套这个 helper：3 次重试、指数 backoff（起 100ms 翻倍），失败照抛。

包 Harness;

导入 标准库.字符串;
导入 标准库.时间;
导入 Harness.追踪::{事件, 错误事件};

公开 类型 重试策略 {
    最大次数: 整数,         // 总试次次数（含第一次），默认 3
    起始延迟毫秒: 整数,      // 第一次失败后等多久，默认 100
    最大延迟毫秒: 整数,      // 上限，默认 10000
    倍数: 整数,              // backoff 倍数（×10 整数表达，3 = 1.0 ×… 暂 simplify 为整数倍数 2/3/4），默认 2
}

公开 函数 默认策略() : 重试策略 {
    返回 新建 重试策略 {
        最大次数: 3,
        起始延迟毫秒: 100,
        最大延迟毫秒: 10000,
        倍数: 2,
    };
}

// 判断是否「值得重试」的响应——简单策略：包含 "error" 或空字符串视为失败
// 实际可改成 parse JSON 看 status_code。
公开 函数 是失败(响应: 字符串) : 整数 {
    如果 (字符串::字节长度(响应) == 0) {
        返回 1;
    }
    // 简易检测：以 "[" 错误前缀开头（harness::一次对话 失败 fallback 用这格式）
    如果 (字符串::开始于(响应, "[") == 1) {
        返回 1;
    }
    // 底层 LLM 调用失败时返回 "LLM调用失败: ..."（如 401/网络错误），
    // 之前漏判导致真实错误不会触发重试。这里补上。
    如果 (字符串::开始于(响应, "LLM调用失败") == 1) {
        返回 1;
    }
    返回 0;
}

// 调用方传一个零参数 closure，本函数包重试。closure 必须返回 字符串。
公开 函数 重试调用(策略: 重试策略, 代理名: 字符串, 调用: 函数(): 字符串) : 字符串 {
    变量 试次: 整数 = 0;
    变量 延迟: 整数 = 策略.起始延迟毫秒;
    变量 上次响应: 字符串 = "";

    当 (试次 < 策略.最大次数) {
        上次响应 = 调用();
        如果 (是失败(上次响应) == 0) {
            如果 (试次 > 0) {
                事件("retry_ok", 代理名, "成功于试次 " + 整数转字符串(试次 + 1));
            }
            返回 上次响应;
        }
        试次 = 试次 + 1;
        如果 (试次 < 策略.最大次数) {
            事件("retry", 代理名,
                "试次 " + 整数转字符串(试次) + " 失败，延迟 " + 整数转字符串(延迟) + " ms");
            时间.睡眠毫秒(延迟);
            延迟 = 延迟 * 策略.倍数;
            如果 (延迟 > 策略.最大延迟毫秒) {
                延迟 = 策略.最大延迟毫秒;
            }
        }
    }
    错误事件(代理名, "重试 " + 整数转字符串(策略.最大次数) + " 次全部失败");
    返回 上次响应;
}

// ===== 错误分类 =====
// 0 = 成功；1 = 可重试（429 / 5xx / 超时 / 网络抖动 / 空响应）；2 = 致命（4xx，别浪费退避）
// LLM 对话只回文本，拿不到 HTTP status，只能按错误串里的特征分类（best-effort）。
公开 函数 错误类别(响应: 字符串) : 整数 {
    如果 (字符串::字节长度(响应) == 0) { 返回 1; }   // 空 = 网络层挂了，值得重试

    // 致命：鉴权 / 请求本身错，重试也没用
    如果 (字符串::包含(响应, "401") == 1) { 返回 2; }
    如果 (字符串::包含(响应, "403") == 1) { 返回 2; }
    如果 (字符串::包含(响应, "400") == 1) { 返回 2; }
    如果 (字符串::包含(响应, "invalid_api_key") == 1) { 返回 2; }
    如果 (字符串::包含(响应, "Unauthorized") == 1) { 返回 2; }

    // 可重试：限流 / 服务端 / 超时
    如果 (字符串::包含(响应, "429") == 1) { 返回 1; }
    如果 (字符串::包含(响应, "500") == 1) { 返回 1; }
    如果 (字符串::包含(响应, "502") == 1) { 返回 1; }
    如果 (字符串::包含(响应, "503") == 1) { 返回 1; }
    如果 (字符串::包含(响应, "504") == 1) { 返回 1; }
    如果 (字符串::包含(响应, "timeout") == 1) { 返回 1; }
    如果 (字符串::包含(响应, "超时") == 1) { 返回 1; }
    如果 (字符串::开始于(响应, "LLM调用失败") == 1) { 返回 1; }
    如果 (字符串::开始于(响应, "HTTP错误") == 1) { 返回 1; }
    如果 (字符串::开始于(响应, "[") == 1) { 返回 1; }   // harness 错误前缀

    返回 0;   // 看起来是正常响应
}

// ===== 熔断器（进程级单实例）=====
// 连续失败到阈值 → 断路打开，冷却期内直接快失败（不再打后端），冷却过后半开放一次试探。
变量 熔断阈值: 整数 = 5;
变量 熔断冷却毫秒: 整数 = 30000;
变量 连续失败数: 整数 = 0;
变量 断路开启时刻: 整数 = 0;   // 0 = 闭合（正常）

公开 函数 配置熔断(阈值: 整数, 冷却毫秒: 整数) : 整数 {
    熔断阈值 = 阈值;
    熔断冷却毫秒 = 冷却毫秒;
    返回 1;
}

// 现在是否允许放行请求。1 = 允许；0 = 断路打开且仍在冷却期，快失败。
公开 函数 熔断允许() : 整数 {
    如果 (断路开启时刻 == 0) { 返回 1; }   // 闭合
    变量 过去: 整数 = 时间.当前毫秒() - 断路开启时刻;
    如果 (过去 >= 熔断冷却毫秒) {
        // 冷却结束 → 半开：放行一次试探，闭合计数（成功则完全恢复，失败则重新打开）
        断路开启时刻 = 0;
        连续失败数 = 0;
        事件("circuit_half_open", "熔断", "冷却结束，放行试探");
        返回 1;
    }
    返回 0;
}

公开 函数 熔断记成功() {
    连续失败数 = 0;
    断路开启时刻 = 0;
}

公开 函数 熔断记失败() {
    连续失败数 = 连续失败数 + 1;
    如果 (连续失败数 >= 熔断阈值) {
        断路开启时刻 = 时间.当前毫秒();
        事件("circuit_open", "熔断", "连续失败 " + 整数转字符串(连续失败数) + " 次，断路打开 " + 整数转字符串(熔断冷却毫秒) + "ms");
    }
}

公开 函数 熔断状态() : 字符串 {
    如果 (断路开启时刻 == 0) { 返回 "闭合"; }
    返回 "打开";
}

// ===== 令牌桶限流（进程级单实例）=====
// 匀速补充令牌，取不到就睡到有为止。用于控整体 QPS，别把后端打爆触发 429。
变量 桶容量: 整数 = 0;              // 0 = 未启用限流
变量 桶令牌: 浮点数 = 0.0;
变量 每毫秒补充: 浮点数 = 0.0;      // 令牌/ms
变量 上次补充时刻: 整数 = 0;

// 设置每秒许可数（QPS）与桶容量（突发上限）。每秒许可 <=0 关闭限流。
公开 函数 配置限流(每秒许可: 整数, 容量: 整数) : 整数 {
    如果 (每秒许可 <= 0) {
        桶容量 = 0;
        返回 0;
    }
    桶容量 = 容量;
    桶令牌 = 容量 * 1.0;
    每毫秒补充 = (每秒许可 * 1.0) / 1000.0;
    上次补充时刻 = 时间.当前毫秒();
    返回 1;
}

// 取一个令牌；不够就 sleep 到够。未启用限流时立即返回。
公开 函数 限流获取() {
    如果 (桶容量 == 0) { 返回; }   // 未启用
    // 先按流逝时间补充
    变量 现: 整数 = 时间.当前毫秒();
    变量 流逝: 整数 = 现 - 上次补充时刻;
    如果 (流逝 > 0) {
        桶令牌 = 桶令牌 + (流逝 * 1.0) * 每毫秒补充;
        如果 (桶令牌 > (桶容量 * 1.0)) { 桶令牌 = 桶容量 * 1.0; }
        上次补充时刻 = 现;
    }
    // 令牌不足则算出还差多少、睡够
    当 (桶令牌 < 1.0) {
        变量 缺: 浮点数 = 1.0 - 桶令牌;
        变量 需等毫秒: 整数 = 浮点数转整数(缺 / 每毫秒补充) + 1;
        时间.睡眠毫秒(需等毫秒);
        变量 现2: 整数 = 时间.当前毫秒();
        变量 流逝2: 整数 = 现2 - 上次补充时刻;
        桶令牌 = 桶令牌 + (流逝2 * 1.0) * 每毫秒补充;
        如果 (桶令牌 > (桶容量 * 1.0)) { 桶令牌 = 桶容量 * 1.0; }
        上次补充时刻 = 现2;
    }
    桶令牌 = 桶令牌 - 1.0;
}

// ===== 智能重试 =====
// 比 重试调用 更聪明：先过限流 + 熔断闸；按 错误类别 决定——致命(2)立即返回不重试，
// 可重试(1)才退避。每次结果记进熔断器。断路打开时直接快失败。
公开 函数 智能重试调用(策略: 重试策略, 代理名: 字符串, 调用: 函数(): 字符串) : 字符串 {
    变量 试次: 整数 = 0;
    变量 延迟: 整数 = 策略.起始延迟毫秒;
    变量 上次响应: 字符串 = "";

    当 (试次 < 策略.最大次数) {
        如果 (熔断允许() == 0) {
            错误事件(代理名, "熔断打开，快失败（冷却中）");
            返回 "[harness] 熔断打开，请求被快失败";
        }
        限流获取();
        上次响应 = 调用();
        变量 类别: 整数 = 错误类别(上次响应);

        如果 (类别 == 0) {
            熔断记成功();
            如果 (试次 > 0) { 事件("retry_ok", 代理名, "成功于试次 " + 整数转字符串(试次 + 1)); }
            返回 上次响应;
        }
        熔断记失败();
        如果 (类别 == 2) {
            错误事件(代理名, "致命错误，不重试: " + 上次响应);
            返回 上次响应;
        }

        试次 = 试次 + 1;
        如果 (试次 < 策略.最大次数) {
            事件("retry", 代理名, "试次 " + 整数转字符串(试次) + " 可重试错误，延迟 " + 整数转字符串(延迟) + " ms");
            时间.睡眠毫秒(延迟);
            延迟 = 延迟 * 策略.倍数;
            如果 (延迟 > 策略.最大延迟毫秒) { 延迟 = 策略.最大延迟毫秒; }
        }
    }
    错误事件(代理名, "智能重试 " + 整数转字符串(策略.最大次数) + " 次全部失败");
    返回 上次响应;
}
