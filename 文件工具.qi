    如果 (列表库::获取整数(沙箱可删表, 句柄) == 0) { 返回 只读串; }
    变量 真实: 字符串 = 解析安全路径(句柄, J.获取字符串(对象, "路径"));
    如果 (字符串::字节长度(真实) == 0) { 返回 拒绝串; }
    IO.删除文件(真实);
    返回 "{\"ok\":true}";
}

函数 工具_删除目录(参数JSON: 字符串) : 字符串 {
    变量 对象: 整数 = J.解码(参数JSON);
    变量 句柄: 整数 = 参数句柄(对象);
    如果 (句柄有效(句柄) == 0) { 返回 无绑定串; }
    如果 (列表库::获取整数(沙箱可删表, 句柄) == 0) { 返回 只读串; }
    变量 真实: 字符串 = 解析安全路径(句柄, J.获取字符串(对象, "路径"));
    如果 (字符串::字节长度(真实) == 0) { 返回 拒绝串; }
