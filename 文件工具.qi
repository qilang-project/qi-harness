}

// 按已绑定句柄装备工具。句柄配置不可变，可安全地被一个或多个注册表复用。
公开 函数 装备文件工具按句柄(代理值: 代理, 沙箱句柄: 整数) : 代理 {
    如果 (句柄有效(沙箱句柄) == 0) { 返回 代理值; }
    变量 可写: 整数 = 列表库::获取整数(沙箱可写表, 沙箱句柄);
    变量 可删: 整数 = 列表库::获取整数(沙箱可删表, 沙箱句柄);

    // 只读三件套：始终装备
    代理值 = 添加工具(代理值, 新建 工具 {
        名字: "读文件",
        描述: "读取沙箱内文本文件的内容。路径为相对沙箱根的相对路径，不能含 .. 或绝对路径。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"路径\":{\"type\":\"string\"}},\"required\":[\"路径\"]}",
        处理: 工具_读文件,
    });
    代理值 = 绑定工具槽位(代理值, "读文件", 沙箱句柄);
    代理值 = 添加工具(代理值, 新建 工具 {
        名字: "列目录",
        描述: "列出沙箱内某目录下的文件与子目录（每行一个名字）。路径缺省为沙箱根。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"路径\":{\"type\":\"string\"}}}",
        处理: 工具_列目录,
    });
    代理值 = 绑定工具槽位(代理值, "列目录", 沙箱句柄);
    代理值 = 添加工具(代理值, 新建 工具 {
        名字: "文件信息",
        描述: "查询沙箱内某路径是否存在、是否目录、文件大小（字节）。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"路径\":{\"type\":\"string\"}},\"required\":[\"路径\"]}",
        处理: 工具_文件信息,
    });
    代理值 = 绑定工具槽位(代理值, "文件信息", 沙箱句柄);

    如果 (可写 == 1) {
        代理值 = 添加工具(代理值, 新建 工具 {
            名字: "写文件",
            描述: "把内容写入沙箱内文件（覆盖；父目录会自动创建）。",
            参数schema: "{\"type\":\"object\",\"properties\":{\"路径\":{\"type\":\"string\"},\"内容\":{\"type\":\"string\"}},\"required\":[\"路径\",\"内容\"]}",
            处理: 工具_写文件,
        });
        代理值 = 绑定工具槽位(代理值, "写文件", 沙箱句柄);
        代理值.工具表 = 设置执行模式(代理值.工具表, "写文件", 1);
        代理值 = 添加工具(代理值, 新建 工具 {
            名字: "追加文件",
            描述: "把内容追加到沙箱内文件末尾。",
            参数schema: "{\"type\":\"object\",\"properties\":{\"路径\":{\"type\":\"string\"},\"内容\":{\"type\":\"string\"}},\"required\":[\"路径\",\"内容\"]}",
            处理: 工具_追加文件,
        });
        代理值 = 绑定工具槽位(代理值, "追加文件", 沙箱句柄);
        代理值.工具表 = 设置执行模式(代理值.工具表, "追加文件", 1);
        代理值 = 添加工具(代理值, 新建 工具 {
            名字: "建目录",
            描述: "在沙箱内创建目录。",
            参数schema: "{\"type\":\"object\",\"properties\":{\"路径\":{\"type\":\"string\"}},\"required\":[\"路径\"]}",
            处理: 工具_建目录,
        });
        代理值 = 绑定工具槽位(代理值, "建目录", 沙箱句柄);
        代理值.工具表 = 设置执行模式(代理值.工具表, "建目录", 1);
    }

    如果 (可删 == 1) {
        代理值 = 添加工具(代理值, 新建 工具 {
            名字: "删除文件",
            描述: "删除沙箱内的文件。",
            参数schema: "{\"type\":\"object\",\"properties\":{\"路径\":{\"type\":\"string\"}},\"required\":[\"路径\"]}",
            处理: 工具_删除文件,
        });
        代理值 = 绑定工具槽位(代理值, "删除文件", 沙箱句柄);
        代理值.工具表 = 设置执行模式(代理值.工具表, "删除文件", 1);
        代理值 = 添加工具(代理值, 新建 工具 {
            名字: "删除目录",
            描述: "删除沙箱内的目录。",
            参数schema: "{\"type\":\"object\",\"properties\":{\"路径\":{\"type\":\"string\"}},\"required\":[\"路径\"]}",
            处理: 工具_删除目录,
        });
        代理值 = 绑定工具槽位(代理值, "删除目录", 沙箱句柄);
        代理值.工具表 = 设置执行模式(代理值.工具表, "删除目录", 1);
    }

    返回 代理值;
}

// 兼容原 API：每次装备创建一个独立绑定，不再修改进程级活动沙箱。
公开 函数 装备文件工具(代理值: 代理, 沙箱: 文件沙箱) : 代理 {
    变量 句柄: 整数 = 创建文件沙箱句柄(沙箱);
    如果 (句柄 < 0) { 返回 代理值; }
    返回 装备文件工具按句柄(代理值, 句柄);
}
