// 运行日志 — Phase B SQLite run journal, leases, attempts, tools, and budgets.

包 Harness;

导入 标准库.数据库;
导入 标准库.字符串;
导入 标准库.JSON 作为 J;

// Result conventions: mutations return 1 for a new change, 2 for an identical
// idempotent replay, 0 for a conflict/stale lease, and -1 for invalid input or DB error.

函数 日志SQL文本(原文: 字符串) : 字符串 {
    返回 "'" + 字符串::替换(原文, "'", "''") + "'";
}

函数 日志首行(行JSON: 字符串) : 整数 {
    变量 数组值: 整数 = J.解码(行JSON);
    如果 (数组值 <= 0 || J.数组长度(数组值) == 0) { 返回 0; }
    返回 J.数组获取对象(数组值, 0);
}

函数 日志是JSON(文本: 字符串) : 整数 {
    变量 值: 整数 = J.解码(文本);
    如果 (值 <= 0) { 返回 0; }
    J.删除(值);
    返回 1;
}

函数 日志非空(文本: 字符串) : 整数 {
    如果 (字符串::字节长度(文本) > 0) { 返回 1; }
    返回 0;
}

函数 日志回滚(库: 整数) : 整数 {
    数据库.执行(库, "ROLLBACK");
    返回 0 - 1;
}

函数 日志提交(库: 整数) : 整数 {
    如果 (数据库.执行(库, "COMMIT") < 0) { 返回 日志回滚(库); }
    返回 1;
}

函数 日志运行存在(库: 整数, 运行ID: 字符串) : 整数 {
    变量 行: 整数 = 日志首行(数据库.查询(库,
        "SELECT COUNT(*) AS count FROM agent_runs WHERE run_id = " + 日志SQL文本(运行ID)));
    如果 (行 > 0 && J.获取整数(行, "count") == 1) { 返回 1; }
    返回 0;
}

函数 日志工具列存在(库: 整数, 列名: 字符串) : 整数 {
    变量 行: 整数 = 日志首行(数据库.查询(库,
        "SELECT COUNT(*) AS count FROM pragma_table_info('tool_executions') WHERE name = "
        + 日志SQL文本(列名)));
    如果 (行 > 0 && J.获取整数(行, "count") == 1) { 返回 1; }
    返回 0;
}

函数 日志租约匹配SQL(运行ID: 字符串, 所有者: 字符串, 栅栏: 整数,
                    期望状态: 字符串, 当前时间: 整数) : 字符串 {
    返回 "run_id = " + 日志SQL文本(运行ID)
        + " AND lease_owner = " + 日志SQL文本(所有者)
        + " AND lease_fence = " + 整数转字符串(栅栏)
        + " AND lease_expires_at > " + 整数转字符串(当前时间)
        + " AND current_state = " + 日志SQL文本(期望状态);
}

// Opens a standalone journal DB or adds the companion tables to an existing SQLite DB.
公开 函数 打开运行日志(路径: 字符串) : 整数 {
    变量 库: 整数 = 数据库.连接(路径);
    如果 (库 <= 0) { 返回 0; }
    如果 (数据库.执行(库, "PRAGMA foreign_keys = ON") < 0
        || 数据库.执行(库, "CREATE TABLE IF NOT EXISTS agent_runs ("
            + "run_id TEXT PRIMARY KEY, tenant_id TEXT NOT NULL, session_id TEXT NOT NULL, "
            + "request_id TEXT NOT NULL, request_hash TEXT NOT NULL, status TEXT NOT NULL, "
            + "current_state TEXT NOT NULL, lease_owner TEXT, lease_expires_at INTEGER, "
            + "lease_fence INTEGER NOT NULL DEFAULT 0, last_seq INTEGER NOT NULL DEFAULT 0, "
            + "partial_output_committed INTEGER NOT NULL DEFAULT 0, final_text TEXT, "
            + "usage_json TEXT, error_json TEXT, created_at INTEGER NOT NULL, updated_at INTEGER NOT NULL, "
            + "UNIQUE (tenant_id, session_id, request_id))") < 0
        || 数据库.执行(库, "CREATE TABLE IF NOT EXISTS agent_run_events ("
            + "run_id TEXT NOT NULL, seq INTEGER NOT NULL, type TEXT NOT NULL, timestamp INTEGER NOT NULL, "
            + "payload_json TEXT NOT NULL, PRIMARY KEY (run_id, seq), "
            + "FOREIGN KEY (run_id) REFERENCES agent_runs(run_id))") < 0
        || 数据库.执行(库, "CREATE TABLE IF NOT EXISTS model_attempts ("
            + "attempt_id TEXT PRIMARY KEY, run_id TEXT NOT NULL, step_id TEXT NOT NULL, "
            + "attempt_number INTEGER NOT NULL, status TEXT NOT NULL, provider_request_id TEXT, "
            + "first_output_at INTEGER, usage_json TEXT, usage_status TEXT NOT NULL, error_json TEXT, "
            + "UNIQUE (run_id, step_id, attempt_number), "
            + "FOREIGN KEY (run_id) REFERENCES agent_runs(run_id))") < 0
        || 数据库.执行(库, "CREATE TABLE IF NOT EXISTS tool_executions ("
            + "execution_key TEXT PRIMARY KEY, run_id TEXT NOT NULL, step_id TEXT NOT NULL, "
            + "tool_call_id TEXT NOT NULL, tool_name TEXT NOT NULL, arguments_hash TEXT NOT NULL, "
            + "idempotency_key TEXT, status TEXT NOT NULL, dispatch_started_at INTEGER, "
            + "external_commit_state TEXT NOT NULL, reconciliation_status TEXT NOT NULL, "
            + "result_json TEXT, error_json TEXT, started_at INTEGER, completed_at INTEGER, "
            + "FOREIGN KEY (run_id) REFERENCES agent_runs(run_id))") < 0
        || 数据库.执行(库, "CREATE TABLE IF NOT EXISTS budget_reservations ("
            + "reservation_id TEXT PRIMARY KEY, run_id TEXT NOT NULL, attempt_id TEXT NOT NULL, "
            + "tenant_id TEXT NOT NULL, reserved_tokens INTEGER NOT NULL, "
            + "reserved_cost_micros INTEGER NOT NULL DEFAULT 0, actual_tokens INTEGER, "
            + "actual_cost_micros INTEGER, status TEXT NOT NULL, usage_status TEXT NOT NULL, "
            + "created_at INTEGER NOT NULL, settled_at INTEGER, UNIQUE (attempt_id), "
            + "FOREIGN KEY (run_id) REFERENCES agent_runs(run_id), "
            + "FOREIGN KEY (attempt_id) REFERENCES model_attempts(attempt_id))") < 0
        || 数据库.执行(库, "CREATE INDEX IF NOT EXISTS agent_run_events_replay ON agent_run_events(run_id, seq)") < 0
        || 数据库.执行(库, "CREATE INDEX IF NOT EXISTS model_attempts_run ON model_attempts(run_id, step_id)") < 0
        || 数据库.执行(库, "CREATE INDEX IF NOT EXISTS tool_executions_run ON tool_executions(run_id, step_id)") < 0
        || 数据库.执行(库, "CREATE INDEX IF NOT EXISTS budget_reservations_run ON budget_reservations(run_id)") < 0) {
        数据库.关闭(库);
        返回 0;
    }
    如果 (日志工具列存在(库, "dispatch_lease_fence") == 0
        && 数据库.执行(库, "ALTER TABLE tool_executions ADD COLUMN dispatch_lease_fence INTEGER") < 0) {
        数据库.关闭(库);
        返回 0;
    }
    如果 (日志工具列存在(库, "completion_lease_fence") == 0
        && 数据库.执行(库, "ALTER TABLE tool_executions ADD COLUMN completion_lease_fence INTEGER") < 0) {
        数据库.关闭(库);
        返回 0;
    }
    变量 模式: 整数 = 日志首行(数据库.查询(库,
        "SELECT COUNT(*) AS count FROM sqlite_master WHERE type = 'table' AND name IN "
        + "('agent_runs','agent_run_events','model_attempts','tool_executions','budget_reservations')"));
    如果 (模式 <= 0 || J.获取整数(模式, "count") != 5) {
        数据库.关闭(库);
        返回 0;
    }
    返回 库;
}

公开 函数 打开内存运行日志() : 整数 { 返回 打开运行日志(":memory:"); }

公开 函数 关闭运行日志(库: 整数) : 整数 {
    如果 (库 <= 0) { 返回 0; }
    数据库.关闭(库);
    返回 1;
}

// The scoped request key is idempotent only when request_hash is identical.
公开 函数 创建代理运行(库: 整数, 运行ID: 字符串, 租户ID: 字符串, 会话ID: 字符串,
                    请求ID: 字符串, 请求哈希: 字符串, 初始状态: 字符串, 创建时间: 整数) : 整数 {
    如果 (库 <= 0 || 日志非空(运行ID) == 0 || 日志非空(租户ID) == 0
        || 日志非空(会话ID) == 0 || 日志非空(请求ID) == 0
        || 日志非空(请求哈希) == 0 || 日志非空(初始状态) == 0) { 返回 0 - 1; }
    如果 (数据库.执行(库, "BEGIN IMMEDIATE") < 0) { 返回 0 - 1; }
    变量 已有: 整数 = 日志首行(数据库.查询(库,
        "SELECT run_id, request_hash FROM agent_runs WHERE tenant_id = " + 日志SQL文本(租户ID)
        + " AND session_id = " + 日志SQL文本(会话ID) + " AND request_id = " + 日志SQL文本(请求ID)));
    如果 (已有 > 0) {
        数据库.执行(库, "ROLLBACK");
        如果 (字符串::等于(J.获取字符串(已有, "run_id"), 运行ID) == 1
            && 字符串::等于(J.获取字符串(已有, "request_hash"), 请求哈希) == 1) { 返回 2; }
        返回 0;
    }
    如果 (日志运行存在(库, 运行ID) == 1) {
        数据库.执行(库, "ROLLBACK");
        返回 0;
    }
    变量 写入: 整数 = 数据库.执行(库,
        "INSERT INTO agent_runs (run_id, tenant_id, session_id, request_id, request_hash, status, "
        + "current_state, created_at, updated_at) VALUES (" + 日志SQL文本(运行ID) + ", "
        + 日志SQL文本(租户ID) + ", " + 日志SQL文本(会话ID) + ", " + 日志SQL文本(请求ID) + ", "
        + 日志SQL文本(请求哈希) + ", 'running', " + 日志SQL文本(初始状态) + ", "
        + 整数转字符串(创建时间) + ", " + 整数转字符串(创建时间) + ")");
    如果 (写入 <= 0 || 日志提交(库) < 0) { 返回 0 - 1; }
    返回 1;
}

// Returns the newly incremented fence, 0 when another unexpired owner holds it, -1 on error.
公开 函数 获取运行租约(库: 整数, 运行ID: 字符串, 所有者: 字符串,
                    当前时间: 整数, 到期时间: 整数) : 整数 {
    如果 (库 <= 0 || 日志非空(所有者) == 0 || 到期时间 <= 当前时间) { 返回 0 - 1; }
    如果 (数据库.执行(库, "BEGIN IMMEDIATE") < 0) { 返回 0 - 1; }
    变量 更新: 整数 = 数据库.执行(库, "UPDATE agent_runs SET lease_owner = " + 日志SQL文本(所有者)
        + ", lease_expires_at = " + 整数转字符串(到期时间)
        + ", lease_fence = lease_fence + 1, updated_at = " + 整数转字符串(当前时间)
        + " WHERE run_id = " + 日志SQL文本(运行ID)
        + " AND (lease_owner IS NULL OR lease_expires_at <= " + 整数转字符串(当前时间)
        + " OR lease_owner = " + 日志SQL文本(所有者) + ")");
    如果 (更新 < 0) { 返回 日志回滚(库); }
    如果 (更新 == 0) { 数据库.执行(库, "ROLLBACK"); 返回 0; }
    变量 行: 整数 = 日志首行(数据库.查询(库, "SELECT lease_fence FROM agent_runs WHERE run_id = "
        + 日志SQL文本(运行ID) + " AND lease_owner = " + 日志SQL文本(所有者)));
    如果 (行 <= 0) { 返回 日志回滚(库); }
    变量 栅栏: 整数 = J.获取整数(行, "lease_fence");
    如果 (日志提交(库) < 0) { 返回 0 - 1; }
    返回 栅栏;
}

公开 函数 续期运行租约(库: 整数, 运行ID: 字符串, 所有者: 字符串, 栅栏: 整数,
                    当前时间: 整数, 到期时间: 整数) : 整数 {
    如果 (库 <= 0 || 到期时间 <= 当前时间) { 返回 0 - 1; }
    变量 影响: 整数 = 数据库.执行(库, "UPDATE agent_runs SET lease_expires_at = "
        + 整数转字符串(到期时间) + ", updated_at = " + 整数转字符串(当前时间)
        + " WHERE run_id = " + 日志SQL文本(运行ID) + " AND lease_owner = " + 日志SQL文本(所有者)
        + " AND lease_fence = " + 整数转字符串(栅栏)
        + " AND lease_expires_at > " + 整数转字符串(当前时间));
    如果 (影响 < 0) { 返回 0 - 1; }
    如果 (影响 == 0) { 返回 0; }
    返回 1;
}

公开 函数 释放运行租约(库: 整数, 运行ID: 字符串, 所有者: 字符串,
                    栅栏: 整数, 当前时间: 整数) : 整数 {
    变量 影响: 整数 = 数据库.执行(库, "UPDATE agent_runs SET lease_owner = NULL, lease_expires_at = NULL, "
        + "updated_at = " + 整数转字符串(当前时间) + " WHERE run_id = " + 日志SQL文本(运行ID)
        + " AND lease_owner = " + 日志SQL文本(所有者) + " AND lease_fence = " + 整数转字符串(栅栏));
    如果 (影响 < 0) { 返回 0 - 1; }
    如果 (影响 == 0) { 返回 0; }
    返回 1;
}

// State update, sequence allocation, and event insertion are one transaction.
公开 函数 追加运行事件(库: 整数, 运行ID: 字符串, 所有者: 字符串, 栅栏: 整数,
                    期望状态: 字符串, 新状态: 字符串, 新运行状态: 字符串,
                    事件类型: 字符串, 时间戳: 整数, 载荷JSON: 字符串) : 整数 {
    如果 (库 <= 0 || 日志非空(事件类型) == 0 || 日志非空(新状态) == 0
        || 日志非空(新运行状态) == 0 || 日志是JSON(载荷JSON) == 0) { 返回 0 - 1; }
    如果 (数据库.执行(库, "BEGIN IMMEDIATE") < 0) { 返回 0 - 1; }
    变量 更新: 整数 = 数据库.执行(库, "UPDATE agent_runs SET last_seq = last_seq + 1, current_state = "
        + 日志SQL文本(新状态) + ", status = " + 日志SQL文本(新运行状态)
        + ", updated_at = " + 整数转字符串(时间戳) + " WHERE "
        + 日志租约匹配SQL(运行ID, 所有者, 栅栏, 期望状态, 时间戳));
    如果 (更新 < 0) { 返回 日志回滚(库); }
    如果 (更新 == 0) { 数据库.执行(库, "ROLLBACK"); 返回 0; }
    变量 行: 整数 = 日志首行(数据库.查询(库,
        "SELECT last_seq FROM agent_runs WHERE run_id = " + 日志SQL文本(运行ID)));
    如果 (行 <= 0) { 返回 日志回滚(库); }
    变量 序号: 整数 = J.获取整数(行, "last_seq");
    如果 (数据库.执行(库, "INSERT INTO agent_run_events (run_id, seq, type, timestamp, payload_json) VALUES ("
        + 日志SQL文本(运行ID) + ", " + 整数转字符串(序号) + ", " + 日志SQL文本(事件类型) + ", "
        + 整数转字符串(时间戳) + ", " + 日志SQL文本(载荷JSON) + ")") <= 0) {
        返回 日志回滚(库);
    }
    如果 (日志提交(库) < 0) { 返回 0 - 1; }
    返回 序号;
}

公开 函数 列出运行事件(库: 整数, 运行ID: 字符串, 之后序号: 整数) : 字符串 {
    如果 (库 <= 0) { 返回 "[]"; }
    返回 数据库.查询(库, "SELECT run_id, seq, type, timestamp, payload_json FROM agent_run_events WHERE run_id = "
        + 日志SQL文本(运行ID) + " AND seq > " + 整数转字符串(之后序号) + " ORDER BY seq");
}

// Reliable-stream coordinator lookup by the tenant-scoped idempotency key.
公开 函数 获取请求代理运行JSON(库: 整数, 租户ID: 字符串, 会话ID: 字符串,
                    请求ID: 字符串) : 字符串 {
    如果 (库 <= 0) { 返回 "[]"; }
    返回 数据库.查询(库, "SELECT run_id, tenant_id, session_id, request_id, request_hash, status, current_state, "
        + "COALESCE(lease_owner, '') AS lease_owner, COALESCE(lease_expires_at, 0) AS lease_expires_at, "
        + "lease_fence, last_seq, partial_output_committed, COALESCE(final_text, '') AS final_text, "
        + "COALESCE(usage_json, '') AS usage_json, COALESCE(error_json, '') AS error_json, created_at, updated_at "
        + "FROM agent_runs WHERE tenant_id = " + 日志SQL文本(租户ID)
        + " AND session_id = " + 日志SQL文本(会话ID)
        + " AND request_id = " + 日志SQL文本(请求ID));
}

// Persists an externally deliverable event and its commitment boundary in one transaction.
公开 函数 追加流运行事件(库: 整数, 运行ID: 字符串, 所有者: 字符串, 栅栏: 整数,
                    期望状态: 字符串, 新状态: 字符串, 事件类型: 字符串,
                    时间戳: 整数, 载荷JSON: 字符串, 已提交输出: 整数) : 整数 {
    如果 (库 <= 0 || 日志非空(事件类型) == 0 || 日志非空(新状态) == 0
        || 日志是JSON(载荷JSON) == 0) { 返回 0 - 1; }
    如果 (数据库.执行(库, "BEGIN IMMEDIATE") < 0) { 返回 0 - 1; }
    变量 更新: 整数 = 数据库.执行(库, "UPDATE agent_runs SET last_seq = last_seq + 1, current_state = "
        + 日志SQL文本(新状态) + ", partial_output_committed = CASE WHEN "
        + 整数转字符串(已提交输出) + " = 1 THEN 1 ELSE partial_output_committed END, updated_at = "
        + 整数转字符串(时间戳) + " WHERE "
        + 日志租约匹配SQL(运行ID, 所有者, 栅栏, 期望状态, 时间戳)
        + " AND status = 'running'");
    如果 (更新 < 0) { 返回 日志回滚(库); }
    如果 (更新 == 0) { 数据库.执行(库, "ROLLBACK"); 返回 0; }
    变量 行: 整数 = 日志首行(数据库.查询(库,
        "SELECT last_seq FROM agent_runs WHERE run_id = " + 日志SQL文本(运行ID)));
    如果 (行 <= 0) { 返回 日志回滚(库); }
    变量 序号: 整数 = J.获取整数(行, "last_seq");
    如果 (数据库.执行(库, "INSERT INTO agent_run_events (run_id, seq, type, timestamp, payload_json) VALUES ("
        + 日志SQL文本(运行ID) + ", " + 整数转字符串(序号) + ", " + 日志SQL文本(事件类型) + ", "
        + 整数转字符串(时间戳) + ", " + 日志SQL文本(载荷JSON) + ")") <= 0) {
        返回 日志回滚(库);
    }
    如果 (日志提交(库) < 0) { 返回 0 - 1; }
    返回 序号;
}

// Exactly one terminal event updates the replay result and run status atomically.
公开 函数 终结流运行(库: 整数, 运行ID: 字符串, 所有者: 字符串, 栅栏: 整数,
                    期望状态: 字符串, 终态: 字符串, 运行状态: 字符串,
                    事件类型: 字符串, 时间戳: 整数, 载荷JSON: 字符串,
                    已提交输出: 整数, 最终文本: 字符串, 使用JSON: 字符串,
                    错误JSON: 字符串) : 整数 {
    如果 (库 <= 0 || 日志非空(终态) == 0 || 日志非空(运行状态) == 0
        || 日志非空(事件类型) == 0 || 日志是JSON(载荷JSON) == 0
        || (日志非空(使用JSON) == 1 && 日志是JSON(使用JSON) == 0)
        || (日志非空(错误JSON) == 1 && 日志是JSON(错误JSON) == 0)) { 返回 0 - 1; }
    如果 (数据库.执行(库, "BEGIN IMMEDIATE") < 0) { 返回 0 - 1; }
    变量 更新: 整数 = 数据库.执行(库, "UPDATE agent_runs SET last_seq = last_seq + 1, current_state = "
        + 日志SQL文本(终态) + ", status = " + 日志SQL文本(运行状态)
        + ", partial_output_committed = CASE WHEN " + 整数转字符串(已提交输出)
        + " = 1 THEN 1 ELSE partial_output_committed END, final_text = " + 日志SQL文本(最终文本)
        + ", usage_json = " + 日志SQL文本(使用JSON) + ", error_json = " + 日志SQL文本(错误JSON)
        + ", updated_at = " + 整数转字符串(时间戳) + " WHERE "
        + 日志租约匹配SQL(运行ID, 所有者, 栅栏, 期望状态, 时间戳)
        + " AND status = 'running'");
    如果 (更新 < 0) { 返回 日志回滚(库); }
    如果 (更新 == 0) { 数据库.执行(库, "ROLLBACK"); 返回 0; }
    变量 行: 整数 = 日志首行(数据库.查询(库,
        "SELECT last_seq FROM agent_runs WHERE run_id = " + 日志SQL文本(运行ID)));
    如果 (行 <= 0) { 返回 日志回滚(库); }
    变量 序号: 整数 = J.获取整数(行, "last_seq");
    如果 (数据库.执行(库, "INSERT INTO agent_run_events (run_id, seq, type, timestamp, payload_json) VALUES ("
        + 日志SQL文本(运行ID) + ", " + 整数转字符串(序号) + ", " + 日志SQL文本(事件类型) + ", "
        + 整数转字符串(时间戳) + ", " + 日志SQL文本(载荷JSON) + ")") <= 0) {
