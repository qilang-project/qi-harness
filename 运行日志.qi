    如果 (数据库.执行(库, "BEGIN IMMEDIATE") < 0) { 返回 0 - 1; }
    变量 租约: 整数 = 日志首行(数据库.查询(库, "SELECT COUNT(*) AS count FROM agent_runs WHERE "
        + 日志租约匹配SQL(运行ID, 所有者, 栅栏, 期望状态, 当前时间)));
    如果 (租约 <= 0 || J.获取整数(租约, "count") == 0) { 数据库.执行(库, "ROLLBACK"); 返回 0; }
    变量 查重条件: 字符串 = "execution_key = " + 日志SQL文本(执行键);
    如果 (日志非空(幂等键) == 1) {
        查重条件 = 查重条件 + " OR (run_id = " + 日志SQL文本(运行ID)
            + " AND tool_name = " + 日志SQL文本(工具名)
