    }
    变量 已有: 整数 = 日志首行(数据库.查询(库,
        "SELECT execution_key, run_id, tool_name, arguments_hash, COALESCE(idempotency_key, '') AS idempotency_key "
        + "FROM tool_executions WHERE " + 查重条件 + " ORDER BY CASE WHEN execution_key = "
        + 日志SQL文本(执行键) + " THEN 0 ELSE 1 END LIMIT 1"));
    如果 (已有 > 0) {
        数据库.执行(库, "ROLLBACK");
        如果 (字符串::等于(J.获取字符串(已有, "execution_key"), 执行键) == 1
            && 字符串::等于(J.获取字符串(已有, "run_id"), 运行ID) == 1
            && 字符串::等于(J.获取字符串(已有, "tool_name"), 工具名) == 1
            && 字符串::等于(J.获取字符串(已有, "arguments_hash"), 参数哈希) == 1
            && 字符串::等于(J.获取字符串(已有, "idempotency_key"), 幂等键) == 1) { 返回 2; }
        如果 (日志非空(幂等键) == 1
            && 字符串::等于(J.获取字符串(已有, "run_id"), 运行ID) == 1
            && 字符串::等于(J.获取字符串(已有, "tool_name"), 工具名) == 1
            && 字符串::等于(J.获取字符串(已有, "arguments_hash"), 参数哈希) == 1
            && 字符串::等于(J.获取字符串(已有, "idempotency_key"), 幂等键) == 1) { 返回 2; }
        返回 0;
    }
    变量 幂等SQL: 字符串 = "NULL";
    如果 (日志非空(幂等键) == 1) { 幂等SQL = 日志SQL文本(幂等键); }
    如果 (数据库.执行(库, "INSERT INTO tool_executions (execution_key, run_id, step_id, tool_call_id, tool_name, "
        + "arguments_hash, idempotency_key, status, dispatch_started_at, dispatch_lease_fence, "
        + "external_commit_state, reconciliation_status) VALUES ("
        + 日志SQL文本(执行键) + ", " + 日志SQL文本(运行ID) + ", " + 日志SQL文本(步骤ID) + ", "
