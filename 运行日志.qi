// Resolves a duplicate dispatch without invoking the tool again. Completed rows replay
// their durable result. An in-flight idempotent row remains owned by the first dispatch;
// a no-key non-idempotent row is made explicitly ambiguous because the crash boundary
// cannot prove whether the external side effect happened.
公开 函数 处置重复工具执行JSON(库: 整数, 运行ID: 字符串, 所有者: 字符串, 栅栏: 整数,
                    期望状态: 字符串, 当前时间: 整数, 执行键: 字符串, 工具名: 字符串,
                    参数哈希: 字符串, 幂等键: 字符串) : 字符串 {
    变量 拒绝: 字符串 = "{\"disposition\":\"rejected\"}";
    如果 (库 <= 0 || 日志非空(执行键) == 0) { 返回 拒绝; }
    如果 (数据库.执行(库, "BEGIN IMMEDIATE") < 0) { 返回 拒绝; }
    变量 租约: 整数 = 日志首行(数据库.查询(库, "SELECT COUNT(*) AS count FROM agent_runs WHERE "
        + 日志租约匹配SQL(运行ID, 所有者, 栅栏, 期望状态, 当前时间)));
    如果 (租约 <= 0 || J.获取整数(租约, "count") == 0) {
        数据库.执行(库, "ROLLBACK");
        返回 拒绝;
    }
    变量 条件: 字符串 = "execution_key = " + 日志SQL文本(执行键);
    如果 (日志非空(幂等键) == 1) {
        条件 = 条件 + " OR (run_id = " + 日志SQL文本(运行ID)
            + " AND tool_name = " + 日志SQL文本(工具名)
            + " AND idempotency_key = " + 日志SQL文本(幂等键) + ")";
    }
    变量 行: 整数 = 日志首行(数据库.查询(库,
        "SELECT execution_key, run_id, tool_name, arguments_hash, COALESCE(idempotency_key, '') AS idempotency_key, "
        + "status, reconciliation_status, COALESCE(result_json, '') AS result_json, COALESCE(error_json, '') AS error_json "
        + "FROM tool_executions WHERE " + 条件 + " ORDER BY CASE WHEN execution_key = "
        + 日志SQL文本(执行键) + " THEN 0 ELSE 1 END LIMIT 1"));
    如果 (行 <= 0) {
        数据库.执行(库, "ROLLBACK");
        返回 拒绝;
    }
    如果 (字符串::等于(J.获取字符串(行, "run_id"), 运行ID) == 0
        || 字符串::等于(J.获取字符串(行, "tool_name"), 工具名) == 0
        || 字符串::等于(J.获取字符串(行, "arguments_hash"), 参数哈希) == 0
        || 字符串::等于(J.获取字符串(行, "idempotency_key"), 幂等键) == 0) {
        数据库.执行(库, "ROLLBACK");
        返回 "{\"disposition\":\"needs_reconciliation\"}";
    }
    变量 结果JSON: 字符串 = J.获取字符串(行, "result_json");
    如果 (日志非空(结果JSON) == 1) {
        数据库.执行(库, "ROLLBACK");
        变量 回放: 整数 = J.创建对象();
        J.设置字符串(回放, "disposition", "replay");
        J.设置字符串(回放, "execution_key", J.获取字符串(行, "execution_key"));
        J.设置字符串(回放, "status", J.获取字符串(行, "status"));
        J.设置字符串(回放, "result_json", 结果JSON);
        变量 回放文本: 字符串 = J.转字符串(回放);
        J.删除(回放);
        返回 回放文本;
    }
    如果 (日志非空(幂等键) == 1) {
        数据库.执行(库, "ROLLBACK");
        返回 "{\"disposition\":\"existing\"}";
    }
    变量 不确定错误: 字符串 = "{\"code\":\"duplicate_dispatch_unknown\"}";
    变量 影响: 整数 = 数据库.执行(库, "UPDATE tool_executions SET status = 'ambiguous', "
        + "external_commit_state = 'unknown', reconciliation_status = 'required', error_json = "
        + 日志SQL文本(不确定错误) + " WHERE execution_key = "
        + 日志SQL文本(J.获取字符串(行, "execution_key")) + " AND run_id = " + 日志SQL文本(运行ID)
        + " AND result_json IS NULL");
    如果 (影响 < 0 || 日志提交(库) < 0) { 返回 拒绝; }
    返回 "{\"disposition\":\"needs_reconciliation\"}";
}

// A non-idempotent dispatch with unknown external commit cannot be retried safely.
