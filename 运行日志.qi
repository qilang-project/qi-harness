    如果 (数据库.执行(库, "BEGIN IMMEDIATE") < 0) { 返回 0 - 1; }
    变量 租约: 整数 = 日志首行(数据库.查询(库, "SELECT COUNT(*) AS count FROM agent_runs WHERE "
        + 日志租约匹配SQL(运行ID, 所有者, 栅栏, 期望状态, 当前时间)));
    如果 (租约 <= 0 || J.获取整数(租约, "count") == 0) { 数据库.执行(库, "ROLLBACK"); 返回 0; }
    变量 已有: 整数 = 日志首行(数据库.查询(库,
        "SELECT status, usage_status, COALESCE(actual_tokens, -1) AS actual_tokens, "
        + "COALESCE(actual_cost_micros, -1) AS actual_cost_micros FROM budget_reservations WHERE reservation_id = "
        + 日志SQL文本(预留ID) + " AND run_id = " + 日志SQL文本(运行ID)));
    如果 (已有 <= 0) { 数据库.执行(库, "ROLLBACK"); 返回 0; }
    如果 (字符串::等于(J.获取字符串(已有, "status"), "reserved") == 0) {
        数据库.执行(库, "ROLLBACK");
        如果 (字符串::等于(J.获取字符串(已有, "status"), 结算状态) == 1
            && 字符串::等于(J.获取字符串(已有, "usage_status"), 使用状态) == 1
            && J.获取整数(已有, "actual_tokens") == 实际令牌
            && J.获取整数(已有, "actual_cost_micros") == 实际成本微元) { 返回 2; }
        返回 0;
    }
    变量 影响: 整数 = 数据库.执行(库, "UPDATE budget_reservations SET actual_tokens = "
        + 整数转字符串(实际令牌) + ", actual_cost_micros = " + 整数转字符串(实际成本微元)
        + ", status = " + 日志SQL文本(结算状态) + ", usage_status = " + 日志SQL文本(使用状态)
        + ", settled_at = " + 整数转字符串(当前时间) + " WHERE reservation_id = " + 日志SQL文本(预留ID)
        + " AND status = 'reserved'");
    如果 (影响 <= 0) { 返回 日志回滚(库); }
    如果 (数据库.执行(库, "UPDATE agent_runs SET last_seq = last_seq + 1, updated_at = "
        + 整数转字符串(当前时间) + " WHERE " + 日志租约匹配SQL(运行ID, 所有者, 栅栏, 期望状态, 当前时间)
        + " AND status = 'running'") <= 0) { 返回 日志回滚(库); }
    变量 行: 整数 = 日志首行(数据库.查询(库, "SELECT last_seq FROM agent_runs WHERE run_id = " + 日志SQL文本(运行ID)));
    变量 序号: 整数 = J.获取整数(行, "last_seq");
    变量 事件类型: 字符串 = "budget.released";
    如果 (字符串::等于(使用状态, "actual") == 1) { 事件类型 = "budget.settled"; }
    否则如果 (字符串::等于(使用状态, "usage_unknown") == 1) { 事件类型 = "budget.usage_unknown"; }
    如果 (行 <= 0 || 数据库.执行(库, "INSERT INTO agent_run_events (run_id, seq, type, timestamp, payload_json) VALUES ("
        + 日志SQL文本(运行ID) + ", " + 整数转字符串(序号) + ", " + 日志SQL文本(事件类型) + ", "
        + 整数转字符串(当前时间) + ", '{\"tokens\":" + 整数转字符串(实际令牌) + "}')") <= 0) {
        返回 日志回滚(库);
    }
    返回 日志提交(库);
}

// A stale writer cannot mutate the run, but it must not leave a provider reservation
// outstanding. This monotonic fallback conservatively retains the full reservation.
公开 函数 保守保留运行预算(库: 整数, 运行ID: 字符串, 预留ID: 字符串,
                    当前时间: 整数) : 整数 {
    如果 (库 <= 0 || 日志非空(运行ID) == 0 || 日志非空(预留ID) == 0) { 返回 0 - 1; }
    如果 (数据库.执行(库, "BEGIN IMMEDIATE") < 0) { 返回 0 - 1; }
    变量 已有: 整数 = 日志首行(数据库.查询(库,
        "SELECT status, usage_status, reserved_tokens, COALESCE(actual_tokens, -1) AS actual_tokens "
        + "FROM budget_reservations WHERE reservation_id = " + 日志SQL文本(预留ID)
        + " AND run_id = " + 日志SQL文本(运行ID)));
    如果 (已有 <= 0) { 数据库.执行(库, "ROLLBACK"); 返回 0; }
    如果 (字符串::等于(J.获取字符串(已有, "status"), "reserved") == 0) {
        数据库.执行(库, "ROLLBACK");
        如果 (字符串::等于(J.获取字符串(已有, "status"), "retained") == 1
            && 字符串::等于(J.获取字符串(已有, "usage_status"), "usage_unknown") == 1
            && J.获取整数(已有, "actual_tokens") == J.获取整数(已有, "reserved_tokens")) { 返回 2; }
        返回 0;
    }
    变量 影响: 整数 = 数据库.执行(库, "UPDATE budget_reservations SET actual_tokens = reserved_tokens, "
        + "actual_cost_micros = reserved_cost_micros, status = 'retained', usage_status = 'usage_unknown', settled_at = "
        + 整数转字符串(当前时间) + " WHERE reservation_id = " + 日志SQL文本(预留ID)
        + " AND run_id = " + 日志SQL文本(运行ID) + " AND status = 'reserved'");
    如果 (影响 <= 0) { 返回 日志回滚(库); }
    返回 日志提交(库);
}

公开 函数 获取运行预算JSON(库: 整数, 运行ID: 字符串) : 字符串 {
    如果 (库 <= 0) { 返回 "[]"; }
    返回 数据库.查询(库, "SELECT reservation_id, run_id, attempt_id, tenant_id, reserved_tokens, "
        + "reserved_cost_micros, COALESCE(actual_tokens, -1) AS actual_tokens, "
        + "COALESCE(actual_cost_micros, -1) AS actual_cost_micros, status, usage_status, created_at, "
        + "COALESCE(settled_at, 0) AS settled_at FROM budget_reservations WHERE run_id = "
        + 日志SQL文本(运行ID) + " ORDER BY created_at, reservation_id");
}

// Recovery never calls a provider. The new owner must first acquire the expired
// lease; this fenced transaction adds the sole terminal event or loses harmlessly.
公开 函数 恢复终结运行(库: 整数, 运行ID: 字符串, 所有者: 字符串, 栅栏: 整数,
                    期望状态: 字符串, 当前时间: 整数, 终态: 字符串,
                    运行状态: 字符串, 事件类型: 字符串, 错误JSON: 字符串) : 整数 {
    变量 行: 整数 = 日志首行(获取代理运行JSON(库, 运行ID));
    如果 (行 <= 0 || 字符串::等于(J.获取字符串(行, "status"), "running") == 0) { 返回 2; }
    返回 终结流运行(库, 运行ID, 所有者, 栅栏, 期望状态, 终态, 运行状态,
        事件类型, 当前时间, 错误JSON, J.获取整数(行, "partial_output_committed"),
        J.获取字符串(行, "final_text"), J.获取字符串(行, "usage_json"), 错误JSON);
}

公开 函数 获取代理运行JSON(库: 整数, 运行ID: 字符串) : 字符串 {
    如果 (库 <= 0) { 返回 "[]"; }
    返回 数据库.查询(库, "SELECT run_id, tenant_id, session_id, request_id, request_hash, status, current_state, "
        + "COALESCE(lease_owner, '') AS lease_owner, COALESCE(lease_expires_at, 0) AS lease_expires_at, "
        + "lease_fence, last_seq, partial_output_committed, COALESCE(final_text, '') AS final_text, "
        + "COALESCE(usage_json, '') AS usage_json, COALESCE(error_json, '') AS error_json, created_at, updated_at "
        + "FROM agent_runs WHERE run_id = " + 日志SQL文本(运行ID));
}

公开 函数 获取模型尝试JSON(库: 整数, 运行ID: 字符串) : 字符串 {
    如果 (库 <= 0) { 返回 "[]"; }
    返回 数据库.查询(库, "SELECT attempt_id, run_id, step_id, attempt_number, status, "
        + "COALESCE(provider_request_id, '') AS provider_request_id, "
        + "COALESCE(first_output_at, 0) AS first_output_at, COALESCE(usage_json, '') AS usage_json, "
        + "usage_status, COALESCE(error_json, '') AS error_json FROM model_attempts WHERE run_id = "
        + 日志SQL文本(运行ID) + " ORDER BY step_id, attempt_number");
}

公开 函数 获取工具执行JSON(库: 整数, 执行键: 字符串) : 字符串 {
    如果 (库 <= 0) { 返回 "[]"; }
    返回 数据库.查询(库, "SELECT execution_key, run_id, step_id, tool_call_id, tool_name, arguments_hash, "
        + "COALESCE(idempotency_key, '') AS idempotency_key, status, COALESCE(dispatch_started_at, 0) AS dispatch_started_at, "
        + "COALESCE(dispatch_lease_fence, 0) AS dispatch_lease_fence, "
        + "external_commit_state, reconciliation_status, COALESCE(result_json, '') AS result_json, "
        + "COALESCE(error_json, '') AS error_json, COALESCE(started_at, 0) AS started_at, "
        + "COALESCE(completed_at, 0) AS completed_at, COALESCE(completion_lease_fence, 0) AS completion_lease_fence "
        + "FROM tool_executions WHERE execution_key = " + 日志SQL文本(执行键));
}
