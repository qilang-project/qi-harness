        + ", started_at = " + 整数转字符串(开始时间) + ", completed_at = " + 整数转字符串(完成时间)
        + ", completion_lease_fence = " + 整数转字符串(栅栏)
        + " WHERE execution_key = " + 日志SQL文本(执行键) + " AND run_id = " + 日志SQL文本(运行ID)
        + " AND status = 'dispatching'"
        + " AND EXISTS (SELECT 1 FROM agent_runs WHERE "
        + 日志租约匹配SQL(运行ID, 所有者, 栅栏, 期望状态, 当前时间) + ")");
    如果 (影响 < 0) { 返回 日志回滚(库); }
