    返回 日志提交(库);
}

公开 函数 预留运行预算(库: 整数, 运行ID: 字符串, 所有者: 字符串, 栅栏: 整数,
                    期望状态: 字符串, 当前时间: 整数, 预留ID: 字符串, 尝试ID: 字符串,
                    租户ID: 字符串, 预留令牌: 整数, 预留成本微元: 整数,
                    使用状态: 字符串) : 整数 {
    如果 (库 <= 0 || 预留令牌 < 0 || 预留成本微元 < 0) { 返回 0 - 1; }
    如果 (数据库.执行(库, "BEGIN IMMEDIATE") < 0) { 返回 0 - 1; }
    变量 更新: 整数 = 数据库.执行(库, "UPDATE agent_runs SET last_seq = last_seq + 1, updated_at = "
        + 整数转字符串(当前时间) + " WHERE "
        + 日志租约匹配SQL(运行ID, 所有者, 栅栏, 期望状态, 当前时间)
        + " AND status = 'running' AND tenant_id = " + 日志SQL文本(租户ID));
    如果 (更新 < 0) { 返回 日志回滚(库); }
    如果 (更新 == 0) { 数据库.执行(库, "ROLLBACK"); 返回 0; }
    变量 已有: 整数 = 日志首行(数据库.查询(库,
        "SELECT reservation_id, reserved_tokens, reserved_cost_micros FROM budget_reservations WHERE attempt_id = "
        + 日志SQL文本(尝试ID)));
    如果 (已有 > 0) {
        数据库.执行(库, "ROLLBACK");
        如果 (字符串::等于(J.获取字符串(已有, "reservation_id"), 预留ID) == 1
            && J.获取整数(已有, "reserved_tokens") == 预留令牌
            && J.获取整数(已有, "reserved_cost_micros") == 预留成本微元) { 返回 2; }
        返回 0;
    }
    如果 (数据库.执行(库, "INSERT INTO budget_reservations (reservation_id, run_id, attempt_id, tenant_id, "
        + "reserved_tokens, reserved_cost_micros, status, usage_status, created_at) VALUES ("
        + 日志SQL文本(预留ID) + ", " + 日志SQL文本(运行ID) + ", " + 日志SQL文本(尝试ID) + ", "
        + 日志SQL文本(租户ID) + ", " + 整数转字符串(预留令牌) + ", "
        + 整数转字符串(预留成本微元) + ", 'reserved', " + 日志SQL文本(使用状态) + ", "
        + 整数转字符串(当前时间) + ")") <= 0) { 返回 日志回滚(库); }
    变量 行: 整数 = 日志首行(数据库.查询(库, "SELECT last_seq FROM agent_runs WHERE run_id = " + 日志SQL文本(运行ID)));
    变量 序号: 整数 = J.获取整数(行, "last_seq");
    如果 (行 <= 0 || 数据库.执行(库, "INSERT INTO agent_run_events (run_id, seq, type, timestamp, payload_json) VALUES ("
        + 日志SQL文本(运行ID) + ", " + 整数转字符串(序号) + ", 'budget.reserved', "
        + 整数转字符串(当前时间) + ", '{\"tokens\":" + 整数转字符串(预留令牌) + "}')") <= 0) {
        返回 日志回滚(库);
    }
    返回 日志提交(库);
}

// Identical settlement is idempotent; a different second settlement conflicts.
公开 函数 结算运行预算(库: 整数, 运行ID: 字符串, 所有者: 字符串, 栅栏: 整数,
                    期望状态: 字符串, 当前时间: 整数, 预留ID: 字符串,
                    实际令牌: 整数, 实际成本微元: 整数, 结算状态: 字符串,
