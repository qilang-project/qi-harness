// 递归分解 — Hierarchical / 递归任务分解（分解 → 委派 → 汇总）
//
// 复杂任务一步做不完时的分治外壳：一个「规划代理」把任务拆成子任务，每个子任务
// 要么交给「工人代理」直接完成，要么继续递归拆分，直到触底（最大深度）；再由
// 规划代理把各子结果综合成对原任务的最终答案。
//
//   规划代理.分解(任务) → [子任务…]
//        每个子任务：  最大深度到底 ?  工人代理.直接解
//                      否则         :  递归求解(… 最大深度-1)
//   规划代理.汇总([子结果…]) → 最终答案
//
// 硬 最大深度 护栏：防止「分解→再分解→…」无限展开导致 token/成本失控。
// 复用既有原语：结构化运行（schema 约束 + 自动重试，见 代理.qi）拿结构化子任务列表；
// 运行（自动 tool dispatch）让工人真正干活；简单问 做汇总。
//
// opt-in：不在 Harness.qi 核心自动导入。用法：
//   导入 Harness.递归分解::{递归求解};
//   变量 答案: 字符串 = 递归求解(规划代理, 工人代理, "写一篇关于X的报告", 3);

包 Harness;

导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 标准库.JSON 作为 J;
导入 Harness.代理::{代理, 运行, 简单问, 结构化运行};
导入 Harness.追踪::{事件, 错误事件};

// 工人直接解一个（子）任务：走 运行 → 自动 tool dispatch。
函数 直接解(工人代理: 代理, 任务文本: 字符串) : 字符串 {
    返回 运行(工人代理, 任务文本);
}

// 递归求解 —— 分解-委派-汇总的入口。
//   规划代理：负责拆解与最终汇总（通常无工具、纯推理）
//   工人代理：负责把叶子子任务真正做出来（可带工具，走 运行）
//   任务文本：要完成的目标描述
//   最大深度：递归护栏。<=1 视为叶子，直接交工人解，不再拆分。
// 返回：对该任务的最终答案文本。
公开 函数 递归求解(规划代理: 代理, 工人代理: 代理, 任务文本: 字符串, 最大深度: 整数) : 字符串 {
    事件("decompose_enter", 规划代理.名字,
        "深度余 " + 整数转字符串(最大深度) + " · 任务: " + 任务文本);

    // 基例：深度触底 → 工人直接解，不再分解
    如果 (最大深度 <= 1) {
        事件("decompose_leaf", 工人代理.名字, 任务文本);
        返回 直接解(工人代理, 任务文本);
    }

    // 1) 规划代理把任务分解为结构化子任务列表（结构化运行保证字段齐全）
    变量 必需: 整数 = 列表库::创建字符串列表();
    列表库::添加字符串(必需, "可分");
    列表库::添加字符串(必需, "子任务");
    变量 分解提示: 字符串 = "任务：" + 任务文本
        + "\n\n判断该任务是否需要先拆分成更小的子任务再分别完成。"
        + "若可直接完成，则 可分=0、子任务=[]；"
        + "若需要拆分，则 可分=1、子任务=按执行顺序列出的 2 至 5 个子任务字符串。"
        + "字段：\"可分\"(整数 0 或 1)、\"子任务\"(字符串数组)。";
    变量 计划JSON: 字符串 = 结构化运行(规划代理, 分解提示, 必需);
    变量 计划对象: 整数 = J.解码(计划JSON);
    如果 (计划对象 <= 0) {
        // 分解不可用（LLM 不可用 / 输出不合规）→ 退化为工人直接解，不崩
        错误事件(规划代理.名字, "任务分解失败，退化为工人直接求解");
        返回 直接解(工人代理, 任务文本);
    }

    变量 可分: 整数 = 0;
    如果 (J.是否包含键(计划对象, "可分") == 1) { 可分 = J.获取整数(计划对象, "可分"); }
    变量 子任务数组: 整数 = J.获取数组(计划对象, "子任务");
    变量 子数: 整数 = 0;
    如果 (子任务数组 > 0) { 子数 = J.数组长度(子任务数组); }

    // 规划代理判定不必拆，或没给出子任务 → 工人直接解
    如果 (可分 == 0 || 子数 == 0) {
        事件("decompose_leaf", 工人代理.名字, 任务文本);
        返回 直接解(工人代理, 任务文本);
    }

    // 2) 逐个子任务：递归下探一层（最大深度-1），叶子层自然落到工人直接解
    事件("decompose_split", 规划代理.名字,
        "拆出 " + 整数转字符串(子数) + " 个子任务");
    变量 汇总: 字符串 = "";
    变量 i: 整数 = 0;
    当 (i < 子数) {
        变量 子任务: 字符串 = J.数组获取字符串(子任务数组, i);
        变量 子结果: 字符串 = 递归求解(规划代理, 工人代理, 子任务, 最大深度 - 1);
        汇总 = 汇总 + "\n### 子任务 " + 整数转字符串(i + 1) + "：" + 子任务
            + "\n" + 子结果 + "\n";
        i = i + 1;
    }

    // 3) 规划代理把子结果综合成对原任务的最终答案
    变量 汇总提示: 字符串 = "原始任务：" + 任务文本
        + "\n\n各子任务的完成结果如下：\n" + 汇总
        + "\n\n请综合以上子任务结果，给出对原始任务的完整、连贯的最终答案。";
    变量 最终答案: 字符串 = 简单问(规划代理, 汇总提示);
    事件("decompose_synth", 规划代理.名字, 最终答案);
    返回 最终答案;
}
