// MCP 客户端 — 标准库.MCP客户端 Rust 核心薄封装
//
// 连接描述符由本模块的代际注册表签发，不暴露或接受 Rust 核心连接 ID。
//   连接MCP_stdio(命令, 参数JSON)  : 字符串  (描述符)
//   连接MCP_http(基址)             : 字符串  (描述符)
//   发送请求(描述符, 方法, 参数JSON): 字符串  (完整 JSON-RPC 响应行)
//   MCP列出工具/MCP调用工具/...    : 字符串
//   关闭MCP(描述符)               : 整数
//
// 核心调用链：
//   连接MCP_stdio → qi_mcpc_connect_stdio → "mcpc|<id>"
//   发送请求 → 解析 id → qi_mcpc_request → 完整 JSON-RPC 行
//
// 修复：HTTP 大 SSE 响应（如 browser_evaluate）在纯 Qi 层由于 SSE 解析不完整
// 而返回 mcp_no_response；Rust 核心用 reqwest::blocking .text() 全量读取，
// 并正确定位 result/error 携带的 data: 行，彻底修复该 bug。

包 Harness;

导入 标准库.字符串;
导入 标准库.MCP客户端 作为 核心;
导入 标准库.列表 作为 列表库;
导入 标准库.JSON 作为 J;
导入 标准库.输入输出 作为 IO;
导入 标准库.随机 作为 随机;
导入 标准库.时间;
导入 Harness.出站安全::{出站运行时网址允许, 出站策略是生产, MCP清单索引,
    MCP清单命令, MCP清单参数, MCP清理环境, 出站策略有效};
导入 Harness.安全上下文::{安全上下文, 安全上下文有效, 安全上下文未过期,
    安全上下文租户ID};

变量 连接描述符表: 整数 = 0;
变量 连接核心ID表: 整数 = 0;
变量 连接代际表: 整数 = 0;
变量 连接启用表: 整数 = 0;
变量 连接策略表: 整数 = 0;
变量 连接安全句柄表: 整数 = 0;
变量 连接租户表: 整数 = 0;
变量 连接表已建: 整数 = 0;

函数 确保连接表() {
    如果 (连接表已建 == 1) { 返回; }
    连接描述符表 = 列表库::创建字符串列表();
    连接核心ID表 = 列表库::创建整数列表();
    连接代际表 = 列表库::创建整数列表();
    连接启用表 = 列表库::创建整数列表();
    连接策略表 = 列表库::创建整数列表();
    连接安全句柄表 = 列表库::创建整数列表();
    连接租户表 = 列表库::创建字符串列表();
    连接表已建 = 1;
}

函数 注册连接(id: 整数, 策略句柄: 整数, 上下文值: 安全上下文) : 字符串 {
    如果 (id <= 0) { 返回 ""; }
    确保连接表();
    // String-list slots cannot be cleared safely, so registry entries are append-only. The
    // monotonically increasing generation prevents a closed entry from ever becoming current again.
    变量 槽位: 整数 = 列表库::整数列表大小(连接启用表);
    变量 代际: 整数 = 槽位 + 1;
    变量 租户: 字符串 = "";
    如果 (安全上下文有效(上下文值) == 1) { 租户 = 安全上下文租户ID(上下文值); }
    变量 描述符: 字符串 = "mcpr|" + 整数转字符串(槽位) + "|"
        + 整数转字符串(代际) + "|" + 随机.UUID();
    列表库::添加字符串(连接描述符表, 描述符);
    列表库::添加整数(连接核心ID表, id);
    列表库::添加整数(连接代际表, 代际);
    列表库::添加整数(连接启用表, 1);
    列表库::添加整数(连接策略表, 策略句柄);
    列表库::添加整数(连接安全句柄表, 上下文值.句柄);
    列表库::添加字符串(连接租户表, 租户);
    返回 描述符;
}

函数 描述符槽位(描述符: 字符串) : 整数 {
    如果 (连接表已建 == 0 || 字符串::开始于(描述符, "mcpr|") == 0) { 返回 0 - 1; }
    变量 i: 整数 = 0;
    当 (i < 列表库::字符串列表大小(连接描述符表)) {
        如果 (列表库::获取整数(连接启用表, i) == 1
            && 字符串::等于(列表库::获取字符串(连接描述符表, i), 描述符) == 1) {
            变量 策略: 整数 = 列表库::获取整数(连接策略表, i);
            如果 (策略 >= 0 && 出站策略有效(策略) == 0) { 返回 0 - 1; }
            变量 安全句柄: 整数 = 列表库::获取整数(连接安全句柄表, i);
            如果 (安全句柄 > 0) {
                变量 上下文值: 安全上下文 = 新建 安全上下文 { 句柄: 安全句柄 };
                如果 (安全上下文未过期(上下文值, 时间.当前毫秒()) == 0
                    || 字符串::等于(安全上下文租户ID(上下文值),
                        列表库::获取字符串(连接租户表, i)) == 0) { 返回 0 - 1; }
            }
            返回 i;
        }
        i = i + 1;
    }
    返回 0 - 1;
}

函数 描述符取连接id(描述符: 字符串) : 整数 {
    变量 槽位: 整数 = 描述符槽位(描述符);
    如果 (槽位 < 0) { 返回 0; }
    返回 列表库::获取整数(连接核心ID表, 槽位);
}

// ——— 连接 stdio MCP server ———

// 启动一个 stdio MCP server 子进程并完成 initialize 握手。
// 命令如 "npx"，参数JSON 如 "[\"-y\",\"@playwright/mcp@latest\"]"。
// 成功返回描述符字符串 "mcpc|<id>"；失败返回 ""。
公开 函数 连接MCP_stdio(命令: 字符串, 参数JSON: 字符串) : 字符串 {
    变量 id: 整数 = 核心.连接stdio(命令, 参数JSON);
    如果 (id <= 0) {
        IO.打印行("[MCP] stdio 连接失败");
        返回 "";
    }
    返回 注册连接(id, 0 - 1, 新建 安全上下文 { 句柄: 0 });
}

// ——— 连接 HTTP(Streamable) MCP server ———

// 基址形如 "http://localhost:43528/mcp"。
// 成功返回描述符字符串 "mcpc|<id>"；失败返回 ""。
公开 函数 连接MCP_http(基址: 字符串) : 字符串 {
    变量 id: 整数 = 核心.连接http(基址);
    如果 (id <= 0) {
        IO.打印行("[MCP] HTTP 连接失败");
        返回 "";
    }
    返回 注册连接(id, 0 - 1, 新建 安全上下文 { 句柄: 0 });
}

// Policy-aware HTTP registration. Legacy registration remains unchanged when no policy is attached.
公开 函数 连接MCP_http按策略(策略句柄: 整数, 基址: 字符串) : 字符串 {
    如果 (出站运行时网址允许(策略句柄, 基址) == 0) {
        IO.打印行("[MCP] HTTP 出站策略拒绝");
        返回 "";
    }
    // The Rust core does not expose redirect disabling or a per-hop validation callback. A
    // production policy must therefore reject HTTP MCP before opening the connection.
    如果 (出站策略是生产(策略句柄) == 1) {
        IO.打印行("[MCP] HTTP 核心不能逐跳校验重定向，生产策略拒绝连接");
        返回 "";
    }
    变量 id: 整数 = 核心.连接http(基址);
    如果 (id <= 0) { 返回 ""; }
    返回 注册连接(id, 策略句柄, 新建 安全上下文 { 句柄: 0 });
}

公开 函数 连接MCP_http按安全上下文(策略句柄: 整数, 上下文值: 安全上下文,
                              基址: 字符串) : 字符串 {
    如果 (安全上下文有效(上下文值) == 0 || 出站运行时网址允许(策略句柄, 基址) == 0
        || 出站策略是生产(策略句柄) == 1) { 返回 ""; }
    变量 id: 整数 = 核心.连接http(基址);
    如果 (id <= 0) { 返回 ""; }
    返回 注册连接(id, 策略句柄, 上下文值);
}

// Production stdio fails closed: the current runtime cannot disable inherited environment variables.
// Development still requires a static manifest ID and ignores request-selected command/arguments.
公开 函数 连接MCP_stdio按策略(策略句柄: 整数, 清单ID: 字符串, 环境JSON: 字符串) : 字符串 {
    如果 (MCP清单索引(策略句柄, 清单ID) < 0) {
        IO.打印行("[MCP] stdio 清单未允许");
        返回 "";
    }
    变量 清洁环境: 字符串 = MCP清理环境(策略句柄, 清单ID, 环境JSON);
    如果 (出站策略是生产(策略句柄) == 1) {
        IO.打印行("[MCP] stdio 运行时不能隔离继承环境，生产策略拒绝启动");
        返回 "";
    }
    // The current runtime has no environment parameter. The sanitized value is intentionally not
    // applied; development mode is the only mode allowed to use this compatibility path.
    如果 (字符串::字节长度(清洁环境) == 0) { 返回 ""; }
    变量 id: 整数 = 核心.连接stdio(MCP清单命令(策略句柄, 清单ID), MCP清单参数(策略句柄, 清单ID));
    如果 (id <= 0) { 返回 ""; }
    返回 注册连接(id, 策略句柄, 新建 安全上下文 { 句柄: 0 });
}

// ——— 统一发请求 ———

// 发一条请求；method + 已是 JSON 串的 params → 原始响应行（含 result/error）。
公开 函数 发送请求(描述符: 字符串, 方法: 字符串, 参数JSON: 字符串) : 字符串 {
    变量 id: 整数 = 描述符取连接id(描述符);
    如果 (id <= 0) {
        IO.打印行("[MCP] 无效描述符: " + 描述符);
        返回 "";
    }
    返回 核心.请求(id, 方法, 参数JSON);
}

// ——— 高层 MCP 方法（统一描述符）———

// tools/list — 返回原始响应行（result.tools 是工具数组）
公开 函数 MCP列出工具(描述符: 字符串) : 字符串 {
    返回 发送请求(描述符, "tools/list", "{}");
}

// tools/call — 返回 result 的 JSON 串（喂回给 LLM 当工具结果）。
// 参数JSON 是模型生成的 arguments 对象串。
公开 函数 MCP调用工具(描述符: 字符串, 工具名: 字符串, 参数JSON: 字符串) : 字符串 {
    变量 调用参数: 字符串 = "{\"name\":\"" + 工具名 + "\",\"arguments\":" + 参数JSON + "}";
    变量 响应行: 字符串 = 发送请求(描述符, "tools/call", 调用参数);
    如果 (字符串::字节长度(响应行) == 0) {
        返回 "{\"error\":\"mcp_no_response\",\"tool\":\"" + 工具名 + "\"}";
    }
    变量 对象: 整数 = J.解码(响应行);
    如果 (对象 <= 0) {
        返回 响应行;
    }
    如果 (J.是否包含键(对象, "result") == 1) {
        变量 结果对象: 整数 = J.获取对象(对象, "result");
        返回 J.转字符串(结果对象);
    }
    返回 响应行;
}

// 关闭 MCP 连接
公开 函数 关闭MCP(描述符: 字符串) : 整数 {
    变量 槽位: 整数 = 描述符槽位(描述符);
    如果 (槽位 < 0) { 返回 0; }
    变量 id: 整数 = 列表库::获取整数(连接核心ID表, 槽位);
    列表库::设置整数(连接启用表, 槽位, 0);
    列表库::设置整数(连接核心ID表, 槽位, 0);
    列表库::设置整数(连接策略表, 槽位, 0 - 1);
    列表库::设置整数(连接安全句柄表, 槽位, 0);
    返回 核心.关闭(id);
}

// ——— Resources / Prompts / Completion ———

// resources/list — 返回原始响应行（result.resources 是资源数组）
公开 函数 MCP列出资源(描述符: 字符串) : 字符串 { 返回 发送请求(描述符, "resources/list", "{}"); }

// resources/read — 读取指定 URI 的资源内容
公开 函数 MCP读取资源(描述符: 字符串, URI: 字符串) : 字符串 {
    返回 发送请求(描述符, "resources/read", "{\"uri\":\"" + URI + "\"}");
}

// prompts/list — 返回原始响应行（result.prompts 是提示数组）
公开 函数 MCP列出提示(描述符: 字符串) : 字符串 { 返回 发送请求(描述符, "prompts/list", "{}"); }

// prompts/get — 按名称取提示模板，可附参数
公开 函数 MCP获取提示(描述符: 字符串, 名字: 字符串, 参数JSON: 字符串) : 字符串 {
    返回 发送请求(描述符, "prompts/get", "{\"name\":\"" + 名字 + "\",\"arguments\":" + 参数JSON + "}");
}

// completion/complete — 补全请求，参数JSON 为完整 params 对象串
公开 函数 MCP补全(描述符: 字符串, 参数JSON: 字符串) : 字符串 { 返回 发送请求(描述符, "completion/complete", 参数JSON); }

// Raw core IDs are not capabilities. The historical entry point now fails closed.
公开 函数 MCP请求(句柄: 整数, 方法: 字符串, 参数JSON: 字符串) : 字符串 {
    返回 "";
}

// Explicit development-only compatibility for callers that still own a core ID out of band.
公开 函数 MCP请求开发兼容(策略句柄: 整数, 句柄: 整数, 方法: 字符串,
                         参数JSON: 字符串) : 字符串 {
    如果 (句柄 <= 0 || 出站策略有效(策略句柄) == 0 || 出站策略是生产(策略句柄) == 1) {
        返回 "";
    }
    返回 核心.请求(句柄, 方法, 参数JSON);
}

// ——— 双向客户端能力（P6）———

// 注册 sampling/createMessage 处理器。
// 处理函数签名：函数(参数JSON: 字符串): 字符串
//   - 输入：服务器发来的 sampling/createMessage params JSON
//   - 输出：符合 MCP 规范的采样结果 JSON（含 role/content/model/stopReason）
// 成功返回 1；失败返回 0。
公开 函数 设置采样处理(描述符: 字符串, 处理: 函数(字符串): 字符串) : 整数 {
    变量 id: 整数 = 描述符取连接id(描述符);
    如果 (id <= 0) {
        IO.打印行("[MCP] 无效描述符: " + 描述符);
        返回 0;
    }
    核心.设置采样处理(id, 处理);
    返回 1;
}

// 设置 roots/list 返回的根目录 JSON 数组。
// 根JSON 格式：[{"uri":"file:///home/user","name":"主目录"}]
// 成功返回 1；失败返回 0。
公开 函数 设置根目录(描述符: 字符串, 根JSON: 字符串) : 整数 {
    变量 id: 整数 = 描述符取连接id(描述符);
    如果 (id <= 0) {
        IO.打印行("[MCP] 无效描述符: " + 描述符);
        返回 0;
    }
    核心.设置根目录(id, 根JSON);
    返回 1;
}

// 排空服务器推送的通知缓冲区，返回 JSON 数组串（每项为一条通知）。
// 无通知时返回 "[]"。
公开 函数 取通知(描述符: 字符串) : 字符串 {
    变量 id: 整数 = 描述符取连接id(描述符);
    如果 (id <= 0) {
        IO.打印行("[MCP] 无效描述符: " + 描述符);
        返回 "[]";
    }
    返回 核心.取通知(id);
}

// 注册 elicitation/create 处理器（询问处理）。
// 处理函数签名：函数(参数JSON: 字符串): 字符串
//   - 输入：服务器发来的 elicitation/create params JSON
//   - 输出：符合 MCP 规范的询问响应 JSON
// 成功返回 1；失败返回 0。
公开 函数 设置询问处理(描述符: 字符串, 处理: 函数(字符串): 字符串) : 整数 {
    变量 id: 整数 = 描述符取连接id(描述符);
    如果 (id <= 0) {
        IO.打印行("[MCP] 无效描述符: " + 描述符);
        返回 0;
    }
    核心.设置询问处理(id, 处理);
    返回 1;
}
