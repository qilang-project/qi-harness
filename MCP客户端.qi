// MCP 客户端 — 统一 stdio + HTTP(Streamable) 传输，连接描述符字符串
//
// 描述符格式：
//   stdio 传输: "stdio|<子进程句柄>"
//   http  传输: "http|<基址>|<会话id>"
//
// 所有高层函数（MCP列出工具/MCP调用工具/关闭MCP）统一接收描述符。

包 Harness;

导入 标准库.字符串;
导入 标准库.文本 作为 文本;
导入 标准库.列表 作为 列表库;
导入 标准库.JSON 作为 J;
导入 标准库.子进程 作为 子进程;
导入 标准库.输入输出 作为 IO;
导入 标准库.HTTP;

// ——— 描述符解析助手 ———

// 从 "stdio|<句柄>" 取出句柄整数
函数 描述符取句柄(描述符: 字符串) : 整数 {
    变量 部分: 整数 = 文本.分割(描述符, "|");
    变量 句柄串: 字符串 = 列表库::获取字符串(部分, 1);
    返回 字符串转整数(句柄串);
}

// 从 "http|<基址>|<会话id>" 取基址
函数 描述符取基址(描述符: 字符串) : 字符串 {
    变量 部分: 整数 = 文本.分割(描述符, "|");
    返回 列表库::获取字符串(部分, 1);
}

// 从 "http|<基址>|<会话id>" 取会话id
函数 描述符取会话(描述符: 字符串) : 字符串 {
    变量 部分: 整数 = 文本.分割(描述符, "|");
    返回 列表库::获取字符串(部分, 2);
}

// ——— SSE 解析 ———

// 从 SSE 响应体里取 data: 后的 JSON。
// 体格式: "event: message\ndata: {json}\n\n" 或直接 JSON。
// 无 data: 标记则原样返回。
函数 取SSE数据(体: 字符串) : 字符串 {
    变量 标记位置: 整数 = 文本.查找(体, "data:");
    如果 (标记位置 < 0) {
        返回 体;
    }
    变量 起始: 整数 = 标记位置 + 5;
    变量 子串: 字符串 = 字符串::子串(体, 起始, 字符串::字节长度(体));
    返回 字符串::去空白(子串);
}

// ——— stdio 低层读 ———

// 读行直到拿到一条带 result/error 的 JSON 响应；跳过通知/日志行。
// 失败（EOF 或超过最大行数）返回 ""。
函数 读stdio响应(句柄: 整数) : 字符串 {
    变量 次数: 整数 = 0;
    当 (次数 < 200) {
        变量 行内容: 字符串 = 子进程.读取行(句柄);
        如果 (字符串::字节长度(行内容) == 0) {
            返回 "";
        }
        变量 对象: 整数 = J.解码(行内容);
        如果 (对象 > 0) {
            如果 (J.是否包含键(对象, "result") == 1) {
                返回 行内容;
            }
            如果 (J.是否包含键(对象, "error") == 1) {
                返回 行内容;
            }
        }
        次数 = 次数 + 1;
    }
    返回 "";
}

// ——— 初始化参数串（两种传输共用）———

函数 初始化参数串() : 字符串 {
    返回 "{\"protocolVersion\":\"2025-06-18\",\"capabilities\":{},\"clientInfo\":{\"name\":\"qi-harness\",\"version\":\"0.1.0\"}}";
}

// ——— 统一发请求：描述符前缀决定传输 ———

// 发一条请求；method + 已是 JSON 串的 params → 原始响应行（含 result/error）。
公开 函数 发送请求(描述符: 字符串, 方法: 字符串, 参数JSON: 字符串) : 字符串 {
    变量 请求: 字符串 = "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"" + 方法
        + "\",\"params\":" + 参数JSON + "}";
    如果 (字符串::开始于(描述符, "stdio|") == 1) {
        变量 句柄: 整数 = 描述符取句柄(描述符);
        子进程.写入行(句柄, 请求);
        返回 读stdio响应(句柄);
    }
    // http|<基址>|<会话id>
    变量 基址: 字符串 = 描述符取基址(描述符);
    变量 会话id: 字符串 = 描述符取会话(描述符);
    变量 头: 字符串 = "{\"Content-Type\":\"application/json\",\"Accept\":\"application/json, text/event-stream\",\"Mcp-Session-Id\":\""
        + 会话id + "\"}";
    变量 响应: 字符串 = HTTP.请求("POST", 基址, 头, 请求);
    变量 响应对象: 整数 = J.解码(响应);
    如果 (响应对象 <= 0) {
        返回 "";
    }
    变量 体: 字符串 = J.获取字符串(响应对象, "body");
    返回 取SSE数据(体);
}

// ——— 连接 stdio MCP server ———

// 启动一个 stdio MCP server 子进程并完成 initialize 握手。
// 命令如 "npx"，参数JSON 如 "[\"-y\",\"@playwright/mcp@latest\"]"。
// 成功返回描述符字符串 "stdio|<句柄>"；失败返回 ""。
公开 函数 连接MCP_stdio(命令: 字符串, 参数JSON: 字符串) : 字符串 {
    变量 句柄: 整数 = 子进程.生成(命令, 参数JSON);
    如果 (句柄 <= 0) {
        返回 "";
    }
    变量 描述符: 字符串 = "stdio|" + 整数转字符串(句柄);
    变量 初始化响应: 字符串 = 发送请求(描述符, "initialize", 初始化参数串());
    如果 (字符串::字节长度(初始化响应) == 0) {
        IO.打印行("[MCP] initialize 失败");
        子进程.结束(句柄);
        返回 "";
    }
    子进程.写入行(句柄, "{\"jsonrpc\":\"2.0\",\"method\":\"notifications/initialized\"}");
    返回 描述符;
}

// ——— 连接 HTTP(Streamable) MCP server ———

// 基址形如 "http://localhost:43526/mcp"（host 必须 localhost）。
// 成功返回描述符字符串 "http|<基址>|<会话id>"；失败返回 ""。
公开 函数 连接MCP_http(基址: 字符串) : 字符串 {
    变量 头: 字符串 = "{\"Content-Type\":\"application/json\",\"Accept\":\"application/json, text/event-stream\"}";
    变量 请求: 字符串 = "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":" + 初始化参数串() + "}";
    变量 响应: 字符串 = HTTP.请求("POST", 基址, 头, 请求);
    变量 响应对象: 整数 = J.解码(响应);
    如果 (响应对象 <= 0) {
        返回 "";
    }
    变量 状态: 整数 = J.获取整数(响应对象, "status");
    如果 (状态 <= 0) {
        返回 "";
    }
    变量 头对象: 整数 = J.获取对象(响应对象, "headers");
    变量 会话id: 字符串 = J.获取字符串(头对象, "mcp-session-id");
    如果 (字符串::字节长度(会话id) == 0) {
        IO.打印行("[MCP] HTTP initialize 未返回 mcp-session-id");
        返回 "";
    }
    变量 描述符: 字符串 = "http|" + 基址 + "|" + 会话id;
    // 发送 initialized 通知
    变量 通知头: 字符串 = "{\"Content-Type\":\"application/json\",\"Accept\":\"application/json, text/event-stream\",\"Mcp-Session-Id\":\""
        + 会话id + "\"}";
    HTTP.请求("POST", 基址, 通知头, "{\"jsonrpc\":\"2.0\",\"method\":\"notifications/initialized\"}");
    返回 描述符;
}

// ——— 高层 MCP 方法（统一描述符）———

// tools/list — 返回原始响应行（result.tools 是工具数组）
公开 函数 MCP列出工具(描述符: 字符串) : 字符串 {
    返回 发送请求(描述符, "tools/list", "{}");
}

// tools/call — 返回 result 的 JSON 串（喂回给 LLM 当工具结果）。
// 参数JSON 是模型生成的 arguments 对象串。
公开 函数 MCP调用工具(描述符: 字符串, 工具名: 字符串, 参数JSON: 字符串) : 字符串 {
    变量 调用参数: 字符串 = "{\"name\":\"" + 工具名 + "\",\"arguments\":" + 参数JSON + "}";
    变量 响应行: 字符串 = 发送请求(描述符, "tools/call", 调用参数);
    如果 (字符串::字节长度(响应行) == 0) {
        返回 "{\"error\":\"mcp_no_response\",\"tool\":\"" + 工具名 + "\"}";
    }
    变量 对象: 整数 = J.解码(响应行);
    如果 (对象 <= 0) {
        返回 响应行;
    }
    如果 (J.是否包含键(对象, "result") == 1) {
        变量 结果对象: 整数 = J.获取对象(对象, "result");
        返回 J.转字符串(结果对象);
    }
    返回 响应行;
}

// 关闭 MCP 连接
// stdio: 结束子进程；http: 可选 DELETE（忽略失败）
公开 函数 关闭MCP(描述符: 字符串) : 整数 {
    如果 (字符串::开始于(描述符, "stdio|") == 1) {
        变量 句柄: 整数 = 描述符取句柄(描述符);
        子进程.结束(句柄);
        返回 1;
    }
    // http: 发 DELETE（Playwright 支持；失败静默忽略）
    变量 基址: 字符串 = 描述符取基址(描述符);
    变量 会话id: 字符串 = 描述符取会话(描述符);
    变量 头: 字符串 = "{\"Mcp-Session-Id\":\"" + 会话id + "\"}";
    HTTP.请求("DELETE", 基址, 头, "");
    返回 1;
}

// ——— Resources / Prompts / Completion ———

// resources/list — 返回原始响应行（result.resources 是资源数组）
公开 函数 MCP列出资源(描述符: 字符串) : 字符串 { 返回 发送请求(描述符, "resources/list", "{}"); }

// resources/read — 读取指定 URI 的资源内容
公开 函数 MCP读取资源(描述符: 字符串, URI: 字符串) : 字符串 {
    返回 发送请求(描述符, "resources/read", "{\"uri\":\"" + URI + "\"}");
}

// prompts/list — 返回原始响应行（result.prompts 是提示数组）
公开 函数 MCP列出提示(描述符: 字符串) : 字符串 { 返回 发送请求(描述符, "prompts/list", "{}"); }

// prompts/get — 按名称取提示模板，可附参数
公开 函数 MCP获取提示(描述符: 字符串, 名字: 字符串, 参数JSON: 字符串) : 字符串 {
    返回 发送请求(描述符, "prompts/get", "{\"name\":\"" + 名字 + "\",\"arguments\":" + 参数JSON + "}");
}

// completion/complete — 补全请求，参数JSON 为完整 params 对象串
公开 函数 MCP补全(描述符: 字符串, 参数JSON: 字符串) : 字符串 { 返回 发送请求(描述符, "completion/complete", 参数JSON); }

// 保留向后兼容：旧接口（整数句柄）— 已废弃，迁移用。勿新增调用。
公开 函数 MCP请求(句柄: 整数, 方法: 字符串, 参数JSON: 字符串) : 字符串 {
    变量 描述符: 字符串 = "stdio|" + 整数转字符串(句柄);
    返回 发送请求(描述符, 方法, 参数JSON);
}
