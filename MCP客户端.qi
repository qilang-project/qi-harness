// MCP 客户端 — stdio JSON-RPC 2.0（换行分隔）
//
// 在 标准库.子进程 之上实现最小 MCP host：启动 server 子进程、initialize 握手、
// tools/list、tools/call。句柄式 API：所有函数以 子进程句柄(整数) 为标识。

包 Harness;

导入 标准库.字符串;
导入 标准库.JSON 作为 J;
导入 标准库.子进程 作为 子进程;
导入 标准库.输入输出 作为 IO;

// 读行直到拿到一条带 result/error 的 JSON 响应；跳过通知/日志行。
// 失败（EOF 或超过最大行数）返回 "" 。
函数 读响应(句柄: 整数) : 字符串 {
    变量 次数: 整数 = 0;
    当 (次数 < 200) {
        变量 行内容: 字符串 = 子进程.读取行(句柄);
        如果 (字符串::字节长度(行内容) == 0) {
            返回 "";
        }
        变量 对象: 整数 = J.解码(行内容);
        如果 (对象 > 0) {
            如果 (J.是否包含键(对象, "result") == 1) {
                返回 行内容;
            }
            如果 (J.是否包含键(对象, "error") == 1) {
                返回 行内容;
            }
        }
        次数 = 次数 + 1;
    }
    返回 "";
}

// 发一条请求（method + 已是 JSON 串的 params），返回原始响应行（含 result/error）。
公开 函数 MCP请求(句柄: 整数, 方法: 字符串, 参数JSON: 字符串) : 字符串 {
    变量 请求: 字符串 = "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"" + 方法
        + "\",\"params\":" + 参数JSON + "}";
    子进程.写入行(句柄, 请求);
    返回 读响应(句柄);
}

// 启动一个 stdio MCP server 子进程并完成 initialize 握手。
// 命令如 "npx"，参数JSON 如 "[\"@playwright/mcp@latest\"]"。
// 返回子进程句柄(>0) 供后续调用；失败返回 -1。
公开 函数 连接MCP_stdio(命令: 字符串, 参数JSON: 字符串) : 整数 {
    变量 句柄: 整数 = 子进程.生成(命令, 参数JSON);
    如果 (句柄 <= 0) {
        返回 -1;
    }
    变量 初始化参数: 字符串 = "{\"protocolVersion\":\"2025-06-18\",\"capabilities\":{},\"clientInfo\":{\"name\":\"qi-harness\",\"version\":\"0.1.0\"}}";
    变量 初始化响应: 字符串 = MCP请求(句柄, "initialize", 初始化参数);
    如果 (字符串::字节长度(初始化响应) == 0) {
        IO.打印行("[MCP] initialize 失败");
        子进程.结束(句柄);
        返回 -1;
    }
    // 发送 initialized 通知（无需响应）
    子进程.写入行(句柄, "{\"jsonrpc\":\"2.0\",\"method\":\"notifications/initialized\"}");
    返回 句柄;
}

// tools/list — 返回原始响应行（result.tools 是工具数组）
公开 函数 MCP列出工具(句柄: 整数) : 字符串 {
    返回 MCP请求(句柄, "tools/list", "{}");
}

// tools/call — 返回 result 的 JSON 串（喂回给 LLM 当工具结果）。
// 参数JSON 是模型生成的 arguments 对象串。
公开 函数 MCP调用工具(句柄: 整数, 工具名: 字符串, 参数JSON: 字符串) : 字符串 {
    变量 调用参数: 字符串 = "{\"name\":\"" + 工具名 + "\",\"arguments\":" + 参数JSON + "}";
    变量 响应行: 字符串 = MCP请求(句柄, "tools/call", 调用参数);
    如果 (字符串::字节长度(响应行) == 0) {
        返回 "{\"error\":\"mcp_no_response\",\"tool\":\"" + 工具名 + "\"}";
    }
    变量 对象: 整数 = J.解码(响应行);
    如果 (对象 <= 0) {
        返回 响应行;
    }
    如果 (J.是否包含键(对象, "result") == 1) {
        变量 结果对象: 整数 = J.获取对象(对象, "result");
        返回 J.转字符串(结果对象);
    }
    返回 响应行;
}

// 关闭 MCP server 子进程
公开 函数 关闭MCP(句柄: 整数) : 整数 {
    子进程.结束(句柄);   // 返回 i32，不直接 return 以避开 i32→整数(i64) 强转
    返回 1;
}
