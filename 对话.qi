// 对话 — 消息类型 + 工具调用解析
//
// 大模型 底层的工具对话返回 JSON 字符串，里面可能含 tool_call 字段。
// 本模块封装 has_tool_call / get_tool_call_* 那一套，让上层 agent 写起来像
//   while (有工具调用?) { dispatch; continue; }

包 Harness;

导入 标准库.字符串;
导入 标准库.大模型 作为 底层模型;
导入 标准库.JSON 作为 J;
导入 标准库.列表 作为 列表库;

// 助手消息（assistant role）— 可能含文本或多个 parallel tool_calls
公开 类型 助手消息 {
    文本: 字符串,           // 模型的文字回复（无 tool_call 时为主要输出）
    工具调用数: 整数,        // tool_calls 数组长度（0 / 1 / N）
    原始JSON: 字符串,        // 保留原始 JSON 给按索引取
    会话句柄: 整数,          // 取工具调用名称 需要 session
}

// 从底层 工具对话 / 继续工具对话 的 JSON 输出解析成 助手消息
公开 函数 解析助手消息(会话句柄: 整数, 原始JSON: 字符串) : 助手消息 {
    // 运行/继续工具对话 返回的是 assistant message JSON；最终文字回复取其 content 字段。
    // 非 JSON（如底层返回的错误字符串）则原样保留，避免吞掉错误信息。
    变量 文本值: 字符串 = 原始JSON;
    变量 消息对象: 整数 = J.解码(原始JSON);
    如果 (消息对象 > 0) {
        如果 (J.是否包含键(消息对象, "content") == 1) {
            文本值 = J.获取字符串(消息对象, "content");
        }
    }
    返回 (助手消息 {
        文本: 文本值,
        工具调用数: 底层模型.工具调用数量(原始JSON),
        原始JSON: 原始JSON,
        会话句柄: 会话句柄,
    });
}

// 按 index 取第 i 个工具调用 — agent loop 循环 0..N 各 dispatch
公开 函数 工具调用ID(消息: 助手消息, 索引: 整数) : 字符串 {
    返回 底层模型.工具调用ID索引(消息.原始JSON, 索引);
}
公开 函数 工具调用名(消息: 助手消息, 索引: 整数) : 字符串 {
    返回 底层模型.工具调用名称索引(消息.会话句柄, 消息.原始JSON, 索引);
}
公开 函数 工具调用参数(消息: 助手消息, 索引: 整数) : 字符串 {
    返回 底层模型.工具调用参数索引(消息.原始JSON, 索引);
}

// 系统提示 — 写入会话 system 配置
公开 函数 设置系统提示(会话句柄: 整数, 提示: 字符串) : 整数 {
    返回 底层模型.设置配置(会话句柄, "system", 提示);
}

// 把 tool 执行结果加回对话历史，让 agent 下一轮继续
公开 函数 回写工具结果(会话句柄: 整数, 工具ID: 字符串, 工具名: 字符串, 结果文本: 字符串) : 整数 {
    返回 底层模型.添加工具结果(会话句柄, 工具ID, 工具名, 结果文本);
}

// 校验JSON对象 —— 结构化输出的 schema 约束基础原语（纯函数，无 LLM 依赖）。
//   JSON文本：待校验的字符串
//   必需字段：标准库.列表 的字符串列表句柄，每个元素是一个必须存在的顶层键名
// 返回：1 = 可解析为 JSON 对象且所有必需字段都存在；否则 0。
//
// 注意 JSON 模块真实导出名：解析用 J.解码（不是「解析」），存在性用 J.是否包含键。
公开 函数 校验JSON对象(JSON文本: 字符串, 必需字段: 整数) : 整数 {
    变量 对象: 整数 = J.解码(JSON文本);
    如果 (对象 <= 0) {
        返回 0;   // 不是合法 JSON
    }
    变量 字段数: 整数 = 列表库::字符串列表大小(必需字段);
    变量 i: 整数 = 0;
    当 (i < 字段数) {
        变量 键: 字符串 = 列表库::获取字符串(必需字段, i);
        如果 (J.是否包含键(对象, 键) == 0) {
            返回 0;   // 缺字段
        }
        i = i + 1;
    }
    返回 1;
}
