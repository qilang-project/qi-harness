// 提示模板 — 带命名占位的提示词模板（抢救自旧 runtime 的 提示模板 设计，移进活栈）
//
// 拼字符串拼提示词易错、易被注入、难维护。模板把「结构」和「数据」分开：
//   模板里用 {变量名} 占位，填充时用键值替换 —— 提示词一处定义、多处安全复用。
//
// 旧 qi/src/runtime/stdlib/llm.rs 的 提示模板 是 Rust-only、没接进语言（Qi 调不到）。
// 这里用纯 Qi 重写并接入 harness：变量提取 + JSON 参数填充。
//
// 用法：
//   导入 Harness.提示模板::{提取变量, 填充};
//   变量 模板: 字符串 = "查询 {城市} 在 {日期} 的天气，用 {语言} 回答";
//   变量 参数: 整数 = J.创建对象();
//   J.设置字符串(参数, "城市", "东京"); J.设置字符串(参数, "日期", "明天"); J.设置字符串(参数, "语言", "中文");
//   变量 提示: 字符串 = 填充(模板, 参数);   // → "查询 东京 在 明天 的天气，用 中文 回答"
//   变量 变量表: 整数 = 提取变量(模板);      // 字符串列表：["城市","日期","语言"]

包 Harness;

导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 标准库.JSON 作为 J;

// 提取模板里所有 {变量名} 占位符，返回字符串列表（按出现序，含重复）。
公开 函数 提取变量(模板: 字符串) : 整数 {
    变量 结果值: 整数 = 列表库::创建字符串列表();
    变量 n: 整数 = 字符串::字节长度(模板);
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 左: 整数 = 字符串::查找从位置(模板, "{", i);
        如果 (左 < 0) {
            i = n;   // 没有更多占位符
        } 否则 {
            变量 右: 整数 = 字符串::查找从位置(模板, "}", 左 + 1);
            如果 (右 < 0) {
                i = n;   // 无闭合，停
            } 否则 {
                变量 名: 字符串 = 字符串::去空白(字符串::子串(模板, 左 + 1, 右 - 左 - 1));
                如果 (字符串::字节长度(名) > 0) {
                    列表库::添加字符串(结果值, 名);
                }
                i = 右 + 1;
            }
        }
    }
    返回 结果值;
}

// 用参数对象（JSON 对象句柄：变量名 → 字符串值）填充模板，返回填好的字符串。
// 未提供的变量原样保留 {变量名}（便于发现漏填）。
公开 函数 填充(模板: 字符串, 参数对象: 整数) : 字符串 {
    变量 变量表: 整数 = 提取变量(模板);
    变量 数: 整数 = 列表库::字符串列表大小(变量表);
    变量 结果值: 字符串 = 模板;
    变量 i: 整数 = 0;
    当 (i < 数) {
        变量 名: 字符串 = 列表库::获取字符串(变量表, i);
        变量 值: 字符串 = J.获取字符串(参数对象, 名);
        如果 (字符串::字节长度(值) > 0) {
            结果值 = 字符串::替换(结果值, "{" + 名 + "}", 值);
        }
        i = i + 1;
    }
    返回 结果值;
}

// 校验模板的所有变量都在参数对象里给了值：全给齐返回 ""；否则返回第一个缺的变量名。
// 用于「模板洞必须填全」的运行时守卫（编译期版见语言级 提示 字面量，规划中）。
公开 函数 校验填充(模板: 字符串, 参数对象: 整数) : 字符串 {
    变量 变量表: 整数 = 提取变量(模板);
    变量 数: 整数 = 列表库::字符串列表大小(变量表);
    变量 i: 整数 = 0;
    当 (i < 数) {
        变量 名: 字符串 = 列表库::获取字符串(变量表, i);
        如果 (字符串::字节长度(J.获取字符串(参数对象, 名)) == 0) {
            返回 名;
        }
        i = i + 1;
    }
    返回 "";
}
