// 会话存储 — append-only 持久对话历史与非破坏性分支
//
// 条目一经写入不可更新或删除；会话表只保存当前 leaf 指针。把 leaf 移到历史条目后
// 再追加，就会形成新分支，旧分支仍完整保留。payload 必须是合法 JSON。

包 Harness;

导入 标准库.数据库;
导入 标准库.字符串;
导入 标准库.时间;
导入 标准库.随机 作为 随机;
导入 标准库.大模型 作为 底层模型;
导入 标准库.JSON 作为 J;

// 标准库数据库当前只提供执行/查询，没有参数绑定接口。所有文本值统一从这里生成
// SQLite 字面量；数字只由整数转字符串生成，不接收外部 SQL 片段。
函数 SQL文本(原文: 字符串) : 字符串 {
    返回 "'" + 字符串::替换(原文, "'", "''") + "'";
}

函数 首行(行JSON: 字符串) : 整数 {
    变量 数组值: 整数 = J.解码(行JSON);
    如果 (数组值 <= 0) { 返回 0; }
    如果 (J.数组长度(数组值) == 0) { 返回 0; }
    返回 J.数组获取对象(数组值, 0);
}

函数 是JSON(文本: 字符串) : 整数 {
    变量 值: 整数 = J.解码(文本);
    如果 (值 <= 0) { 返回 0; }
    J.删除(值);
    返回 1;
}

// 打开或创建 SQLite 会话库。返回数据库句柄，失败返回 0。
公开 函数 打开会话存储(路径: 字符串) : 整数 {
    变量 库: 整数 = 数据库.连接(路径);
    如果 (库 <= 0) { 返回 0; }
    数据库.执行(库, "PRAGMA foreign_keys = ON");
    数据库.执行(库, "CREATE TABLE IF NOT EXISTS 持久会话 ("
        + "会话ID TEXT PRIMARY KEY, "
        + "当前叶 TEXT NOT NULL DEFAULT '', "
        + "创建时间戳 INTEGER NOT NULL)");
    数据库.执行(库, "CREATE TABLE IF NOT EXISTS 会话条目 ("
        + "序号 INTEGER PRIMARY KEY AUTOINCREMENT, "
        + "会话ID TEXT NOT NULL, "
        + "条目ID TEXT NOT NULL UNIQUE, "
        + "父条目ID TEXT, "
        + "类型 TEXT NOT NULL, "
        + "时间戳 INTEGER NOT NULL, "
        + "载荷JSON TEXT NOT NULL, "
        + "FOREIGN KEY (会话ID) REFERENCES 持久会话(会话ID))");
    数据库.执行(库, "CREATE INDEX IF NOT EXISTS 会话条目_会话序号 ON 会话条目(会话ID, 序号)");
    数据库.执行(库, "CREATE INDEX IF NOT EXISTS 会话条目_父条目 ON 会话条目(会话ID, 父条目ID)");
    // 数据库层也阻止误改历史；正常 API 从不发出 UPDATE/DELETE 条目语句。
    数据库.执行(库, "CREATE TRIGGER IF NOT EXISTS 会话条目_禁止更新 "
        + "BEFORE UPDATE ON 会话条目 BEGIN SELECT RAISE(ABORT, 'session entries are append-only'); END");
    数据库.执行(库, "CREATE TRIGGER IF NOT EXISTS 会话条目_禁止删除 "
        + "BEFORE DELETE ON 会话条目 BEGIN SELECT RAISE(ABORT, 'session entries are append-only'); END");
    变量 模式行: 整数 = 首行(数据库.查询(库,
        "SELECT COUNT(*) AS 数量 FROM sqlite_master WHERE "
        + "(type = 'table' AND name IN ('持久会话', '会话条目')) OR "
        + "(type = 'trigger' AND name IN ('会话条目_禁止更新', '会话条目_禁止删除'))"));
    如果 (模式行 <= 0 || J.获取整数(模式行, "数量") != 4) {
        数据库.关闭(库);
        返回 0;
    }
    返回 库;
}

// SQLite 的进程内数据库，共用持久存储的完整 API，关闭句柄后内容即释放。
公开 函数 打开内存会话存储() : 整数 {
    返回 打开会话存储(":memory:");
}

公开 函数 关闭会话存储(库: 整数) : 整数 {
    如果 (库 <= 0) { 返回 0; }
    数据库.关闭(库);
    返回 1;
}

// 新建空会话。重复 ID 返回 0，不覆盖已有 leaf 或历史。
公开 函数 创建持久会话(库: 整数, 会话ID: 字符串) : 整数 {
    如果 (库 <= 0 || 字符串::字节长度(会话ID) == 0) { 返回 0; }
    返回 数据库.执行(库, "INSERT OR IGNORE INTO 持久会话 (会话ID, 当前叶, 创建时间戳) VALUES ("
        + SQL文本(会话ID) + ", '', " + 整数转字符串(时间.当前毫秒()) + ")");
}

公开 函数 会话存在(库: 整数, 会话ID: 字符串) : 整数 {
    如果 (库 <= 0) { 返回 0; }
    变量 行: 整数 = 首行(数据库.查询(库, "SELECT COUNT(*) AS 数量 FROM 持久会话 WHERE 会话ID = "
        + SQL文本(会话ID)));
    如果 (行 <= 0) { 返回 0; }
    如果 (J.获取整数(行, "数量") > 0) { 返回 1; }
    返回 0;
}

公开 函数 当前会话叶(库: 整数, 会话ID: 字符串) : 字符串 {
    如果 (库 <= 0) { 返回 ""; }
    变量 行: 整数 = 首行(数据库.查询(库, "SELECT 当前叶 FROM 持久会话 WHERE 会话ID = "
        + SQL文本(会话ID)));
    如果 (行 <= 0) { 返回 ""; }
    返回 J.获取字符串(行, "当前叶");
}

// 移动当前 leaf 即创建/切换分支。目标必须属于同一会话；空 ID 表示回到空根。
公开 函数 设置当前会话叶(库: 整数, 会话ID: 字符串, 条目ID: 字符串) : 整数 {
    如果 (库 <= 0) { 返回 0; }
    如果 (字符串::字节长度(条目ID) == 0) {
        返回 数据库.执行(库, "UPDATE 持久会话 SET 当前叶 = '' WHERE 会话ID = " + SQL文本(会话ID));
    }
    返回 数据库.执行(库, "UPDATE 持久会话 SET 当前叶 = " + SQL文本(条目ID)
        + " WHERE 会话ID = " + SQL文本(会话ID)
        + " AND EXISTS (SELECT 1 FROM 会话条目 WHERE 会话ID = " + SQL文本(会话ID)
        + " AND 条目ID = " + SQL文本(条目ID) + ")");
}

// 期望叶非空/空都参与比较。成功返回 1，叶已变化返回 0，存储错误返回 -1。
// 比较、写条目和移动 leaf 在同一 IMMEDIATE 事务内完成。
公开 函数 按期望叶追加会话条目(库: 整数, 会话ID: 字符串, 期望叶: 字符串,
                        条目类型: 字符串, 载荷JSON: 字符串) : 整数 {
    如果 (库 <= 0 || 字符串::字节长度(条目类型) == 0 || 是JSON(载荷JSON) == 0) { 返回 0 - 1; }
    如果 (数据库.执行(库, "BEGIN IMMEDIATE") < 0) { 返回 0 - 1; }
    变量 会话行: 整数 = 首行(数据库.查询(库, "SELECT 当前叶 FROM 持久会话 WHERE 会话ID = "
        + SQL文本(会话ID)));
    如果 (会话行 <= 0) {
        数据库.执行(库, "ROLLBACK");
        返回 0 - 1;
    }
    如果 (字符串::等于(J.获取字符串(会话行, "当前叶"), 期望叶) == 0) {
        数据库.执行(库, "ROLLBACK");
        返回 0;
    }

    变量 条目ID: 字符串 = 随机.UUID();
    变量 父SQL: 字符串 = "NULL";
    如果 (字符串::字节长度(期望叶) > 0) { 父SQL = SQL文本(期望叶); }
    变量 写入: 整数 = 数据库.执行(库,
        "INSERT INTO 会话条目 (会话ID, 条目ID, 父条目ID, 类型, 时间戳, 载荷JSON) VALUES ("
        + SQL文本(会话ID) + ", " + SQL文本(条目ID) + ", " + 父SQL + ", "
        + SQL文本(条目类型) + ", " + 整数转字符串(时间.当前毫秒()) + ", " + SQL文本(载荷JSON) + ")");
    如果 (写入 <= 0) {
        数据库.执行(库, "ROLLBACK");
        返回 0 - 1;
    }
    变量 叶更新: 整数 = 数据库.执行(库, "UPDATE 持久会话 SET 当前叶 = " + SQL文本(条目ID)
        + " WHERE 会话ID = " + SQL文本(会话ID) + " AND 当前叶 = " + SQL文本(期望叶));
    如果 (叶更新 <= 0) {
        数据库.执行(库, "ROLLBACK");
        返回 0 - 1;
    }
    如果 (数据库.执行(库, "COMMIT") < 0) {
        数据库.执行(库, "ROLLBACK");
        返回 0 - 1;
    }
    返回 1;
}

// 服务租约校验、条目追加和 leaf 更新必须处于同一事务，避免校验后被接管的窗口。
// 成功返回 1，leaf 或租约失效返回 0，存储错误返回 -1。
函数 按写栅栏及期望叶追加会话条目(库: 整数, 会话ID: 字符串, 期望叶: 字符串,
                              所有者令牌: 字符串, 栅栏: 整数,
                              条目类型: 字符串, 载荷JSON: 字符串) : 整数 {
    如果 (库 <= 0 || 字符串::字节长度(所有者令牌) == 0 || 栅栏 <= 0
        || 字符串::字节长度(条目类型) == 0 || 是JSON(载荷JSON) == 0) { 返回 0 - 1; }
    如果 (数据库.执行(库, "BEGIN IMMEDIATE") < 0) { 返回 0 - 1; }
    变量 当前时间: 整数 = 时间.当前毫秒();
    变量 会话行: 整数 = 首行(数据库.查询(库,
        "SELECT s.当前叶 FROM 持久会话 s WHERE s.会话ID = " + SQL文本(会话ID)
        + " AND EXISTS (SELECT 1 FROM 服务会话请求锁 l WHERE l.会话ID = s.会话ID"
        + " AND l.所有者令牌 = " + SQL文本(所有者令牌)
        + " AND l.栅栏 = " + 整数转字符串(栅栏)
        + " AND l.租约到期毫秒 > " + 整数转字符串(当前时间) + ")"));
    如果 (会话行 <= 0) {
        数据库.执行(库, "ROLLBACK");
        返回 0;
    }
    如果 (字符串::等于(J.获取字符串(会话行, "当前叶"), 期望叶) == 0) {
        数据库.执行(库, "ROLLBACK");
        返回 0;
    }
    变量 条目ID: 字符串 = 随机.UUID();
    变量 父SQL: 字符串 = "NULL";
    如果 (字符串::字节长度(期望叶) > 0) { 父SQL = SQL文本(期望叶); }
    变量 写入: 整数 = 数据库.执行(库,
        "INSERT INTO 会话条目 (会话ID, 条目ID, 父条目ID, 类型, 时间戳, 载荷JSON) VALUES ("
        + SQL文本(会话ID) + ", " + SQL文本(条目ID) + ", " + 父SQL + ", "
        + SQL文本(条目类型) + ", " + 整数转字符串(当前时间) + ", " + SQL文本(载荷JSON) + ")");
    如果 (写入 <= 0) {
        数据库.执行(库, "ROLLBACK");
        返回 0 - 1;
    }
    变量 叶更新: 整数 = 数据库.执行(库, "UPDATE 持久会话 SET 当前叶 = " + SQL文本(条目ID)
        + " WHERE 会话ID = " + SQL文本(会话ID) + " AND 当前叶 = " + SQL文本(期望叶)
        + " AND EXISTS (SELECT 1 FROM 服务会话请求锁 WHERE 会话ID = " + SQL文本(会话ID)
        + " AND 所有者令牌 = " + SQL文本(所有者令牌)
        + " AND 栅栏 = " + 整数转字符串(栅栏)
        + " AND 租约到期毫秒 > " + 整数转字符串(当前时间) + ")");
    如果 (叶更新 <= 0) {
        数据库.执行(库, "ROLLBACK");
        返回 0;
    }
    如果 (数据库.执行(库, "COMMIT") < 0) {
        数据库.执行(库, "ROLLBACK");
        返回 0 - 1;
    }
    返回 1;
}

函数 按写栅栏追加会话条目(库: 整数, 会话ID: 字符串,
                         所有者令牌: 字符串, 栅栏: 整数,
                         条目类型: 字符串, 载荷JSON: 字符串) : 字符串 {
    变量 期望叶: 字符串 = 当前会话叶(库, 会话ID);
    如果 (按写栅栏及期望叶追加会话条目(库, 会话ID, 期望叶,
        所有者令牌, 栅栏, 条目类型, 载荷JSON) != 1) { 返回 ""; }
    返回 当前会话叶(库, 会话ID);
}

// 调用方已持有 IMMEDIATE 事务。租约接管时只回退与旧 owner/fence 精确匹配的
// request.started 分支；旧条目仍保持 append-only，但不再属于当前可见历史。
函数 回退未完成写栅栏请求(库: 整数, 会话ID: 字符串,
                         所有者令牌: 字符串, 栅栏: 整数) : 整数 {
    如果 (库 <= 0 || 字符串::字节长度(所有者令牌) == 0 || 栅栏 < 0) { 返回 0 - 1; }
    变量 开始载荷: 字符串 = "{\"source\":\"service\",\"owner_token\":\""
        + 所有者令牌 + "\",\"fence\":" + 整数转字符串(栅栏) + "}";
    返回 数据库.执行(库,
        "UPDATE 持久会话 SET 当前叶 = COALESCE((WITH RECURSIVE 当前分支(序号, 条目ID, 父条目ID, 类型, 载荷JSON) AS ("
        + "SELECT e.序号, e.条目ID, e.父条目ID, e.类型, e.载荷JSON FROM 会话条目 e "
        + "WHERE e.会话ID = " + SQL文本(会话ID) + " AND e.条目ID = 持久会话.当前叶 "
        + "UNION ALL SELECT p.序号, p.条目ID, p.父条目ID, p.类型, p.载荷JSON FROM 会话条目 p "
        + "JOIN 当前分支 c ON p.条目ID = c.父条目ID WHERE p.会话ID = " + SQL文本(会话ID)
        + ") SELECT COALESCE(start.父条目ID, '') FROM 当前分支 start "
        + "WHERE start.类型 = 'request.started' AND start.载荷JSON = " + SQL文本(开始载荷)
        + " AND NOT EXISTS (SELECT 1 FROM 当前分支 terminal WHERE terminal.序号 > start.序号 "
        + "AND terminal.类型 IN ('turn.complete', 'turn.failed')) LIMIT 1), 当前叶) WHERE 会话ID = "
        + SQL文本(会话ID));
}

// 在指定 parent 下追加；parent="" 表示根条目。成功返回新 UUID，失败返回 ""。
公开 函数 追加会话条目到(库: 整数, 会话ID: 字符串, 父条目ID: 字符串,
                    条目类型: 字符串, 载荷JSON: 字符串) : 字符串 {
    如果 (库 <= 0 || 字符串::字节长度(条目类型) == 0 || 是JSON(载荷JSON) == 0) { 返回 ""; }
    如果 (数据库.执行(库, "BEGIN IMMEDIATE") < 0) { 返回 ""; }
    变量 会话行: 整数 = 首行(数据库.查询(库, "SELECT COUNT(*) AS 数量 FROM 持久会话 WHERE 会话ID = "
        + SQL文本(会话ID)));
    如果 (会话行 <= 0 || J.获取整数(会话行, "数量") == 0) {
        数据库.执行(库, "ROLLBACK");
        返回 "";
    }
    如果 (字符串::字节长度(父条目ID) > 0) {
        变量 父行: 整数 = 首行(数据库.查询(库, "SELECT COUNT(*) AS 数量 FROM 会话条目 WHERE 会话ID = "
            + SQL文本(会话ID) + " AND 条目ID = " + SQL文本(父条目ID)));
        如果 (父行 <= 0 || J.获取整数(父行, "数量") == 0) {
            数据库.执行(库, "ROLLBACK");
            返回 "";
        }
    }
    变量 条目ID: 字符串 = 随机.UUID();
    变量 父SQL: 字符串 = "NULL";
    如果 (字符串::字节长度(父条目ID) > 0) { 父SQL = SQL文本(父条目ID); }
    变量 写入: 整数 = 数据库.执行(库,
        "INSERT INTO 会话条目 (会话ID, 条目ID, 父条目ID, 类型, 时间戳, 载荷JSON) VALUES ("
        + SQL文本(会话ID) + ", " + SQL文本(条目ID) + ", " + 父SQL + ", "
        + SQL文本(条目类型) + ", " + 整数转字符串(时间.当前毫秒()) + ", " + SQL文本(载荷JSON) + ")");
    如果 (写入 <= 0) {
        数据库.执行(库, "ROLLBACK");
        返回 "";
    }
    变量 叶更新: 整数 = 数据库.执行(库, "UPDATE 持久会话 SET 当前叶 = " + SQL文本(条目ID)
        + " WHERE 会话ID = " + SQL文本(会话ID));
    如果 (叶更新 <= 0) {
        数据库.执行(库, "ROLLBACK");
        返回 "";
    }
    如果 (数据库.执行(库, "COMMIT") < 0) {
        数据库.执行(库, "ROLLBACK");
        返回 "";
    }
    返回 条目ID;
}

// 在当前 leaf 后追加，并把新条目设为 leaf。
公开 函数 追加会话条目(库: 整数, 会话ID: 字符串, 条目类型: 字符串, 载荷JSON: 字符串) : 字符串 {
    返回 追加会话条目到(库, 会话ID, 当前会话叶(库, 会话ID), 条目类型, 载荷JSON);
}

// 返回数据库查询生成的 JSON 数组，按原始追加顺序包含会话全部分支。
公开 函数 加载会话条目(库: 整数, 会话ID: 字符串) : 字符串 {
    如果 (库 <= 0) { 返回 "[]"; }
    返回 数据库.查询(库, "SELECT 会话ID AS session_id, 条目ID AS entry_id, "
        + "COALESCE(父条目ID, '') AS parent_id, 类型 AS type, 时间戳 AS timestamp, 载荷JSON AS payload_json "
        + "FROM 会话条目 WHERE 会话ID = " + SQL文本(会话ID) + " ORDER BY 序号");
}

// 导出格式版本固定为 1。对象字段与条目顺序固定，重复导出同一未修改会话结果相同。
// 会话不存在或查询失败返回空字符串。
公开 函数 导出持久会话JSON(库: 整数, 会话ID: 字符串) : 字符串 {
    如果 (库 <= 0 || 会话存在(库, 会话ID) == 0) { 返回 ""; }
    变量 会话行: 整数 = 首行(数据库.查询(库,
        "SELECT 会话ID AS session_id, 当前叶 AS leaf_entry_id, 创建时间戳 AS created_at "
        + "FROM 持久会话 WHERE 会话ID = " + SQL文本(会话ID)));
    如果 (会话行 <= 0) { 返回 ""; }
    变量 条目: 整数 = J.解码(加载会话条目(库, 会话ID));
    如果 (条目 <= 0) { 返回 ""; }

    变量 根: 整数 = J.创建对象();
    J.设置整数(根, "version", 1);
    J.设置字符串(根, "session_id", J.获取字符串(会话行, "session_id"));
    J.设置字符串(根, "leaf_entry_id", J.获取字符串(会话行, "leaf_entry_id"));
    J.设置整数(根, "created_at", J.获取整数(会话行, "created_at"));
    J.设置数组(根, "entries", 条目);
    变量 文本: 字符串 = J.转字符串(根);
    J.删除(根);
    返回 文本;
}

函数 导入条目ID已出现(条目: 整数, 结束索引: 整数, 条目ID: 字符串) : 整数 {
    变量 i: 整数 = 0;
    当 (i < 结束索引) {
        如果 (字符串::等于(J.获取字符串(J.数组获取对象(条目, i), "entry_id"), 条目ID) == 1) {
            返回 1;
        }
        i = i + 1;
    }
    返回 0;
}

// 先完整校验再单事务导入。返回 1=成功，0=格式/引用错误，-1=会话或条目 ID 碰撞。
// parent 必须指向导出序列中更早的条目，因此循环、悬空引用和乱序输入都会被拒绝。
公开 函数 导入持久会话JSON(库: 整数, 导出JSON: 字符串) : 整数 {
    如果 (库 <= 0) { 返回 0; }
    变量 根: 整数 = J.解码(导出JSON);
    如果 (根 <= 0) { 返回 0; }
    如果 (J.是否包含键(根, "version") == 0
        || J.是否包含键(根, "session_id") == 0
        || J.是否包含键(根, "leaf_entry_id") == 0
        || J.是否包含键(根, "created_at") == 0
        || J.是否包含键(根, "entries") == 0
        || J.获取整数(根, "version") != 1) {
        J.删除(根);
        返回 0;
    }
    变量 会话ID: 字符串 = J.获取字符串(根, "session_id");
    变量 当前叶: 字符串 = J.获取字符串(根, "leaf_entry_id");
    变量 创建时间戳: 整数 = J.获取整数(根, "created_at");
    变量 条目: 整数 = J.获取数组(根, "entries");
    如果 (字符串::字节长度(会话ID) == 0 || 创建时间戳 <= 0 || 条目 <= 0) {
        J.删除(根);
        返回 0;
    }
    如果 (会话存在(库, 会话ID) == 1) {
        J.删除(根);
        返回 0 - 1;
    }

    变量 数量: 整数 = J.数组长度(条目);
    变量 i: 整数 = 0;
    当 (i < 数量) {
        变量 项: 整数 = J.数组获取对象(条目, i);
        如果 (项 <= 0
            || J.是否包含键(项, "session_id") == 0
            || J.是否包含键(项, "entry_id") == 0
            || J.是否包含键(项, "parent_id") == 0
            || J.是否包含键(项, "type") == 0
            || J.是否包含键(项, "timestamp") == 0
            || J.是否包含键(项, "payload_json") == 0) {
            J.删除(根);
            返回 0;
        }
        变量 条目会话ID: 字符串 = J.获取字符串(项, "session_id");
        变量 条目ID: 字符串 = J.获取字符串(项, "entry_id");
        变量 父条目ID: 字符串 = J.获取字符串(项, "parent_id");
        变量 条目类型: 字符串 = J.获取字符串(项, "type");
        变量 时间戳: 整数 = J.获取整数(项, "timestamp");
        变量 载荷JSON: 字符串 = J.获取字符串(项, "payload_json");
        如果 (字符串::等于(条目会话ID, 会话ID) == 0
            || 字符串::字节长度(条目ID) == 0
            || 字符串::字节长度(条目类型) == 0
            || 时间戳 <= 0 || 是JSON(载荷JSON) == 0
            || 导入条目ID已出现(条目, i, 条目ID) == 1) {
            J.删除(根);
            返回 0;
        }
        如果 (字符串::字节长度(父条目ID) > 0
            && 导入条目ID已出现(条目, i, 父条目ID) == 0) {
            J.删除(根);
            返回 0;
        }
        变量 碰撞行: 整数 = 首行(数据库.查询(库,
            "SELECT COUNT(*) AS 数量 FROM 会话条目 WHERE 条目ID = " + SQL文本(条目ID)));
        如果 (碰撞行 <= 0) {
            J.删除(根);
            返回 0;
        }
        如果 (J.获取整数(碰撞行, "数量") > 0) {
            J.删除(根);
            返回 0 - 1;
        }
        i = i + 1;
    }
    如果 (字符串::字节长度(当前叶) > 0
        && 导入条目ID已出现(条目, 数量, 当前叶) == 0) {
        J.删除(根);
        返回 0;
    }

    如果 (数据库.执行(库, "BEGIN IMMEDIATE") < 0) {
        J.删除(根);
        返回 0;
    }
    变量 创建结果: 整数 = 数据库.执行(库,
        "INSERT INTO 持久会话 (会话ID, 当前叶, 创建时间戳) VALUES ("
        + SQL文本(会话ID) + ", '', " + 整数转字符串(创建时间戳) + ")");
    如果 (创建结果 <= 0) {
        数据库.执行(库, "ROLLBACK");
        J.删除(根);
        返回 0 - 1;
    }
    i = 0;
    当 (i < 数量) {
        变量 写项: 整数 = J.数组获取对象(条目, i);
        变量 写父ID: 字符串 = J.获取字符串(写项, "parent_id");
        变量 父SQL: 字符串 = "NULL";
        如果 (字符串::字节长度(写父ID) > 0) { 父SQL = SQL文本(写父ID); }
        变量 写结果: 整数 = 数据库.执行(库,
            "INSERT INTO 会话条目 (会话ID, 条目ID, 父条目ID, 类型, 时间戳, 载荷JSON) VALUES ("
            + SQL文本(会话ID) + ", " + SQL文本(J.获取字符串(写项, "entry_id")) + ", "
            + 父SQL + ", " + SQL文本(J.获取字符串(写项, "type")) + ", "
            + 整数转字符串(J.获取整数(写项, "timestamp")) + ", "
            + SQL文本(J.获取字符串(写项, "payload_json")) + ")");
        如果 (写结果 <= 0) {
            数据库.执行(库, "ROLLBACK");
            J.删除(根);
            返回 0 - 1;
        }
        i = i + 1;
    }
    变量 叶结果: 整数 = 数据库.执行(库, "UPDATE 持久会话 SET 当前叶 = "
        + SQL文本(当前叶) + " WHERE 会话ID = " + SQL文本(会话ID));
    如果 (叶结果 <= 0) {
        数据库.执行(库, "ROLLBACK");
        J.删除(根);
        返回 0;
    }
    如果 (数据库.执行(库, "COMMIT") < 0) {
        数据库.执行(库, "ROLLBACK");
        J.删除(根);
        返回 0;
    }
    J.删除(根);
    返回 1;
}

// 从当前 leaf 沿 parent 回溯，并以 root -> leaf 顺序返回 JSON 数组。
公开 函数 当前会话路径(库: 整数, 会话ID: 字符串) : 字符串 {
    如果 (库 <= 0) { 返回 "[]"; }
    返回 数据库.查询(库, "WITH RECURSIVE 路径(会话ID, 条目ID, 父条目ID, 类型, 时间戳, 载荷JSON, 深度) AS ("
        + "SELECT e.会话ID, e.条目ID, e.父条目ID, e.类型, e.时间戳, e.载荷JSON, 0 "
        + "FROM 会话条目 e JOIN 持久会话 s ON s.会话ID = e.会话ID AND s.当前叶 = e.条目ID "
        + "WHERE e.会话ID = " + SQL文本(会话ID)
        + " UNION ALL SELECT p.会话ID, p.条目ID, p.父条目ID, p.类型, p.时间戳, p.载荷JSON, c.深度 + 1 "
        + "FROM 会话条目 p JOIN 路径 c ON p.会话ID = c.会话ID AND p.条目ID = c.父条目ID) "
        + "SELECT 会话ID AS session_id, 条目ID AS entry_id, COALESCE(父条目ID, '') AS parent_id, "
        + "类型 AS type, 时间戳 AS timestamp, 载荷JSON AS payload_json FROM 路径 ORDER BY 深度 DESC");
}

函数 消息载荷(角色: 字符串, 内容: 字符串) : 字符串 {
    变量 对象: 整数 = J.创建对象();
    J.设置字符串(对象, "role", 角色);
    J.设置字符串(对象, "content", 内容);
    变量 文本: 字符串 = J.转字符串(对象);
    J.删除(对象);
    返回 文本;
}

公开 函数 追加用户消息(库: 整数, 会话ID: 字符串, 内容: 字符串) : 字符串 {
    返回 追加会话条目(库, 会话ID, "message.user", 消息载荷("user", 内容));
}

公开 函数 追加助手消息(库: 整数, 会话ID: 字符串, 内容: 字符串) : 字符串 {
    返回 追加会话条目(库, 会话ID, "message.assistant", 消息载荷("assistant", 内容));
}

// provider 原始响应单独保存，供恢复工具调用消息；最终展示文本另存为审计条目，
// 恢复时不会重复加入 runtime 历史。
公开 函数 追加助手原始消息(库: 整数, 会话ID: 字符串, 原始响应: 字符串) : 字符串 {
    变量 对象: 整数 = J.创建对象();
    J.设置字符串(对象, "role", "assistant");
    J.设置字符串(对象, "raw", 原始响应);
    变量 文本: 字符串 = J.转字符串(对象);
    J.删除(对象);
    返回 追加会话条目(库, 会话ID, "message.assistant.raw", 文本);
}

公开 函数 追加助手最终消息(库: 整数, 会话ID: 字符串, 内容: 字符串) : 字符串 {
    返回 追加会话条目(库, 会话ID, "message.assistant.final", 消息载荷("assistant", 内容));
}

公开 函数 追加工具结果条目(库: 整数, 会话ID: 字符串, 工具调用ID: 字符串,
                        工具名: 字符串, 结果文本: 字符串) : 字符串 {
    变量 对象: 整数 = J.创建对象();
    J.设置字符串(对象, "tool_call_id", 工具调用ID);
    J.设置字符串(对象, "name", 工具名);
    J.设置字符串(对象, "result", 结果文本);
    变量 文本: 字符串 = J.转字符串(对象);
    J.删除(对象);
    返回 追加会话条目(库, 会话ID, "tool.result", 文本);
}

公开 函数 追加会话错误(库: 整数, 会话ID: 字符串, 来源: 字符串,
                    错误文本: 字符串, 类别: 整数) : 字符串 {
    变量 对象: 整数 = J.创建对象();
    J.设置字符串(对象, "source", 来源);
    J.设置字符串(对象, "message", 错误文本);
    J.设置整数(对象, "category", 类别);
    变量 文本: 字符串 = J.转字符串(对象);
    J.删除(对象);
    返回 追加会话条目(库, 会话ID, "error." + 来源, 文本);
}

函数 轮载荷(轮ID: 字符串) : 字符串 {
    变量 对象: 整数 = J.创建对象();
    J.设置字符串(对象, "turn_id", 轮ID);
    变量 文本: 字符串 = J.转字符串(对象);
    J.删除(对象);
    返回 文本;
}

// 轮状态也是 append-only 条目。完成/失败只追加终态，不修改已写消息。
// 恢复层据此排除没有完成的轮，同时保留错误条目供审计。
公开 函数 开始会话轮(库: 整数, 会话ID: 字符串) : 字符串 {
    变量 轮ID: 字符串 = 随机.UUID();
    变量 对象: 整数 = J.创建对象();
    J.设置字符串(对象, "turn_id", 轮ID);
    变量 文本: 字符串 = J.转字符串(对象);
    J.删除(对象);
    变量 条目ID: 字符串 = 追加会话条目(库, 会话ID, "turn.start", 文本);
    如果 (字符串::字节长度(条目ID) == 0) { 返回 ""; }
    返回 轮ID;
}

公开 函数 完成会话轮(库: 整数, 会话ID: 字符串, 轮ID: 字符串) : 字符串 {
    如果 (字符串::字节长度(轮ID) == 0) { 返回 ""; }
    返回 追加会话条目(库, 会话ID, "turn.complete", 轮载荷(轮ID));
}

公开 函数 失败会话轮(库: 整数, 会话ID: 字符串, 轮ID: 字符串) : 字符串 {
    如果 (字符串::字节长度(轮ID) == 0) { 返回 ""; }
    返回 追加会话条目(库, 会话ID, "turn.failed", 轮载荷(轮ID));
}

函数 添加普通消息到历史(历史: 整数, 角色: 字符串, 内容: 字符串) {
    变量 消息: 整数 = J.创建对象();
    J.设置字符串(消息, "role", 角色);
    J.设置字符串(消息, "content", 内容);
    J.数组添加对象(历史, 消息);
}

函数 轮已完成(路径: 整数, 开始索引: 整数, 轮ID: 字符串) : 整数 {
    变量 i: 整数 = 开始索引 + 1;
    当 (i < J.数组长度(路径)) {
        变量 条目: 整数 = J.数组获取对象(路径, i);
        变量 类型值: 字符串 = J.获取字符串(条目, "type");
        如果 (字符串::等于(类型值, "turn.start") == 1) { 返回 0; }
        如果 (字符串::等于(类型值, "turn.complete") == 1) {
            变量 载荷: 整数 = J.解码(J.获取字符串(条目, "payload_json"));
            如果 (载荷 > 0
                && 字符串::等于(J.获取字符串(载荷, "turn_id"), 轮ID) == 1) {
                返回 1;
            }
        }
        i = i + 1;
    }
    返回 0;
}

// 用当前 root-to-leaf 路径整体覆盖 runtime 历史。错误、元数据和 final 审计条目
// 不参与重放；带 turn 标记的消息只恢复已完成轮，失败/中断轮仍完整留在审计路径。
// 没有 turn 标记的旧版历史保持原恢复语义。
公开 函数 恢复会话到运行时(库: 整数, 会话ID: 字符串, 会话句柄: 整数) : 整数 {
    如果 (库 <= 0 || 会话句柄 <= 0 || 会话存在(库, 会话ID) == 0) { 返回 0 - 1; }
    变量 路径: 整数 = J.解码(当前会话路径(库, 会话ID));
    如果 (路径 <= 0) { 返回 0 - 1; }
    变量 历史: 整数 = J.创建数组();
    变量 数量: 整数 = J.数组长度(路径);
    变量 i: 整数 = 0;
    变量 当前轮可恢复: 整数 = 1;
    当 (i < 数量) {
        变量 条目: 整数 = J.数组获取对象(路径, i);
        变量 类型值: 字符串 = J.获取字符串(条目, "type");
        变量 载荷: 整数 = J.解码(J.获取字符串(条目, "payload_json"));
        如果 (字符串::等于(类型值, "turn.start") == 1) {
            当前轮可恢复 = 0;
            如果 (载荷 > 0) {
                当前轮可恢复 = 轮已完成(路径, i, J.获取字符串(载荷, "turn_id"));
            }
        } 否则如果 (载荷 > 0 && 当前轮可恢复 == 1) {
            如果 (字符串::等于(类型值, "message.user") == 1
                || 字符串::等于(类型值, "message.assistant") == 1) {
                添加普通消息到历史(历史, J.获取字符串(载荷, "role"), J.获取字符串(载荷, "content"));
            } 否则如果 (字符串::等于(类型值, "message.assistant.raw") == 1) {
                变量 原始: 字符串 = J.获取字符串(载荷, "raw");
                变量 原始对象: 整数 = J.解码(原始);
                如果 (原始对象 > 0 && 字符串::等于(J.获取字符串(原始对象, "role"), "assistant") == 1) {
                    J.数组添加对象(历史, 原始对象);
                } 否则 {
                    添加普通消息到历史(历史, "assistant", 原始);
                }
            } 否则如果 (字符串::等于(类型值, "tool.result") == 1) {
                变量 工具消息: 整数 = J.创建对象();
                J.设置字符串(工具消息, "role", "tool");
                J.设置字符串(工具消息, "tool_call_id", J.获取字符串(载荷, "tool_call_id"));
                J.设置字符串(工具消息, "name", J.获取字符串(载荷, "name"));
                J.设置字符串(工具消息, "content", J.获取字符串(载荷, "result"));
                J.数组添加对象(历史, 工具消息);
            }
        }
        i = i + 1;
    }
    返回 底层模型.设置历史JSON(会话句柄, J.转字符串(历史));
}

公开 函数 追加模型变更(库: 整数, 会话ID: 字符串, 模型: 字符串) : 字符串 {
    变量 对象: 整数 = J.创建对象();
    J.设置字符串(对象, "model", 模型);
    变量 文本: 字符串 = J.转字符串(对象);
    J.删除(对象);
    返回 追加会话条目(库, 会话ID, "model.change", 文本);
}

// 配置作为 JSON 原文保存，恢复层可按当时 entry 重放，不在此模块解释配置内容。
公开 函数 追加配置变更(库: 整数, 会话ID: 字符串, 配置JSON: 字符串) : 字符串 {
    返回 追加会话条目(库, 会话ID, "config.change", 配置JSON);
}

公开 函数 追加压缩摘要(库: 整数, 会话ID: 字符串, 摘要: 字符串,
                    起始条目ID: 字符串, 结束条目ID: 字符串) : 字符串 {
    变量 对象: 整数 = J.创建对象();
    J.设置字符串(对象, "summary", 摘要);
    J.设置字符串(对象, "from_entry_id", 起始条目ID);
    J.设置字符串(对象, "to_entry_id", 结束条目ID);
    变量 文本: 字符串 = J.转字符串(对象);
    J.删除(对象);
    返回 追加会话条目(库, 会话ID, "compaction.summary", 文本);
}

公开 函数 追加分支摘要(库: 整数, 会话ID: 字符串, 摘要: 字符串,
                    分支叶条目ID: 字符串) : 字符串 {
    变量 对象: 整数 = J.创建对象();
    J.设置字符串(对象, "summary", 摘要);
    J.设置字符串(对象, "branch_leaf_entry_id", 分支叶条目ID);
    变量 文本: 字符串 = J.转字符串(对象);
    J.删除(对象);
    返回 追加会话条目(库, 会话ID, "branch.summary", 文本);
}

公开 函数 追加会话元数据(库: 整数, 会话ID: 字符串, 元数据JSON: 字符串) : 字符串 {
    返回 追加会话条目(库, 会话ID, "session.metadata", 元数据JSON);
}
