// 工具 — Tool 定义 + 注册 + 派发
//
// 一个工具 = 名字 + 描述 + 参数 JSON Schema + 处理函数。
// 注册到会话后模型能看到这个工具；agent loop 检测到 tool_call 时按工具名
// dispatch 到对应处理函数。
//
// 处理函数签名固定为 `函数(参数JSON: 字符串) : 字符串`：
//   - 输入：模型生成的 arguments JSON 字符串
//   - 输出：工具执行结果（也是字符串，会回写到对话历史）

包 Harness;

导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 标准库.哈希表 作为 哈希表;
导入 标准库.JSON 作为 J;
导入 标准库.大模型 作为 底层模型;
导入 标准库.同步 作为 同步;
导入 Harness.MCP客户端::{ MCP调用工具 };

公开 类型 工具 {
    名字: 字符串,
    描述: 字符串,
    参数schema: 字符串,                   // JSON Schema 字符串
    处理: 函数(字符串): 字符串,            // (参数JSON) -> 结果文本
}

// 工具注册表保持 0.1.0 的公开字段形状；新增管线元数据存放在模块私有表中。
公开 类型 注册表 {
    名字列表: 整数,         // 字符串列表句柄
    处理列表: 整数,         // 指针列表句柄（MCP 工具填占位指针）
    来源列表: 整数,         // 整数列表句柄：0=本地, 1=MCP
    连接列表: 整数,         // 字符串列表句柄：MCP 连接描述符（本地填 ""）
}

公开 函数 创建注册表() : 注册表 {
    返回 新建 注册表 {
        名字列表: 列表库::创建字符串列表(),
        处理列表: 列表库::创建指针列表(),
        来源列表: 列表库::创建整数列表(),
        连接列表: 列表库::创建字符串列表(),
    };
}

// schema 不加入公开 注册表 类型，避免破坏已发布的结构体 ABI/API；名字列表句柄和
// 注册下标共同构成稳定键，仍可让每个注册项（含 MCP 与钩子覆盖项）保留原 schema。
变量 schema表: 整数 = 0;
变量 受控句柄表: 整数 = 0;
变量 模式值表: 整数 = 0;
变量 元数据注册表键: 整数 = 0;
变量 模式表组: 整数 = 0;
变量 前钩子表组: 整数 = 0;
变量 后钩子表组: 整数 = 0;
变量 工具元数据锁: 整数 = 同步.创建锁();
变量 工具注册锁: 整数 = 同步.创建锁();

函数 确保schema表() {
    同步.加锁(工具元数据锁);
    如果 (schema表 == 0) {
        schema表 = 哈希表::创建字符串表();
        受控句柄表 = 哈希表::创建字符串表();
        模式值表 = 哈希表::创建字符串表();
    }
    同步.解锁(工具元数据锁);
}

函数 保存模式(注册表值: 注册表, 模式: 整数) {
    确保schema表();
    变量 idx: 整数 = 列表库::字符串列表大小(注册表值.名字列表) - 1;
    如果 (模式 == 1) { 哈希表::设置字符串(模式值表, schema键(注册表值, idx), "1"); }
    否则 { 哈希表::设置字符串(模式值表, schema键(注册表值, idx), "0"); }
}

函数 设置索引模式(注册表值: 注册表, idx: 整数, 模式: 整数) {
    确保schema表();
    如果 (模式 == 1) { 哈希表::设置字符串(模式值表, schema键(注册表值, idx), "1"); }
    否则 { 哈希表::设置字符串(模式值表, schema键(注册表值, idx), "0"); }
}

函数 读取模式(注册表值: 注册表, idx: 整数) : 整数 {
    确保schema表();
    返回 字符串转整数(哈希表::获取字符串(模式值表, schema键(注册表值, idx)));
}

函数 锁内确保元数据注册表() {
    如果 (元数据注册表键 == 0) {
        元数据注册表键 = 列表库::创建整数列表();
        模式表组 = 列表库::创建整数列表();
        前钩子表组 = 列表库::创建整数列表();
        后钩子表组 = 列表库::创建整数列表();
    }
}

函数 元数据槽位(注册表值: 注册表) : 整数 {
    同步.加锁(工具元数据锁);
    锁内确保元数据注册表();
    变量 i: 整数 = 0;
    当 (i < 列表库::整数列表大小(元数据注册表键)) {
        如果 (列表库::获取整数(元数据注册表键, i) == 注册表值.名字列表) {
            同步.解锁(工具元数据锁);
            返回 i;
        }
        i = i + 1;
    }
    列表库::添加整数(元数据注册表键, 注册表值.名字列表);
    列表库::添加整数(模式表组, 列表库::创建整数列表());
    列表库::添加整数(前钩子表组, 列表库::创建指针列表());
    列表库::添加整数(后钩子表组, 列表库::创建指针列表());
    变量 槽位: 整数 = 列表库::整数列表大小(元数据注册表键) - 1;
    同步.解锁(工具元数据锁);
    返回 槽位;
}

函数 模式列表(注册表值: 注册表) : 整数 {
    返回 列表库::获取整数(模式表组, 元数据槽位(注册表值));
}

函数 前钩子列表(注册表值: 注册表) : 整数 {
    返回 列表库::获取整数(前钩子表组, 元数据槽位(注册表值));
}

函数 后钩子列表(注册表值: 注册表) : 整数 {
    返回 列表库::获取整数(后钩子表组, 元数据槽位(注册表值));
}

函数 schema键(注册表值: 注册表, idx: 整数) : 字符串 {
    返回 整数转字符串(注册表值.名字列表) + ":" + 整数转字符串(idx);
}

函数 保存schema(注册表值: 注册表, schema文本: 字符串) {
    确保schema表();
    变量 idx: 整数 = 列表库::字符串列表大小(注册表值.名字列表) - 1;
    哈希表::设置字符串(schema表, schema键(注册表值, idx), schema文本);
}

函数 读取schema(注册表值: 注册表, idx: 整数) : 字符串 {
    确保schema表();
    返回 哈希表::获取字符串(schema表, schema键(注册表值, idx));
}

函数 保存受控句柄(注册表值: 注册表, 句柄: 整数) {
    确保schema表();
    变量 idx: 整数 = 列表库::字符串列表大小(注册表值.名字列表) - 1;
    哈希表::设置字符串(受控句柄表, schema键(注册表值, idx), 整数转字符串(句柄 + 1));
}

// MCP 工具不走本地指针，但 处理列表 需要一个占位 fn ptr 保持下标对齐
函数 占位处理(参数JSON: 字符串) : 字符串 {
    返回 "";
}

函数 原样钩子(工具名: 字符串, 值: 字符串) : 字符串 {
    返回 值;
}

// 标准工具结果 helper。为避免改变模型可见的既有文本，派发不会自动包装旧处理器输出；
// 需要统一成功 envelope 的处理器应显式使用本 helper。
公开 函数 工具成功(输出: 字符串) : 字符串 {
    变量 对象: 整数 = J.创建对象();
    J.设置布尔(对象, "ok", 1);
    J.设置字符串(对象, "result", 输出);
    变量 文本: 字符串 = J.转字符串(对象);
    J.删除(对象);
    返回 文本;
}

// 标准工具错误 helper。JSON 构造保证工具名和消息中的引号等字符被正确转义。
公开 函数 工具错误(代码: 字符串, 工具名: 字符串, 消息: 字符串) : 字符串 {
    变量 对象: 整数 = J.创建对象();
    J.设置字符串(对象, "error", 代码);
    J.设置字符串(对象, "message", 消息);
    J.设置字符串(对象, "name", 工具名);
    J.设置布尔(对象, "ok", 0);
    变量 文本: 字符串 = J.转字符串(对象);
    J.删除(对象);
    返回 文本;
}

// 当前 JSON API 没有直接的类型查询；解码后再序列化，以首字符可靠区分对象与数组/标量。
函数 是JSON对象(文本: 字符串) : 整数 {
    变量 值: 整数 = J.解码(文本);
    如果 (值 <= 0) { 返回 0; }
    变量 规范文本: 字符串 = J.转字符串(值);
    J.删除(值);
    返回 字符串::开始于(规范文本, "{");
}

函数 跳过JSON字符串(文本: 字符串, 开始: 整数) : 整数 {
    变量 i: 整数 = 开始 + 1;
    变量 n: 整数 = 字符串::字节长度(文本);
    变量 转义: 整数 = 0;
    当 (i < n) {
        变量 字符值: 字符串 = 字符串::子串(文本, i, 1);
        如果 (转义 == 1) { 转义 = 0; }
        否则 如果 (字符串::等于(字符值, "\\") == 1) { 转义 = 1; }
        否则 如果 (字符串::等于(字符值, "\"") == 1) { 返回 i + 1; }
        i = i + 1;
    }
    返回 n;
}

函数 跳过JSON值(文本: 字符串, 开始: 整数) : 整数 {
    变量 n: 整数 = 字符串::字节长度(文本);
    如果 (开始 >= n) { 返回 n; }
    变量 首: 字符串 = 字符串::子串(文本, 开始, 1);
    如果 (字符串::等于(首, "\"") == 1) { 返回 跳过JSON字符串(文本, 开始); }
    如果 (字符串::等于(首, "{") == 1 或 字符串::等于(首, "[") == 1) {
        变量 深度: 整数 = 0;
        变量 i: 整数 = 开始;
        当 (i < n) {
            变量 字符值: 字符串 = 字符串::子串(文本, i, 1);
            如果 (字符串::等于(字符值, "\"") == 1) { i = 跳过JSON字符串(文本, i); }
            否则 {
                如果 (字符串::等于(字符值, "{") == 1 或 字符串::等于(字符值, "[") == 1) { 深度 = 深度 + 1; }
                如果 (字符串::等于(字符值, "}") == 1 或 字符串::等于(字符值, "]") == 1) {
                    深度 = 深度 - 1;
                    如果 (深度 == 0) { 返回 i + 1; }
                }
                i = i + 1;
            }
        }
        返回 n;
    }
    变量 i: 整数 = 开始;
    当 (i < n) {
        变量 字符值: 字符串 = 字符串::子串(文本, i, 1);
        如果 (字符串::等于(字符值, ",") == 1 或 字符串::等于(字符值, "}") == 1 或 字符串::等于(字符值, "]") == 1) { 返回 i; }
        i = i + 1;
    }
    返回 n;
}

函数 解码JSON字符串(原文: 字符串) : 字符串 {
    变量 数组值: 整数 = J.解码("[" + 原文 + "]");
    如果 (数组值 <= 0) { 返回 ""; }
    变量 值: 字符串 = J.数组获取字符串(数组值, 0);
    J.删除(数组值);
    返回 值;
}

// 返回对象字段的规范 JSON 原文；空字符串表示字段不存在。
函数 取对象字段原文(对象文本: 字符串, 目标键: 字符串) : 字符串 {
    变量 n: 整数 = 字符串::字节长度(对象文本);
    变量 i: 整数 = 1;
    当 (i < n - 1) {
        如果 (字符串::等于(字符串::子串(对象文本, i, 1), "\"") != 1) { 返回 ""; }
        变量 键末: 整数 = 跳过JSON字符串(对象文本, i);
        变量 键: 字符串 = 解码JSON字符串(字符串::子串(对象文本, i, 键末 - i));
        i = 键末 + 1;
        变量 值末: 整数 = 跳过JSON值(对象文本, i);
        如果 (字符串::等于(键, 目标键) == 1) { 返回 字符串::子串(对象文本, i, 值末 - i); }
        i = 值末 + 1;
    }
    返回 "";
}

函数 是JSON数字原文(原文: 字符串) : 整数 {
    如果 (字符串::字节长度(原文) == 0) { 返回 0; }
    变量 首: 字符串 = 字符串::子串(原文, 0, 1);
    如果 (字符串::等于(首, "-") == 1) { 返回 1; }
    如果 (字符串::等于(首, "0") == 1 或 字符串::等于(首, "1") == 1 或 字符串::等于(首, "2") == 1 或 字符串::等于(首, "3") == 1 或 字符串::等于(首, "4") == 1 或 字符串::等于(首, "5") == 1 或 字符串::等于(首, "6") == 1 或 字符串::等于(首, "7") == 1 或 字符串::等于(首, "8") == 1 或 字符串::等于(首, "9") == 1) { 返回 1; }
    返回 0;
}

函数 类型匹配(原文: 字符串, 期望: 字符串) : 整数 {
    变量 首: 字符串 = 字符串::子串(原文, 0, 1);
    如果 (字符串::等于(期望, "string") == 1) { 返回 字符串::等于(首, "\""); }
    如果 (字符串::等于(期望, "object") == 1) { 返回 字符串::等于(首, "{"); }
    如果 (字符串::等于(期望, "array") == 1) { 返回 字符串::等于(首, "["); }
    如果 (字符串::等于(期望, "boolean") == 1) {
        如果 (字符串::等于(原文, "true") == 1 或 字符串::等于(原文, "false") == 1) { 返回 1; }
        返回 0;
    }
    如果 (字符串::等于(期望, "number") == 1) { 返回 是JSON数字原文(原文); }
    如果 (字符串::等于(期望, "integer") == 1) {
        如果 (是JSON数字原文(原文) == 0) { 返回 0; }
        如果 (字符串::查找(原文, ".") >= 0 或 字符串::查找(原文, "e") >= 0 或 字符串::查找(原文, "E") >= 0) { 返回 0; }
        返回 1;
    }
    返回 1;
}

函数 枚举包含(枚举文本: 字符串, 原文: 字符串) : 整数 {
    变量 n: 整数 = 字符串::字节长度(枚举文本);
    变量 i: 整数 = 1;
    当 (i < n - 1) {
        变量 值末: 整数 = 跳过JSON值(枚举文本, i);
        如果 (字符串::等于(字符串::子串(枚举文本, i, 值末 - i), 原文) == 1) { 返回 1; }
        i = 值末 + 1;
    }
    返回 0;
}

函数 字段路径(父路径: 字符串, 字段: 字符串) : 字符串 {
    如果 (字符串::字节长度(父路径) == 0) { 返回 字段; }
    返回 父路径 + "." + 字段;
}

函数 验证Schema值(原文: 字符串, schema值: 整数, 路径: 字符串) : 字符串 {
    变量 期望: 字符串 = J.获取字符串(schema值, "type");
    如果 (字符串::字节长度(期望) > 0 && 类型匹配(原文, 期望) == 0) {
        返回 "field '" + 路径 + "' must be " + 期望;
    }
    变量 枚举值: 整数 = J.获取数组(schema值, "enum");
    如果 (枚举值 > 0 && 枚举包含(J.转字符串(枚举值), 原文) == 0) {
        返回 "field '" + 路径 + "' must be one of the allowed enum values";
    }
    如果 (字符串::等于(期望, "object") == 1) {
        变量 必需: 整数 = J.获取数组(schema值, "required");
        如果 (必需 > 0) {
            变量 r: 整数 = 0;
            当 (r < J.数组长度(必需)) {
                变量 必需字段: 字符串 = J.数组获取字符串(必需, r);
                如果 (字符串::字节长度(取对象字段原文(原文, 必需字段)) == 0) {
                    返回 "field '" + 字段路径(路径, 必需字段) + "' is required";
                }
                r = r + 1;
            }
        }
        变量 属性: 整数 = J.获取对象(schema值, "properties");
        变量 禁止额外: 整数 = 0;
        如果 (字符串::等于(取对象字段原文(J.转字符串(schema值), "additionalProperties"), "false") == 1) { 禁止额外 = 1; }
        变量 对象长度: 整数 = 字符串::字节长度(原文);
        变量 i: 整数 = 1;
        当 (i < 对象长度 - 1) {
            变量 键末: 整数 = 跳过JSON字符串(原文, i);
            变量 字段: 字符串 = 解码JSON字符串(字符串::子串(原文, i, 键末 - i));
            i = 键末 + 1;
            变量 值末: 整数 = 跳过JSON值(原文, i);
            变量 字段原文: 字符串 = 字符串::子串(原文, i, 值末 - i);
            如果 (属性 <= 0 或 J.是否包含键(属性, 字段) == 0) {
                如果 (禁止额外 == 1) { 返回 "field '" + 字段路径(路径, 字段) + "' is not allowed"; }
            } 否则 {
                变量 字段schema: 整数 = J.获取对象(属性, 字段);
                变量 字段错误: 字符串 = 验证Schema值(字段原文, 字段schema, 字段路径(路径, 字段));
                如果 (字符串::字节长度(字段错误) > 0) { 返回 字段错误; }
            }
            i = 值末 + 1;
        }
    }
    如果 (字符串::等于(期望, "array") == 1) {
        变量 项schema: 整数 = J.获取对象(schema值, "items");
        如果 (项schema > 0) {
            变量 数组长度值: 整数 = 字符串::字节长度(原文);
            变量 i: 整数 = 1;
            变量 索引: 整数 = 0;
            当 (i < 数组长度值 - 1) {
                变量 值末: 整数 = 跳过JSON值(原文, i);
                变量 项错误: 字符串 = 验证Schema值(字符串::子串(原文, i, 值末 - i), 项schema, 路径 + "[" + 整数转字符串(索引) + "]");
                如果 (字符串::字节长度(项错误) > 0) { 返回 项错误; }
                i = 值末 + 1;
                索引 = 索引 + 1;
            }
        }
    }
    返回 "";
}

函数 验证参数(参数JSON: 字符串, schema文本: 字符串) : 字符串 {
    变量 参数值: 整数 = J.解码(参数JSON);
    如果 (参数值 <= 0) { 返回 "arguments must be a JSON object"; }
    变量 规范参数: 字符串 = J.转字符串(参数值);
    J.删除(参数值);
    如果 (字符串::开始于(规范参数, "{") == 0) { 返回 "arguments must be a JSON object"; }
    变量 schema值: 整数 = J.解码(schema文本);
    如果 (schema值 <= 0) { 返回 ""; }
    变量 错误: 字符串 = 验证Schema值(规范参数, schema值, "");
    J.删除(schema值);
    返回 错误;
}

// 注册一个工具：写入会话 + 加入本地 dispatch 表
公开 函数 注册(注册表值: 注册表, 会话句柄: 整数, 工具值: 工具) : 注册表 {
    底层模型.注册工具(会话句柄, 工具值.名字, 工具值.描述, 工具值.参数schema);
    同步.加锁(工具注册锁);
    列表库::添加字符串(注册表值.名字列表, 工具值.名字);
    保存schema(注册表值, 工具值.参数schema);
    列表库::添加指针(注册表值.处理列表, 工具值.处理);
    列表库::添加整数(注册表值.来源列表, 0);
    列表库::添加字符串(注册表值.连接列表, "");
    列表库::添加整数(模式列表(注册表值), 0);
    保存模式(注册表值, 0);
    列表库::添加指针(前钩子列表(注册表值), 原样钩子);
    列表库::添加指针(后钩子列表(注册表值), 原样钩子);
    同步.解锁(工具注册锁);
    返回 注册表值;
}

// 注册一个 MCP-backed 工具：用 server 给的 name/description/inputSchema 注册到会话，
// 本地仅记录来源=1 与连接描述符，dispatch 时转发到 MCP。
公开 函数 注册MCP工具(注册表值: 注册表, 会话句柄: 整数, 名字: 字符串, 描述: 字符串, 参数schema: 字符串, 连接描述符: 字符串) : 注册表 {
    底层模型.注册工具(会话句柄, 名字, 描述, 参数schema);
    同步.加锁(工具注册锁);
    列表库::添加字符串(注册表值.名字列表, 名字);
    保存schema(注册表值, 参数schema);
    列表库::添加指针(注册表值.处理列表, 占位处理);
    列表库::添加整数(注册表值.来源列表, 1);
    列表库::添加字符串(注册表值.连接列表, 连接描述符);
    列表库::添加整数(模式列表(注册表值), 1);
    保存模式(注册表值, 1);
    列表库::添加指针(前钩子列表(注册表值), 原样钩子);
    列表库::添加指针(后钩子列表(注册表值), 原样钩子);
    同步.解锁(工具注册锁);
    返回 注册表值;
}

// 注册受控工具的模型 schema 和调度元数据。实际处理器由 Harness.受控工具 持有，
// 因此这里仅保存不可解引用的定义句柄，避免两个模块形成类型导入环。
公开 函数 注册受控工具项(注册表值: 注册表, 会话句柄: 整数, 名字: 字符串,
                       描述: 字符串, 参数schema: 字符串, 受控句柄: 整数,
                       模式: 整数) : 注册表 {
    底层模型.注册工具(会话句柄, 名字, 描述, 参数schema);
    同步.加锁(工具注册锁);
    列表库::添加字符串(注册表值.名字列表, 名字);
    保存schema(注册表值, 参数schema);
    保存受控句柄(注册表值, 受控句柄);
    列表库::添加指针(注册表值.处理列表, 占位处理);
    列表库::添加整数(注册表值.来源列表, 2);
    列表库::添加字符串(注册表值.连接列表, "");
    如果 (模式 == 1) { 列表库::添加整数(模式列表(注册表值), 1); }
    否则 { 列表库::添加整数(模式列表(注册表值), 0); }
    保存模式(注册表值, 模式);
    列表库::添加指针(前钩子列表(注册表值), 原样钩子);
    列表库::添加指针(后钩子列表(注册表值), 原样钩子);
    同步.解锁(工具注册锁);
    返回 注册表值;
}

// 按名字查找当前生效项，和派发使用相同的“最后注册覆盖”语义。
公开 函数 查找索引(注册表值: 注册表, 工具名: 字符串) : 整数 {
    同步.加锁(工具注册锁);
    变量 索引: 整数 = 查找最新索引(注册表值, 工具名);
    同步.解锁(工具注册锁);
    返回 索引;
}

// 调用者必须持有 工具注册锁，确保不会观察到尚未完整追加的注册项。
函数 查找最新索引(注册表值: 注册表, 工具名: 字符串) : 整数 {
    变量 索引: 整数 = 列表库::字符串列表大小(注册表值.名字列表) - 1;
    当 (索引 >= 0) {
        如果 (字符串::等于(列表库::获取字符串(注册表值.名字列表, 索引), 工具名) == 1) {
            返回 索引;
        }
        索引 = 索引 - 1;
    }
    返回 -1;
}

// 独立元数据 API，避免给 工具 类型加字段而破坏现有构造点。
// 模式：0=可并发，1=串行。未知工具返回原注册表且查询仍为 -1。
公开 函数 设置执行模式(注册表值: 注册表, 工具名: 字符串, 模式: 整数) : 注册表 {
    同步.加锁(工具注册锁);
    变量 idx: 整数 = 查找最新索引(注册表值, 工具名);
    如果 (idx >= 0) {
        如果 (模式 == 1) { 列表库::设置整数(模式列表(注册表值), idx, 1); }
        否则 { 列表库::设置整数(模式列表(注册表值), idx, 0); }
        设置索引模式(注册表值, idx, 模式);
    }
    同步.解锁(工具注册锁);
    返回 注册表值;
}

// 为单个工具设置无状态 before/after 钩子；不依赖全局调用上下文。
公开 函数 设置工具钩子(注册表值: 注册表, 工具名: 字符串, 前钩子: 函数(字符串, 字符串): 字符串, 后钩子: 函数(字符串, 字符串): 字符串) : 注册表 {
    同步.加锁(工具注册锁);
    变量 idx: 整数 = 查找最新索引(注册表值, 工具名);
    如果 (idx >= 0) {
        // 指针列表没有 indexed setter，只能追加覆盖；查找和派发都取最后一项。
        变量 原schema: 字符串 = 读取schema(注册表值, idx);
        变量 原来源: 整数 = 列表库::获取整数(注册表值.来源列表, idx);
        变量 原受控句柄: 整数 = 锁内受控工具句柄(注册表值, 工具名);
        列表库::添加字符串(注册表值.名字列表, 工具名);
        保存schema(注册表值, 原schema);
        如果 (原来源 == 2) { 保存受控句柄(注册表值, 原受控句柄); }
        列表库::添加指针(注册表值.处理列表, 列表库::获取指针(注册表值.处理列表, idx));
        列表库::添加整数(注册表值.来源列表, 原来源);
        列表库::添加字符串(注册表值.连接列表, 列表库::获取字符串(注册表值.连接列表, idx));
        列表库::添加整数(模式列表(注册表值), 列表库::获取整数(模式列表(注册表值), idx));
        保存模式(注册表值, 读取模式(注册表值, idx));
        列表库::添加指针(前钩子列表(注册表值), 前钩子);
        列表库::添加指针(后钩子列表(注册表值), 后钩子);
    }
    同步.解锁(工具注册锁);
    返回 注册表值;
}

// 派发：找到 fn 并跑，找不到返回错误字符串；MCP 工具转发到 MCP调用工具
公开 函数 派发(注册表值: 注册表, 工具名: 字符串, 参数JSON: 字符串) : 字符串 {
    同步.加锁(工具注册锁);
    变量 idx: 整数 = 查找最新索引(注册表值, 工具名);
    如果 (idx < 0) {
        同步.解锁(工具注册锁);
        返回 工具错误("unknown_tool", 工具名, "tool is not registered");
    }
    // 在锁内复制完整行，调用用户钩子和处理器前释放锁，避免用户代码反向注册导致死锁。
    变量 schema文本: 字符串 = 读取schema(注册表值, idx);
    变量 前钩子: 函数(字符串, 字符串): 字符串 = 列表库::获取指针(前钩子列表(注册表值), idx);
    变量 来源: 整数 = 列表库::获取整数(注册表值.来源列表, idx);
    变量 连接描述符: 字符串 = 列表库::获取字符串(注册表值.连接列表, idx);
    变量 处理: 函数(字符串): 字符串 = 列表库::获取指针(注册表值.处理列表, idx);
    变量 后钩子: 函数(字符串, 字符串): 字符串 = 列表库::获取指针(后钩子列表(注册表值), idx);
    同步.解锁(工具注册锁);
    变量 参数错误: 字符串 = 验证参数(参数JSON, schema文本);
    如果 (字符串::字节长度(参数错误) > 0) { 返回 工具错误("invalid_arguments", 工具名, 参数错误); }
    变量 实际参数: 字符串 = 前钩子(工具名, 参数JSON);
    如果 (是JSON对象(实际参数) == 0) {
        返回 工具错误("invalid_arguments", 工具名, "before hook must return a JSON object");
    }
    变量 输出: 字符串 = "";
    如果 (来源 == 1) {
        输出 = MCP调用工具(连接描述符, 工具名, 实际参数);
    } 否则如果 (来源 == 2) {
        返回 工具错误("controlled_dispatch_required", 工具名,
            "controlled tools must be executed by Agent");
    } 否则 {
        输出 = 处理(实际参数);
    }
    如果 (字符串::开始于(输出, "[harness]") == 1) {
        返回 工具错误("handler_error", 工具名, 输出);
    }
    输出 = 后钩子(工具名, 输出);
    如果 (字符串::开始于(输出, "[harness]") == 1) {
        返回 工具错误("after_hook_error", 工具名, 输出);
    }
    返回 输出;
}

公开 函数 验证工具调用参数(注册表值: 注册表, 工具名: 字符串,
                       参数JSON: 字符串) : 字符串 {
    同步.加锁(工具注册锁);
    变量 idx: 整数 = 查找最新索引(注册表值, 工具名);
    如果 (idx < 0) {
        同步.解锁(工具注册锁);
        返回 "tool is not registered";
    }
    变量 schema文本: 字符串 = 读取schema(注册表值, idx);
    同步.解锁(工具注册锁);
    返回 验证参数(参数JSON, schema文本);
}

// 返回受控定义句柄；-1 表示旧本地工具、MCP 或未知工具。
函数 锁内受控工具句柄(注册表值: 注册表, 工具名: 字符串) : 整数 {
    变量 idx: 整数 = 查找最新索引(注册表值, 工具名);
    如果 (idx < 0 || 列表库::获取整数(注册表值.来源列表, idx) != 2) { 返回 -1; }
    确保schema表();
    变量 编码: 字符串 = 哈希表::获取字符串(受控句柄表, schema键(注册表值, idx));
    如果 (字符串::字节长度(编码) == 0) { 返回 -1; }
    返回 字符串转整数(编码) - 1;
}

公开 函数 受控工具句柄(注册表值: 注册表, 工具名: 字符串) : 整数 {
    同步.加锁(工具注册锁);
    变量 句柄: 整数 = 锁内受控工具句柄(注册表值, 工具名);
    同步.解锁(工具注册锁);
    返回 句柄;
}

// 工具来源：复用 查找索引 + 来源列表 判断一个工具是本地还是 MCP。
//   返回 1 = MCP 工具（走同一条 stdio，必须串行）
//   返回 0 = 本地工具（纯 Qi 函数指针，可并发）
//   返回 -1 = 未知工具
公开 函数 工具来源(注册表值: 注册表, 工具名: 字符串) : 整数 {
    同步.加锁(工具注册锁);
    变量 idx: 整数 = 查找最新索引(注册表值, 工具名);
    如果 (idx < 0) {
        同步.解锁(工具注册锁);
        返回 -1;
    }
    变量 来源: 整数 = 列表库::获取整数(注册表值.来源列表, idx);
    同步.解锁(工具注册锁);
    返回 来源;
}

公开 函数 工具执行模式(注册表值: 注册表, 工具名: 字符串) : 整数 {
    同步.加锁(工具注册锁);
    变量 idx: 整数 = 查找最新索引(注册表值, 工具名);
    如果 (idx < 0) {
        同步.解锁(工具注册锁);
        返回 -1;
    }
    变量 模式: 整数 = 1;
    如果 (列表库::获取整数(注册表值.来源列表, idx) != 1) {
        模式 = 读取模式(注册表值, idx);
    }
    同步.解锁(工具注册锁);
    返回 模式;
}

// 并发工具工人 —— 顶层命名 goroutine 入口（启动 不支持内联闭包）。
// 各 worker 独立调 派发，把「序号|结果」编码后 push 进共享结果表（列表底层有
// 全局 Mutex，并发 push 安全），再往 完成信道 发自己的序号作完成信号。
//
// 为什么用「序号|结果」编码 + 完成信号 i64 通道，而不是直接用 通道<字符串>？
//   编译器当前 通道<字符串> 的 payload 被当成 i64 处理（收端类型错位 → IR 报错/
//   值损坏），且「全局通道 + goroutine」会段错误。实测可靠组合是：
//   「i64 通道作参数 + 共享列表存字符串结果」。详见报告。
//   下标对齐靠序号前缀，结果文本本身可含 `|`（接收端按第一个 `|` 切分）。
公开 函数 并发工具工人(注册表值: 注册表, 序号: 整数, 工具名: 字符串, 参数JSON: 字符串, 结果表: 整数, 完成信道: 通道<整数>) {
    变量 r: 字符串 = 派发(注册表值, 工具名, 参数JSON);
    列表库::添加字符串(结果表, 整数转字符串(序号) + "|" + r);
    完成信道 <- 序号;
}

// 从「序号|结果」编码表里取出指定序号对应的结果文本，找不到返回 ""。
// （字符串列表无 set-by-index，所以用编码表 + 按序号检索来对齐下标。）
函数 取编码结果(编码表: 整数, 目标序号: 整数) : 字符串 {
    变量 条目数: 整数 = 列表库::字符串列表大小(编码表);
    变量 k: 整数 = 0;
    当 (k < 条目数) {
        变量 条目: 字符串 = 列表库::获取字符串(编码表, k);
        变量 竖线位: 整数 = 字符串::查找(条目, "|");
        如果 (竖线位 >= 0) {
            变量 序号串: 字符串 = 字符串::子串(条目, 0, 竖线位);
            如果 (字符串转整数(序号串) == 目标序号) {
                返回 字符串::子串从位置(条目, 竖线位 + 1);
            }
        }
        k = k + 1;
    }
    返回 "";
}

// 并发派发 —— 本地工具并发跑，MCP/未知工具当场串行。
//   工具名列表 / 参数列表：标准库.列表 的字符串列表句柄，下标对齐
//   返回：一个新的「结果字符串列表」句柄，下标与输入对齐（结果[i] 对应 工具名[i]）
//
// 协议安全：MCP 工具共用一条 stdio 连接，并发会破坏 JSON-RPC 帧，所以这里
// 严格区分——只有本地工具进 goroutine，MCP 必须串行原地派发。
//
// 实现：所有结果（本地 + MCP）都先编码成「序号|结果」进同一张编码表（列表底层
// 全局 Mutex，并发 push 安全），最后按 0..个数 顺序检索编码表，append 进对齐的
// 返回列表（字符串列表只能 append，不能 set-by-index）。
公开 函数 并发派发(注册表值: 注册表, 工具名列表: 整数, 参数列表: 整数, 个数: 整数) : 整数 {
    变量 编码表: 整数 = 列表库::创建字符串列表();
    变量 完成信道: 通道<整数> = 通道<整数>(个数 + 1);
    变量 本地数: 整数 = 0;

    变量 i: 整数 = 0;
    当 (i < 个数) {
        变量 名: 字符串 = 列表库::获取字符串(工具名列表, i);
        变量 参: 字符串 = 列表库::获取字符串(参数列表, i);
        变量 来源: 整数 = 工具来源(注册表值, 名);
        变量 模式: 整数 = 工具执行模式(注册表值, 名);
        如果 (来源 == 0 && 模式 == 0) {
            // 本地工具 → 并发 goroutine
            启动 并发工具工人(注册表值, i, 名, 参, 编码表, 完成信道);
            本地数 = 本地数 + 1;
        } 否则 {
            // MCP 或 未知 → 当场串行派发，同样按「序号|结果」编码进表
            变量 r: 字符串 = 派发(注册表值, 名, 参);
            列表库::添加字符串(编码表, 整数转字符串(i) + "|" + r);
        }
        i = i + 1;
    }

    // 收齐所有本地完成信号（信号值是序号，这里只用于计数同步 + join）
    变量 收: 整数 = 0;
    当 (收 < 本地数) {
        变量 信号: 整数 = <- 完成信道;
        收 = 收 + 1;
    }

    // 按输入顺序检索编码表，append 进对齐的返回列表
    变量 结果列表: 整数 = 列表库::创建字符串列表();
    变量 j: 整数 = 0;
    当 (j < 个数) {
        列表库::添加字符串(结果列表, 取编码结果(编码表, j));
        j = j + 1;
    }
    返回 结果列表;
}
