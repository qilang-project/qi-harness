// 报告 — 一次运行的可观测闭环：步骤计时 + 真实 token 成本汇总 + 结构化导出
//
// 追踪.qi 的 span 是「即时打出去就完」的日志流；本模块把一次运行的各步骤留在内存里，
// 跑完能导出一份汇总报告：哪几步、各花多少毫秒/多少 token、总成本、哪步最慢。
//
// 用法：
//   开始报告("任务名");
//   变量 步 = 开始步骤("llm", "问首都");
//   ... 底层模型.对话(会话, ...) ...
//   结束步骤按会话(步, "答北京", 会话);          // 自动读 大模型.用量 记真实 token
//   变量 步2 = 开始步骤("tool", "本地处理");
//   结束步骤(步2, "完成", 0, 0);                 // 非 LLM 步骤手填 token/成本
//   IO.打印行(文本报告());                        // 人类可读
//   保存报告("/tmp/run_report.json");             // 结构化 JSON（面板/CI 消费）
//
// 每个步骤同时会开/关一个 追踪 span（同一条数据两个出口：日志流 + 汇总报告）。

包 Harness;

导入 标准库.字符串;
导入 标准库.输入输出 作为 IO;
导入 标准库.时间;
导入 标准库.列表 作为 列表库;
导入 标准库.哈希表 作为 哈希表;
导入 标准库.JSON 作为 J;
导入 标准库.大模型 作为 底层模型;
导入 Harness.追踪::{开始跨度, 结束跨度, 当前追踪};

// ——— 报告状态（进程内单例；并行列表，下标即步骤号）———
变量 报告标题: 字符串 = "";
变量 报告起始毫秒: 整数 = 0;
变量 步名表: 整数 = 0;          // 字符串列表：步骤名
变量 步种类表: 整数 = 0;        // 字符串列表：llm / tool / ...
变量 步起表: 整数 = 0;          // 整数列表：起始毫秒
变量 步耗时表: 整数 = 0;        // 整数列表：耗时毫秒（-1 = 未结束）
变量 步令牌表: 整数 = 0;        // 整数列表：总 token
变量 步提示令牌表: 整数 = 0;    // 整数列表：prompt token
变量 步补全令牌表: 整数 = 0;    // 整数列表：completion token
变量 步成本表: 整数 = 0;        // 整数列表：成本（分）
变量 步跨度表: 整数 = 0;        // 整数列表：对应 追踪 span id
变量 步详情表: 整数 = 0;        // 字符串哈希表：键=步骤号（字符串列表不支持按位改，用表）
变量 报告表已建: 整数 = 0;

函数 重建报告表() {
    步名表 = 列表库::创建字符串列表();
    步种类表 = 列表库::创建字符串列表();
    步起表 = 列表库::创建整数列表();
    步耗时表 = 列表库::创建整数列表();
    步令牌表 = 列表库::创建整数列表();
    步提示令牌表 = 列表库::创建整数列表();
    步补全令牌表 = 列表库::创建整数列表();
    步成本表 = 列表库::创建整数列表();
    步跨度表 = 列表库::创建整数列表();
    步详情表 = 哈希表::创建字符串表();
    报告表已建 = 1;
}

// 开一份新报告（清空上一份）。
公开 函数 开始报告(标题: 字符串) : 整数 {
    重建报告表();
    报告标题 = 标题;
    报告起始毫秒 = 时间.当前毫秒();
    返回 1;
}

公开 函数 步骤数() : 整数 {
    如果 (报告表已建 == 0) { 返回 0; }
    返回 列表库::字符串列表大小(步名表);
}

// 开一个步骤：记名字/种类/起始时刻，同时开一个 追踪 span。返回步骤号（结束时用）。
公开 函数 开始步骤(种类: 字符串, 名字: 字符串) : 整数 {
    如果 (报告表已建 == 0) { 重建报告表(); }
    变量 步骤号: 整数 = 列表库::字符串列表大小(步名表);
    列表库::添加字符串(步名表, 名字);
    列表库::添加字符串(步种类表, 种类);
    列表库::添加整数(步起表, 时间.当前毫秒());
    列表库::添加整数(步耗时表, 0 - 1);
    列表库::添加整数(步令牌表, 0);
    列表库::添加整数(步提示令牌表, 0);
    列表库::添加整数(步补全令牌表, 0);
    列表库::添加整数(步成本表, 0);
    变量 跨度ID: 整数 = 开始跨度(种类, "报告", 名字, 0);
    列表库::添加整数(步跨度表, 跨度ID);
    返回 步骤号;
}

// 结束一个步骤：算耗时、记 token/成本、关掉对应 span。返回耗时毫秒。
公开 函数 结束步骤(步骤号: 整数, 详情: 字符串, 令牌数: 整数, 成本分: 整数) : 整数 {
    如果 (报告表已建 == 0) { 返回 0; }
    变量 n: 整数 = 列表库::字符串列表大小(步名表);
    如果 (步骤号 < 0) { 返回 0; }
    如果 (步骤号 >= n) { 返回 0; }
    变量 耗时: 整数 = 时间.当前毫秒() - 列表库::获取整数(步起表, 步骤号);
    列表库::设置整数(步耗时表, 步骤号, 耗时);
    列表库::设置整数(步令牌表, 步骤号, 令牌数);
    列表库::设置整数(步成本表, 步骤号, 成本分);
    哈希表::设置字符串(步详情表, 整数转字符串(步骤号), 详情);
    结束跨度(列表库::获取整数(步跨度表, 步骤号), "报告",
             列表库::获取字符串(步种类表, 步骤号), 详情, 令牌数, 成本分);
    返回 耗时;
}

// LLM 步骤专用：自动读会话最近一次请求的真实用量（大模型.用量 → prompt/completion/total）。
公开 函数 结束步骤按会话(步骤号: 整数, 详情: 字符串, 会话: 整数) : 整数 {
    变量 提示数: 整数 = 0;
    变量 补全数: 整数 = 0;
    变量 总数: 整数 = 0;
    变量 对象: 整数 = J.解码(底层模型.用量(会话));
    如果 (对象 > 0) {
        提示数 = J.获取整数(对象, "prompt");
        补全数 = J.获取整数(对象, "completion");
        总数 = J.获取整数(对象, "total");
    }
    变量 耗时: 整数 = 结束步骤(步骤号, 详情, 总数, 0);
    变量 n: 整数 = 列表库::整数列表大小(步提示令牌表);
    如果 (步骤号 >= 0) {
        如果 (步骤号 < n) {
            列表库::设置整数(步提示令牌表, 步骤号, 提示数);
            列表库::设置整数(步补全令牌表, 步骤号, 补全数);
        }
    }
    返回 耗时;
}

// ——— 汇总 ———
公开 函数 报告总令牌() : 整数 {
    变量 n: 整数 = 步骤数();
    变量 合计: 整数 = 0;
    变量 i: 整数 = 0;
    当 (i < n) {
        合计 = 合计 + 列表库::获取整数(步令牌表, i);
        i = i + 1;
    }
    返回 合计;
}

公开 函数 报告总成本() : 整数 {
    变量 n: 整数 = 步骤数();
    变量 合计: 整数 = 0;
    变量 i: 整数 = 0;
    当 (i < n) {
        合计 = 合计 + 列表库::获取整数(步成本表, i);
        i = i + 1;
    }
    返回 合计;
}

公开 函数 报告总耗时() : 整数 {
    如果 (报告表已建 == 0) { 返回 0; }
    返回 时间.当前毫秒() - 报告起始毫秒;
}

// 最慢步骤的下标（无步骤返回 -1）。
公开 函数 最慢步骤() : 整数 {
    变量 n: 整数 = 步骤数();
    如果 (n <= 0) { 返回 0 - 1; }
    变量 最慢: 整数 = 0;
    变量 最慢耗时: 整数 = 列表库::获取整数(步耗时表, 0);
    变量 i: 整数 = 1;
    当 (i < n) {
        变量 耗: 整数 = 列表库::获取整数(步耗时表, i);
        如果 (耗 > 最慢耗时) {
            最慢 = i;
            最慢耗时 = 耗;
        }
        i = i + 1;
    }
    返回 最慢;
}

// ——— 导出 ———

// 结构化 JSON：{"标题":..,"trace":..,"总耗时毫秒":..,"总令牌":..,"总成本分":..,
//              "步骤":[{"名字","种类","详情","耗时毫秒","令牌","提示令牌","补全令牌","成本分"}]}
公开 函数 报告JSON() : 字符串 {
    变量 根: 整数 = J.创建对象();
    J.设置字符串(根, "标题", 报告标题);
    J.设置字符串(根, "trace", 当前追踪());
    J.设置整数(根, "总耗时毫秒", 报告总耗时());
    J.设置整数(根, "总令牌", 报告总令牌());
    J.设置整数(根, "总成本分", 报告总成本());
    变量 明细: 整数 = J.创建数组();
    变量 n: 整数 = 步骤数();
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 项: 整数 = J.创建对象();
        J.设置字符串(项, "名字", 列表库::获取字符串(步名表, i));
        J.设置字符串(项, "种类", 列表库::获取字符串(步种类表, i));
        J.设置字符串(项, "详情", 哈希表::获取字符串(步详情表, 整数转字符串(i)));
        J.设置整数(项, "耗时毫秒", 列表库::获取整数(步耗时表, i));
        J.设置整数(项, "令牌", 列表库::获取整数(步令牌表, i));
        J.设置整数(项, "提示令牌", 列表库::获取整数(步提示令牌表, i));
        J.设置整数(项, "补全令牌", 列表库::获取整数(步补全令牌表, i));
        J.设置整数(项, "成本分", 列表库::获取整数(步成本表, i));
        J.数组添加对象(明细, 项);
        i = i + 1;
    }
    J.设置数组(根, "步骤", 明细);
    返回 J.转字符串(根);
}

公开 函数 保存报告(路径: 字符串) : 整数 {
    返回 IO.写入文件(路径, 报告JSON());
}

// 人类可读文本报告（跑完看一眼：哪几步、各花多少 token、总成本、哪步慢）。
公开 函数 文本报告() : 字符串 {
    变量 文本: 字符串 = "===== 运行报告：" + 报告标题 + " =====\n";
    文本 = 文本 + "trace: " + 当前追踪() + "\n";
    变量 n: 整数 = 步骤数();
    变量 慢: 整数 = 最慢步骤();
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 行: 字符串 = "  [" + 整数转字符串(i + 1) + "] "
            + 列表库::获取字符串(步种类表, i) + " · "
            + 列表库::获取字符串(步名表, i)
            + " — " + 整数转字符串(列表库::获取整数(步耗时表, i)) + "ms"
            + " · 令牌 " + 整数转字符串(列表库::获取整数(步令牌表, i))
            + "(提示 " + 整数转字符串(列表库::获取整数(步提示令牌表, i))
            + "/补全 " + 整数转字符串(列表库::获取整数(步补全令牌表, i)) + ")"
            + " · 成本 " + 整数转字符串(列表库::获取整数(步成本表, i)) + "分";
        如果 (i == 慢) {
            如果 (n > 1) { 行 = 行 + "   ← 最慢"; }
        }
        文本 = 文本 + 行 + "\n";
        i = i + 1;
    }
    文本 = 文本 + "总计：" + 整数转字符串(n) + " 步 · 耗时 " + 整数转字符串(报告总耗时())
        + "ms · 令牌 " + 整数转字符串(报告总令牌())
        + " · 成本 " + 整数转字符串(报告总成本()) + "分\n";
    返回 文本;
}

// 极简 HTML 表格（#3 可选项）—— 直接落盘一个能用浏览器打开的单文件报告。
公开 函数 HTML报告() : 字符串 {
    变量 页: 字符串 = "<!DOCTYPE html><html><head><meta charset=\"utf-8\">"
        + "<title>运行报告</title>"
        + "<style>body{font-family:sans-serif;margin:2em}table{border-collapse:collapse}"
        + "td,th{border:1px solid #999;padding:4px 10px;text-align:left}"
        + "th{background:#eee}.slow{background:#ffe0e0}</style></head><body>";
    页 = 页 + "<h2>运行报告：" + 报告标题 + "</h2>";
    页 = 页 + "<p>trace: <code>" + 当前追踪() + "</code></p>";
    页 = 页 + "<table><tr><th>#</th><th>种类</th><th>名字</th><th>耗时(ms)</th>"
        + "<th>令牌(提示/补全)</th><th>成本(分)</th></tr>";
    变量 n: 整数 = 步骤数();
    变量 慢: 整数 = 最慢步骤();
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 类名: 字符串 = "";
        如果 (i == 慢) {
            如果 (n > 1) { 类名 = " class=\"slow\""; }
        }
        页 = 页 + "<tr" + 类名 + "><td>" + 整数转字符串(i + 1) + "</td>"
            + "<td>" + 列表库::获取字符串(步种类表, i) + "</td>"
            + "<td>" + 列表库::获取字符串(步名表, i) + "</td>"
            + "<td>" + 整数转字符串(列表库::获取整数(步耗时表, i)) + "</td>"
            + "<td>" + 整数转字符串(列表库::获取整数(步令牌表, i))
            + " (" + 整数转字符串(列表库::获取整数(步提示令牌表, i))
            + "/" + 整数转字符串(列表库::获取整数(步补全令牌表, i)) + ")</td>"
            + "<td>" + 整数转字符串(列表库::获取整数(步成本表, i)) + "</td></tr>";
        i = i + 1;
    }
    页 = 页 + "</table><p>总计：" + 整数转字符串(n) + " 步 · 耗时 "
        + 整数转字符串(报告总耗时()) + "ms · 令牌 " + 整数转字符串(报告总令牌())
        + " · 成本 " + 整数转字符串(报告总成本()) + "分</p></body></html>";
    返回 页;
}

公开 函数 保存HTML报告(路径: 字符串) : 整数 {
    返回 IO.写入文件(路径, HTML报告());
}
