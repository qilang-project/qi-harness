// 报告 — 句柄式运行报告；旧的无句柄 API 委托给默认报告，保持兼容。

包 Harness;

导入 标准库.字符串;
导入 标准库.输入输出 作为 IO;
导入 标准库.时间;
导入 标准库.列表 作为 列表库;
导入 标准库.哈希表 作为 哈希表;
导入 标准库.JSON 作为 J;
导入 标准库.大模型 作为 底层模型;
导入 Harness.追踪::{开始跨度, 结束跨度, 当前追踪};
导入 Harness.事件::{订阅生命周期事件};

// 外层并行列表下标即报告句柄；内层列表/哈希表保存该报告自己的步骤。
变量 报告标题表: 整数 = 0;
变量 报告追踪表: 整数 = 0;
变量 报告起始表: 整数 = 0;
变量 步名表组: 整数 = 0;
变量 步种类表组: 整数 = 0;
变量 步起表组: 整数 = 0;
变量 步耗时表组: 整数 = 0;
变量 步令牌表组: 整数 = 0;
变量 步提示令牌表组: 整数 = 0;
变量 步补全令牌表组: 整数 = 0;
变量 步成本表组: 整数 = 0;
变量 步跨度表组: 整数 = 0;
变量 步详情表组: 整数 = 0;
变量 事件步骤表组: 整数 = 0;
变量 报告注册表已建: 整数 = 0;
变量 默认报告句柄: 整数 = 0 - 1;

函数 确保报告注册表() {
    如果 (报告注册表已建 == 0) {
        报告标题表 = 列表库::创建字符串列表();
        报告追踪表 = 列表库::创建字符串列表();
        报告起始表 = 列表库::创建整数列表();
        步名表组 = 列表库::创建整数列表();
        步种类表组 = 列表库::创建整数列表();
        步起表组 = 列表库::创建整数列表();
        步耗时表组 = 列表库::创建整数列表();
        步令牌表组 = 列表库::创建整数列表();
        步提示令牌表组 = 列表库::创建整数列表();
        步补全令牌表组 = 列表库::创建整数列表();
        步成本表组 = 列表库::创建整数列表();
        步跨度表组 = 列表库::创建整数列表();
        步详情表组 = 列表库::创建整数列表();
        事件步骤表组 = 列表库::创建整数列表();
        报告注册表已建 = 1;
    }
}

函数 报告有效(报告句柄: 整数) : 整数 {
    如果 (报告注册表已建 == 0 || 报告句柄 < 0) { 返回 0; }
    如果 (报告句柄 >= 列表库::字符串列表大小(报告标题表)) { 返回 0; }
    返回 1;
}

// 创建独立报告，返回句柄。报告捕获创建时的 trace，后续其他运行不会覆盖它。
公开 函数 创建报告(标题: 字符串) : 整数 {
    确保报告注册表();
    变量 句柄: 整数 = 列表库::字符串列表大小(报告标题表);
    列表库::添加字符串(报告标题表, 标题);
    列表库::添加字符串(报告追踪表, 当前追踪());
    列表库::添加整数(报告起始表, 时间.当前毫秒());
    列表库::添加整数(步名表组, 列表库::创建字符串列表());
    列表库::添加整数(步种类表组, 列表库::创建字符串列表());
    列表库::添加整数(步起表组, 列表库::创建整数列表());
    列表库::添加整数(步耗时表组, 列表库::创建整数列表());
    列表库::添加整数(步令牌表组, 列表库::创建整数列表());
    列表库::添加整数(步提示令牌表组, 列表库::创建整数列表());
    列表库::添加整数(步补全令牌表组, 列表库::创建整数列表());
    列表库::添加整数(步成本表组, 列表库::创建整数列表());
    列表库::添加整数(步跨度表组, 列表库::创建整数列表());
    列表库::添加整数(步详情表组, 哈希表::创建字符串表());
    列表库::添加整数(事件步骤表组, 哈希表::创建字符串表());
    返回 句柄;
}

公开 函数 开始报告(标题: 字符串) : 整数 {
    默认报告句柄 = 创建报告(标题);
    返回 1;
}

公开 函数 报告步骤数(报告句柄: 整数) : 整数 {
    如果 (报告有效(报告句柄) == 0) { 返回 0; }
    返回 列表库::字符串列表大小(列表库::获取整数(步名表组, 报告句柄));
}

公开 函数 步骤数() : 整数 { 返回 报告步骤数(默认报告句柄); }

函数 开始报告步骤内部(报告句柄: 整数, 种类: 字符串, 名字: 字符串, 写追踪: 整数) : 整数 {
    如果 (报告有效(报告句柄) == 0) { 返回 0 - 1; }
    变量 名表: 整数 = 列表库::获取整数(步名表组, 报告句柄);
    变量 步骤号: 整数 = 列表库::字符串列表大小(名表);
    列表库::添加字符串(名表, 名字);
    列表库::添加字符串(列表库::获取整数(步种类表组, 报告句柄), 种类);
    列表库::添加整数(列表库::获取整数(步起表组, 报告句柄), 时间.当前毫秒());
    列表库::添加整数(列表库::获取整数(步耗时表组, 报告句柄), 0 - 1);
    列表库::添加整数(列表库::获取整数(步令牌表组, 报告句柄), 0);
    列表库::添加整数(列表库::获取整数(步提示令牌表组, 报告句柄), 0);
    列表库::添加整数(列表库::获取整数(步补全令牌表组, 报告句柄), 0);
    列表库::添加整数(列表库::获取整数(步成本表组, 报告句柄), 0);
    变量 跨度ID: 整数 = 0;
    如果 (写追踪 == 1) { 跨度ID = 开始跨度(种类, "报告", 名字, 0); }
    列表库::添加整数(列表库::获取整数(步跨度表组, 报告句柄), 跨度ID);
    返回 步骤号;
}

公开 函数 开始报告步骤(报告句柄: 整数, 种类: 字符串, 名字: 字符串) : 整数 {
    返回 开始报告步骤内部(报告句柄, 种类, 名字, 1);
}

公开 函数 开始步骤(种类: 字符串, 名字: 字符串) : 整数 {
    如果 (报告有效(默认报告句柄) == 0) { 开始报告(""); }
    返回 开始报告步骤(默认报告句柄, 种类, 名字);
}

函数 结束报告步骤内部(报告句柄: 整数, 步骤号: 整数, 详情: 字符串, 令牌数: 整数,
                      成本分: 整数, 提示令牌: 整数, 补全令牌: 整数, 写追踪: 整数) : 整数 {
    如果 (报告有效(报告句柄) == 0 || 步骤号 < 0 || 步骤号 >= 报告步骤数(报告句柄)) { 返回 0; }
    变量 耗时: 整数 = 时间.当前毫秒()
        - 列表库::获取整数(列表库::获取整数(步起表组, 报告句柄), 步骤号);
    列表库::设置整数(列表库::获取整数(步耗时表组, 报告句柄), 步骤号, 耗时);
    列表库::设置整数(列表库::获取整数(步令牌表组, 报告句柄), 步骤号, 令牌数);
    列表库::设置整数(列表库::获取整数(步提示令牌表组, 报告句柄), 步骤号, 提示令牌);
    列表库::设置整数(列表库::获取整数(步补全令牌表组, 报告句柄), 步骤号, 补全令牌);
    列表库::设置整数(列表库::获取整数(步成本表组, 报告句柄), 步骤号, 成本分);
    哈希表::设置字符串(列表库::获取整数(步详情表组, 报告句柄), 整数转字符串(步骤号), 详情);
    如果 (写追踪 == 1) {
        结束跨度(列表库::获取整数(列表库::获取整数(步跨度表组, 报告句柄), 步骤号), "报告",
                 列表库::获取字符串(列表库::获取整数(步种类表组, 报告句柄), 步骤号), 详情, 令牌数, 成本分);
    }
    返回 耗时;
}

公开 函数 结束报告步骤(报告句柄: 整数, 步骤号: 整数, 详情: 字符串, 令牌数: 整数, 成本分: 整数) : 整数 {
    返回 结束报告步骤内部(报告句柄, 步骤号, 详情, 令牌数, 成本分, 0, 0, 1);
}

公开 函数 结束步骤(步骤号: 整数, 详情: 字符串, 令牌数: 整数, 成本分: 整数) : 整数 {
    返回 结束报告步骤(默认报告句柄, 步骤号, 详情, 令牌数, 成本分);
}

公开 函数 结束报告步骤按会话(报告句柄: 整数, 步骤号: 整数, 详情: 字符串, 会话: 整数) : 整数 {
    变量 提示数: 整数 = 0;
    变量 补全数: 整数 = 0;
    变量 总数: 整数 = 0;
    变量 对象: 整数 = J.解码(底层模型.用量(会话));
    如果 (对象 > 0) {
        提示数 = J.获取整数(对象, "prompt");
        补全数 = J.获取整数(对象, "completion");
        总数 = J.获取整数(对象, "total");
        J.删除(对象);
    }
    返回 结束报告步骤内部(报告句柄, 步骤号, 详情, 总数, 0, 提示数, 补全数, 1);
}

公开 函数 结束步骤按会话(步骤号: 整数, 详情: 字符串, 会话: 整数) : 整数 {
    返回 结束报告步骤按会话(默认报告句柄, 步骤号, 详情, 会话);
}

函数 去开始后缀(事件类型: 字符串) : 字符串 {
    变量 长度: 整数 = 字符串::字节长度(事件类型);
    如果 (长度 < 6) { 返回 ""; }
    返回 字符串::子串(事件类型, 0, 长度 - 6);
}

函数 有后缀(文本: 字符串, 后缀: 字符串) : 整数 {
    变量 文本长度: 整数 = 字符串::字节长度(文本);
    变量 后缀长度: 整数 = 字符串::字节长度(后缀);
    如果 (文本长度 < 后缀长度) { 返回 0; }
    返回 字符串::等于(字符串::子串(文本, 文本长度 - 后缀长度, 文本长度), 后缀);
}

公开 函数 处理生命周期报告事件按句柄(报告句柄: 整数, 事件JSON: 字符串) : 整数 {
    如果 (报告有效(报告句柄) == 0) { 返回 0; }
    变量 根: 整数 = J.解码(事件JSON);
    如果 (根 <= 0) { 返回 0; }
    变量 类型值: 字符串 = J.获取字符串(根, "type");
    变量 是开始: 整数 = 有后缀(类型值, "_start");
    变量 是结束: 整数 = 有后缀(类型值, "_end");
    如果 (是开始 == 0 && 是结束 == 0) { J.删除(根); 返回 1; }
    变量 步骤ID: 字符串 = J.获取字符串(根, "step_id");
    如果 (字符串::字节长度(步骤ID) == 0) { J.删除(根); 返回 1; }
    // 同一步骤内可能嵌套 llm/retry 等生命周期，事件种类必须参与配对，避免互相覆盖。
    变量 基础类型: 字符串 = 去开始后缀(类型值);
    如果 (是结束 == 1) {
        变量 类型长度: 整数 = 字符串::字节长度(类型值);
        基础类型 = 字符串::子串(类型值, 0, 类型长度 - 4);
    }
    变量 键: 字符串 = J.获取字符串(根, "run_id") + "\n" + 步骤ID + "\n" + 基础类型;
    变量 载荷: 整数 = J.获取对象(根, "payload");
    变量 事件步骤表: 整数 = 列表库::获取整数(事件步骤表组, 报告句柄);
    如果 (是开始 == 1) {
        变量 名字: 字符串 = 步骤ID;
        如果 (载荷 > 0 && J.是否包含键(载荷, "name") == 1) { 名字 = J.获取字符串(载荷, "name"); }
        变量 步骤号: 整数 = 开始报告步骤内部(报告句柄, 基础类型, 名字, 0);
        哈希表::设置字符串(事件步骤表, 键, 整数转字符串(步骤号 + 1));
        J.删除(根);
        返回 1;
    }
    变量 步骤串: 字符串 = 哈希表::获取字符串(事件步骤表, 键);
    如果 (字符串::字节长度(步骤串) == 0) { J.删除(根); 返回 1; }
    变量 详情: 字符串 = "{}";
    变量 令牌: 整数 = 0;
    变量 提示令牌: 整数 = 0;
    变量 补全令牌: 整数 = 0;
    变量 成本: 整数 = 0;
    如果 (载荷 > 0) {
        详情 = J.转字符串(载荷);
        如果 (J.是否包含键(载荷, "detail") == 1) { 详情 = J.获取字符串(载荷, "detail"); }
        如果 (J.是否包含键(载荷, "tokens") == 1) { 令牌 = J.获取整数(载荷, "tokens"); }
        如果 (J.是否包含键(载荷, "prompt_tokens") == 1) { 提示令牌 = J.获取整数(载荷, "prompt_tokens"); }
        如果 (J.是否包含键(载荷, "completion_tokens") == 1) { 补全令牌 = J.获取整数(载荷, "completion_tokens"); }
        如果 (J.是否包含键(载荷, "cost") == 1) { 成本 = J.获取整数(载荷, "cost"); }
    }
    结束报告步骤内部(报告句柄, 字符串转整数(步骤串) - 1, 详情, 令牌, 成本, 提示令牌, 补全令牌, 0);
    J.删除(根);
    返回 1;
}

公开 函数 处理生命周期报告事件(事件JSON: 字符串) : 整数 {
    如果 (报告有效(默认报告句柄) == 0) { 开始报告("生命周期事件"); }
    返回 处理生命周期报告事件按句柄(默认报告句柄, 事件JSON);
}

// 事件订阅回调同样不能捕获句柄。提供 16 个固定槽，安装超过上限返回 -1。
常量 生命周期报告适配器上限值 = 16;
变量 生命周期报告槽位表: 整数 = 0;
变量 生命周期报告槽位启用表: 整数 = 0;
变量 生命周期报告订阅表: 整数 = 0;
变量 生命周期报告槽位已建: 整数 = 0;
函数 确保生命周期报告槽位() {
    如果 (生命周期报告槽位已建 == 0) {
        生命周期报告槽位表 = 列表库::创建整数列表();
        生命周期报告槽位启用表 = 列表库::创建整数列表();
        生命周期报告订阅表 = 列表库::创建整数列表();
        生命周期报告槽位已建 = 1;
    }
}
函数 处理生命周期报告槽位(槽: 整数, x: 字符串) : 整数 {
    如果 (列表库::获取整数(生命周期报告槽位启用表, 槽) == 0) { 返回 1; }
    返回 处理生命周期报告事件按句柄(列表库::获取整数(生命周期报告槽位表, 槽), x);
}
函数 生命周期报告回调0(x: 字符串):整数 { 返回 处理生命周期报告槽位(0, x); }
函数 生命周期报告回调1(x: 字符串):整数 { 返回 处理生命周期报告槽位(1, x); }
函数 生命周期报告回调2(x: 字符串):整数 { 返回 处理生命周期报告槽位(2, x); }
函数 生命周期报告回调3(x: 字符串):整数 { 返回 处理生命周期报告槽位(3, x); }
函数 生命周期报告回调4(x: 字符串):整数 { 返回 处理生命周期报告槽位(4, x); }
函数 生命周期报告回调5(x: 字符串):整数 { 返回 处理生命周期报告槽位(5, x); }
函数 生命周期报告回调6(x: 字符串):整数 { 返回 处理生命周期报告槽位(6, x); }
函数 生命周期报告回调7(x: 字符串):整数 { 返回 处理生命周期报告槽位(7, x); }
函数 生命周期报告回调8(x: 字符串):整数 { 返回 处理生命周期报告槽位(8, x); }
函数 生命周期报告回调9(x: 字符串):整数 { 返回 处理生命周期报告槽位(9, x); }
函数 生命周期报告回调10(x: 字符串):整数 { 返回 处理生命周期报告槽位(10, x); }
函数 生命周期报告回调11(x: 字符串):整数 { 返回 处理生命周期报告槽位(11, x); }
函数 生命周期报告回调12(x: 字符串):整数 { 返回 处理生命周期报告槽位(12, x); }
函数 生命周期报告回调13(x: 字符串):整数 { 返回 处理生命周期报告槽位(13, x); }
函数 生命周期报告回调14(x: 字符串):整数 { 返回 处理生命周期报告槽位(14, x); }
函数 生命周期报告回调15(x: 字符串):整数 { 返回 处理生命周期报告槽位(15, x); }

公开 函数 安装生命周期报告适配器按句柄(报告句柄: 整数) : 整数 {
    如果 (报告有效(报告句柄) == 0) { 返回 0 - 1; }
    确保生命周期报告槽位();
    变量 槽: 整数 = 0;
    变量 总数: 整数 = 列表库::整数列表大小(生命周期报告槽位表);
    当 (槽 < 总数 && 列表库::获取整数(生命周期报告槽位启用表, 槽) == 1) { 槽 = 槽 + 1; }
    如果 (槽 < 总数) {
        列表库::设置整数(生命周期报告槽位表, 槽, 报告句柄);
        列表库::设置整数(生命周期报告槽位启用表, 槽, 1);
        返回 列表库::获取整数(生命周期报告订阅表, 槽);
    }
    如果 (槽 >= 生命周期报告适配器上限值) { 返回 0 - 1; }
    列表库::添加整数(生命周期报告槽位表, 报告句柄);
    列表库::添加整数(生命周期报告槽位启用表, 1);
    变量 订阅: 整数 = 0;
    如果 (槽 == 0) { 订阅 = 订阅生命周期事件(生命周期报告回调0, 1); }
    如果 (槽 == 1) { 订阅 = 订阅生命周期事件(生命周期报告回调1, 1); }
    如果 (槽 == 2) { 订阅 = 订阅生命周期事件(生命周期报告回调2, 1); }
    如果 (槽 == 3) { 订阅 = 订阅生命周期事件(生命周期报告回调3, 1); }
    如果 (槽 == 4) { 订阅 = 订阅生命周期事件(生命周期报告回调4, 1); }
    如果 (槽 == 5) { 订阅 = 订阅生命周期事件(生命周期报告回调5, 1); }
    如果 (槽 == 6) { 订阅 = 订阅生命周期事件(生命周期报告回调6, 1); }
    如果 (槽 == 7) { 订阅 = 订阅生命周期事件(生命周期报告回调7, 1); }
    如果 (槽 == 8) { 订阅 = 订阅生命周期事件(生命周期报告回调8, 1); }
    如果 (槽 == 9) { 订阅 = 订阅生命周期事件(生命周期报告回调9, 1); }
    如果 (槽 == 10) { 订阅 = 订阅生命周期事件(生命周期报告回调10, 1); }
    如果 (槽 == 11) { 订阅 = 订阅生命周期事件(生命周期报告回调11, 1); }
    如果 (槽 == 12) { 订阅 = 订阅生命周期事件(生命周期报告回调12, 1); }
    如果 (槽 == 13) { 订阅 = 订阅生命周期事件(生命周期报告回调13, 1); }
    如果 (槽 == 14) { 订阅 = 订阅生命周期事件(生命周期报告回调14, 1); }
    如果 (槽 == 15) { 订阅 = 订阅生命周期事件(生命周期报告回调15, 1); }
    列表库::添加整数(生命周期报告订阅表, 订阅);
    返回 订阅;
}

公开 函数 释放生命周期报告适配器(订阅句柄: 整数) : 整数 {
    确保生命周期报告槽位();
    变量 i: 整数 = 0;
    变量 总数: 整数 = 列表库::整数列表大小(生命周期报告订阅表);
    当 (i < 总数) {
        如果 (列表库::获取整数(生命周期报告订阅表, i) == 订阅句柄
            && 列表库::获取整数(生命周期报告槽位启用表, i) == 1) {
            列表库::设置整数(生命周期报告槽位启用表, i, 0);
            列表库::设置整数(生命周期报告槽位表, i, 0 - 1);
            返回 1;
        }
        i = i + 1;
    }
    返回 0;
}

公开 函数 生命周期报告适配器上限() : 整数 { 返回 生命周期报告适配器上限值; }

公开 函数 安装生命周期报告适配器(标题: 字符串) : 整数 {
    开始报告(标题);
    返回 安装生命周期报告适配器按句柄(默认报告句柄);
}

公开 函数 报告总令牌按句柄(报告句柄: 整数) : 整数 {
    变量 n: 整数 = 报告步骤数(报告句柄);
    变量 表: 整数 = 0;
    如果 (报告有效(报告句柄) == 1) { 表 = 列表库::获取整数(步令牌表组, 报告句柄); }
    变量 合计: 整数 = 0;
    变量 i: 整数 = 0;
    当 (i < n) { 合计 = 合计 + 列表库::获取整数(表, i); i = i + 1; }
    返回 合计;
}
公开 函数 报告总令牌() : 整数 { 返回 报告总令牌按句柄(默认报告句柄); }

公开 函数 报告总成本按句柄(报告句柄: 整数) : 整数 {
    变量 n: 整数 = 报告步骤数(报告句柄);
    变量 表: 整数 = 0;
    如果 (报告有效(报告句柄) == 1) { 表 = 列表库::获取整数(步成本表组, 报告句柄); }
    变量 合计: 整数 = 0;
    变量 i: 整数 = 0;
    当 (i < n) { 合计 = 合计 + 列表库::获取整数(表, i); i = i + 1; }
    返回 合计;
}
公开 函数 报告总成本() : 整数 { 返回 报告总成本按句柄(默认报告句柄); }

公开 函数 报告总耗时按句柄(报告句柄: 整数) : 整数 {
    如果 (报告有效(报告句柄) == 0) { 返回 0; }
    返回 时间.当前毫秒() - 列表库::获取整数(报告起始表, 报告句柄);
}
公开 函数 报告总耗时() : 整数 { 返回 报告总耗时按句柄(默认报告句柄); }

公开 函数 最慢报告步骤(报告句柄: 整数) : 整数 {
    变量 n: 整数 = 报告步骤数(报告句柄);
    如果 (n <= 0) { 返回 0 - 1; }
    变量 表: 整数 = 列表库::获取整数(步耗时表组, 报告句柄);
    变量 最慢: 整数 = 0;
    变量 最慢耗时: 整数 = 列表库::获取整数(表, 0);
    变量 i: 整数 = 1;
    当 (i < n) {
        变量 耗: 整数 = 列表库::获取整数(表, i);
        如果 (耗 > 最慢耗时) { 最慢 = i; 最慢耗时 = 耗; }
        i = i + 1;
    }
    返回 最慢;
}
公开 函数 最慢步骤() : 整数 { 返回 最慢报告步骤(默认报告句柄); }

公开 函数 报告JSON按句柄(报告句柄: 整数) : 字符串 {
    变量 根: 整数 = J.创建对象();
    如果 (报告有效(报告句柄) == 0) { 返回 J.转字符串(根); }
    J.设置字符串(根, "标题", 列表库::获取字符串(报告标题表, 报告句柄));
    J.设置字符串(根, "trace", 列表库::获取字符串(报告追踪表, 报告句柄));
    J.设置整数(根, "总耗时毫秒", 报告总耗时按句柄(报告句柄));
    J.设置整数(根, "总令牌", 报告总令牌按句柄(报告句柄));
    J.设置整数(根, "总成本分", 报告总成本按句柄(报告句柄));
    变量 明细: 整数 = J.创建数组();
    变量 n: 整数 = 报告步骤数(报告句柄);
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 项: 整数 = J.创建对象();
        J.设置字符串(项, "名字", 列表库::获取字符串(列表库::获取整数(步名表组, 报告句柄), i));
        J.设置字符串(项, "种类", 列表库::获取字符串(列表库::获取整数(步种类表组, 报告句柄), i));
        J.设置字符串(项, "详情", 哈希表::获取字符串(列表库::获取整数(步详情表组, 报告句柄), 整数转字符串(i)));
        J.设置整数(项, "耗时毫秒", 列表库::获取整数(列表库::获取整数(步耗时表组, 报告句柄), i));
        J.设置整数(项, "令牌", 列表库::获取整数(列表库::获取整数(步令牌表组, 报告句柄), i));
        J.设置整数(项, "提示令牌", 列表库::获取整数(列表库::获取整数(步提示令牌表组, 报告句柄), i));
        J.设置整数(项, "补全令牌", 列表库::获取整数(列表库::获取整数(步补全令牌表组, 报告句柄), i));
        J.设置整数(项, "成本分", 列表库::获取整数(列表库::获取整数(步成本表组, 报告句柄), i));
        J.数组添加对象(明细, 项);
        i = i + 1;
    }
    J.设置数组(根, "步骤", 明细);
    返回 J.转字符串(根);
}
公开 函数 报告JSON() : 字符串 { 返回 报告JSON按句柄(默认报告句柄); }

公开 函数 保存报告按句柄(报告句柄: 整数, 路径值: 字符串) : 整数 {
    返回 IO.写入文件(路径值, 报告JSON按句柄(报告句柄));
}
公开 函数 保存报告(路径值: 字符串) : 整数 { 返回 保存报告按句柄(默认报告句柄, 路径值); }

公开 函数 文本报告按句柄(报告句柄: 整数) : 字符串 {
    如果 (报告有效(报告句柄) == 0) { 返回 "===== 运行报告： =====\n总计：0 步 · 耗时 0ms · 令牌 0 · 成本 0分\n"; }
    变量 文本: 字符串 = "===== 运行报告：" + 列表库::获取字符串(报告标题表, 报告句柄) + " =====\n";
    文本 = 文本 + "trace: " + 列表库::获取字符串(报告追踪表, 报告句柄) + "\n";
    变量 n: 整数 = 报告步骤数(报告句柄);
    变量 慢: 整数 = 最慢报告步骤(报告句柄);
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 行: 字符串 = "  [" + 整数转字符串(i + 1) + "] "
            + 列表库::获取字符串(列表库::获取整数(步种类表组, 报告句柄), i) + " · "
            + 列表库::获取字符串(列表库::获取整数(步名表组, 报告句柄), i)
            + " — " + 整数转字符串(列表库::获取整数(列表库::获取整数(步耗时表组, 报告句柄), i)) + "ms"
            + " · 令牌 " + 整数转字符串(列表库::获取整数(列表库::获取整数(步令牌表组, 报告句柄), i))
            + "(提示 " + 整数转字符串(列表库::获取整数(列表库::获取整数(步提示令牌表组, 报告句柄), i))
            + "/补全 " + 整数转字符串(列表库::获取整数(列表库::获取整数(步补全令牌表组, 报告句柄), i)) + ")"
            + " · 成本 " + 整数转字符串(列表库::获取整数(列表库::获取整数(步成本表组, 报告句柄), i)) + "分";
        如果 (i == 慢 && n > 1) { 行 = 行 + "   ← 最慢"; }
        文本 = 文本 + 行 + "\n";
        i = i + 1;
    }
    文本 = 文本 + "总计：" + 整数转字符串(n) + " 步 · 耗时 " + 整数转字符串(报告总耗时按句柄(报告句柄))
        + "ms · 令牌 " + 整数转字符串(报告总令牌按句柄(报告句柄))
        + " · 成本 " + 整数转字符串(报告总成本按句柄(报告句柄)) + "分\n";
    返回 文本;
}
公开 函数 文本报告() : 字符串 { 返回 文本报告按句柄(默认报告句柄); }

公开 函数 HTML报告按句柄(报告句柄: 整数) : 字符串 {
    变量 页: 字符串 = "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><title>运行报告</title>"
        + "<style>body{font-family:sans-serif;margin:2em}table{border-collapse:collapse}"
        + "td,th{border:1px solid #999;padding:4px 10px;text-align:left}th{background:#eee}.slow{background:#ffe0e0}</style></head><body>";
    如果 (报告有效(报告句柄) == 0) { 返回 页 + "</body></html>"; }
    页 = 页 + "<h2>运行报告：" + 列表库::获取字符串(报告标题表, 报告句柄) + "</h2>";
    页 = 页 + "<p>trace: <code>" + 列表库::获取字符串(报告追踪表, 报告句柄) + "</code></p>";
    页 = 页 + "<table><tr><th>#</th><th>种类</th><th>名字</th><th>耗时(ms)</th><th>令牌(提示/补全)</th><th>成本(分)</th></tr>";
    变量 n: 整数 = 报告步骤数(报告句柄);
    变量 慢: 整数 = 最慢报告步骤(报告句柄);
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 类名: 字符串 = "";
        如果 (i == 慢 && n > 1) { 类名 = " class=\"slow\""; }
        页 = 页 + "<tr" + 类名 + "><td>" + 整数转字符串(i + 1) + "</td>"
            + "<td>" + 列表库::获取字符串(列表库::获取整数(步种类表组, 报告句柄), i) + "</td>"
            + "<td>" + 列表库::获取字符串(列表库::获取整数(步名表组, 报告句柄), i) + "</td>"
            + "<td>" + 整数转字符串(列表库::获取整数(列表库::获取整数(步耗时表组, 报告句柄), i)) + "</td>"
            + "<td>" + 整数转字符串(列表库::获取整数(列表库::获取整数(步令牌表组, 报告句柄), i))
            + " (" + 整数转字符串(列表库::获取整数(列表库::获取整数(步提示令牌表组, 报告句柄), i))
            + "/" + 整数转字符串(列表库::获取整数(列表库::获取整数(步补全令牌表组, 报告句柄), i)) + ")</td>"
            + "<td>" + 整数转字符串(列表库::获取整数(列表库::获取整数(步成本表组, 报告句柄), i)) + "</td></tr>";
        i = i + 1;
    }
    页 = 页 + "</table><p>总计：" + 整数转字符串(n) + " 步 · 耗时 "
        + 整数转字符串(报告总耗时按句柄(报告句柄)) + "ms · 令牌 " + 整数转字符串(报告总令牌按句柄(报告句柄))
        + " · 成本 " + 整数转字符串(报告总成本按句柄(报告句柄)) + "分</p></body></html>";
    返回 页;
}
公开 函数 HTML报告() : 字符串 { 返回 HTML报告按句柄(默认报告句柄); }

公开 函数 保存HTML报告按句柄(报告句柄: 整数, 路径值: 字符串) : 整数 {
    返回 IO.写入文件(路径值, HTML报告按句柄(报告句柄));
}
公开 函数 保存HTML报告(路径值: 字符串) : 整数 { 返回 保存HTML报告按句柄(默认报告句柄, 路径值); }
