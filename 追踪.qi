// 追踪 — agent 执行链路日志
//
// Harness engineering 核心要求：每一次 LLM 调用、每一次 tool 派发都要可观测。
// 这模块提供轻量 event log：每个 agent 实例有一个 trace ID，往 stderr 打 JSON
// 行。生产环境换 sink 到 Loki/CloudWatch/...
//
// 设计：用全局列表存事件，提供 dump_json 一次性导出。也可即时 print。

包 Harness;

导入 标准库.字符串;
导入 标准库.输入输出 作为 IO;
导入 标准库.时间;

// 全局 trace 开关
变量 启用追踪: 整数 = 1;
变量 即时打印: 整数 = 1;

公开 函数 启用() : 整数 {
    启用追踪 = 1;
    返回 1;
}

公开 函数 禁用() : 整数 {
    启用追踪 = 0;
    返回 0;
}

公开 函数 启用即时打印() : 整数 {
    即时打印 = 1;
    返回 1;
}

公开 函数 禁用即时打印() : 整数 {
    即时打印 = 0;
    返回 0;
}

// 一条事件 — JSON 行格式
// 字段：ts (毫秒) / type (llm_call/tool_call/error/...) / agent / detail
公开 函数 事件(事件类型: 字符串, 代理名: 字符串, 详情: 字符串) {
    如果 (启用追踪 == 0) {
        返回;
    }
    变量 行: 字符串 = "{\"ts\":" + 整数转字符串(时间.当前毫秒());
    行 = 行 + ",\"type\":\"" + 事件类型 + "\"";
    行 = 行 + ",\"agent\":\"" + 代理名 + "\"";
    行 = 行 + ",\"detail\":\"" + 转义引号(详情) + "\"}";
    如果 (即时打印 == 1) {
        IO.打印行(行);
    }
}

公开 函数 LLM调用事件(代理名: 字符串, 提示: 字符串) {
    事件("llm_call", 代理名, 提示);
}

公开 函数 LLM响应事件(代理名: 字符串, 响应: 字符串) {
    事件("llm_response", 代理名, 响应);
}

公开 函数 工具调用事件(代理名: 字符串, 工具名: 字符串, 参数JSON: 字符串) {
    事件("tool_call", 代理名, 工具名 + "(" + 参数JSON + ")");
}

公开 函数 工具结果事件(代理名: 字符串, 工具名: 字符串, 输出: 字符串) {
    事件("tool_result", 代理名, 工具名 + " → " + 输出);
}

公开 函数 错误事件(代理名: 字符串, 错误: 字符串) {
    事件("error", 代理名, 错误);
}

公开 函数 完成事件(代理名: 字符串, 最终输出: 字符串) {
    事件("done", 代理名, 最终输出);
}

// JSON 字符串里转义引号 — 极简版（实际生产可再扩 \n \t \\）
函数 转义引号(文本: 字符串) : 字符串 {
    返回 文本; // TODO：等 qi 字符串::替换 通用版后接
}
