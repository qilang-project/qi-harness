// 追踪 — agent 执行链路日志（可观测）
//
// Harness engineering 核心：每次 LLM 调用 / 每次 tool 派发都要可观测。本模块提供：
//   - 事件：单行 JSON，带 trace_id，即时打到 stderr 或文件 sink
//   - 跨度（span）：开始/结束配对，自动算 duration_ms，可记 token / 成本 → 一棵调用树
//   - sink：默认 stderr，可切到文件（生产再从文件转发到 Loki/Langfuse/OTLP collector）
//
// JSON 行样例（span 完成）：
//   {"ts":..,"trace":"<uuid>","span":7,"parent":3,"type":"llm","agent":"助手",
//    "dur_ms":842,"tokens":1234,"cost":0,"detail":"东京天气..."}

包 Harness;

导入 标准库.字符串;
导入 标准库.输入输出 作为 IO;
导入 标准库.时间;
导入 标准库.列表 作为 列表库;
导入 标准库.随机 作为 随机;
导入 标准库.HTTP 作为 HTTP;
导入 标准库.JSON 作为 J;
导入 Harness.事件::{订阅生命周期事件};

// ——— 全局开关 / sink ———
变量 启用追踪: 整数 = 1;
变量 即时打印: 整数 = 1;
变量 当前追踪ID: 字符串 = "-";     // 一次会话/任务一个 trace，串起同一批 span
变量 输出文件路径: 字符串 = "";     // "" = stderr；非空 = 追加到该文件
变量 OTLP端点: 字符串 = "";         // "" = 关；非空 = 每个完成的 span POST 到该 OTLP/HTTP collector

// ——— span 计时表（惰性建）———
变量 跨度计数器: 整数 = 0;
变量 跨度ID表: 整数 = 0;            // 整数列表句柄：span_id
变量 跨度开始表: 整数 = 0;          // 整数列表句柄：对应起始毫秒（下标对齐）

公开 函数 启用() : 整数 { 启用追踪 = 1; 返回 1; }
公开 函数 禁用() : 整数 { 启用追踪 = 0; 返回 0; }
公开 函数 启用即时打印() : 整数 { 即时打印 = 1; 返回 1; }
公开 函数 禁用即时打印() : 整数 { 即时打印 = 0; 返回 0; }

// 开一个新 trace：生成 UUID 作 trace_id，之后的事件/跨度都归到它下面。返回 trace_id。
公开 函数 新追踪() : 字符串 {
    当前追踪ID = 随机.UUID();
    返回 当前追踪ID;
}

公开 函数 当前追踪() : 字符串 { 返回 当前追踪ID; }

// 把 sink 切到文件（追加写）。传 "" 切回 stderr。
公开 函数 设置输出文件(路径: 字符串) : 整数 {
    输出文件路径 = 路径;
    返回 1;
}

// 写一行到当前 sink
函数 写一行(行: 字符串) {
    如果 (字符串::字节长度(输出文件路径) > 0) {
        IO.追加文件(输出文件路径, 行 + "\n");
    } 否则 {
        IO.打印行(行);
    }
}

// 生命周期总线适配器。只有显式安装后才写 sink，避免与 Agent 既有直写追踪重复。
// 回调本身公开，便于调用方按自己的订阅策略安装。
公开 函数 处理生命周期追踪事件(事件JSON: 字符串) : 整数 {
    变量 根: 整数 = J.解码(事件JSON);
    如果 (根 <= 0) { 返回 0; }
    如果 (启用追踪 == 0) {
        J.删除(根);
        返回 1;
    }
    变量 载荷: 整数 = J.获取对象(根, "payload");
    变量 详情: 字符串 = "{}";
    如果 (载荷 > 0) { 详情 = J.转字符串(载荷); }
    变量 行: 字符串 = "{\"ts\":" + 整数转字符串(J.获取整数(根, "ts_ms"))
        + ",\"trace\":\"" + 转义引号(J.获取字符串(根, "run_id")) + "\""
        + ",\"turn\":\"" + 转义引号(J.获取字符串(根, "turn_id")) + "\""
        + ",\"step\":\"" + 转义引号(J.获取字符串(根, "step_id")) + "\""
        + ",\"type\":\"" + 转义引号(J.获取字符串(根, "type")) + "\""
        + ",\"agent\":\"" + 转义引号(J.获取字符串(根, "agent")) + "\""
        + ",\"detail\":\"" + 转义引号(详情) + "\"}";
    如果 (即时打印 == 1) { 写一行(行); }
    J.删除(根);
    返回 1;
}

公开 函数 安装生命周期追踪适配器() : 整数 {
    返回 订阅生命周期事件(处理生命周期追踪事件, 1);
}

// JSON 字符串转义 —— \、"、换行、回车、Tab（之前是 TODO 空实现，detail 里有引号/换行就把 JSON 打烂）
公开 函数 转义引号(文本: 字符串) : 字符串 {
    变量 s: 字符串 = 字符串::替换(文本, "\\", "\\\\");
    s = 字符串::替换(s, "\"", "\\\"");
    s = 字符串::替换(s, "\n", "\\n");
    s = 字符串::替换(s, "\r", "\\r");
    s = 字符串::替换(s, "\t", "\\t");
    返回 s;
}

// 一条事件 — 单行 JSON，含 trace_id。
公开 函数 事件(事件类型: 字符串, 代理名: 字符串, 详情: 字符串) {
    如果 (启用追踪 == 0) { 返回; }
    变量 行: 字符串 = "{\"ts\":" + 整数转字符串(时间.当前毫秒());
    行 = 行 + ",\"trace\":\"" + 当前追踪ID + "\"";
    行 = 行 + ",\"type\":\"" + 转义引号(事件类型) + "\"";
    行 = 行 + ",\"agent\":\"" + 转义引号(代理名) + "\"";
    行 = 行 + ",\"detail\":\"" + 转义引号(详情) + "\"}";
    如果 (即时打印 == 1) {
        写一行(行);
    }
}

// ——— span（跨度）———
函数 确保跨度表() {
    如果 (跨度ID表 == 0) {
        跨度ID表 = 列表库::创建整数列表();
        跨度开始表 = 列表库::创建整数列表();
    }
}

// 开始一个跨度：记录起始时刻，返回 span_id。父跨度传 0 表示顶层。
// 立刻发一条 span_start 事件（便于看“正在做什么”）。
公开 函数 开始跨度(跨度类型: 字符串, 代理名: 字符串, 详情: 字符串, 父跨度: 整数) : 整数 {
    确保跨度表();
    跨度计数器 = 跨度计数器 + 1;
    变量 跨度ID: 整数 = 跨度计数器;
    列表库::添加整数(跨度ID表, 跨度ID);
    列表库::添加整数(跨度开始表, 时间.当前毫秒());
    如果 (启用追踪 == 1) {
        变量 行: 字符串 = "{\"ts\":" + 整数转字符串(时间.当前毫秒())
            + ",\"trace\":\"" + 当前追踪ID + "\""
            + ",\"span\":" + 整数转字符串(跨度ID)
            + ",\"parent\":" + 整数转字符串(父跨度)
            + ",\"type\":\"" + 转义引号(跨度类型) + "\""
            + ",\"agent\":\"" + 转义引号(代理名) + "\""
            + ",\"phase\":\"start\""
            + ",\"detail\":\"" + 转义引号(详情) + "\"}";
        如果 (即时打印 == 1) { 写一行(行); }
    }
    返回 跨度ID;
}

// 按 span_id 找起始毫秒，找不到返回 -1
函数 查起始(跨度ID: 整数) : 整数 {
    如果 (跨度ID表 == 0) { 返回 -1; }
    变量 n: 整数 = 列表库::整数列表大小(跨度ID表);
    变量 i: 整数 = 0;
    当 (i < n) {
        如果 (列表库::获取整数(跨度ID表, i) == 跨度ID) {
            返回 列表库::获取整数(跨度开始表, i);
        }
        i = i + 1;
    }
    返回 -1;
}

// 结束一个跨度：算 duration_ms，发一条 span 完成事件，带 tokens / cost。
// 令牌数 / 成本 未知就传 0。
公开 函数 结束跨度(跨度ID: 整数, 代理名: 字符串, 跨度类型: 字符串, 详情: 字符串, 令牌数: 整数, 成本: 整数) {
    如果 (启用追踪 == 0) { 返回; }
    变量 起: 整数 = 查起始(跨度ID);
    变量 现: 整数 = 时间.当前毫秒();
    变量 耗时: 整数 = 0 - 1;
    如果 (起 >= 0) { 耗时 = 现 - 起; }
    变量 行: 字符串 = "{\"ts\":" + 整数转字符串(现)
        + ",\"trace\":\"" + 当前追踪ID + "\""
        + ",\"span\":" + 整数转字符串(跨度ID)
        + ",\"type\":\"" + 转义引号(跨度类型) + "\""
        + ",\"agent\":\"" + 转义引号(代理名) + "\""
        + ",\"phase\":\"end\""
        + ",\"dur_ms\":" + 整数转字符串(耗时)
        + ",\"tokens\":" + 整数转字符串(令牌数)
        + ",\"cost\":" + 整数转字符串(成本)
        + ",\"detail\":\"" + 转义引号(详情) + "\"}";
    如果 (即时打印 == 1) { 写一行(行); }
    // OTLP 导出：把这个完成的 span POST 到 collector（开了才走）
    如果 (字符串::字节长度(OTLP端点) > 0) {
        导出OTLP跨度(跨度ID, 代理名, 跨度类型, 详情, 起, 现, 令牌数, 成本);
    }
}

// ——— OTLP/HTTP span 导出 ———
//
// 把 span 打成 OpenTelemetry 的 resourceSpans JSON，POST 到 collector 的 /v1/traces。
// trace_id 需 32 位 hex（16 字节）—— 用 UUID 去横杠正好；span_id 需 16 位 hex（8 字节）
// —— 用计数器整数转 hex 左填零。时间要纳秒 —— 毫秒 ×1e6（末尾补 6 个 0）。
// 逐 span 同步 POST（开了才有开销）；生产可换批量。

// 整数转小写十六进制（无前缀，n<=0 → "0"）
函数 转十六(n: 整数) : 字符串 {
    如果 (n <= 0) { 返回 "0"; }
    变量 位: 字符串 = "0123456789abcdef";
    变量 结果值: 字符串 = "";
    变量 x: 整数 = n;
    当 (x > 0) {
        变量 余: 整数 = x - (x / 16) * 16;
        结果值 = 字符串::子串(位, 余, 余 + 1) + 结果值;
        x = x / 16;
    }
    返回 结果值;
}

// 左填零到指定宽度（超宽则原样）
函数 左填零(s: 字符串, 宽: 整数) : 字符串 {
    变量 r: 字符串 = s;
    当 (字符串::字节长度(r) < 宽) {
        r = "0" + r;
    }
    返回 r;
}

// OTLP 属性项 {"key":k,"value":{"stringValue":v}}
函数 属性串(键: 字符串, 值: 字符串) : 字符串 {
    返回 "{\"key\":\"" + 键 + "\",\"value\":{\"stringValue\":\"" + 转义引号(值) + "\"}}";
}
函数 属性整数(键: 字符串, 值: 整数) : 字符串 {
    返回 "{\"key\":\"" + 键 + "\",\"value\":{\"intValue\":\"" + 整数转字符串(值) + "\"}}";
}

// 开启 OTLP 导出：传 collector 基址（如 http://localhost:4318），span 会 POST 到 {基址}/v1/traces。
// 传 "" 关闭。
公开 函数 设置OTLP(端点基址: 字符串) : 整数 {
    OTLP端点 = 端点基址;
    返回 1;
}

函数 导出OTLP跨度(跨度ID: 整数, 代理名: 字符串, 跨度类型: 字符串, 详情: 字符串,
              起毫秒: 整数, 止毫秒: 整数, 令牌数: 整数, 成本: 整数) {
    变量 traceHex: 字符串 = 字符串::替换(当前追踪ID, "-", "");
    变量 spanHex: 字符串 = 左填零(转十六(跨度ID), 16);
    变量 起纳: 字符串 = 整数转字符串(起毫秒) + "000000";
    变量 止纳: 字符串 = 整数转字符串(止毫秒) + "000000";
    如果 (起毫秒 < 0) { 起纳 = 止纳; }

    变量 属性: 字符串 = 属性串("agent", 代理名) + ","
        + 属性整数("tokens", 令牌数) + ","
        + 属性整数("cost", 成本) + ","
        + 属性串("detail", 详情);

    变量 span: 字符串 = "{\"traceId\":\"" + traceHex + "\",\"spanId\":\"" + spanHex + "\""
        + ",\"name\":\"" + 转义引号(跨度类型) + "\",\"kind\":1"
        + ",\"startTimeUnixNano\":\"" + 起纳 + "\",\"endTimeUnixNano\":\"" + 止纳 + "\""
        + ",\"attributes\":[" + 属性 + "]}";

    变量 信封: 字符串 = "{\"resourceSpans\":[{\"resource\":{\"attributes\":["
        + 属性串("service.name", "qi-harness")
        + "]},\"scopeSpans\":[{\"spans\":[" + span + "]}]}]}";

    变量 句柄: 整数 = HTTP.创建请求("POST", OTLP端点 + "/v1/traces");
    如果 (句柄 <= 0) { 返回; }
    HTTP.设置请求头(句柄, "Content-Type", "application/json");
    HTTP.设置请求体(句柄, 信封);
    HTTP.设置超时(句柄, 5000);
    HTTP.执行请求(句柄);
}

// ——— 语义化事件助手（保持既有接口不变）———
公开 函数 LLM调用事件(代理名: 字符串, 提示: 字符串) { 事件("llm_call", 代理名, 提示); }
公开 函数 LLM响应事件(代理名: 字符串, 响应: 字符串) { 事件("llm_response", 代理名, 响应); }
公开 函数 工具调用事件(代理名: 字符串, 工具名: 字符串, 参数JSON: 字符串) { 事件("tool_call", 代理名, 工具名 + "(" + 参数JSON + ")"); }
公开 函数 工具结果事件(代理名: 字符串, 工具名: 字符串, 输出: 字符串) { 事件("tool_result", 代理名, 工具名 + " → " + 输出); }
公开 函数 错误事件(代理名: 字符串, 错误: 字符串) { 事件("error", 代理名, 错误); }
公开 函数 工具被拒事件(代理名: 字符串, 工具名: 字符串) { 事件("tool_denied", 代理名, 工具名 + " 不在该代理的工具白名单内，已拒绝执行"); }
公开 函数 完成事件(代理名: 字符串, 最终输出: 字符串) { 事件("done", 代理名, 最终输出); }
公开 函数 流开始事件(代理名: 字符串, 提示: 字符串) { 事件("stream_start", 代理名, 提示); }
公开 函数 流块事件(代理名: 字符串, 片段: 字符串) { 事件("stream_chunk", 代理名, 片段); }
公开 函数 流结束事件(代理名: 字符串, 最终输出: 字符串) { 事件("stream_end", 代理名, 最终输出); }
