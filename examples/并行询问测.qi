// 并行询问测 —— 查询级并行 LLM 扇出（Harness.并行），需 LLM。
//
// 3 个独立提示各开独立会话并发问，结果下标对齐；再串行跑同样 3 个
// 调用计时对比，验证并行确实省时。
//
// 跑：
//   QI_CHAT_URL="https://.../v1" QI_CHAT_KEY="sk-..." QI_CHAT_MODEL="qwen3.7-plus" \
//   qi run examples/并行询问测.qi

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 标准库.时间 作为 时间;
导入 Harness.模型::{模型配置, 大模型, 一次对话};
导入 Harness.并行::{并行对话, 并行对话_配置, 并行映射};

函数 入口() {
    变量 端点: 字符串 = 系统.获取环境变量("QI_CHAT_URL");
    变量 密钥: 字符串 = 系统.获取环境变量("QI_CHAT_KEY");
    变量 模型: 字符串 = 系统.获取环境变量("QI_CHAT_MODEL");
    如果 (字符串::字节长度(端点) == 0) {
        IO.打印行("需要 QI_CHAT_URL / QI_CHAT_KEY / QI_CHAT_MODEL");
        返回;
    }

    变量 提示列表: 整数 = 列表库::创建字符串列表();
    列表库::添加字符串(提示列表, "用一句话介绍长城");
    列表库::添加字符串(提示列表, "用一句话介绍故宫");
    列表库::添加字符串(提示列表, "用一句话介绍西湖");
    变量 个数: 整数 = 列表库::字符串列表大小(提示列表);

    // ===== 并行：N 个独立会话并发问 =====
    IO.打印行("=== 并行对话（" + 整数转字符串(个数) + " 个提示并发） ===");
    变量 并行起: 整数 = 时间.现在毫秒();
    变量 结果列表: 整数 = 并行对话(端点, 密钥, 模型, 提示列表, 个数);
    变量 并行耗时: 整数 = 时间.现在毫秒() - 并行起;

    变量 i: 整数 = 0;
    当 (i < 个数) {
        变量 提示: 字符串 = 列表库::获取字符串(提示列表, i);
        变量 结果值: 字符串 = 列表库::获取字符串(结果列表, i);
        IO.打印行("[" + 整数转字符串(i) + "] " + 提示 + " → " + 结果值);
        i = i + 1;
    }

    // ===== 串行：同样的调用逐个跑，计时对比 =====
    IO.打印行("");
    IO.打印行("=== 串行对照（同样 " + 整数转字符串(个数) + " 个调用逐个跑） ===");
    变量 配置: 模型配置 = 大模型(端点, 密钥, 模型);
    变量 串行起: 整数 = 时间.现在毫秒();
    变量 j: 整数 = 0;
    当 (j < 个数) {
        变量 提示2: 字符串 = 列表库::获取字符串(提示列表, j);
        变量 回复: 字符串 = 一次对话(配置, 提示2);
        IO.打印行("[" + 整数转字符串(j) + "] " + 提示2 + " → " + 回复);
        j = j + 1;
    }
    变量 串行耗时: 整数 = 时间.现在毫秒() - 串行起;

    IO.打印行("");
    IO.打印行("并行 " + 整数转字符串(并行耗时) + " ms vs 串行 " + 整数转字符串(串行耗时) + " ms");
    如果 (并行耗时 < 串行耗时) {
        IO.打印行("并行确实更快 ✓");
    } 否则 {
        IO.打印行("警告：并行没有更快（网络抖动？）");
    }

    // ===== 并行映射：模板 {} 占位 + 项目列表 =====
    IO.打印行("");
    IO.打印行("=== 并行映射（模板 + 项目） ===");
    变量 项目列表: 整数 = 列表库::创建字符串列表();
    列表库::添加字符串(项目列表, "黄山");
    列表库::添加字符串(项目列表, "泰山");
    变量 项目数: 整数 = 列表库::字符串列表大小(项目列表);
    变量 映射结果: 整数 = 并行映射(端点, 密钥, 模型, "用一句话介绍{}", 项目列表, 项目数);
    变量 k: 整数 = 0;
    当 (k < 项目数) {
        IO.打印行("[" + 整数转字符串(k) + "] " + 列表库::获取字符串(项目列表, k) + " → " + 列表库::获取字符串(映射结果, k));
        k = k + 1;
    }
}
