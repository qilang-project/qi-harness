// qi-harness tool-use 示例：天气助手 + 时间助手
//
// 演示 agent loop：用户问「东京 几点 + 天气」，agent 看到 prompt 决定调
// 哪些工具，harness 自动 dispatch + 回写 + 继续。
//
// 这里 tool 用 mock 实现（不真调天气 API），证明 dispatch 流程。

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.时间;
导入 Harness::{
    模型配置, 默认配置, 配置模型, 配置密钥, 配置系统提示, 开启会话,
    创建代理, 添加工具, 运行, 关闭代理,
    工具, 启用追踪
};
导入 标准库.字符串;
导入 标准库.操作系统 作为 系统;

// ===== 工具实现 =====

函数 当前时间(参数JSON: 字符串) : 字符串 {
    // 真实可解析 args JSON 找时区；这里 mock 固定北京时间
    返回 "{\"time\":\"2026-05-07 22:30:00 +08:00\"}";
}

函数 天气查询(参数JSON: 字符串) : 字符串 {
    // 真实应 parse args 拿 "city" 字段；mock：含 "tokyo" 返天晴
    如果 (字符串::包含(字符串::转小写(参数JSON), "tokyo") == 1) {
        返回 "{\"city\":\"Tokyo\",\"temp\":18,\"condition\":\"晴\"}";
    }
    如果 (字符串::包含(字符串::转小写(参数JSON), "beijing") == 1) {
        返回 "{\"city\":\"Beijing\",\"temp\":24,\"condition\":\"多云\"}";
    }
    返回 "{\"error\":\"city not found\"}";
}

函数 入口() {
    变量 密钥: 字符串 = 系统.获取环境变量("QI_LLM_KEY");
    如果 (字符串::字节长度(密钥) == 0) {
        IO.打印行("未设 QI_LLM_KEY — dry run（编译通过即胜利）");
        返回;
    }

    启用追踪();
    变量 配置: 模型配置 = 默认配置();
    配置 = 配置模型(配置, "gpt-4o-mini");
    配置 = 配置密钥(配置, 密钥);
    配置 = 配置系统提示(配置, "你是助手，能调用工具查询时间和天气。");

    变量 会话: 整数 = 开启会话(配置);
    如果 (会话 <= 0) {
        IO.打印行("会话开启失败");
        返回;
    }

    变量 代理值: 代理 = 创建代理("天气时间助手", 会话);

    变量 时间工具: 工具 = (工具 {
        名字: "当前时间",
        描述: "查询当前时间。",
        参数schema: "{\"type\":\"object\",\"properties\":{}}",
        处理: 当前时间,
    });
    代理值 = 添加工具(代理值, 时间工具);

    变量 天气工具: 工具 = (工具 {
        名字: "天气查询",
        描述: "查询指定城市的天气。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"city\":{\"type\":\"string\"}},\"required\":[\"city\"]}",
        处理: 天气查询,
    });
    代理值 = 添加工具(代理值, 天气工具);

    变量 回复: 字符串 = 运行(代理值, "东京现在几点？天气怎样？");
    IO.打印行("");
    IO.打印行("=== Final ===");
    IO.打印行(回复);

    关闭代理(代理值);
}
