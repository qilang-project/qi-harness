// 可观测 自测：转义引号（修的真 bug）+ span 计时 + trace_id。
// 跑：qi run examples/追踪_跨度测.qi

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.时间;
导入 Harness.追踪::{转义引号, 新追踪, 当前追踪, 开始跨度, 结束跨度, 事件};

函数 入口() {
    变量 过: 整数 = 0;

    // 转义引号：含引号/换行的脏串必须被转义（否则 JSON 行被打烂）
    变量 脏: 字符串 = "他说\"你好\"\n换行";
    变量 净: 字符串 = 转义引号(脏);
    IO.打印行("转义前字节: " + 整数转字符串(字符串::字节长度(脏)));
    IO.打印行("转义后: " + 净);
    如果 (字符串::包含(净, "\\\"") == 1) {
        IO.打印行("✅ 引号已转义");
        过 = 过 + 1;
    } 否则 {
        IO.打印行("❌ 引号未转义");
    }
    如果 (字符串::包含(净, "\\n") == 1) {
        IO.打印行("✅ 换行已转义");
        过 = 过 + 1;
    } 否则 {
        IO.打印行("❌ 换行未转义");
    }

    IO.打印行("");
    // trace + span：开一个 trace，套一个父 span，里面套子 span
    变量 追踪ID: 字符串 = 新追踪();
    IO.打印行("trace_id = " + 追踪ID);
    IO.打印行("(以下为 span JSON 行，看 dur_ms 是否 > 0)");

    变量 父: 整数 = 开始跨度("task", "演示", "跑一个两步任务", 0);
    变量 子: 整数 = 开始跨度("llm", "演示", "调模型", 父);
    时间.睡眠毫秒(20);
    结束跨度(子, "演示", "llm", "模型返回", 128, 0);
    结束跨度(父, "演示", "task", "任务完成", 128, 0);

    如果 (字符串::字节长度(当前追踪()) > 0) {
        过 = 过 + 1;
    }

    IO.打印行("");
    如果 (过 == 3) {
        IO.打印行("✅ 全部 3 项通过：转义 + 换行 + trace 就位（span dur_ms 见上方 JSON）");
    } 否则 {
        IO.打印行("❌ 通过 " + 整数转字符串(过) + "/3");
    }
}
