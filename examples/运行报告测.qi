// 运行报告 —— 跑几步（LLM + 本地），导出「哪几步、各花多少 token、总成本、哪步慢」的报告。
//
// 跑（可配合磁带 QI_LLM_RECORD / QI_LLM_REPLAY）：
//   QI_CHAT_URL=.. QI_CHAT_KEY=.. QI_CHAT_MODEL=.. qi run examples/运行报告测.qi

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 标准库.字符串;
导入 标准库.时间;
导入 标准库.JSON 作为 J;
导入 标准库.大模型 作为 底层模型;
导入 Harness.追踪::{新追踪, 禁用即时打印};
导入 Harness.报告::{开始报告, 开始步骤, 结束步骤, 结束步骤按会话,
                    文本报告, 报告JSON, 保存报告, 保存HTML报告, 报告总令牌};

函数 入口() {
    变量 端点: 字符串 = 系统.获取环境变量("QI_CHAT_URL");
    变量 密钥: 字符串 = 系统.获取环境变量("QI_CHAT_KEY");
    变量 模型: 字符串 = 系统.获取环境变量("QI_CHAT_MODEL");
    如果 (字符串::字节长度(端点) == 0) {
        IO.打印行("需要 QI_CHAT_URL / QI_CHAT_KEY / QI_CHAT_MODEL");
        返回;
    }

    新追踪();
    禁用即时打印();   // span 日志流静音，只看汇总报告（生产两者可同时开）

    变量 会话: 整数 = 底层模型.创建会话(端点, 模型, 密钥);
    开始报告("两步问答 + 本地处理");

    // 步骤 1：LLM 调用，token 用量自动从 大模型.用量 读真值
    变量 步1: 整数 = 开始步骤("llm", "问首都");
    变量 答1: 字符串 = 底层模型.对话(会话, "中国的首都是哪个城市？只回答城市名。");
    结束步骤按会话(步1, 答1, 会话);

    // 步骤 2：再一次 LLM 调用
    变量 步2: 整数 = 开始步骤("llm", "问算术");
    变量 答2: 字符串 = 底层模型.对话(会话, "3乘7等于几？只回答一个数字。");
    结束步骤按会话(步2, 答2, 会话);

    // 步骤 3：非 LLM 的本地步骤（token/成本手填）
    变量 步3: 整数 = 开始步骤("tool", "本地处理");
    时间.睡眠毫秒(30);
    结束步骤(步3, "拼接完成: " + 答1 + "/" + 答2, 0, 0);

    // —— 人类可读报告 ——
    IO.打印(文本报告());

    // —— 结构化导出 + 校验 JSON 有效、总令牌为真值 ——
    变量 JSON路径: 字符串 = "/tmp/qi_run_report.json";
    变量 HTML路径: 字符串 = "/tmp/qi_run_report.html";
    保存报告(JSON路径);
    保存HTML报告(HTML路径);

    变量 对象: 整数 = J.解码(IO.读取文件(JSON路径));
    如果 (对象 > 0) {
        变量 步骤组: 整数 = J.获取数组(对象, "步骤");
        IO.打印行("✅ 报告 JSON 有效：步骤 " + 整数转字符串(J.数组长度(步骤组))
                  + " 个，总令牌 " + 整数转字符串(J.获取整数(对象, "总令牌"))
                  + "（内存侧 " + 整数转字符串(报告总令牌()) + "，应一致）");
    } 否则 {
        IO.打印行("❌ 报告 JSON 解析失败");
    }
    IO.打印行("已导出: " + JSON路径 + " / " + HTML路径);

    IO.删除文件(JSON路径);
    IO.删除文件(HTML路径);
    底层模型.关闭会话(会话);
}
