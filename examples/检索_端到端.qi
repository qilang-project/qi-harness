// 检索 端到端 —— 加载长文 → 分块 → 索引文档（双索引 ID 对齐）→ 混合召回 + LLM 重排 → top-3。
// 顺带验证 HTML转文本 粗剥。
//
// 跑（需要 embeddings + chat API）：
//   QI_EMBED_URL="https://<...>/compatible-mode/v1" QI_EMBED_KEY="sk-..." \
//   QI_CHAT_URL="https://<...>/compatible-mode/v1" QI_CHAT_KEY="sk-..." QI_CHAT_MODEL="qwen3.7-plus" \
//   qi run examples/检索_端到端.qi

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 标准库.词法索引 作为 词法索引;
导入 Harness.向量记忆::{打开向量库, 关闭向量库};
导入 Harness.文档::{加载文本, 分块, HTML转文本};
导入 Harness.检索::{配置检索, 关闭检索, 索引文档, 检索};
导入 Harness.模型::{大模型, 开启会话, 关闭会话Harness};

// 一段较长的中文运维手册（段落间 \n\n，供分块在段落边界断）
函数 手册文本() : 字符串 {
    返回 "数据库运维手册（内部版）\n\n"
        + "第一章 慢查询治理。定位慢查询的第一步是打开慢日志，把阈值设为 200 毫秒，"
        + "观察一天内被记录的语句。对高频慢语句优先加合适的索引，避免全表扫描；"
        + "对无法用索引优化的统计类语句，改成夜间跑批预聚合。此外，"
        + "EXPLAIN 的执行计划要重点看扫描行数与是否用到临时表。\n\n"
        + "第二章 连接管理。应用侧必须使用连接池，上限按「核数 x 2 + 磁盘数」估算起步，"
        + "避免连接风暴打垮数据库。空闲连接超过十分钟应回收。\n\n"
        + "第三章 备份与恢复。备份策略为每日凌晨增量、每周日全量，备份文件异地保存三十天。"
        + "每季度必须做一次真实恢复演练，未演练过的备份等于没有备份。\n\n"
        + "第四章 监控告警。核心指标包括 QPS、置换缓存命中率、主从延迟与磁盘水位。"
        + "主从延迟超过三秒要立即告警，磁盘超过八成水位要扩容。\n\n"
        + "附录 团建安排。本季度团建定在杭州，具体日期由行政另行通知，费用从部门预算列支。";
}

函数 入口() {
    变量 嵌端: 字符串 = 系统.获取环境变量("QI_EMBED_URL");
    变量 嵌钥: 字符串 = 系统.获取环境变量("QI_EMBED_KEY");
    变量 嵌模: 字符串 = 系统.获取环境变量("QI_EMBED_MODEL");
    变量 聊端: 字符串 = 系统.获取环境变量("QI_CHAT_URL");
    变量 聊钥: 字符串 = 系统.获取环境变量("QI_CHAT_KEY");
    变量 聊模: 字符串 = 系统.获取环境变量("QI_CHAT_MODEL");
    如果 (字符串::字节长度(嵌端) == 0 || 字符串::字节长度(聊端) == 0) {
        IO.打印行("需要环境变量 QI_EMBED_URL/QI_EMBED_KEY + QI_CHAT_URL/QI_CHAT_KEY/QI_CHAT_MODEL");
        返回;
    }
    如果 (字符串::结束于(嵌端, "/embeddings") == 0) { 嵌端 = 嵌端 + "/embeddings"; }
    如果 (字符串::字节长度(嵌模) == 0) { 嵌模 = "text-embedding-v4"; }
    如果 (字符串::字节长度(嵌钥) == 0) { 嵌钥 = 聊钥; }

    // ── 0) HTML 粗剥小验 ──
    变量 网页: 字符串 = "<html><head><style>p{color:red}</style>"
        + "<script>alert('x')</script></head>"
        + "<body><h1>标题</h1><p>正文 &amp; 附注</p></body></html>";
    IO.打印行("HTML转文本: " + HTML转文本(网页));

    // ── 1) 写长文到 /tmp 再 加载文本（走真实文件路径）──
    变量 文档路径: 字符串 = "/tmp/qi_检索_手册.txt";
    IO.写入文件(文档路径, 手册文本());
    变量 文本: 字符串 = 加载文本(文档路径);
    IO.打印行("加载文本: " + 整数转字符串(字符串::字节长度(文本)) + " 字节");

    // ── 2) 分块（400 字节 / 80 重叠，优先段落断点）──
    变量 块表: 整数 = 分块(文本, 400, 80);
    变量 块数: 整数 = 列表库::字符串列表大小(块表);
    IO.打印行("分块: " + 整数转字符串(块数) + " 块");
    变量 i: 整数 = 0;
    当 (i < 块数) {
        变量 块: 字符串 = 列表库::获取字符串(块表, i);
        IO.打印行("  块" + 整数转字符串(i + 1) + " (" + 整数转字符串(字符串::字节长度(块))
            + " 字节): " + 字符串::子串(块, 0, 45) + "...");
        i = i + 1;
    }
    列表库::删除列表(块表);

    // ── 3) 建库 + 双索引 ──
    变量 库路径: 字符串 = "/tmp/qi_检索_端到端.db";
    如果 (IO.文件存在(库路径) == 1) { IO.删除文件(库路径); }
    变量 库: 整数 = 打开向量库(库路径);
    如果 (库 <= 0) {
        IO.打印行("打开向量库失败");
        返回;
    }
    词法索引.重置(库);
    配置检索(嵌端, 嵌钥, 嵌模);
    变量 入数: 整数 = 索引文档(库, 库, 文本, 400, 80);
    IO.打印行("索引文档: " + 整数转字符串(入数) + " 块进双索引（ID 对齐）");

    // ── 4) 一站式检索：混合召回 6 → LLM 重排取 3 ──
    变量 会话: 整数 = 开启会话(大模型(聊端, 聊钥, 聊模));
    如果 (会话 <= 0) {
        IO.打印行("chat 会话开启失败（重排将退回原序）");
    }
    变量 查询: 字符串 = "怎么减少慢查询";
    IO.打印行("");
    IO.打印行("查询: " + 查询);
    变量 命中表: 整数 = 检索(库, 库, 会话, 查询, 6, 3);
    变量 命中数: 整数 = 列表库::字符串列表大小(命中表);
    IO.打印行("重排后 top-" + 整数转字符串(命中数) + ":");
    i = 0;
    当 (i < 命中数) {
        IO.打印行("  " + 整数转字符串(i + 1) + ". " + 列表库::获取字符串(命中表, i));
        i = i + 1;
    }

    // 验收：重排后第一条应是「慢查询治理」那块
    如果 (命中数 > 0 && 字符串::包含(列表库::获取字符串(命中表, 0), "慢查询") == 1) {
        IO.打印行("");
        IO.打印行("[通过] 最相关的「慢查询治理」块排在第一");
    } 否则 {
        IO.打印行("");
        IO.打印行("[失败] 第一条不是慢查询治理块");
    }
    列表库::删除列表(命中表);

    如果 (会话 > 0) { 关闭会话Harness(会话); }
    关闭检索();
    词法索引.卸载(库);
    关闭向量库(库);
}
