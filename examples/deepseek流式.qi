// qi-harness DeepSeek 流式实测
// 跑：QI_LLM_KEY=sk-... qi run deepseek流式.qi
//
// 块回调实时打到 stdout（不换行），最终完整回复也作为返回值。
// 同时 stream_chunk trace 事件也会打到 stdout（即时打印=1）。

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.操作系统 作为 系统;
导入 Harness::{
    模型配置, 大模型, 配置系统提示, 开启会话,
    创建代理, 流式问, 关闭代理
};

导入 Harness.追踪 作为 追踪;

// 流块回调 — 每片段实时拼到一行
函数 打印片段(片段: 字符串) : 整数 {
    IO.打印(片段);
    返回 1;
}

函数 入口() {
    变量 密钥: 字符串 = 系统.获取环境变量("QI_LLM_KEY");
    如果 (字符串::字节长度(密钥) == 0) {
        IO.打印行("未设 QI_LLM_KEY");
        返回;
    }

    // 关掉 trace 即时打印，避免和回调输出混在一起
    追踪.禁用即时打印();

    变量 配置: 模型配置 = 大模型("https://api.deepseek.com", 密钥, "deepseek-chat");
    配置 = 配置系统提示(配置, "你是 qi 编程语言的助手。回答简短。");

    变量 会话: 整数 = 开启会话(配置);
    如果 (会话 <= 0) {
        IO.打印行("会话开启失败");
        返回;
    }

    变量 代理值: 代理 = 创建代理("DeepSeek流式", 会话);

    IO.打印行("=== 流式输出 ===");
    变量 完整: 字符串 = 流式问(代理值, "用三句话介绍 qi 编程语言（中文）", 打印片段);
    IO.打印行("");
    IO.打印行("=== 完整回复 ===");
    IO.打印行(完整);

    关闭代理(代理值);
}
