// 预算账本 确定性自测（无需 LLM）—— 成本路径 + 超限 + 余量。
包 主程序;
导入 标准库.输入输出 作为 IO;
导入 Harness.预算::{创建预算, 记入成本, 超预算, 令牌余量, 已用令牌, 预算报告};

函数 断言(名: 字符串, 实际: 整数, 期望: 整数, 过: 整数) : 整数 {
    如果 (实际 == 期望) { IO.打印行("✅ " + 名); 返回 过 + 1; }
    IO.打印行("❌ " + 名 + "（得 " + 整数转字符串(实际) + " 期望 " + 整数转字符串(期望) + "）");
    返回 过;
}

函数 入口() {
    变量 过: 整数 = 0;
    // 令牌上限 1000，成本上限 500 分
    变量 b: 整数 = 创建预算(1000, 500);
    过 = 断言("初始不超", 超预算(b), 0, 过);
    过 = 断言("初始余量1000", 令牌余量(b), 1000, 过);
    // 加成本 300 → 不超
    记入成本(b, 300);
    过 = 断言("成本300不超", 超预算(b), 0, 过);
    // 再加 300 → 累计 600 > 500 上限 → 超
    记入成本(b, 300);
    过 = 断言("成本600超限", 超预算(b), 1, 过);
    // 无限预算
    变量 b2: 整数 = 创建预算(0, 0);
    记入成本(b2, 999999);
    过 = 断言("无限预算不超", 超预算(b2), 0, 过);
    过 = 断言("无限余量-1", 令牌余量(b2), 0 - 1, 过);

    IO.打印行(预算报告(b));
    IO.打印行("");
    如果 (过 == 6) { IO.打印行("✅ 全部 6 项通过：预算账本 + 超限判定正确"); }
    否则 { IO.打印行("❌ 通过 " + 整数转字符串(过) + "/6"); }
}
