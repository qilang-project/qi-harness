// qi-harness · 优先级队列（Prioritization）演示 —— 无需 LLM
//
// 乱序入队 3 个任务，出队应按优先级从高到低返回。全程确定性纯计算，无网络、无 API key。
//
// 跑：qi run examples/优先级示例.qi

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 Harness.优先级::{
    优先队列, 创建队列, 入队, 出队, 队列大小, 队列报告
};
导入 Harness.追踪::{启用};

函数 入口() {
    启用();

    变量 队列值: 优先队列 = 创建队列();
    队列值 = 入队(队列值, "写单元测试", 3);
    队列值 = 入队(队列值, "修复线上 P0", 9);
    队列值 = 入队(队列值, "更新文档", 1);

    IO.打印行("=== 入队后（乱序 3, 9, 1）===");
    IO.打印行(队列报告(队列值));

    IO.打印行("=== 依次出队（应 9 → 3 → 1）===");
    变量 第一: 字符串 = 出队(队列值);
    变量 第二: 字符串 = 出队(队列值);
    变量 第三: 字符串 = 出队(队列值);
    IO.打印行("1) " + 第一);
    IO.打印行("2) " + 第二);
    IO.打印行("3) " + 第三);

    IO.打印行("=== 断言 ===");
    如果 (字符串::等于(第一, "修复线上 P0") == 1
        && 字符串::等于(第二, "写单元测试") == 1
        && 字符串::等于(第三, "更新文档") == 1) {
        IO.打印行("PASS：出队顺序为最高优先级优先（9 → 3 → 1）");
    } 否则 {
        IO.打印行("FAIL：出队顺序不对");
    }
    如果 (队列大小(队列值) == 0 && 字符串::字节长度(出队(队列值)) == 0) {
        IO.打印行("PASS：出空后大小为 0、再出队返回空串");
    } 否则 {
        IO.打印行("FAIL：空队处理异常");
    }
}
