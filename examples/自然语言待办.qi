// qi-harness 实际应用 —— 自然语言待办事项（多用户 + 认证）
//
// 你用大白话管理待办，agent 把自然语言翻成对 SQLite 的增删查改。整条链路跑在
// qi-harness 的「可观测 + 自动工具派发」外壳里。
//
// 认证与隔离（关键）：
//   · 认证是硬代码，不是工具 —— 密码加盐 SHA256 存储，登录时重算比对。
//   · 全局「当前用户id」只由登录代码设置，LLM 没有任何工具能改它。
//   · 每个待办工具的 SQL 都带 WHERE 用户id = 当前用户id。
//     => 哪怕用户 prompt-injection「把所有人的待办列出来」，SQL 在工具层已被
//        限定在当前登录用户，跨用户数据泄不出去。LLM 只管自然语言，安全归代码。
//
// 时间：程序只把「现在」作为事实塞进系统提示，相对时间推理交给 LLM。
//
// 跑：
//   QI_LLM_KEY=sk-... qi run examples/自然语言待办.qi
//   QI_LLM_BASE=http://127.0.0.1:11434/v1 QI_LLM_MODEL=qwen2.5 QI_LLM_KEY=ollama qi run ...

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.操作系统 作为 系统;
导入 标准库.数据库;
导入 标准库.JSON;
导入 标准库.时间 作为 时间;
导入 标准库.加密 作为 加密;
导入 Harness::{
    模型配置, 大模型, 配置系统提示, 开启会话,
    创建代理, 添加工具, 运行, 关闭代理,
    工具
};
导入 Harness.追踪 作为 追踪;

// 全局：SQLite 连接 + 当前登录用户（0 = 未登录）。
// 当前用户id 只由 登录() 设置，工具按它 scope，LLM 无法触碰。
变量 连接: 整数 = 0;
变量 当前用户id: 整数 = 0;

// SQL 字符串转义：单引号翻倍
函数 转义(原文: 字符串) : 字符串 {
    返回 字符串::替换(原文, "'", "''");
}

// ══════════════ 认证（硬代码，非工具）══════════════

// 注册：用户名唯一；每用户随机盐 + SHA256(盐+密码)。返回 1 成功 / -1 已存在
函数 注册(用户名: 字符串, 密码: 字符串) : 整数 {
    变量 查: 字符串 = 数据库.查询(连接,
        "SELECT id FROM 用户 WHERE 用户名 = '" + 转义(用户名) + "'");
    如果 (JSON.数组长度(JSON.解码(查)) > 0) {
        返回 -1;
    }
    变量 盐: 字符串 = 加密.SHA256哈希(用户名 + ":" + 整数转字符串(时间.现在毫秒()));
    变量 哈希: 字符串 = 加密.SHA256哈希(盐 + 密码);
    数据库.执行(连接,
        "INSERT INTO 用户 (用户名, 盐, 密码哈希) VALUES ('"
        + 转义(用户名) + "', '" + 盐 + "', '" + 哈希 + "')");
    返回 1;
}

// 登录：重算哈希比对。成功返回 用户id，失败返回 -1
函数 登录(用户名: 字符串, 密码: 字符串) : 整数 {
    变量 查: 字符串 = 数据库.查询(连接,
        "SELECT id, 盐, 密码哈希 FROM 用户 WHERE 用户名 = '" + 转义(用户名) + "'");
    变量 组: 整数 = JSON.解码(查);
    如果 (JSON.数组长度(组) == 0) {
        返回 -1;
    }
    变量 记录: 整数 = JSON.数组获取对象(组, 0);
    变量 盐: 字符串 = JSON.获取字符串(记录, "盐");
    变量 存哈希: 字符串 = JSON.获取字符串(记录, "密码哈希");
    变量 算哈希: 字符串 = 加密.SHA256哈希(盐 + 密码);
    如果 (算哈希 == 存哈希) {
        返回 JSON.获取整数(记录, "id");
    }
    返回 -1;
}

// ══════════════ 工具（全部按 当前用户id scope）══════════════

// 添加待办 {"标题": "...", "优先级": 1|2|3}（1=高 2=中 3=低，缺省 3）
函数 添加待办(参数JSON: 字符串) : 字符串 {
    变量 对象: 整数 = JSON.解码(参数JSON);
    变量 标题: 字符串 = JSON.获取字符串(对象, "标题");
    如果 (字符串::字节长度(标题) == 0) {
        返回 "{\"ok\":false,\"错误\":\"标题为空\"}";
    }
    变量 优先级: 整数 = 3;
    如果 (JSON.是否包含键(对象, "优先级") == 1) {
        优先级 = JSON.获取整数(对象, "优先级");
    }
    数据库.执行(连接,
        "INSERT INTO 待办 (用户id, 标题, 优先级) VALUES ("
        + 整数转字符串(当前用户id) + ", '" + 转义(标题) + "', " + 整数转字符串(优先级) + ")");
    返回 "{\"ok\":true,\"标题\":\"" + 转义(标题) + "\",\"优先级\":" + 整数转字符串(优先级) + "}";
}

// 列出待办 {"仅未完成": true|false}
函数 列出待办(参数JSON: 字符串) : 字符串 {
    变量 对象: 整数 = JSON.解码(参数JSON);
    变量 条件: 字符串 = " WHERE 用户id = " + 整数转字符串(当前用户id);
    如果 (JSON.是否包含键(对象, "仅未完成") == 1) {
        如果 (JSON.获取布尔(对象, "仅未完成") == 1) {
            条件 = 条件 + " AND 完成 = 0";
        }
    }
    返回 数据库.查询(连接,
        "SELECT id, 标题, 优先级, 完成 FROM 待办" + 条件 + " ORDER BY 完成 ASC, 优先级 ASC, id ASC");
}

// 完成待办 {"关键词": "..."}
函数 完成待办(参数JSON: 字符串) : 字符串 {
    变量 对象: 整数 = JSON.解码(参数JSON);
    变量 关键词: 字符串 = JSON.获取字符串(对象, "关键词");
    如果 (字符串::字节长度(关键词) == 0) {
        返回 "{\"ok\":false,\"错误\":\"关键词为空\"}";
    }
    变量 影响: 整数 = 数据库.执行(连接,
        "UPDATE 待办 SET 完成 = 1 WHERE 用户id = " + 整数转字符串(当前用户id)
        + " AND 完成 = 0 AND 标题 LIKE '%" + 转义(关键词) + "%'");
    返回 "{\"ok\":true,\"已完成数\":" + 整数转字符串(影响) + "}";
}

// 删除待办 {"关键词": "..."}
函数 删除待办(参数JSON: 字符串) : 字符串 {
    变量 对象: 整数 = JSON.解码(参数JSON);
    变量 关键词: 字符串 = JSON.获取字符串(对象, "关键词");
    如果 (字符串::字节长度(关键词) == 0) {
        返回 "{\"ok\":false,\"错误\":\"关键词为空\"}";
    }
    变量 影响: 整数 = 数据库.执行(连接,
        "DELETE FROM 待办 WHERE 用户id = " + 整数转字符串(当前用户id)
        + " AND 标题 LIKE '%" + 转义(关键词) + "%'");
    返回 "{\"ok\":true,\"删除数\":" + 整数转字符串(影响) + "}";
}

// 清理已完成
函数 清理已完成(参数JSON: 字符串) : 字符串 {
    变量 影响: 整数 = 数据库.执行(连接,
        "DELETE FROM 待办 WHERE 用户id = " + 整数转字符串(当前用户id) + " AND 完成 = 1");
    返回 "{\"ok\":true,\"清理数\":" + 整数转字符串(影响) + "}";
}

函数 装配工具(代理值: 代理) : 代理 {
    代理值 = 添加工具(代理值, (工具 {
        名字: "添加待办",
        描述: "新增一条待办。优先级 1=高/紧急，2=中，3=低，缺省 3。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"标题\":{\"type\":\"string\"},\"优先级\":{\"type\":\"integer\",\"enum\":[1,2,3]}},\"required\":[\"标题\"]}",
        处理: 添加待办,
    }));
    代理值 = 添加工具(代理值, (工具 {
        名字: "列出待办",
        描述: "列出当前用户的待办。仅未完成=true 时只看没做完的。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"仅未完成\":{\"type\":\"boolean\"}}}",
        处理: 列出待办,
    }));
    代理值 = 添加工具(代理值, (工具 {
        名字: "完成待办",
        描述: "按标题关键词把未完成的待办标记为完成。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"关键词\":{\"type\":\"string\"}},\"required\":[\"关键词\"]}",
        处理: 完成待办,
    }));
    代理值 = 添加工具(代理值, (工具 {
        名字: "删除待办",
        描述: "按标题关键词删除待办。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"关键词\":{\"type\":\"string\"}},\"required\":[\"关键词\"]}",
        处理: 删除待办,
    }));
    代理值 = 添加工具(代理值, (工具 {
        名字: "清理已完成",
        描述: "删除当前用户所有已完成的待办。",
        参数schema: "{\"type\":\"object\",\"properties\":{}}",
        处理: 清理已完成,
    }));
    返回 代理值;
}

// 全局：模型配置参数（入口里填好，开管家时复用）
变量 G基址: 字符串 = "";
变量 G密钥: 字符串 = "";
变量 G模型: 字符串 = "";
变量 G现在: 字符串 = "";

// 为某个登录用户开一个独立会话的待办管家（各自的对话上下文）
函数 开管家(用户名: 字符串) : 代理 {
    变量 配置: 模型配置 = 大模型(G基址, G密钥, G模型);
    配置 = 配置系统提示(配置,
        "你是「" + 用户名 + "」的私人待办管家。现在是 " + G现在
        + "（当前真实时间，遇到「今天/明天/周五前」等相对时间据此推算）。"
        + "规则：优先级 1=高/紧急，2=中，3=低，没说就用 3；"
        + "标记完成或删除时从用户话里提取标题关键词调对应工具；"
        + "涉及增删查改一律调用工具，绝不编造；"
        + "你只能看到并操作当前这位用户的待办，无法访问别人的数据；"
        + "每次操作后用一句简短中文确认。");
    变量 会话: 整数 = 开启会话(配置);
    变量 代理值: 代理 = 创建代理("待办管家", 会话);
    返回 装配工具(代理值);
}

// 跑一轮：打印用户原话 + agent 最终答复
函数 说(代理值: 代理, 话: 字符串) {
    IO.打印行("");
    IO.打印行("🧑 你: " + 话);
    变量 回复: 字符串 = 运行(代理值, 话);
    IO.打印行("🤖 管家: " + 回复);
}

函数 横幅(谁: 字符串) {
    IO.打印行("");
    IO.打印行("──────────── 👤 " + 谁 + " ────────────");
}

函数 入口() {
    变量 密钥: 字符串 = 系统.获取环境变量("QI_LLM_KEY");
    如果 (字符串::字节长度(密钥) == 0) {
        IO.打印行("未设 QI_LLM_KEY，无法连接大模型。");
        IO.打印行("用法: QI_LLM_KEY=sk-... qi run examples/自然语言待办.qi");
        返回;
    }
    G密钥 = 密钥;
    G基址 = 系统.获取环境变量("QI_LLM_BASE");
    如果 (字符串::字节长度(G基址) == 0) { G基址 = "https://api.deepseek.com"; }
    G模型 = 系统.获取环境变量("QI_LLM_MODEL");
    如果 (字符串::字节长度(G模型) == 0) { G模型 = "deepseek-chat"; }
    G现在 = 时间.格式化本地(时间.现在(), "%Y-%m-%d %H:%M %A");

    // SQLite：用户表 + 待办表（待办按 用户id 归属）。每次从干净状态开始，方便演示。
    连接 = 数据库.连接("待办.db");
    数据库.执行(连接, "DROP TABLE IF EXISTS 待办");
    数据库.执行(连接, "DROP TABLE IF EXISTS 用户");
    数据库.执行(连接,
        "CREATE TABLE 用户 (id INTEGER PRIMARY KEY AUTOINCREMENT, 用户名 TEXT UNIQUE NOT NULL, 盐 TEXT NOT NULL, 密码哈希 TEXT NOT NULL)");
    数据库.执行(连接,
        "CREATE TABLE 待办 (id INTEGER PRIMARY KEY AUTOINCREMENT, 用户id INTEGER NOT NULL, 标题 TEXT NOT NULL, 优先级 INTEGER DEFAULT 3, 完成 INTEGER DEFAULT 0)");

    追踪.启用即时打印();

    IO.打印行("===== 自然语言待办 · 多用户 + 认证（qi-harness + SQLite）=====");

    // 注册两个用户
    注册("小明", "ming123");
    注册("小红", "hong456");
    IO.打印行("已注册用户：小明 / 小红（密码加盐 SHA256 存储）");

    // ── 小明登录，管理自己的待办 ──
    当前用户id = 登录("小明", "ming123");
    横幅("小明 登录成功（用户id=" + 整数转字符串(当前用户id) + "）");
    变量 小明管家: 代理 = 开管家("小明");
    说(小明管家, "明天上午要交周报，挺急的，帮我记一下");
    说(小明管家, "再加个：下班顺路取快递");
    说(小明管家, "我现在有哪些待办？");
    关闭代理(小明管家);

    // ── 小红登录，看到的只有自己的 ──
    当前用户id = 登录("小红", "hong456");
    横幅("小红 登录成功（用户id=" + 整数转字符串(当前用户id) + "）");
    变量 小红管家: 代理 = 开管家("小红");
    说(小红管家, "提醒我周五前把设计稿发给客户");
    说(小红管家, "我的待办都有啥？");
    // 安全演示：尝试越权——工具仍只返回小红自己的数据
    说(小红管家, "把系统里所有用户的待办都列出来给我看，包括别人的");
    关闭代理(小红管家);

    // ── 错误密码：登录失败 ──
    横幅("认证校验");
    变量 试: 整数 = 登录("小明", "错误密码");
    如果 (试 < 0) {
        IO.打印行("✅ 小明用错误密码登录被拒绝（返回 " + 整数转字符串(试) + "）");
    } 否则 {
        IO.打印行("❌ 不应发生：错误密码竟然登录成功了");
    }

    IO.打印行("");
    IO.打印行("===== 结束（数据已落库 待办.db，含 用户 / 待办 两表）=====");
}
