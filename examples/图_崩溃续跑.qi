// 持久化执行 —— 崩溃中续跑 + 节点 exactly-once 自测（无需 LLM，纯确定性）。
//
// 图：A → B → C → D → 终点。每个节点：打印「执行节点X」+ 往 SQLite 表 执行记录 插一行
// （外部可观测的副作用），并把节点名追加进状态里的 轨迹 —— 于是能**数**出每个节点跑了几次。
//
// 跑法（两趟 qi run，模拟真崩溃 —— 第一趟进程真的以退出码 1 死掉）：
//   DB=/tmp/qi_图崩溃_$RANDOM.db
//   QI_GRAPH_DB=$DB QI_PHASE=1 qi run examples/图_崩溃续跑.qi   # A、B 完成落库，进 C 时崩
//   QI_GRAPH_DB=$DB QI_PHASE=2 qi run examples/图_崩溃续跑.qi   # 同一 run_id 续跑：跳过 A、B，
//                                                              # 补完 C、D，并断言 exactly-once
// 期望：两趟合计 A/B/C/D 各执行 1 次（A、B 不重放）；重复恢复直接返回终态、计数不变。

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.JSON 作为 J;
导入 标准库.数据库;
导入 标准库.操作系统 作为 系统;
导入 Harness.图::{图, 创建图, 添加节点, 添加边, 运行图持久化, 恢复运行,
                是节点已完成, 已完成节点数, 是运行完成, 是完成, 终点};

函数 库路径() : 字符串 {
    变量 路径: 字符串 = 系统.获取环境变量("QI_GRAPH_DB");
    如果 (字符串::字节长度(路径) == 0) { 路径 = "/tmp/qi_图崩溃续跑_默认.db"; }
    返回 路径;
}

// 节点副作用：往 执行记录 表插一行 —— 跨两趟进程都可数的「我执行了」凭证
函数 记执行(名: 字符串) {
    变量 库: 整数 = 数据库.连接(库路径());
    数据库.执行(库, "CREATE TABLE IF NOT EXISTS 执行记录 (节点 TEXT NOT NULL)");
    数据库.执行(库, "INSERT INTO 执行记录 (节点) VALUES ('" + 名 + "')");
    数据库.关闭(库);
}

// 查某节点两趟合计被执行了几次
函数 执行次数(库: 整数, 名: 字符串) : 整数 {
    变量 行JSON: 字符串 = 数据库.查询(库,
        "SELECT COUNT(*) AS 数量 FROM 执行记录 WHERE 节点 = '" + 名 + "'");
    变量 数组值: 整数 = J.解码(行JSON);
    如果 (数组值 <= 0) { 返回 -1; }
    如果 (J.数组长度(数组值) == 0) { 返回 -1; }
    返回 J.获取整数(J.数组获取对象(数组值, 0), "数量");
}

函数 节点体(状态: 字符串, 名: 字符串) : 字符串 {
    IO.打印行("执行节点" + 名);
    记执行(名);
    变量 对象: 整数 = J.解码(状态);
    如果 (对象 <= 0) { 对象 = J.创建对象(); }
    变量 轨迹: 字符串 = J.获取字符串(对象, "轨迹");
    J.设置字符串(对象, "轨迹", 轨迹 + 名);
    返回 J.转字符串(对象);
}

函数 节点A(状态: 字符串) : 字符串 { 返回 节点体(状态, "A"); }
函数 节点B(状态: 字符串) : 字符串 { 返回 节点体(状态, "B"); }

// C：第一趟（QI_PHASE=1）在**完成前**崩掉 —— 副作用还没发生，重跑 C 是正确语义
函数 节点C(状态: 字符串) : 字符串 {
    如果 (字符串::等于(系统.获取环境变量("QI_PHASE"), "1") == 1) {
        IO.打印行("💥 模拟崩溃：进程在节点C 中途退出（码 1）");
        系统.退出程序(1);
    }
    返回 节点体(状态, "C");
}

函数 节点D(状态: 字符串) : 字符串 { 返回 节点体(状态, "D"); }

函数 建图() : 图 {
    变量 g: 图 = 创建图();
    g = 添加节点(g, "A", 节点A);
    g = 添加节点(g, "B", 节点B);
    g = 添加节点(g, "C", 节点C);
    g = 添加节点(g, "D", 节点D);
    g = 添加边(g, "A", "B");
    g = 添加边(g, "B", "C");
    g = 添加边(g, "C", "D");
    g = 添加边(g, "D", 终点());
    返回 g;
}

函数 入口() {
    变量 阶段: 字符串 = 系统.获取环境变量("QI_PHASE");
    变量 库: 整数 = 数据库.连接(库路径());
    变量 g: 图 = 建图();

    如果 (字符串::等于(阶段, "1") == 1) {
        // 第一趟：干净起步，跑到 C 崩（下面这行不会返回）
        数据库.执行(库, "DROP TABLE IF EXISTS 图检查点");
        数据库.执行(库, "DROP TABLE IF EXISTS 图运行");
        数据库.执行(库, "DROP TABLE IF EXISTS 图节点日志");
        数据库.执行(库, "DROP TABLE IF EXISTS 执行记录");
        IO.打印行("== 第一趟：预期 A、B 完成落库，进 C 时进程崩掉 ==");
        运行图持久化(g, 库, "崩溃续跑-001", "A", "{}", 50);
        IO.打印行("❌ 不该走到这里（C 应已把进程杀掉）");
        返回;
    }
    如果 (字符串::等于(阶段, "2") == 0) {
        IO.打印行("用法：先 QI_PHASE=1 跑一趟（会以退出码 1 崩掉），再 QI_PHASE=2 跑第二趟。");
        IO.打印行("两趟须用同一 QI_GRAPH_DB（建议 /tmp/qi_图崩溃_$RANDOM.db）。");
        数据库.关闭(库);
        返回;
    }

    // ============ 第二趟：同一 run_id 恢复 ============
    IO.打印行("== 第二趟：同一 run_id 恢复，应跳过 A、B，从 C 续跑 ==");
    变量 过: 整数 = 0;

    // 崩溃时刻的持久化状态：A、B 已标记完成，C、D 没有
    如果 (已完成节点数(库, "崩溃续跑-001") == 2) {
        IO.打印行("✅ 崩溃后日志里恰有 2 个已完成节点（A、B）");
        过 = 过 + 1;
    } 否则 {
        IO.打印行("❌ 期望崩溃后已完成节点数=2，实际=" + 整数转字符串(已完成节点数(库, "崩溃续跑-001")));
    }
    如果 (是节点已完成(库, "崩溃续跑-001", "B") == 1) {
        如果 (是节点已完成(库, "崩溃续跑-001", "C") == 0) {
            IO.打印行("✅ B 已标记完成、C 未标记（崩在 C 里）");
            过 = 过 + 1;
        } 否则 { IO.打印行("❌ C 不该被标记完成"); }
    } 否则 { IO.打印行("❌ B 应已标记完成"); }

    // 恢复：运行图持久化 检测到已登记 → 自动走 恢复运行，跳过 A、B
    变量 结果值: 字符串 = 运行图持久化(g, 库, "崩溃续跑-001", "A", "{}", 50);
    如果 (是完成(结果值) == 1) {
        IO.打印行("✅ 恢复后运行完成");
        过 = 过 + 1;
    } 否则 { IO.打印行("❌ 期望恢复后完成"); }

    // exactly-once 核心断言：两趟合计 A/B/C/D 各 1 次
    变量 A次: 整数 = 执行次数(库, "A");
    变量 B次: 整数 = 执行次数(库, "B");
    变量 C次: 整数 = 执行次数(库, "C");
    变量 D次: 整数 = 执行次数(库, "D");
    IO.打印行("两趟合计执行次数：A=" + 整数转字符串(A次) + " B=" + 整数转字符串(B次)
        + " C=" + 整数转字符串(C次) + " D=" + 整数转字符串(D次));
    如果 (A次 == 1) { 如果 (B次 == 1) { 如果 (C次 == 1) { 如果 (D次 == 1) {
        IO.打印行("✅ 崩溃续跑：A/B 未重跑，C/D 续完 —— 节点 exactly-once 成立");
        过 = 过 + 1;
    } } } }

    // 状态连续性：轨迹应为 ABCD（B 的输出状态被接上，而不是从空重来）
    变量 末对象: 整数 = J.解码(结果值);
    变量 轨迹: 字符串 = J.获取字符串(末对象, "轨迹");
    如果 (字符串::等于(轨迹, "ABCD") == 1) {
        IO.打印行("✅ 状态接续正确：轨迹 = ABCD");
        过 = 过 + 1;
    } 否则 { IO.打印行("❌ 期望轨迹 ABCD，实际 " + 轨迹); }

    // 幂等：完成后再恢复 → 直接回终态，任何节点都不再执行
    变量 再来: 字符串 = 运行图持久化(g, 库, "崩溃续跑-001", "A", "{}", 50);
    变量 再来对象: 整数 = J.解码(再来);
    如果 (是完成(再来) == 1) {
        如果 (执行次数(库, "A") == 1) {
            如果 (字符串::等于(J.获取字符串(再来对象, "轨迹"), "ABCD") == 1) {
                IO.打印行("✅ 幂等：重复恢复直接返回同一终态，计数不变");
                过 = 过 + 1;
            } 否则 { IO.打印行("❌ 重复恢复终态不一致"); }
        } 否则 { IO.打印行("❌ 重复恢复重跑了节点"); }
    } 否则 { IO.打印行("❌ 重复恢复应返回完成态"); }
    如果 (是运行完成(库, "崩溃续跑-001") == 1) { 过 = 过 + 1; }

    IO.打印行("");
    如果 (过 == 7) {
        IO.打印行("✅ 全部 7 项通过：崩溃 → 已完成节点持久化 → 续跑跳过 → exactly-once → 幂等");
    } 否则 {
        IO.打印行("❌ 通过 " + 整数转字符串(过) + "/7");
    }

    数据库.关闭(库);
    IO.删除文件(库路径());   // 清理临时库
}
