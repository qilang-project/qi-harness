// qi-harness DeepSeek + tool calling 实测
// 跑：QI_LLM_KEY=sk-... qi run deepseek工具.qi

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.操作系统 作为 系统;
导入 Harness::{
    模型配置, 大模型, 配置系统提示, 开启会话,
    创建代理, 添加工具, 运行, 关闭代理,
    工具
};

函数 当前时间(参数JSON: 字符串) : 字符串 {
    返回 "{\"time\":\"2026-05-16 14:30:00 +08:00\"}";
}

函数 天气查询(参数JSON: 字符串) : 字符串 {
    如果 (字符串::包含(字符串::转小写(参数JSON), "tokyo") == 1) {
        返回 "{\"city\":\"Tokyo\",\"temp\":18,\"condition\":\"晴\"}";
    }
    如果 (字符串::包含(字符串::转小写(参数JSON), "beijing") == 1) {
        返回 "{\"city\":\"Beijing\",\"temp\":24,\"condition\":\"多云\"}";
    }
    返回 "{\"error\":\"city not found\"}";
}

函数 入口() {
    变量 密钥: 字符串 = 系统.获取环境变量("QI_LLM_KEY");
    如果 (字符串::字节长度(密钥) == 0) {
        IO.打印行("未设 QI_LLM_KEY");
        返回;
    }

    // 一行配置 — DeepSeek (OpenAI 兼容)
    变量 配置: 模型配置 = 大模型("https://api.deepseek.com", 密钥, "deepseek-chat");
    配置 = 配置系统提示(配置, "你是助手，能用工具查询时间和天气。直接调用工具，不要解释。");

    变量 会话: 整数 = 开启会话(配置);
    如果 (会话 <= 0) {
        IO.打印行("会话开启失败");
        返回;
    }

    变量 代理值: 代理 = 创建代理("天气时间助手", 会话);

    变量 时间工具: 工具 = (工具 {
        名字: "当前时间",
        描述: "查询当前时间。",
        参数schema: "{\"type\":\"object\",\"properties\":{}}",
        处理: 当前时间,
    });
    代理值 = 添加工具(代理值, 时间工具);

    变量 天气工具: 工具 = (工具 {
        名字: "天气查询",
        描述: "查询指定城市的天气。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"city\":{\"type\":\"string\"}},\"required\":[\"city\"]}",
        处理: 天气查询,
    });
    代理值 = 添加工具(代理值, 天气工具);

    变量 回复: 字符串 = 运行(代理值, "Tokyo 现在几点？顺便告诉我那里天气怎样？");
    IO.打印行("");
    IO.打印行("=== Final ===");
    IO.打印行(回复);

    关闭代理(代理值);
}
