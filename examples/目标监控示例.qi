// qi-harness · 目标监控（Goal Setting & Monitoring）演示 —— 无需 LLM
//
// 建目标 + 3 个里程碑，完成 2 个 → 进度≈0.67、未达成；再完成最后一个 → 达成。
// 全程确定性纯计算，无网络、无 API key。
//
// 跑：qi run examples/目标监控示例.qi

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 Harness.目标监控::{
    目标, 创建目标, 添加里程碑, 标记完成, 进度, 是否达成, 里程碑数, 已完成数, 目标报告
};
导入 Harness.追踪::{启用};

函数 入口() {
    启用();

    变量 目标值: 目标 = 创建目标("上线奇语 Qi 官网", "首页可访问且通过移动端适配");
    目标值 = 添加里程碑(目标值, "写首页文案");
    目标值 = 添加里程碑(目标值, "实现响应式布局");
    目标值 = 添加里程碑(目标值, "部署到生产");

    IO.打印行("=== 初始 ===");
    IO.打印行(目标报告(目标值));

    // 完成前两个里程碑
    目标值 = 标记完成(目标值, 0);
    目标值 = 标记完成(目标值, 1);

    IO.打印行("=== 完成 2/3 后 ===");
    IO.打印行(目标报告(目标值));

    IO.打印行("=== 断言 ===");
    如果 (里程碑数(目标值) == 3 && 已完成数(目标值) == 2) {
        IO.打印行("PASS：里程碑数=3、已完成=2");
    } 否则 {
        IO.打印行("FAIL：里程碑计数异常");
    }
    如果 (进度(目标值) > 0.66 && 进度(目标值) < 0.67) {
        IO.打印行("PASS：进度≈0.67");
    } 否则 {
        IO.打印行("FAIL：进度应≈0.67");
    }
    如果 (是否达成(目标值) == 0) {
        IO.打印行("PASS：尚未达成");
    } 否则 {
        IO.打印行("FAIL：不应已达成");
    }

    // 完成最后一个里程碑
    目标值 = 标记完成(目标值, 2);
    IO.打印行("=== 完成 3/3 后 ===");
    IO.打印行(目标报告(目标值));
    如果 (是否达成(目标值) == 1 && 进度(目标值) > 0.99) {
        IO.打印行("PASS：全部完成，目标达成");
    } 否则 {
        IO.打印行("FAIL：应已达成");
    }
}
