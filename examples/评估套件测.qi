// eval 数据集 + 基线门禁 —— 配合 LLM 磁带即可 CI 化（确定性、离线、免费）。
//
// 录制（真调 API + 建基线）：
//   QI_LLM_RECORD=1 QI_LLM_TAPE=/tmp/eval_tape.json \
//   EVAL_BASELINE=/tmp/eval_baseline.json \
//   QI_CHAT_URL=.. QI_CHAT_KEY=.. QI_CHAT_MODEL=.. qi run examples/评估套件测.qi
// 回放（CI 里跑，两次分数完全一致）：
//   QI_LLM_REPLAY=1 QI_LLM_TAPE=/tmp/eval_tape.json \
//   EVAL_BASELINE=/tmp/eval_baseline.json ... qi run examples/评估套件测.qi
//
// 门禁返回 1（回归）时 CI 应 exit 非 0（可用 标准库.进程 的 退出）。

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 标准库.字符串;
导入 标准库.大模型 作为 底层模型;
导入 Harness.评估::{评估套件, 创建套件, 添加测例, 记录结果, 运行评估集,
                    平均分百分, 保存基线JSON, 基线门禁};

函数 入口() {
    变量 端点: 字符串 = 系统.获取环境变量("QI_CHAT_URL");
    变量 密钥: 字符串 = 系统.获取环境变量("QI_CHAT_KEY");
    变量 模型: 字符串 = 系统.获取环境变量("QI_CHAT_MODEL");
    如果 (字符串::字节长度(端点) == 0) {
        IO.打印行("需要 QI_CHAT_URL / QI_CHAT_KEY / QI_CHAT_MODEL");
        返回;
    }
    变量 基线路径: 字符串 = 系统.获取环境变量("EVAL_BASELINE");
    如果 (字符串::字节长度(基线路径) == 0) {
        基线路径 = "/tmp/qi_eval_baseline.json";
    }

    变量 会话: 整数 = 底层模型.创建会话(端点, 模型, 密钥);

    // —— 数据集：3 个好判定的用例（默认打分方式 0 = 包含）——
    变量 套件: 评估套件 = 创建套件();
    套件 = 添加测例(套件, "首都判定", "中国的首都是哪个城市？只回答城市名。", "北京");
    套件 = 添加测例(套件, "简单算术", "1+1等于几？只回答一个数字。", "2");
    套件 = 添加测例(套件, "反义词", "汉字「黑」的反义词是哪个字？只回答一个汉字。", "白");

    // —— 跑评估集（磁带回放下完全确定）——
    套件 = 运行评估集(套件, 会话);
    变量 本次分: 整数 = 平均分百分(套件);
    IO.打印行("本次平均分 = " + 整数转字符串(本次分));

    // —— 基线门禁：首跑建基线；再跑（含回放）与基线比，容差 5 分 ——
    变量 门禁码: 整数 = 基线门禁(套件, 基线路径, 5);
    IO.打印行("门禁返回码 = " + 整数转字符串(门禁码) + "（0=通过 1=回归，CI 据此 exit）");

    // —— 确定性演示（不走 LLM）：伪造 100 分基线 + 50 分套件 → 必须报回归 ——
    变量 假基线: 字符串 = "/tmp/qi_eval_fake_baseline.json";
    变量 高分套件: 评估套件 = 创建套件();
    高分套件 = 记录结果(高分套件, "甲", 1);
    高分套件 = 记录结果(高分套件, "乙", 1);
    保存基线JSON(高分套件, 假基线);
    变量 低分套件: 评估套件 = 创建套件();
    低分套件 = 记录结果(低分套件, "甲", 1);
    低分套件 = 记录结果(低分套件, "乙", 0);
    变量 回归码: 整数 = 基线门禁(低分套件, 假基线, 5);
    如果 (回归码 == 1) {
        IO.打印行("✅ 回归门禁生效（100 分基线 vs 50 分本次 → 判回归）");
    } 否则 {
        IO.打印行("❌ 回归门禁失效（应返回 1，得 " + 整数转字符串(回归码) + "）");
    }
    IO.删除文件(假基线);

    底层模型.关闭会话(会话);
}
