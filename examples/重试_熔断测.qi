// 可重试 确定性自测（无需 LLM）：错误分类 + 智能重试 + 熔断器状态机。
// 跑：qi run examples/重试_熔断测.qi

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 Harness::{代理, 创建代理, 共享重试资源};
导入 Harness.重试::{重试策略, 错误类别, 智能重试调用, 创建重试资源,
    配置资源熔断, 资源熔断允许, 资源熔断记成功, 资源熔断记失败,
    配置资源限流, 资源限流获取, 资源限流尝试获取,
    配置熔断, 熔断允许, 熔断记成功, 熔断记失败, 熔断状态};

变量 调用次数: 整数 = 0;

函数 两败一成() : 字符串 {
    调用次数 = 调用次数 + 1;
    如果 (调用次数 < 3) {
        返回 "LLM调用失败: API返回错误 503 Service Unavailable";
    }
    返回 "成功";
}

函数 致命失败() : 字符串 {
    调用次数 = 调用次数 + 1;
    返回 "LLM调用失败: API返回错误 401 Unauthorized";
}

函数 断言(名: 字符串, 实际: 整数, 期望: 整数, 过: 整数) : 整数 {
    如果 (实际 == 期望) {
        IO.打印行("✅ " + 名 + " = " + 整数转字符串(实际));
        返回 过 + 1;
    }
    IO.打印行("❌ " + 名 + " = " + 整数转字符串(实际) + "（期望 " + 整数转字符串(期望) + "）");
    返回 过;
}

函数 入口() {
    变量 过: 整数 = 0;

    // 错误分类：0 成功 / 1 可重试 / 2 致命
    过 = 断言("正常响应→0", 错误类别("北京今天晴，25 度"), 0, 过);
    过 = 断言("空响应→1", 错误类别(""), 1, 过);
    过 = 断言("429→1", 错误类别("HTTP错误: 429 Too Many Requests"), 1, 过);
    过 = 断言("503→1", 错误类别("HTTP错误: 503 Service Unavailable"), 1, 过);
    过 = 断言("超时→1", 错误类别("LLM调用失败: request timeout"), 1, 过);
    过 = 断言("401→2", 错误类别("LLM调用失败: 401 Unauthorized"), 2, 过);
    过 = 断言("403→2", 错误类别("HTTP错误: 403 Forbidden"), 2, 过);
    过 = 断言("422→2", 错误类别("继续工具对话失败: API返回错误 422"), 2, 过);
    过 = 断言("工具网络失败→1", 错误类别("工具对话失败: HTTP请求失败"), 1, 过);
    过 = 断言("JSON数组→0", 错误类别("[1,2,3]"), 0, 过);
    过 = 断言("正常文本含503→0", 错误类别("共有 503 条记录"), 0, 过);

    IO.打印行("");
    变量 快策略: 重试策略 = 新建 重试策略 {
        最大次数: 3,
        起始延迟毫秒: 0,
        最大延迟毫秒: 0,
        倍数: 2,
    };
    调用次数 = 0;
    变量 重试结果: 字符串 = 智能重试调用(快策略, "自测", 两败一成);
    过 = 断言("两败一成调用3次", 调用次数, 3, 过);
    如果 (重试结果 == "成功") { 过 = 过 + 1; IO.打印行("✅ 两败一成返回成功"); }
    否则 { IO.打印行("❌ 两败一成返回: " + 重试结果); }

    调用次数 = 0;
    智能重试调用(快策略, "自测", 致命失败);
    过 = 断言("致命错误只调用1次", 调用次数, 1, 过);

    IO.打印行("");
    // 熔断器：阈值 2 → 两次失败后打开，冷却期内快失败
    // 前面的致命重试用例会给进程级熔断器记一次失败，先重置保证本段独立。
    熔断记成功();
    配置熔断(2, 60000);
    过 = 断言("初始允许", 熔断允许(), 1, 过);
    熔断记失败();
    过 = 断言("失败1后仍允许", 熔断允许(), 1, 过);
    熔断记失败();
    过 = 断言("失败2后打开→拒绝", 熔断允许(), 0, 过);
    IO.打印行("熔断状态: " + 熔断状态());

    // 记成功应重置（先假设未过冷却，手动记成功恢复）
    熔断记成功();
    过 = 断言("记成功后恢复允许", 熔断允许(), 1, 过);

    IO.打印行("");
    // 每个新代理有独立资源：甲熔断不影响乙，两个令牌桶也各有自己的突发令牌。
    变量 甲资源: 整数 = 创建重试资源();
    变量 乙资源: 整数 = 创建重试资源();
    变量 甲: 代理 = 共享重试资源(创建代理("甲", 0), 甲资源);
    变量 乙: 代理 = 共享重试资源(创建代理("乙", 0), 乙资源);
    如果 (甲资源 != 乙资源) { 过 = 过 + 1; IO.打印行("✅ 新代理资源句柄独立"); }
    否则 { IO.打印行("❌ 新代理意外共享资源句柄"); }
    配置资源熔断(甲资源, 1, 60000);
    配置资源熔断(乙资源, 1, 60000);
    资源熔断记失败(甲资源);
    过 = 断言("甲失败后甲熔断", 资源熔断允许(甲资源), 0, 过);
    过 = 断言("甲失败不影响乙", 资源熔断允许(乙资源), 1, 过);
    配置资源限流(甲资源, 1, 1);
    配置资源限流(乙资源, 1, 1);
    过 = 断言("甲取得自己的令牌", 资源限流尝试获取(甲资源), 1, 过);
    过 = 断言("乙仍有独立令牌", 资源限流尝试获取(乙资源), 1, 过);
    过 = 断言("甲第二次无令牌且不等待", 资源限流尝试获取(甲资源), 0, 过);

    // 显式 builder 让两个代理共享同一资源：一方失败/取令牌，另一方立即看到。
    变量 共享资源: 整数 = 创建重试资源();
    变量 丙: 代理 = 共享重试资源(创建代理("丙", 0), 共享资源);
    变量 丁: 代理 = 共享重试资源(创建代理("丁", 0), 共享资源);
    如果 (共享资源 > 0) { 过 = 过 + 1; IO.打印行("✅ builder 显式共享资源"); }
    否则 { IO.打印行("❌ builder 未共享资源"); }
    配置资源熔断(共享资源, 1, 60000);
    资源熔断记失败(共享资源);
    过 = 断言("丙失败使丁看到熔断", 资源熔断允许(共享资源), 0, 过);
    配置资源限流(共享资源, 1, 1);
    过 = 断言("丙取得共享令牌", 资源限流尝试获取(共享资源), 1, 过);
    过 = 断言("丁看到共享桶已空", 资源限流尝试获取(共享资源), 0, 过);

    IO.打印行("");
    如果 (过 == 28) {
        IO.打印行("✅ 全部 28 项通过：兼容 API + 重试资源隔离和显式共享正确");
        系统.退出程序(0);
    } 否则 {
        IO.打印行("❌ 通过 " + 整数转字符串(过) + "/28");
        系统.退出程序(1);
    }
}
