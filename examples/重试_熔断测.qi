// 可重试 确定性自测（无需 LLM）：错误分类 + 熔断器状态机。
// 跑：qi run examples/重试_熔断测.qi

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 Harness.重试::{错误类别, 配置熔断, 熔断允许, 熔断记成功, 熔断记失败, 熔断状态};

函数 断言(名: 字符串, 实际: 整数, 期望: 整数, 过: 整数) : 整数 {
    如果 (实际 == 期望) {
        IO.打印行("✅ " + 名 + " = " + 整数转字符串(实际));
        返回 过 + 1;
    }
    IO.打印行("❌ " + 名 + " = " + 整数转字符串(实际) + "（期望 " + 整数转字符串(期望) + "）");
    返回 过;
}

函数 入口() {
    变量 过: 整数 = 0;

    // 错误分类：0 成功 / 1 可重试 / 2 致命
    过 = 断言("正常响应→0", 错误类别("北京今天晴，25 度"), 0, 过);
    过 = 断言("空响应→1", 错误类别(""), 1, 过);
    过 = 断言("429→1", 错误类别("HTTP错误: 429 Too Many Requests"), 1, 过);
    过 = 断言("503→1", 错误类别("HTTP错误: 503 Service Unavailable"), 1, 过);
    过 = 断言("超时→1", 错误类别("request timeout"), 1, 过);
    过 = 断言("401→2", 错误类别("401 Unauthorized"), 2, 过);
    过 = 断言("403→2", 错误类别("HTTP错误: 403 Forbidden"), 2, 过);

    IO.打印行("");
    // 熔断器：阈值 2 → 两次失败后打开，冷却期内快失败
    配置熔断(2, 60000);
    过 = 断言("初始允许", 熔断允许(), 1, 过);
    熔断记失败();
    过 = 断言("失败1后仍允许", 熔断允许(), 1, 过);
    熔断记失败();
    过 = 断言("失败2后打开→拒绝", 熔断允许(), 0, 过);
    IO.打印行("熔断状态: " + 熔断状态());

    // 记成功应重置（先假设未过冷却，手动记成功恢复）
    熔断记成功();
    过 = 断言("记成功后恢复允许", 熔断允许(), 1, 过);

    IO.打印行("");
    如果 (过 == 11) {
        IO.打印行("✅ 全部 11 项通过：错误分类 + 熔断状态机正确");
    } 否则 {
        IO.打印行("❌ 通过 " + 整数转字符串(过) + "/11");
    }
}
