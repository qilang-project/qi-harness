// 上下文 摘要压缩 —— 需 LLM。把早段对话摘要成一条 system，再接最近 N 条。
//
// 跑：
//   QI_CHAT_URL="https://<...>/compatible-mode/v1" \
//   QI_CHAT_KEY="sk-..." QI_CHAT_MODEL="qwen-plus" \
//   qi run examples/上下文_摘要压缩.qi

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 标准库.字符串;
导入 标准库.大模型 作为 底层模型;
导入 Harness.上下文::{历史令牌估算, 摘要压缩};

函数 入口() {
    变量 端点: 字符串 = 系统.获取环境变量("QI_CHAT_URL");
    变量 密钥: 字符串 = 系统.获取环境变量("QI_CHAT_KEY");
    变量 模型: 字符串 = 系统.获取环境变量("QI_CHAT_MODEL");
    如果 (字符串::字节长度(端点) == 0) {
        IO.打印行("需要 QI_CHAT_URL / QI_CHAT_KEY / QI_CHAT_MODEL");
        返回;
    }

    变量 主会话: 整数 = 底层模型.创建会话(端点, 模型, 密钥);
    变量 摘要会话: 整数 = 底层模型.创建会话(端点, 模型, 密钥);

    // 种入一段较长历史：规划北京三日游（1 system + 8 条对话）
    变量 历史: 字符串 = "["
        + "{\"role\":\"system\",\"content\":\"你是旅行助手\"},"
        + "{\"role\":\"user\",\"content\":\"帮我规划北京三日游\"},"
        + "{\"role\":\"assistant\",\"content\":\"第一天故宫天安门，第二天长城，第三天颐和园\"},"
        + "{\"role\":\"user\",\"content\":\"我预算五千元，喜欢历史文化\"},"
        + "{\"role\":\"assistant\",\"content\":\"预算充足，建议住前门附近，方便逛胡同\"},"
        + "{\"role\":\"user\",\"content\":\"我对辣的食物过敏\"},"
        + "{\"role\":\"assistant\",\"content\":\"好的，避开川菜，推荐京味炸酱面和烤鸭\"},"
        + "{\"role\":\"user\",\"content\":\"第三天想加个环球影城\"},"
        + "{\"role\":\"assistant\",\"content\":\"可以，环球影城建议预留一整天，颐和园挪到第二天下午\"}"
        + "]";
    底层模型.设置历史JSON(主会话, 历史);
    IO.打印行("压缩前历史条数: " + 整数转字符串(底层模型.历史数量(主会话)));
    IO.打印行("压缩前 token 估算: " + 整数转字符串(历史令牌估算(主会话)));
    IO.打印行("");

    // 摘要压缩：保留最近 4 条，早段摘要成 1 条 system
    变量 压缩后: 整数 = 摘要压缩(主会话, 摘要会话, 4);
    IO.打印行("");
    IO.打印行("压缩后历史条数: " + 整数转字符串(压缩后));
    IO.打印行("压缩后 token 估算: " + 整数转字符串(历史令牌估算(主会话)));
    IO.打印行("");
    IO.打印行("压缩后历史:");
    IO.打印行(底层模型.历史JSON(主会话));

    底层模型.关闭会话(主会话);
    底层模型.关闭会话(摘要会话);
}
