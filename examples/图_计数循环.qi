// 图式控制流演示 —— 无需 LLM，纯确定性，验证 分支 + 回环。
//
// 图：  递增 ──→ 判断 ──(计数<3)──→ 递增   (回环)
//                   └──(否则)────→ 终点
//
// 跑：qi run examples/图_计数循环.qi
// 期望：计数 0→1→2→3，走三次递增后从判断出到终点，末态 {"计数":3}

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.JSON 作为 J;
导入 Harness.图::{图, 创建图, 添加节点, 添加边, 添加条件边, 运行图, 终点};

// 节点：把 计数 +1，返回新状态 JSON
函数 递增(状态: 字符串) : 字符串 {
    变量 对象: 整数 = J.解码(状态);
    变量 计数: 整数 = J.获取整数(对象, "计数");
    变量 新对象: 整数 = J.创建对象();
    J.设置整数(新对象, "计数", 计数 + 1);
    返回 J.转字符串(新对象);
}

// 判断节点：本身不改状态，只作为分支点（真正的分支逻辑在条件边上）
函数 判断(状态: 字符串) : 字符串 {
    返回 状态;
}

// 条件：计数 < 3 时命中（→ 回环继续递增）
函数 还要继续(状态: 字符串) : 整数 {
    变量 对象: 整数 = J.解码(状态);
    如果 (J.获取整数(对象, "计数") < 3) {
        返回 1;
    }
    返回 0;
}

函数 入口() {
    变量 g: 图 = 创建图();
    g = 添加节点(g, "递增", 递增);
    g = 添加节点(g, "判断", 判断);

    g = 添加边(g, "递增", "判断");              // 递增后总是去判断
    g = 添加条件边(g, "判断", 还要继续, "递增"); // 计数<3 → 回环
    g = 添加边(g, "判断", 终点());              // 否则 → 结束（兜底无条件边放最后）

    变量 末态: 字符串 = 运行图(g, "递增", "{\"计数\":0}", 20);
    IO.打印行("最终状态: " + 末态);

    变量 对象: 整数 = J.解码(末态);
    如果 (J.获取整数(对象, "计数") == 3) {
        IO.打印行("✅ 图执行正确：分支 + 回环各就位");
    } 否则 {
        IO.打印行("❌ 期望计数=3");
    }
}
