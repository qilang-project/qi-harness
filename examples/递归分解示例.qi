// qi-harness · 递归分解（Hierarchical）演示 —— 分解 → 委派 → 汇总
//
// 一个「规划代理」把大任务拆成子任务，「工人代理」逐个完成，规划代理再汇总成最终答案。
// 带最大深度护栏，防止无限递归 / 成本失控。需 LLM。
//
// 跑：QI_LLM_KEY=sk-... qi run examples/递归分解示例.qi
//   换 provider：QI_LLM_BASE=http://127.0.0.1:11434/v1 QI_LLM_MODEL=qwen2.5 QI_LLM_KEY=ollama qi run ...

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.操作系统 作为 系统;
导入 Harness::{
    模型配置, 大模型, 配置系统提示, 开启会话,
    创建代理, 关闭代理
};
导入 Harness.递归分解::{递归求解};
导入 Harness.追踪 作为 追踪;

函数 建代理(基址: 字符串, 密钥: 字符串, 模型名: 字符串, 名字: 字符串, 系统提示文本: 字符串) : 代理 {
    变量 配置: 模型配置 = 大模型(基址, 密钥, 模型名);
    配置 = 配置系统提示(配置, 系统提示文本);
    变量 会话: 整数 = 开启会话(配置);
    返回 创建代理(名字, 会话);
}

函数 入口() {
    变量 密钥: 字符串 = 系统.获取环境变量("QI_LLM_KEY");
    如果 (字符串::字节长度(密钥) == 0) {
        IO.打印行("未设 QI_LLM_KEY — dry run（编译通过即胜利）");
        返回;
    }
    变量 基址: 字符串 = 系统.获取环境变量("QI_LLM_BASE");
    如果 (字符串::字节长度(基址) == 0) { 基址 = "https://api.deepseek.com"; }
    变量 模型名: 字符串 = 系统.获取环境变量("QI_LLM_MODEL");
    如果 (字符串::字节长度(模型名) == 0) { 模型名 = "deepseek-chat"; }

    // 规划代理：只做拆解与汇总，不需要工具
    变量 规划代理: 代理 = 建代理(基址, 密钥, 模型名, "规划",
        "你是任务规划师，善于把复杂任务拆成有序的小步骤，并在最后把子结果综合成完整答案。");
    // 工人代理：负责把叶子子任务做出来（本例纯写作，无外部工具）
    变量 工人代理: 代理 = 建代理(基址, 密钥, 模型名, "工人",
        "你是执行者，认真、简洁地完成交给你的单个子任务。");

    追踪.启用即时打印();   // decompose_enter / split / leaf / synth 打 JSON trace

    变量 任务文本: 字符串 = "为『奇语 Qi』编程语言写一段 150 字左右的产品简介，"
        + "涵盖：语言定位、核心特色（100% 中文关键字）、适用人群。";

    变量 答案: 字符串 = 递归求解(规划代理, 工人代理, 任务文本, 3);   // 最大深度 3

    IO.打印行("");
    IO.打印行("===== 最终答案 =====");
    IO.打印行(答案);

    关闭代理(规划代理);
    关闭代理(工人代理);
}
