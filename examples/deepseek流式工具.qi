// qi-harness · 流式 + 工具调用 实测
//
// 一次跑通：模型边「流式」吐字、边「自动调工具」。
//   - 文本片段实时 打印片段 流出（打字机效果）
//   - 模型决定调工具时，流式运行 自动派发本地工具 + 回写结果 + 流式续传
//   - 工具调用阶段会注入 `[调用工具 …]` 提示行，让你看到它在用工具
//
// 跑：QI_LLM_KEY=sk-... qi run examples/deepseek流式工具.qi
//   换 provider：QI_LLM_BASE=http://127.0.0.1:11434/v1 QI_LLM_MODEL=qwen2.5 QI_LLM_KEY=ollama qi run ...

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.操作系统 作为 系统;
导入 Harness::{
    模型配置, 大模型, 配置系统提示, 开启会话,
    创建代理, 添加工具, 流式运行, 关闭代理,
    工具
};
导入 Harness.追踪 作为 追踪;

// 流块回调 —— 文本片段 / 工具提示行实时打到 stdout
函数 打印片段(片段: 字符串) : 整数 {
    IO.打印(片段);
    返回 1;
}

函数 当前时间(参数JSON: 字符串) : 字符串 {
    返回 "{\"time\":\"2026-06-27 14:30:00 +08:00\"}";
}

函数 天气查询(参数JSON: 字符串) : 字符串 {
    如果 (字符串::包含(字符串::转小写(参数JSON), "tokyo") == 1) {
        返回 "{\"city\":\"Tokyo\",\"temp\":18,\"condition\":\"晴\"}";
    }
    如果 (字符串::包含(字符串::转小写(参数JSON), "beijing") == 1) {
        返回 "{\"city\":\"Beijing\",\"temp\":24,\"condition\":\"多云\"}";
    }
    返回 "{\"error\":\"city not found\"}";
}

函数 入口() {
    变量 密钥: 字符串 = 系统.获取环境变量("QI_LLM_KEY");
    如果 (字符串::字节长度(密钥) == 0) {
        IO.打印行("未设 QI_LLM_KEY");
        返回;
    }
    变量 基址: 字符串 = 系统.获取环境变量("QI_LLM_BASE");
    如果 (字符串::字节长度(基址) == 0) { 基址 = "https://api.deepseek.com"; }
    变量 模型名: 字符串 = 系统.获取环境变量("QI_LLM_MODEL");
    如果 (字符串::字节长度(模型名) == 0) { 模型名 = "deepseek-chat"; }

    // 关掉 trace 即时打印，避免和流式输出混在一起
    追踪.禁用即时打印();

    变量 配置: 模型配置 = 大模型(基址, 密钥, 模型名);
    配置 = 配置系统提示(配置,
        "你是助手，能用工具查询时间和天气。需要时直接调用工具，拿到结果后用中文简短作答。");

    变量 会话: 整数 = 开启会话(配置);
    如果 (会话 <= 0) {
        IO.打印行("会话开启失败");
        返回;
    }

    变量 代理值: 代理 = 创建代理("流式工具助手", 会话);

    代理值 = 添加工具(代理值, (工具 {
        名字: "当前时间",
        描述: "查询当前时间。",
        参数schema: "{\"type\":\"object\",\"properties\":{}}",
        处理: 当前时间,
    }));

    代理值 = 添加工具(代理值, (工具 {
        名字: "天气查询",
        描述: "查询指定城市的天气。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"city\":{\"type\":\"string\"}},\"required\":[\"city\"]}",
        处理: 天气查询,
    }));

    IO.打印行("=== 流式 + 工具 ===");
    变量 完整: 字符串 = 流式运行(代理值, "Tokyo 现在几点？顺便告诉我那里天气怎样？", 打印片段);
    IO.打印行("");
    IO.打印行("=== 完整回复 ===");
    IO.打印行(完整);

    关闭代理(代理值);
}
