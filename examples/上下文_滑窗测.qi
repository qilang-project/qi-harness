// 上下文窗口管理 确定性自测（无需 LLM）—— 用 设置历史JSON 种入历史，
// 验证 历史令牌估算 / 滑窗裁剪（保留 system + 最近 N）。
//
// 跑：qi run examples/上下文_滑窗测.qi

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.大模型 作为 底层模型;
导入 标准库.字符串;
导入 标准库.操作系统 作为 系统;
导入 Harness.上下文::{估算令牌, 历史令牌估算, 滑窗裁剪, 需要压缩};

函数 断言(名: 字符串, 实际: 整数, 期望: 整数, 过: 整数) : 整数 {
    如果 (实际 == 期望) {
        IO.打印行("✅ " + 名);
        返回 过 + 1;
    }
    IO.打印行("❌ " + 名 + "（得 " + 整数转字符串(实际) + " 期望 " + 整数转字符串(期望) + "）");
    返回 过;
}

函数 入口() {
    变量 过: 整数 = 0;

    // 开个会话（仅存配置，不联网）
    变量 会话: 整数 = 底层模型.创建会话("http://localhost:1/v1", "dummy", "k");
    如果 (会话 <= 0) {
        IO.打印行("创建会话失败");
        系统.退出程序(1);
    }

    // 种入历史：1 条 system + 6 条对话（user/assistant 各 3）
    变量 历史: 字符串 = "["
        + "{\"role\":\"system\",\"content\":\"你是助手\"},"
        + "{\"role\":\"user\",\"content\":\"第一个问题\"},"
        + "{\"role\":\"assistant\",\"content\":\"第一个回答\"},"
        + "{\"role\":\"user\",\"content\":\"第二个问题\"},"
        + "{\"role\":\"assistant\",\"content\":\"第二个回答\"},"
        + "{\"role\":\"user\",\"content\":\"第三个问题\"},"
        + "{\"role\":\"assistant\",\"content\":\"第三个回答\"}"
        + "]";
    变量 条数: 整数 = 底层模型.设置历史JSON(会话, 历史);
    过 = 断言("种入历史7条", 条数, 7, 过);

    IO.打印行("估算令牌('第一个问题') = " + 整数转字符串(估算令牌("第一个问题")));
    IO.打印行("历史令牌估算 = " + 整数转字符串(历史令牌估算(会话)));
    过 = 断言("低阈值需要压缩", 需要压缩(会话, 5), 1, 过);

    // 滑窗裁剪：保留 system + 最近 2 条非 system → 共 3 条
    变量 裁后: 整数 = 滑窗裁剪(会话, 2);
    IO.打印行("");
    过 = 断言("滑窗保留system和最近2条", 裁后, 3, 过);

    // 校验裁剪后内容：应是 [system, 第三个问题, 第三个回答]
    变量 裁后历史: 字符串 = 底层模型.历史JSON(会话);
    IO.打印行("裁剪后历史: " + 裁后历史);
    过 = 断言("保留system", 字符串::包含(裁后历史, "你是助手"), 1, 过);
    过 = 断言("移除较早消息", 字符串::包含(裁后历史, "第二个回答"), 0, 过);
    过 = 断言("保留最近问题", 字符串::包含(裁后历史, "第三个问题"), 1, 过);
    过 = 断言("保留最近回答", 字符串::包含(裁后历史, "第三个回答"), 1, 过);

    底层模型.关闭会话(会话);

    IO.打印行("");
    如果 (过 == 7) {
        IO.打印行("✅ 全部 7 项通过：上下文滑窗裁剪正确");
        系统.退出程序(0);
    } 否则 {
        IO.打印行("❌ 通过 " + 整数转字符串(过) + "/7");
        系统.退出程序(1);
    }
}
