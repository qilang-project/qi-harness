// _并发派发自测.qi — Part A 工具并发派发 自测（不依赖 LLM，纯本地）
//
// 验证 工具::并发派发：
//   ① 3 个本地工具的结果都正确、且下标与输入对齐
//   ② 每个工具内 睡眠300ms；并发总耗时应 ≈ 单个(≈300ms) 而非 3×300=900ms
//
// 注：注册时传 会话句柄=0（无 LLM 会话）。底层 注册工具 对无效会话是 no-op
// （返回 -1，不崩溃），本地 dispatch 表照常填充，所以纯本地派发可独立验证。
//
// 运行：cd qi-harness && ../target/debug/qi run examples/_并发派发自测.qi

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 标准库.时间;
导入 Harness::{ 工具, 创建注册表, 注册, 并发派发 };
导入 Harness.追踪 作为 追踪;

// ── 三个本地工具：各睡 300ms，回不同结果 ──
函数 慢工具甲(参数JSON: 字符串) : 字符串 {
    时间.睡眠毫秒(300);
    返回 "{\"tool\":\"甲\",\"value\":111}";
}
函数 慢工具乙(参数JSON: 字符串) : 字符串 {
    时间.睡眠毫秒(300);
    返回 "{\"tool\":\"乙\",\"value\":222}";
}
函数 慢工具丙(参数JSON: 字符串) : 字符串 {
    时间.睡眠毫秒(300);
    返回 "{\"tool\":\"丙\",\"value\":333}";
}

函数 入口() {
    追踪.禁用();  // 自测里关掉事件噪音

    IO.打印行("=== Part A 并发派发自测 ===");

    // 构建注册表（会话句柄 0 = 无 LLM，注册工具 为 no-op，本地表照填）
    变量 表 = 创建注册表();
    表 = 注册(表, 0, (工具 { 名字: "慢工具甲", 描述: "甲", 参数schema: "{}", 处理: 慢工具甲 }));
    表 = 注册(表, 0, (工具 { 名字: "慢工具乙", 描述: "乙", 参数schema: "{}", 处理: 慢工具乙 }));
    表 = 注册(表, 0, (工具 { 名字: "慢工具丙", 描述: "丙", 参数schema: "{}", 处理: 慢工具丙 }));

    // 构造 3 个并发调用（下标 0=甲 1=乙 2=丙）
    变量 名表 = 列表库::创建字符串列表();
    列表库::添加字符串(名表, "慢工具甲");
    列表库::添加字符串(名表, "慢工具乙");
    列表库::添加字符串(名表, "慢工具丙");

    变量 参表 = 列表库::创建字符串列表();
    列表库::添加字符串(参表, "{}");
    列表库::添加字符串(参表, "{}");
    列表库::添加字符串(参表, "{}");

    变量 开始 = 时间.当前毫秒();
    变量 结果表 = 并发派发(表, 名表, 参表, 3);
    变量 耗时 = 时间.当前毫秒() - 开始;

    // ① 正确性 + 下标对齐
    IO.打印行("");
    IO.打印行("[① 结果正确性 + 下标对齐]");
    变量 r0: 字符串 = 列表库::获取字符串(结果表, 0);
    变量 r1: 字符串 = 列表库::获取字符串(结果表, 1);
    变量 r2: 字符串 = 列表库::获取字符串(结果表, 2);
    IO.打印行("  结果[0] = " + r0);
    IO.打印行("  结果[1] = " + r1);
    IO.打印行("  结果[2] = " + r2);

    变量 通过: 整数 = 0;
    如果 (字符串::包含(r0, "甲") == 1) { 如果 (字符串::包含(r0, "111") == 1) { 通过 = 通过 + 1; } }
    如果 (字符串::包含(r1, "乙") == 1) { 如果 (字符串::包含(r1, "222") == 1) { 通过 = 通过 + 1; } }
    如果 (字符串::包含(r2, "丙") == 1) { 如果 (字符串::包含(r2, "333") == 1) { 通过 = 通过 + 1; } }
    如果 (通过 == 3) {
        IO.打印行("  ✓ 3/3 结果正确且下标对齐");
    } 否则 {
        IO.打印行("  ✗ 仅 " + 整数转字符串(通过) + "/3 正确");
    }

    // ② 计时对比
    IO.打印行("");
    IO.打印行("[② 并发计时]");
    IO.打印行("  3 个 300ms 工具，并发总耗时: " + 整数转字符串(耗时) + " ms");
    IO.打印行("  串行预期: ~900 ms");
    如果 (耗时 < 600) {
        IO.打印行("  ✓ 远小于串行 900ms → 确为并发执行");
    } 否则 {
        IO.打印行("  ✗ 耗时偏高，疑似串行");
    }

    IO.打印行("");
    IO.打印行("=== 自测完成 ===");
}
