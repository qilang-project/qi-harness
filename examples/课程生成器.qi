// ════════════════════════════════════════════════════════════
//   奇语言课程生成器 —— 用奇语言自己的 AI 原语，生成奇语言的课件
//   (dogfooding：agent 造 AI 课件；生成→编译校验→报错反馈重生成→判分草稿)
// ════════════════════════════════════════════════════════════
//
// 管线：主题+受众 → 大模型.对话 生成 .qi 源码 → 子进程调 `qi check` 语法校验
//       → 报错原文喂回模型重生成(最多 3 轮，Instructor 式自修复)
//       → `qi run` 真跑拿输出 → 从数字行生成 练习草稿.json → 生成报告
//
// 跑：在 qilang 根目录执行
//   QI_RUNTIME_LIB=$PWD/qi-runtime/target/release/libqi_runtime.a \
//   QI_PACKAGES_PATH=$PWD/qi_packages \
//   ./target/release/qi run qi-harness/examples/课程生成器.qi
// 换主题/受众用环境变量 QI_TOPIC / QI_AUDIENCE / QI_MODULE 覆盖(须 ASCII 名)。
// 例: QI_TOPIC="复利计算" QI_AUDIENCE="大人" ... ./target/release/qi run ...

包 主程序;
导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 标准库.大模型 作为 大模型;
导入 标准库.子进程 作为 子进程;
导入 标准库.字符串;

// ── 固定路径与默认配置 ─────────────────────────────
函数 目录() : 字符串 { 返回 "/tmp/生成课件"; }
函数 草稿路径() : 字符串 { 返回 "/tmp/生成课件/课件_草稿.qi"; }
函数 练习路径() : 字符串 { 返回 "/tmp/生成课件/练习草稿.json"; }
函数 QI路径() : 字符串 { 返回 "/Users/liliang/Things/AI/projects/qilang/target/release/qi"; }
函数 样例路径() : 字符串 { 返回 "/Users/liliang/Things/AI/projects/qilang/aione-spike/课件_零基础编程_第五讲.qi"; }
函数 默认URL() : 字符串 { 返回 "https://llm-g2ka7zn8vobs5ftf.cn-beijing.maas.aliyuncs.com/compatible-mode/v1"; }
函数 默认模型() : 字符串 { 返回 "qwen3.7-plus"; }
函数 默认KEY() : 字符串 { 返回 "sk-ws-H.REHLLLY.QvfU.MEUCIFPdwxgrDEmT8pnOrinSo2UDNX1GnwNvZVSRGLQK_ODuAiEAwtZtOFZomo3Vh3DU0AogiVGtzre5LCEEeESG2ibQgek"; }

函数 校验命令行() : 字符串 {
    返回 QI路径() + " check " + 草稿路径() + " 2>&1";
}
函数 运行命令行() : 字符串 {
    // 有 timeout 就套 15s 防死循环，没有就直接跑；2>&1 把 stderr 也收进管道
    返回 "command -v timeout >/dev/null 2>&1 && timeout 15 " + QI路径() + " run " + 草稿路径() + " 2>&1 || " + QI路径() + " run " + 草稿路径() + " 2>&1";
}

// ── 环境变量取值（带硬编码兜底）──────────────────────
函数 取配置(键: 字符串, 兜底: 字符串) : 字符串 {
    变量 值: 字符串 = 系统.获取环境变量(键);
    如果 (字符串::字节长度(值) == 0) { 返回 兜底; }
    返回 值;
}

// ── 系统提示：硬性规则 + 语言要点（模型只输出代码）──────
函数 系统规则() : 字符串 {
    返回 `你是"奇语言"(qilang，一种 100% 中文关键字的编译型编程语言)的课程课件生成器。
你的输出会被 qi 编译器直接编译并运行，所以必须是严格合法、可直接编译的 qi 源码。
只输出 .qi 源码本身，不要任何解释文字，不要 Markdown 代码围栏(不要 反引号 三连)。

【硬性格式规则】
1. 第一行必须是: 包 主程序;
2. 第二行必须是: 导入 标准库.输入输出 作为 IO;
3. 必须有且仅有一个入口函数: 函数 入口() { ... }
4. 文件顶部用 // 中文注释写一段横幅，介绍本课主题
5. 正文用 IO.打印行(...) 输出每一步结论，关键结论必须带具体数字
6. 结尾必须有一段以 "// ── 练习 ──" 开头的注释，给 2~3 道小练习
7. 全文 60~100 行，所有标识符用中文

【qi 语言要点(务必遵守，否则编译失败)】
- 变量声明: 变量 名字: 类型 = 值;   类型只有 整数 / 浮点数 / 字符串 / 布尔
- 函数定义: 函数 名字(参数: 类型) : 返回类型 { 返回 值; }
- 循环: 当 (条件) { ... }   条件为真时反复执行，循环体内务必让条件最终变假
- 分支: 如果 (条件) { ... } 否则 { ... }
- 字符串拼接用 + ；整数转文字用 整数转字符串(x)
- 插值模板: 模板"文本 {变量} 文本"  会把大括号里的值转成文字
- 整数相除是整数除法(7 / 2 == 3)；要小数请用浮点数并写成 7.0 / 2.0
- 每条语句以分号 ; 结尾；打印一律用 IO.打印行(...)
- 下列是保留字，绝对不能用作变量名或函数名: 结果 类型 尝试 继续 返回 到 数组 释放 列表 选择 选项 除 新建 导出`;
}

// ── 剥掉 Markdown 代码围栏（模型常不听话仍会包 反引号三连）──
函数 剥围栏(原文: 字符串) : 字符串 {
    如果 (字符串::包含(原文, "```") == 0) { 返回 原文; }
    变量 起点: 整数 = 字符串::查找(原文, "```");
    变量 换行位: 整数 = 字符串::查找从位置(原文, "\n", 起点);
    如果 (换行位 < 0) { 返回 原文; }
    变量 代码起: 整数 = 换行位 + 1;
    变量 结束栏: 整数 = 字符串::查找从位置(原文, "```", 代码起);
    如果 (结束栏 < 0) { 返回 字符串::子串从位置(原文, 代码起); }
    返回 字符串::子串(原文, 代码起, 结束栏 - 代码起);
}

// ── 从模型回复里提取纯净源码：去围栏 + 从 `包 主程序` 起截 ──
函数 提取源码(原始: 字符串) : 字符串 {
    变量 去围栏: 字符串 = 剥围栏(原始);
    变量 起: 整数 = 字符串::查找(去围栏, "包 主程序");
    如果 (起 > 0) { 返回 字符串::子串从位置(去围栏, 起); }
    返回 去围栏;
}

// ── 取一段文本的首行（用于打印报错摘要）─────────────
函数 首行(文本: 字符串) : 字符串 {
    变量 nl: 整数 = 字符串::查找(文本, "\n");
    如果 (nl < 0) { 返回 文本; }
    返回 字符串::子串(文本, 0, nl);
}

// ── 判断一行里是否含阿拉伯数字（挑锚点用）──────────
函数 含数字(行: 字符串) : 整数 {
    如果 (字符串::包含(行, "0") == 1) { 返回 1; }
    如果 (字符串::包含(行, "1") == 1) { 返回 1; }
    如果 (字符串::包含(行, "2") == 1) { 返回 1; }
    如果 (字符串::包含(行, "3") == 1) { 返回 1; }
    如果 (字符串::包含(行, "4") == 1) { 返回 1; }
    如果 (字符串::包含(行, "5") == 1) { 返回 1; }
    如果 (字符串::包含(行, "6") == 1) { 返回 1; }
    如果 (字符串::包含(行, "7") == 1) { 返回 1; }
    如果 (字符串::包含(行, "8") == 1) { 返回 1; }
    如果 (字符串::包含(行, "9") == 1) { 返回 1; }
    返回 0;
}

// ── JSON 字符串转义（防止锚点里有引号/反斜杠破坏 json）──
函数 转义(文本: 字符串) : 字符串 {
    变量 甲: 字符串 = 字符串::替换(文本, "\\", "\\\\");
    返回 字符串::替换(甲, "\"", "\\\"");
}

// ── 收集子进程 stdout 直到进程结束（空读不等于 EOF）──
函数 收集输出(句柄: 整数) : 字符串 {
    变量 全部: 字符串 = "";
    变量 空数: 整数 = 0;
    变量 步: 整数 = 0;
    当 (步 < 5000) {
        变量 行: 字符串 = 子进程.读取行超时(句柄, 400);
        如果 (字符串::字节长度(行) == 0) {
            空数 = 空数 + 1;
            如果 (子进程.存活(句柄) == 0 与 空数 >= 3) { 跳出; }
            如果 (空数 >= 25) { 跳出; }
        } 否则 {
            空数 = 0;
            全部 = 全部 + 行 + "\n";
        }
        步 = 步 + 1;
    }
    返回 全部;
}

// ── 用 sh -c 执行一条命令并收全部输出 ─────────────
函数 执行命令(命令行: 字符串) : 字符串 {
    变量 参数: 字符串 = `["-c", "` + 命令行 + `"]`;
    变量 句柄: 整数 = 子进程.生成("sh", 参数);
    如果 (句柄 <= 0) { 返回 "子进程启动失败"; }
    变量 输出: 字符串 = 收集输出(句柄);
    子进程.结束(句柄);
    返回 输出;
}

// ── 从真实运行输出里挑 2~3 行含数字的文案，写成判分草稿 json ──
函数 生成练习(课程名: 字符串, 真实输出: 字符串, 输出路径: 字符串) : 整数 {
    变量 项: 字符串 = "";
    变量 挑中: 整数 = 0;
    变量 位置: 整数 = 0;
    变量 总长: 整数 = 字符串::字节长度(真实输出);
    当 (位置 < 总长 与 挑中 < 3) {
        变量 换行: 整数 = 字符串::查找从位置(真实输出, "\n", 位置);
        变量 行: 字符串 = "";
        如果 (换行 < 0) {
            行 = 字符串::子串从位置(真实输出, 位置);
            位置 = 总长;
        } 否则 {
            行 = 字符串::子串(真实输出, 位置, 换行 - 位置);
            位置 = 换行 + 1;
        }
        变量 净行: 字符串 = 字符串::去空白(行);
        如果 (含数字(净行) == 1 与 字符串::字节长度(净行) > 3) {
            如果 (挑中 > 0) { 项 = 项 + ",\n"; }
            项 = 项 + `    { "名": "锚点` + 整数转字符串(挑中 + 1) + `", "类型": "包含", "期望": "` + 转义(净行) + `" }`;
            挑中 = 挑中 + 1;
        }
    }
    变量 json: 字符串 = `{
  "课程": "` + 课程名 + `",
  "练习": [
` + 项 + `
  ]
}`;
    IO.写入文件(输出路径, json);
    返回 挑中;
}

// ── 组装本轮提示（首轮塞样例；重试轮塞上版代码+报错）──
函数 首轮提示(主题: 字符串, 受众: 字符串, 模块名: 字符串, 样例文本: 字符串) : 字符串 {
    变量 语气: 字符串 = "面向成年人，语气简洁专业，可带一点实用背景。";
    如果 (受众 == "少儿") {
        语气 = "面向 6~12 岁小朋友，语气活泼，用生活里的比喻，数字要小而直观。";
    }
    返回 系统规则()
        + "\n\n【风格样例 —— 请照这份真实课件的结构与风格，但换成新主题】\n"
        + 样例文本
        + "\n【样例结束】\n\n【本次任务】\n受众: " + 受众 + "（" + 语气 + "）\n主题: " + 主题
        + "\n模块名: " + 模块名 + "\n请现在只输出这门课的 .qi 源码。";
}

函数 重试提示(主题: 字符串, 受众: 字符串, 上版代码: 字符串, 报错文本: 字符串) : 字符串 {
    返回 系统规则()
        + "\n\n上一版 qi 源码没能通过编译，请修正全部错误后，重新输出【完整】的 .qi 源码(仍然只输出代码，不要解释)。\n\n【上一版代码】\n"
        + 上版代码 + "\n\n【qi 编译器报错原文】\n" + 报错文本
        + "\n\n主题仍是: " + 主题 + "，受众: " + 受众 + "。";
}

// ── 核心管线：生成 → 校验 → 自修复 → 真跑 → 判分草稿 → 报告 ──
函数 生成课件(主题: 字符串, 受众: 字符串, 模块名: 字符串, 会话: 整数, 样例文本: 字符串) {
    变量 成功: 整数 = 0;
    变量 轮: 整数 = 1;
    变量 代码文本: 字符串 = "";
    变量 报错文本: 字符串 = "";

    当 (轮 <= 3 与 成功 == 0) {
        IO.打印行(模板"── 第 {轮} 轮 ──────────────────────────");
        变量 提示: 字符串 = "";
        如果 (轮 == 1) {
            提示 = 首轮提示(主题, 受众, 模块名, 样例文本);
        } 否则 {
            提示 = 重试提示(主题, 受众, 代码文本, 报错文本);
        }
        IO.打印行("  · 正在请求大模型生成课件源码 ...");
        变量 原始回复: 字符串 = 大模型.对话(会话, 提示);
        代码文本 = 提取源码(原始回复);
        IO.打印行(模板"  · 收到 {字符串::字节长度(代码文本)} 字节源码，写盘并编译校验 ...");
        IO.写入文件(草稿路径(), 代码文本);
        变量 校验输出: 字符串 = 执行命令(校验命令行());
        如果 (字符串::包含(校验输出, "语法检查通过") == 1) {
            IO.打印行("  ✅ 编译校验通过");
            成功 = 1;
        } 否则 {
            报错文本 = 校验输出;
            IO.打印行("  ❌ 校验失败，报错摘要:");
            IO.打印行("     " + 首行(报错文本));
            轮 = 轮 + 1;
        }
    }

    IO.打印行("");
    如果 (成功 == 0) {
        IO.打印行("════════════ 生成报告 ════════════");
        IO.打印行("结果: 失败(3 轮仍未通过编译)");
        IO.打印行("最后一次报错首行: " + 首行(报错文本));
        返回;
    }

    IO.打印行("── 真实运行验证 ──────────────────────");
    变量 真实输出: 字符串 = 执行命令(运行命令行());
    IO.打印行("  程序真实输出:");
    IO.打印行(真实输出);

    变量 断言数: 整数 = 生成练习("课件_草稿", 真实输出, 练习路径());

    IO.打印行("════════════ 生成报告 ════════════");
    IO.打印行("结果: 成功");
    IO.打印行(模板"自修复轮数: {轮}");
    IO.打印行(模板"最终课件: {草稿路径()}");
    IO.打印行(模板"判分草稿: {练习路径()}  (共 {断言数} 条断言)");
    IO.打印行("是否可运行: 是");
}

函数 入口() {
    IO.打印行("╔══════════════════════════════════════════╗");
    IO.打印行("║   奇语言课程生成器 · 用 AI 原语造 AI 课件  ║");
    IO.打印行("╚══════════════════════════════════════════╝");

    // 注意：POSIX 环境变量名只能用 ASCII，故用 QI_TOPIC/QI_AUDIENCE/QI_MODULE 覆盖
    变量 主题: 字符串 = 取配置("QI_TOPIC", "乘法口诀表");
    变量 受众: 字符串 = 取配置("QI_AUDIENCE", "少儿");
    变量 模块名: 字符串 = 取配置("QI_MODULE", "自动生成");

    // 准备产物目录
    执行命令("mkdir -p " + 目录());

    // dogfooding：读入一门真实课件当风格样例
    变量 样例文本: 字符串 = IO.读取文件(样例路径());
    如果 (字符串::字节长度(样例文本) == 0) {
        IO.打印行("⚠ 未读到风格样例，继续但质量可能下降");
    }

    变量 会话: 整数 = 大模型.创建会话(
        取配置("QI_CHAT_URL", 默认URL()),
        取配置("QI_CHAT_MODEL", 默认模型()),
        取配置("QI_CHAT_KEY", 默认KEY())
    );
    如果 (会话 <= 0) {
        IO.打印行("❌ 大模型会话创建失败");
        返回;
    }

    IO.打印行(模板"主题={主题}  受众={受众}  模块={模块名}");
    IO.打印行("");
    生成课件(主题, 受众, 模块名, 会话, 样例文本);
    大模型.关闭会话(会话);
}
