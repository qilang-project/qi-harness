// qi-harness · 记忆示例 —— agent 的持久记忆：同一程序跑两次看效果（离线，不调 LLM）
//
// 第一次跑：库是空的 → 记住 用户偏好/事实/经验（落盘 SQLite）
// 第二次跑：回忆 命中 → 展示 带记忆运行 将注入提示词的记忆块
//
// 跑（连跑两次看差异）：
//   qi run examples/记忆示例.qi
//   qi run examples/记忆示例.qi
// 想重来：rm /tmp/qi记忆示例.db

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 Harness.记忆::{打开记忆, 记住, 回忆, 记忆条数, 关闭记忆};

常量 库路径 = "/tmp/qi记忆示例.db";

函数 入口() {
    变量 库: 整数 = 打开记忆(库路径);
    如果 (库 <= 0) {
        IO.打印行("打开记忆库失败: " + 库路径);
        返回;
    }

    如果 (记忆条数(库) == 0) {
        IO.打印行("== 第一次运行：库为空，先记住 ==");
        记住(库, "偏好", "用户喜欢简短的中文回答，代码示例要带注释", "回答,风格,代码", 5);
        记住(库, "事实", "用户的项目是用 Qi 语言写的 LLM agent 框架", "项目,Qi,agent", 4);
        记住(库, "经验", "给这个用户排错时先看 trace 事件流最有效", "排错,trace,调试", 3);
        IO.打印行("已记住 " + 整数转字符串(记忆条数(库)) + " 条（偏好/事实/经验各一），落盘 " + 库路径);
        IO.打印行("再跑一次本程序，看记忆如何被回忆并注入提示词。");
    } 否则 {
        IO.打印行("== 第二次运行：跨进程回忆（" + 整数转字符串(记忆条数(库)) + " 条在库）==");
        变量 记忆块: 字符串 = 回忆(库, "回答,项目,排错", 5);
        IO.打印行("");
        IO.打印行("带记忆运行(代理, \"帮我优化这个函数\", \"回答,项目,排错\") 实际发给模型的提示：");
        IO.打印行("----------------------------------------");
        IO.打印行("## 相关记忆与过往经验\n" + 记忆块 + "\n(参考以上背景作答)\n\n帮我优化这个函数");
        IO.打印行("----------------------------------------");
        IO.打印行("真接 LLM 时只需两行：");
        IO.打印行("  代理值 = 启用记忆(代理值, \"" + 库路径 + "\");");
        IO.打印行("  带记忆运行(代理值, 提示, 查询关键词);");
    }
    关闭记忆(库);
}
