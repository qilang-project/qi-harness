// _结构化自测.qi — Part B 结构化输出 自测
//
// 验证 对话::校验JSON对象（纯函数，无 LLM 依赖）三种情况：
//   ① 合法 JSON 且必需字段齐全 → 1
//   ② 合法 JSON 但缺字段       → 0
//   ③ 非法 JSON               → 0
//
// 结构化运行 端到端需有效 LLM 凭证，本机凭证失效，见报告（此处只测纯函数）。
//
// 运行：cd qi-harness && ../target/debug/qi run examples/_结构化自测.qi

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.列表 作为 列表库;
导入 Harness::{ 校验JSON对象 };

函数 入口() {
    IO.打印行("=== Part B 校验JSON对象 自测 ===");
    IO.打印行("");

    // 必需字段：name, age
    变量 必需 = 列表库::创建字符串列表();
    列表库::添加字符串(必需, "name");
    列表库::添加字符串(必需, "age");

    // ① 合法且字段齐
    变量 c1: 整数 = 校验JSON对象("{\"name\":\"张三\",\"age\":30}", 必需);
    IO.打印行("[①] 合法+字段齐  → " + 整数转字符串(c1) + "  (期望 1)");

    // ② 合法但缺 age
    变量 c2: 整数 = 校验JSON对象("{\"name\":\"李四\"}", 必需);
    IO.打印行("[②] 合法但缺字段 → " + 整数转字符串(c2) + "  (期望 0)");

    // ③ 非法 JSON
    变量 c3: 整数 = 校验JSON对象("这不是 JSON {{{", 必需);
    IO.打印行("[③] 非法 JSON    → " + 整数转字符串(c3) + "  (期望 0)");

    IO.打印行("");
    变量 通过: 整数 = 0;
    如果 (c1 == 1) { 通过 = 通过 + 1; }
    如果 (c2 == 0) { 通过 = 通过 + 1; }
    如果 (c3 == 0) { 通过 = 通过 + 1; }
    如果 (通过 == 3) {
        IO.打印行("✓ 3/3 通过");
    } 否则 {
        IO.打印行("✗ 仅 " + 整数转字符串(通过) + "/3 通过");
    }
    IO.打印行("=== 自测完成 ===");
}
