// qi-harness · 家电销售公司店员助手 —— 企业 Agent 最小原型
//
// 场景：家电销售公司，两家门店（东门店/西门店），十个店员共用一个 AI 助手。
// 店员用自然语言问库存、开单、看销量；Agent 通过三个工具直连公司 SQLite 业务库，
// 模型走本机 ollama（零 API 费用、数据不出内网）。
//
// 跑：QI_LLM_BASE=http://127.0.0.1:11434/v1 QI_LLM_KEY=ollama QI_LLM_MODEL=ornith \
//     qi run examples/家电门店助手.qi
// 换模型/换云端 provider 只改这三个环境变量。

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.操作系统 作为 系统;
导入 标准库.数据库;
导入 标准库.JSON 作为 J;
导入 Harness::{
    模型配置, 大模型, 配置系统提示, 开启会话,
    创建代理, 添加工具, 设置工具白名单, 运行, 关闭代理,
    工具
};

变量 库: 整数 = 0;

// ── 业务库：两家店 + 库存 + 销售流水 ─────────────────────────
函数 建业务库() {
    库 = 数据库.连接("/tmp/家电公司.db");
    数据库.执行(库, "DROP TABLE IF EXISTS 库存");
    数据库.执行(库, "DROP TABLE IF EXISTS 销售");
    数据库.执行(库, "CREATE TABLE 库存 (门店 TEXT, 型号 TEXT, 品名 TEXT, 价格 INTEGER, 数量 INTEGER)");
    数据库.执行(库, "CREATE TABLE 销售 (门店 TEXT, 店员 TEXT, 型号 TEXT, 台数 INTEGER, 金额 INTEGER, 日期 TEXT)");
    数据库.执行(库, "INSERT INTO 库存 VALUES "
        + "('东门店','KX-500','变频空调 1.5匹',3299,7),('西门店','KX-500','变频空调 1.5匹',3299,2),"
        + "('东门店','BW-218','双开门冰箱 218L',2599,4),('西门店','BW-218','双开门冰箱 218L',2599,6),"
        + "('东门店','XY-9','滚筒洗衣机 9kg',2899,0),('西门店','XY-9','滚筒洗衣机 9kg',2899,3)");
    数据库.执行(库, "INSERT INTO 销售 VALUES "
        + "('东门店','小张','KX-500',3,9897,'2026-07-20'),('东门店','小李','BW-218',2,5198,'2026-07-21'),"
        + "('西门店','小王','XY-9',1,2899,'2026-07-21'),('东门店','小张','KX-500',2,6598,'2026-07-22')");
}

// ── 工具（名字 ASCII，描述中文；返回 JSON 给模型读）──────────
函数 查库存(参数JSON: 字符串) : 字符串 {
    变量 根: 整数 = J.解码(参数JSON);
    变量 关键: 字符串 = J.获取字符串(根, "keyword");
    返回 数据库.查询(库, "SELECT 门店, 型号, 品名, 价格, 数量 FROM 库存 WHERE 型号 LIKE '%"
        + 字符串::替换(关键, "'", "") + "%' OR 品名 LIKE '%" + 字符串::替换(关键, "'", "") + "%'");
}

函数 开单(参数JSON: 字符串) : 字符串 {
    变量 根: 整数 = J.解码(参数JSON);
    变量 店: 字符串 = 字符串::替换(J.获取字符串(根, "store"), "'", "");
    变量 型: 字符串 = 字符串::替换(J.获取字符串(根, "model"), "'", "");
    变量 店员: 字符串 = 字符串::替换(J.获取字符串(根, "clerk"), "'", "");
    变量 台数: 整数 = J.获取整数(根, "qty");
    如果 (台数 <= 0) { 台数 = 1; }
    变量 行JSON: 字符串 = 数据库.查询(库, "SELECT 价格, 数量 FROM 库存 WHERE 门店='" + 店 + "' AND 型号='" + 型 + "'");
    变量 数组值: 整数 = J.解码(行JSON);
    如果 (数组值 <= 0) { 返回 "{\"error\":\"没找到该门店该型号\"}"; }
    如果 (J.数组长度(数组值) == 0) { 返回 "{\"error\":\"没找到该门店该型号\"}"; }
    变量 首行: 整数 = J.数组获取对象(数组值, 0);
    变量 存量: 整数 = J.获取整数(首行, "数量");
    如果 (存量 < 台数) {
        返回 "{\"error\":\"库存不足\",\"当前库存\":" + 整数转字符串(存量) + "}";
    }
    变量 单价: 整数 = J.获取整数(首行, "价格");
    变量 金额: 整数 = 单价 * 台数;
    数据库.执行(库, "UPDATE 库存 SET 数量 = 数量 - " + 整数转字符串(台数)
        + " WHERE 门店='" + 店 + "' AND 型号='" + 型 + "'");
    数据库.执行(库, "INSERT INTO 销售 VALUES ('" + 店 + "','" + 店员 + "','" + 型 + "',"
        + 整数转字符串(台数) + "," + 整数转字符串(金额) + ",'2026-07-22')");
    返回 "{\"ok\":1,\"门店\":\"" + 店 + "\",\"型号\":\"" + 型 + "\",\"台数\":" + 整数转字符串(台数)
        + ",\"金额\":" + 整数转字符串(金额) + "}";
}

函数 销量榜(参数JSON: 字符串) : 字符串 {
    返回 数据库.查询(库,
        "SELECT 门店, SUM(台数) AS 总台数, SUM(金额) AS 总金额 FROM 销售 GROUP BY 门店 ORDER BY 总金额 DESC");
}

// ── 组装代理 ────────────────────────────────────────────────
函数 问(代理值: 代理, 问题: 字符串) {
    IO.打印行("");
    IO.打印行("👤 店员：${问题}");
    IO.打印行("🤖 助手：" + 运行(代理值, 问题));
}

函数 入口() {
    变量 基址: 字符串 = 系统.获取环境变量("QI_LLM_BASE");
    如果 (字符串::字节长度(基址) == 0) { 基址 = "http://127.0.0.1:11434/v1"; }
    变量 密钥: 字符串 = 系统.获取环境变量("QI_LLM_KEY");
    如果 (字符串::字节长度(密钥) == 0) { 密钥 = "ollama"; }
    变量 模型名: 字符串 = 系统.获取环境变量("QI_LLM_MODEL");
    如果 (字符串::字节长度(模型名) == 0) { 模型名 = "ornith"; }

    建业务库();

    变量 配置: 模型配置 = 大模型(基址, 密钥, 模型名);
    配置 = 配置系统提示(配置,
        "你是「家安电器」的门店助手，公司有东门店和西门店两家门店。"
        + "回答店员问题必须先调工具查真实数据，绝不编造库存和价格；"
        + "开单前先查库存确认够卖。回答用简洁中文，报价格带上元。");
    变量 会话: 整数 = 开启会话(配置);
    如果 (会话 <= 0) { IO.打印行("会话开启失败（ollama 没起？）"); 返回; }

    变量 助手: 代理 = 创建代理("门店助手", 会话);
    助手 = 添加工具(助手, 新建 工具 {
        名字: "cha_kucun",
        描述: "按型号或品名关键词查两家门店的库存和价格。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"keyword\":{\"type\":\"string\",\"description\":\"型号或品名关键词，如 KX-500 / 空调\"}},\"required\":[\"keyword\"]}",
        处理: 查库存,
    });
    助手 = 添加工具(助手, 新建 工具 {
        名字: "kai_dan",
        描述: "给客户开销售单：指定门店、型号、台数、店员名。会扣减库存并记入销售流水。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"store\":{\"type\":\"string\",\"description\":\"东门店或西门店\"},\"model\":{\"type\":\"string\"},\"qty\":{\"type\":\"integer\"},\"clerk\":{\"type\":\"string\",\"description\":\"店员名\"}},\"required\":[\"store\",\"model\",\"qty\",\"clerk\"]}",
        处理: 开单,
    });
    助手 = 添加工具(助手, 新建 工具 {
        名字: "xiao_liang",
        描述: "查两家门店的销量与销售额排行。",
        参数schema: "{\"type\":\"object\",\"properties\":{}}",
        处理: 销量榜,
    });
    // 权限治理：这个代理只许用这三个工具（十个店员共用，不给删库跑路的机会）
    助手 = 设置工具白名单(助手, "cha_kucun,kai_dan,xiao_liang");

    IO.打印行("═══ 家安电器 · 门店 AI 助手（模型: ${模型名} @ ${基址}）═══");
    问(助手, "客户想要台变频空调，KX-500 两家店还有货吗？多少钱？");
    问(助手, "我是东门店小李，帮客户开一单：KX-500 两台。");
    问(助手, "这个月到现在两家店谁卖得好？");

    关闭代理(助手);
    数据库.关闭(库);
}
