// qi-harness DeepSeek 实测 — 用 LLM() 一行配置
// 跑：QI_LLM_KEY=sk-... qi run deepseek测试.qi

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.操作系统 作为 系统;
导入 Harness::{
    模型配置, LLM, 配置系统提示, 开启会话,
    创建代理, 简单问, 关闭代理
};

函数 入口() {
    变量 密钥: 字符串 = 系统.获取环境变量("QI_LLM_KEY");
    如果 (字符串::字节长度(密钥) == 0) {
        IO.打印行("未设 QI_LLM_KEY");
        返回;
    }

    // 一行配置 — 任何 OpenAI 兼容 API
    变量 配置: 模型配置 = LLM("https://api.deepseek.com", 密钥, "deepseek-chat");
    配置 = 配置系统提示(配置, "你是 qi 编程语言的简洁助手。回答用一句话。");

    变量 会话: 整数 = 开启会话(配置);
    如果 (会话 <= 0) {
        IO.打印行("会话开启失败");
        返回;
    }

    变量 代理值: 代理 = 创建代理("DeepSeek助手", 会话);
    变量 回复: 字符串 = 简单问(代理值, "用一句话介绍 qi 编程语言（中文）");
    IO.打印行("");
    IO.打印行("=== 回复 ===");
    IO.打印行(回复);
    关闭代理(代理值);
}
