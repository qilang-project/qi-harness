// qi-harness 技能示例 —— 加载 agentskills.io SKILL.md 并装备到 agent
// 跑：QI_LLM_KEY=sk-... qi run 技能示例.qi
包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.操作系统 作为 系统;
导入 Harness::{
    模型配置, 大模型, 开启会话,
    创建代理, 简单问, 关闭代理,
    技能, 加载技能文件, 装备技能
};
导入 Harness.追踪 作为 追踪;

函数 入口() {
    变量 密钥: 字符串 = 系统.获取环境变量("QI_LLM_KEY");
    如果 (字符串::字节长度(密钥) == 0) { IO.打印行("未设 QI_LLM_KEY"); 返回; }
    追踪.禁用即时打印();

    // 1. 加载技能（agentskills.io 规范 SKILL.md）
    变量 技能值: 技能 = 加载技能文件("技能/海盗腔.md");
    IO.打印行("已加载技能: " + 技能值.名称);

    // 2. 装备技能到配置（开会话前）→ 开会话
    变量 配置: 模型配置 = 大模型("https://api.deepseek.com", 密钥, "deepseek-chat");
    配置 = 装备技能(配置, "你是一个助手。", 技能值);
    变量 会话: 整数 = 开启会话(配置);
    如果 (会话 <= 0) { IO.打印行("会话失败"); 返回; }

    // 3. 提问 —— 行为应受技能影响
    变量 代理值: 代理 = 创建代理("海盗助手", 会话);
    IO.打印行("");
    IO.打印行(简单问(代理值, "介绍一下 qi 编程语言"));
    关闭代理(代理值);
}
