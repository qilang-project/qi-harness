// qi-harness 快速开始 — 教程示例
//
// 一个文件覆盖 qi-harness 的核心用法：
//   1. 配置模型 + 凭证（从环境变量读，绝不硬编码）
//   2. 一次性对话（简单问）
//   3. 流式对话（流式问 + 块回调）
//   4. 工具调用自动派发循环（添加工具 + 运行）
//   5. 可观测（追踪）+ 重试（默认策略 / 重试调用）
//
// 运行：
//   QI_LLM_KEY=sk-... qi run 教程_快速开始.qi
//   （也兼容 DEEPSEEK_API_KEY）
//
// 没设凭证时优雅退出，不会假装有输出。

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.操作系统 作为 系统;

导入 Harness::{
    模型配置, 大模型, 配置系统提示, 配置温度,
    开启会话, 关闭会话Harness,
    创建代理, 设置最大步数, 简单问, 流式问,
    添加工具, 运行, 关闭代理,
    工具,
    重试策略, 默认策略, 重试调用
};

导入 Harness.追踪 作为 追踪;

// ===== 工具实现 =====
// 工具处理函数签名固定：函数(参数JSON: 字符串): 字符串
// 返回值必须是 JSON 字符串，会被自动回写进对话再喂给模型。

函数 天气查询(参数JSON: 字符串) : 字符串 {
    如果 (字符串::包含(字符串::转小写(参数JSON), "beijing") == 1) {
        返回 "{\"city\":\"Beijing\",\"temp\":24,\"condition\":\"多云\"}";
    }
    如果 (字符串::包含(字符串::转小写(参数JSON), "shanghai") == 1) {
        返回 "{\"city\":\"Shanghai\",\"temp\":27,\"condition\":\"晴\"}";
    }
    返回 "{\"error\":\"city not found\"}";
}

// 流块回调：每片段实时打到 stdout，返回 1 表示继续接收。
函数 打印片段(片段: 字符串) : 整数 {
    IO.打印(片段);
    返回 1;
}

// 重试调用 需要一个零参闭包 函数(): 字符串。
// 奇语顶层命名函数不捕获局部变量，所以用一个模块级全局持有会话句柄，
// 在这个命名函数里临时建代理来发起被重试包裹的「调用」。
变量 全局会话: 整数 = 0;

函数 问关键字() : 字符串 {
    变量 临时代理: 代理 = 创建代理("重试助手", 全局会话);
    变量 答: 字符串 = 简单问(临时代理, "qi 语言用什么关键字声明变量？");
    关闭代理(临时代理);
    返回 答;
}

// 读凭证：优先 QI_LLM_KEY，回退 DEEPSEEK_API_KEY。
函数 读取密钥() : 字符串 {
    变量 密钥: 字符串 = 系统.获取环境变量("QI_LLM_KEY");
    如果 (字符串::字节长度(密钥) > 0) {
        返回 密钥;
    }
    返回 系统.获取环境变量("DEEPSEEK_API_KEY");
}

函数 入口() {
    IO.打印行("=== qi-harness 快速开始 ===");

    变量 密钥: 字符串 = 读取密钥();
    如果 (字符串::字节长度(密钥) == 0) {
        IO.打印行("未设凭证：请设置 QI_LLM_KEY 或 DEEPSEEK_API_KEY 后重试。");
        返回;
    }

    // ---- 1. 一行配置任何 OpenAI 兼容端点 ----
    变量 配置: 模型配置 = 大模型("https://api.deepseek.com", 密钥, "deepseek-chat");
    配置 = 配置系统提示(配置, "你是 qi 编程语言的简洁中文助手。");
    配置 = 配置温度(配置, "0.3");

    变量 会话: 整数 = 开启会话(配置);
    如果 (会话 <= 0) {
        IO.打印行("会话开启失败");
        返回;
    }
    全局会话 = 会话;   // 供带重试的命名函数复用

    // ---- 2. 一次性对话 ----
    变量 代理值: 代理 = 创建代理("教程助手", 会话);
    代理值 = 设置最大步数(代理值, 6);   // 工具循环防失控（默认 10）

    IO.打印行("");
    IO.打印行("--- 一次性问答 ---");
    变量 回复一: 字符串 = 简单问(代理值, "用一句话介绍 qi 编程语言。");
    IO.打印行(回复一);

    // ---- 3. 流式对话 ----
    IO.打印行("");
    IO.打印行("--- 流式问答 ---");
    追踪.禁用即时打印();   // 避免 trace 与流式片段输出交错
    变量 完整: 字符串 = 流式问(代理值, "用两句话解释什么是编译器。", 打印片段);
    IO.打印行("");

    // ---- 4. 工具调用自动派发循环 ----
    IO.打印行("");
    IO.打印行("--- 工具调用循环 ---");
    变量 天气工具: 工具 = 新建 工具 {
        名字: "天气查询",
        描述: "查询指定城市的当前天气。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"city\":{\"type\":\"string\"}},\"required\":[\"city\"]}",
        处理: 天气查询,
    };
    代理值 = 添加工具(代理值, 天气工具);

    // 运行：模型若返回 tool_calls，harness 自动派发→回写→继续，直到给出最终文本。
    变量 回复二: 字符串 = 运行(代理值, "北京现在天气怎样？用中文回答。");
    IO.打印行(回复二);

    // ---- 5. 重试（指数退避）包裹任意调用 ----
    // 重试调用 接受零参闭包；429 / 网络抖动 / 空响应会自动退避重试。
    IO.打印行("");
    IO.打印行("--- 带重试的调用 ---");
    变量 策略: 重试策略 = 默认策略();
    变量 回复三: 字符串 = 重试调用(策略, "教程助手", 问关键字);
    IO.打印行(回复三);

    关闭代理(代理值);
    关闭会话Harness(会话);
    IO.打印行("");
    IO.打印行("=== 完成 ===");
}
