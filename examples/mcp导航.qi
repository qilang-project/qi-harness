包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 Harness::{ 模型配置, 大模型, 配置系统提示, 配置温度, 开启会话, 关闭会话Harness,
                创建代理, 装备MCP, 运行, 关闭代理,
                连接MCP_stdio, 关闭MCP };

函数 入口() {
    变量 密钥: 字符串 = 系统.获取环境变量("QI_LLM_KEY");
    变量 配置: 模型配置 = 大模型("https://api.deepseek.com", 密钥, "deepseek-chat");
    配置 = 配置温度(配置, "0");
    配置 = 配置系统提示(配置, "你能用 playwright 工具操作浏览器。简洁回答。");
    变量 会话: 整数 = 开启会话(配置);

    变量 mcp句柄: 整数 = 连接MCP_stdio("npx", "[\"-y\",\"@playwright/mcp@latest\"]");
    变量 代理值: 代理 = 创建代理("浏览器助手", 会话);
    代理值 = 装备MCP(代理值, mcp句柄);

    变量 回复: 字符串 = 运行(代理值, "打开 https://example.com ，告诉我页面 <h1> 的文字。");
    IO.打印行("=== 回复 ===");
    IO.打印行(回复);

    关闭MCP(mcp句柄);
    关闭代理(代理值);
}
