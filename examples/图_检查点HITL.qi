// 断点续跑 + Human-in-the-loop 确定性自测（无需 LLM）。
// 流程：问(发起中断等人工) → 处理(消费人工回复) → 终点
// 跑：qi run examples/图_检查点HITL.qi

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.JSON 作为 J;
导入 标准库.数据库;
导入 Harness.图::{图, 创建图, 添加节点, 添加边, 运行图带检查点, 恢复图, 是中断, 中断问题, 是完成, 有检查点, 终点};

// 节点：发起中断，问人工要不要继续
函数 问(状态: 字符串) : 字符串 {
    变量 对象: 整数 = J.解码(状态);
    如果 (对象 <= 0) { 对象 = J.创建对象(); }
    J.设置字符串(对象, "__中断__", "确认要继续吗？");
    返回 J.转字符串(对象);
}

// 节点：读人工回复，写进结果
函数 处理(状态: 字符串) : 字符串 {
    变量 对象: 整数 = J.解码(状态);
    变量 回复: 字符串 = J.获取字符串(对象, "__人工回复__");
    J.设置字符串(对象, "结果", "收到人工回复: " + 回复);
    返回 J.转字符串(对象);
}

函数 入口() {
    变量 库: 整数 = 数据库.连接("/tmp/qi_图检查点_测.db");
    数据库.执行(库, "DROP TABLE IF EXISTS 图检查点");   // 干净起步

    变量 g: 图 = 创建图();
    g = 添加节点(g, "问", 问);
    g = 添加节点(g, "处理", 处理);
    g = 添加边(g, "问", "处理");
    g = 添加边(g, "处理", 终点());

    变量 过: 整数 = 0;

    // 第一次跑 → 应在「问」处中断
    变量 结果值: 字符串 = 运行图带检查点(g, 库, "任务001", "问", "{}", 50);
    IO.打印行("");
    如果 (是中断(结果值) == 1) {
        IO.打印行("✅ 已中断，等待人工。问题 = " + 中断问题(结果值));
        过 = 过 + 1;
    } 否则 {
        IO.打印行("❌ 期望中断");
    }
    如果 (有检查点(库, "任务001") == 1) {
        IO.打印行("✅ 检查点已落库（进程此刻崩掉也能续）");
        过 = 过 + 1;
    } 否则 {
        IO.打印行("❌ 检查点未落库");
    }

    // 人工答复 → 恢复续跑 → 应完成
    IO.打印行("");
    变量 结果2: 字符串 = 恢复图(g, 库, "任务001", "好的，继续");
    如果 (是完成(结果2) == 1) {
        IO.打印行("✅ 恢复后完成");
        过 = 过 + 1;
    } 否则 {
        IO.打印行("❌ 期望完成");
    }
    变量 末对象: 整数 = J.解码(结果2);
    变量 结果文本: 字符串 = J.获取字符串(末对象, "结果");
    IO.打印行("末态结果 = " + 结果文本);
    如果 (字符串::包含(结果文本, "好的，继续") == 1) { 过 = 过 + 1; }

    // 完成后检查点应清除
    如果 (有检查点(库, "任务001") == 0) {
        IO.打印行("✅ 完成后检查点已清除");
        过 = 过 + 1;
    } 否则 {
        IO.打印行("❌ 检查点未清除");
    }

    IO.打印行("");
    如果 (过 == 5) {
        IO.打印行("✅ 全部 5 项通过：中断→落库→恢复→完成→清除");
    } 否则 {
        IO.打印行("❌ 通过 " + 整数转字符串(过) + "/5");
    }
    数据库.关闭(库);
}
