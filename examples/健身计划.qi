// qi-harness 综合示例 —— 私人健身计划 App（tool-using agent）
//
// 一个「私人教练」智能体：读你的身体数据和目标，自动调用三件工具——
//   1) calc_targets  按 Mifflin-St Jeor 算 BMR/TDEE/目标热量/三大营养素
//   2) exercise_db   按训练部位 + 可用器械查动作库（含组数/次数建议）
//   3) save_plan     把最终计划写成 Markdown 存盘
// 然后综合成一份可执行的一周训练 + 饮食计划。
//
// ⚠️ 工具名必须是 ASCII（该 API 端点校验 ^[a-zA-Z0-9_-]+$，中文工具名会被拒）；
//    但工具的「描述」「参数字段」「返回内容」可以是中文，模型照样懂。
//
// 跑法（密钥只走环境变量，绝不写进文件）：
//   export QI_LLM_KEY=sk-...
//   export QI_LLM_ENDPOINT=https://cpa.superleo.app/v1      # 可选，默认即此
//   export QI_LLM_MODEL=gpt-5.6-luna                        # 可选
//   export QI_FIT_PROFILE="30岁女，165cm，58kg，久坐，想减脂，每周3练，家里只有一对哑铃"  # 可选
//   # 注意：环境变量名必须是 ASCII（shell 的 export 不传中文名变量），值可以是中文。
//   qi run 健身计划.qi

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.操作系统 作为 系统;
导入 标准库.JSON;
导入 Harness::{
    模型配置, 大模型, 配置系统提示, 开启会话,
    创建代理, 添加工具, 运行, 关闭代理,
    工具
};

// ════════════════════ 工具 1：热量与营养素计算 ════════════════════
// 入参 JSON：{身高:cm, 体重:kg, 年龄, 性别:"男|女",
//             活动:"久坐|轻度|中度|高度", 目标:"增肌|减脂|维持"}
函数 calc_targets(参数JSON: 字符串) : 字符串 {
    变量 对象: 整数 = JSON.解码(参数JSON);
    变量 身高: 浮点数 = JSON.获取浮点数(对象, "身高");
    变量 体重: 浮点数 = JSON.获取浮点数(对象, "体重");
    变量 年龄: 整数 = JSON.获取整数(对象, "年龄");
    变量 性别: 字符串 = JSON.获取字符串(对象, "性别");
    变量 活动: 字符串 = JSON.获取字符串(对象, "活动");
    变量 目标: 字符串 = JSON.获取字符串(对象, "目标");

    如果 (身高 <= 0.0 || 体重 <= 0.0) {
        返回 "{\"错误\":\"身高体重必须为正数\"}";
    }

    变量 龄: 浮点数 = 整数转浮点数(年龄);

    // Mifflin-St Jeor 基础代谢率
    变量 代谢: 浮点数 = 10.0 * 体重 + 6.25 * 身高 - 5.0 * 龄;
    如果 (性别 == "女") {
        代谢 = 代谢 - 161.0;
    } 否则 {
        代谢 = 代谢 + 5.0;
    }

    // 活动系数
    变量 系数: 浮点数 = 1.375;
    如果 (活动 == "久坐") { 系数 = 1.2; }
    如果 (活动 == "轻度") { 系数 = 1.375; }
    如果 (活动 == "中度") { 系数 = 1.55; }
    如果 (活动 == "高度") { 系数 = 1.725; }
    变量 消耗: 浮点数 = 代谢 * 系数;

    // 目标热量 + 蛋白摄入（g/kg）
    变量 目标热量: 浮点数 = 消耗;
    变量 蛋白系数: 浮点数 = 1.6;
    如果 (目标 == "增肌") { 目标热量 = 消耗 * 1.15; 蛋白系数 = 2.0; }
    如果 (目标 == "减脂") { 目标热量 = 消耗 * 0.8;  蛋白系数 = 2.2; }
    如果 (目标 == "维持") { 目标热量 = 消耗;        蛋白系数 = 1.6; }

    变量 蛋白克: 浮点数 = 蛋白系数 * 体重;
    变量 脂肪克: 浮点数 = 目标热量 * 0.25 / 9.0;
    变量 碳水克: 浮点数 = (目标热量 - 蛋白克 * 4.0 - 脂肪克 * 9.0) / 4.0;
    如果 (碳水克 < 0.0) { 碳水克 = 0.0; }

    变量 bmr整: 整数 = 浮点数转整数(代谢 + 0.5);
    变量 tdee整: 整数 = 浮点数转整数(消耗 + 0.5);
    变量 热量整: 整数 = 浮点数转整数(目标热量 + 0.5);
    变量 蛋白整: 整数 = 浮点数转整数(蛋白克 + 0.5);
    变量 脂肪整: 整数 = 浮点数转整数(脂肪克 + 0.5);
    变量 碳水整: 整数 = 浮点数转整数(碳水克 + 0.5);

    返回 "{\"BMR基础代谢\":" + 整数转字符串(bmr整)
        + ",\"TDEE每日消耗\":" + 整数转字符串(tdee整)
        + ",\"目标热量\":" + 整数转字符串(热量整)
        + ",\"蛋白质克\":" + 整数转字符串(蛋白整)
        + ",\"脂肪克\":" + 整数转字符串(脂肪整)
        + ",\"碳水克\":" + 整数转字符串(碳水整)
        + ",\"单位\":\"千卡/克每日\"}";
}

// ════════════════════ 工具 2：动作库查询 ════════════════════
// 入参 JSON：{部位:"胸|背|腿|肩|臂|核心|全身", 器械:"无器械|哑铃|健身房"}
函数 exercise_db(参数JSON: 字符串) : 字符串 {
    变量 对象: 整数 = JSON.解码(参数JSON);
    变量 部位: 字符串 = JSON.获取字符串(对象, "部位");
    变量 器械: 字符串 = JSON.获取字符串(对象, "器械");

    // 器械分档：健身房动作最全，哑铃次之，无器械纯自重
    变量 房: 整数 = 0;
    变量 铃: 整数 = 0;
    如果 (器械 == "健身房") { 房 = 1; 铃 = 1; }
    如果 (器械 == "哑铃") { 铃 = 1; }

    变量 列: 字符串 = "";
    如果 (部位 == "胸") {
        列 = "俯卧撑 3x12";
        如果 (铃 == 1) { 列 = 列 + " | 哑铃卧推 4x10 | 哑铃飞鸟 3x12"; }
        如果 (房 == 1) { 列 = 列 + " | 杠铃卧推 4x8 | 器械夹胸 3x15"; }
    }
    如果 (部位 == "背") {
        列 = "俯身划船(书包) 3x12 | 引体向上 3x力竭";
        如果 (铃 == 1) { 列 = 列 + " | 哑铃单臂划船 4x10"; }
        如果 (房 == 1) { 列 = 列 + " | 高位下拉 4x10 | 坐姿划船 4x12 | 硬拉 4x6"; }
    }
    如果 (部位 == "腿") {
        列 = "自重深蹲 4x15 | 箭步蹲 3x12 | 臀桥 3x20";
        如果 (铃 == 1) { 列 = 列 + " | 哑铃深蹲 4x12 | 哑铃罗马尼亚硬拉 4x10"; }
        如果 (房 == 1) { 列 = 列 + " | 杠铃深蹲 4x8 | 腿举 4x12 | 腿弯举 3x15"; }
    }
    如果 (部位 == "肩") {
        列 = "俯卧撑变式(派克) 3x10";
        如果 (铃 == 1) { 列 = 列 + " | 哑铃推举 4x10 | 哑铃侧平举 3x15 | 哑铃前平举 3x12"; }
        如果 (房 == 1) { 列 = 列 + " | 杠铃推举 4x8 | 绳索面拉 3x15"; }
    }
    如果 (部位 == "臂") {
        列 = "窄距俯卧撑 3x12";
        如果 (铃 == 1) { 列 = 列 + " | 哑铃弯举 4x12 | 哑铃颈后臂屈伸 3x12"; }
        如果 (房 == 1) { 列 = 列 + " | 绳索下压 4x15 | 杠铃弯举 4x10"; }
    }
    如果 (部位 == "核心") {
        列 = "平板支撑 3x60秒 | 卷腹 3x20 | 死虫 3x12 | 俄罗斯转体 3x20";
        如果 (房 == 1) { 列 = 列 + " | 悬垂举腿 3x15"; }
    }
    如果 (部位 == "全身") {
        列 = "波比跳 4x12 | 登山者 3x30秒 | 开合跳 3x40";
        如果 (铃 == 1) { 列 = 列 + " | 哑铃硬拉推举(thruster) 4x10 | 哑铃摆荡 4x15"; }
    }

    如果 (字符串::字节长度(列) == 0) {
        返回 "{\"错误\":\"未知部位，请用 胸/背/腿/肩/臂/核心/全身\"}";
    }
    返回 "{\"部位\":\"" + 部位 + "\",\"器械\":\"" + 器械
        + "\",\"动作\":\"" + 列 + "\"}";
}

// ════════════════════ 工具 3：存盘 ════════════════════
// 入参 JSON：{文件名:"...md", 内容:"markdown 全文"}
函数 save_plan(参数JSON: 字符串) : 字符串 {
    变量 对象: 整数 = JSON.解码(参数JSON);
    变量 文件名: 字符串 = JSON.获取字符串(对象, "文件名");
    变量 内容: 字符串 = JSON.获取字符串(对象, "内容");
    如果 (字符串::字节长度(文件名) == 0) {
        文件名 = "健身计划.md";
    }
    变量 结: 整数 = IO.写入文件(文件名, 内容);
    如果 (结 == 1) {
        返回 "{\"ok\":true,\"路径\":\"" + 文件名 + "\"}";
    }
    返回 "{\"ok\":false,\"错误\":\"写入失败\"}";
}

// ════════════════════ 主流程 ════════════════════
函数 入口() {
    变量 密钥: 字符串 = 系统.获取环境变量("QI_LLM_KEY");
    如果 (字符串::字节长度(密钥) == 0) {
        IO.打印行("未设 QI_LLM_KEY（export QI_LLM_KEY=sk-...）");
        返回;
    }

    变量 端点: 字符串 = 系统.获取环境变量("QI_LLM_ENDPOINT");
    如果 (字符串::字节长度(端点) == 0) {
        端点 = "https://cpa.superleo.app/v1";
    }
    变量 模型: 字符串 = 系统.获取环境变量("QI_LLM_MODEL");
    如果 (字符串::字节长度(模型) == 0) {
        模型 = "gpt-5.6-luna";
    }

    变量 需求: 字符串 = 系统.获取环境变量("QI_FIT_PROFILE");
    如果 (字符串::字节长度(需求) == 0) {
        需求 = "28岁男，175cm，70kg，久坐上班族，目标增肌，每周能练4天，家里有一对可调哑铃";
    }

    变量 配置: 模型配置 = 大模型(端点, 密钥, 模型);
    配置 = 配置系统提示(配置,
        "你是资深私人健身教练。拿到用户身体数据和目标后："
        + "① 先调用 calc_targets 算出每日热量与三大营养素；"
        + "② 按训练频率规划分化（如四练=胸/背/腿/肩臂），对每个训练日调用 exercise_db 取动作；"
        + "③ 汇总成一份 Markdown 计划：开头写热量/营养目标表，然后逐日列动作(组数x次数)，"
        + "再给一段饮食与恢复建议；④ 最后调用 save_plan 存成 健身计划.md。"
        + "动作只能来自 exercise_db 的返回，不要编造。全程用中文，语气专业又鼓励。");

    变量 会话: 整数 = 开启会话(配置);
    如果 (会话 <= 0) {
        IO.打印行("会话开启失败（检查端点/密钥/模型）");
        返回;
    }

    变量 教练: 代理 = 创建代理("私人健身教练", 会话);

    教练 = 添加工具(教练, 新建 工具 {
        名字: "calc_targets",
        描述: "按 Mifflin-St Jeor 公式计算每日 BMR、TDEE、目标热量和三大营养素。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"身高\":{\"type\":\"number\",\"description\":\"厘米\"},\"体重\":{\"type\":\"number\",\"description\":\"千克\"},\"年龄\":{\"type\":\"integer\"},\"性别\":{\"type\":\"string\",\"enum\":[\"男\",\"女\"]},\"活动\":{\"type\":\"string\",\"enum\":[\"久坐\",\"轻度\",\"中度\",\"高度\"]},\"目标\":{\"type\":\"string\",\"enum\":[\"增肌\",\"减脂\",\"维持\"]}},\"required\":[\"身高\",\"体重\",\"年龄\",\"性别\",\"活动\",\"目标\"]}",
        处理: calc_targets,
    });

    教练 = 添加工具(教练, 新建 工具 {
        名字: "exercise_db",
        描述: "按训练部位和可用器械查询推荐动作（含组数x次数）。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"部位\":{\"type\":\"string\",\"enum\":[\"胸\",\"背\",\"腿\",\"肩\",\"臂\",\"核心\",\"全身\"]},\"器械\":{\"type\":\"string\",\"enum\":[\"无器械\",\"哑铃\",\"健身房\"]}},\"required\":[\"部位\",\"器械\"]}",
        处理: exercise_db,
    });

    教练 = 添加工具(教练, 新建 工具 {
        名字: "save_plan",
        描述: "把最终的 Markdown 健身计划写入磁盘文件。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"文件名\":{\"type\":\"string\"},\"内容\":{\"type\":\"string\"}},\"required\":[\"文件名\",\"内容\"]}",
        处理: save_plan,
    });

    IO.打印行("=== 私人健身教练 ===");
    IO.打印行("需求：" + 需求);
    IO.打印行("（教练正在计算热量、编排动作、生成计划……）");
    IO.打印行("");

    变量 回复: 字符串 = 运行(教练,
        "请根据这份情况给我制定完整的一周健身计划，并存盘：" + 需求);

    IO.打印行("");
    IO.打印行("========== 最终计划 ==========");
    IO.打印行(回复);

    关闭代理(教练);
}
