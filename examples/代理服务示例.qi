// 常驻 agent 服务：代理 × qi-web。启动后:
//   curl -XPOST 127.0.0.1:6798/chat -d '{"提示":"用一句话介绍长城"}'
//   curl 127.0.0.1:6798/health
包 主程序;
导入 标准库.操作系统 作为 系统;
导入 Harness.代理服务::{配置服务, 启动代理服务};
函数 入口() {
    配置服务(
        系统.获取环境变量("QI_CHAT_URL"),
        系统.获取环境变量("QI_CHAT_KEY"),
        系统.获取环境变量("QI_CHAT_MODEL"),
        "你是简洁的中文助手，回答尽量短。"
    );
    启动代理服务("127.0.0.1", 6798);
}
