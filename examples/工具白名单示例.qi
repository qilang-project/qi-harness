// qi-harness · 每代理工具白名单（精细权限治理）演示 —— 无需 LLM
//
// 场景：一个代理注册了 2 个工具（查天气、删除文件），但出于权限治理只允许它用「查天气」。
// 我们直接走 dispatch 的白名单判定路径（运行/流式运行 内部用的同一个 工具是否放行 谓词），
// 证明：白名单内的工具照常执行，白名单外的工具被拒绝、不执行、返回错误观测串给模型。
//
// 跑：qi run examples/工具白名单示例.qi   （不联网、无需 API key）

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.大模型 作为 底层模型;
导入 Harness::{
    创建代理, 添加工具, 设置工具白名单, 工具是否放行, 工具, 关闭代理
};
导入 Harness.工具::{派发};
导入 Harness.追踪::{工具被拒事件, 启用};

// ===== 两个本地工具 =====
函数 查天气(参数JSON: 字符串) : 字符串 {
    返回 "{\"city\":\"Beijing\",\"temp\":24,\"condition\":\"晴\"}";
}

函数 删除文件(参数JSON: 字符串) : 字符串 {
    // 危险操作：真跑会删文件。本例它被白名单挡在门外，永远不会被执行。
    返回 "{\"deleted\":true}";
}

// 模拟 dispatch：与 代理.运行 内部逻辑一致 —— 先问白名单，放行才 派发，否则拒绝。
函数 受控派发(代理值: 代理, 工具名: 字符串, 参数JSON: 字符串) : 字符串 {
    如果 (工具是否放行(代理值, 工具名) == 1) {
        变量 结果值: 字符串 = 派发(代理值.工具表, 工具名, 参数JSON);
        IO.打印行("  [放行] " + 工具名 + " → " + 结果值);
        返回 结果值;
    }
    工具被拒事件(代理值.名字, 工具名);
    变量 拒绝: 字符串 = "{\"error\":\"tool_not_allowed\",\"name\":\"" + 工具名 + "\"}";
    IO.打印行("  [拒绝] " + 工具名 + " → " + 拒绝);
    返回 拒绝;
}

函数 入口() {
    启用();

    // 会话句柄仅用于向 provider 注册工具 schema；本演示不发起任何网络对话。
    变量 会话: 整数 = 底层模型.创建会话("http://127.0.0.1:1/v1", "demo", "demo");

    变量 代理值: 代理 = 创建代理("受限代理", 会话);

    变量 天气工具: 工具 = 新建 工具 {
        名字: "查天气",
        描述: "查询城市天气。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"city\":{\"type\":\"string\"}}}",
        处理: 查天气,
    };
    代理值 = 添加工具(代理值, 天气工具);

    变量 删除工具: 工具 = 新建 工具 {
        名字: "删除文件",
        描述: "删除指定文件。",
        参数schema: "{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\"}}}",
        处理: 删除文件,
    };
    代理值 = 添加工具(代理值, 删除工具);

    // 只放行「查天气」，「删除文件」不在白名单内
    代理值 = 设置工具白名单(代理值, "查天气");

    IO.打印行("=== 工具白名单 = \"查天气\" ===");
    IO.打印行("模型试图调用 查天气：");
    受控派发(代理值, "查天气", "{\"city\":\"Beijing\"}");
    IO.打印行("模型试图调用 删除文件：");
    受控派发(代理值, "删除文件", "{\"path\":\"/etc/passwd\"}");

    IO.打印行("");
    IO.打印行("=== 断言 ===");
    如果 (工具是否放行(代理值, "查天气") == 1 && 工具是否放行(代理值, "删除文件") == 0) {
        IO.打印行("PASS：查天气 放行、删除文件 被拒");
    } 否则 {
        IO.打印行("FAIL：白名单判定异常");
    }

    // 空白名单 = 全放行（向后兼容）
    变量 代理值2: 代理 = 创建代理("自由代理", 会话);
    如果 (工具是否放行(代理值2, "删除文件") == 1) {
        IO.打印行("PASS：未设白名单的代理默认全放行（向后兼容）");
    } 否则 {
        IO.打印行("FAIL：默认应全放行");
    }

    关闭代理(代理值);
}
