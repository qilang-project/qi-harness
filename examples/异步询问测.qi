// 异步询问::<T> → 未来<T> —— 语言级并行结构化输出。
//
// 两个 异步询问 并发（不同会话、不同提示）先发后收，与串行两次 询问::<T>
// 计时对比：并行总耗时应显著小于串行（< 70%）证明请求真在飞、不是 eager。
//
// 跑：
//   QI_CHAT_URL="https://.../v1" QI_CHAT_KEY="sk-..." QI_CHAT_MODEL="qwen3.7-plus" \
//   qi run examples/异步询问测.qi
包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 标准库.时间 作为 时间;
导入 标准库.大模型 作为 大模型;

类型 人物 { 姓名: 字符串, 年代: 字符串, 代表作: 字符串 }

函数 开会话() : 整数 {
    返回 大模型.创建会话(
        系统.获取环境变量("QI_CHAT_URL"),
        系统.获取环境变量("QI_CHAT_MODEL"),
        系统.获取环境变量("QI_CHAT_KEY"));
}

函数 入口() {
    // ===== 并行：两个 异步询问 同时在飞，再依次 等待 =====
    变量 会话1: 整数 = 开会话();
    变量 会话2: 整数 = 开会话();

    变量 并行起: 整数 = 时间.现在毫秒();
    变量 f: 未来<人物> = 异步询问::<人物>(会话1, "介绍鲁迅");
    变量 g: 未来<人物> = 异步询问::<人物>(会话2, "介绍老舍");
    变量 p: 人物 = 等待 f;
    变量 q: 人物 = 等待 g;
    变量 并行耗时: 整数 = 时间.现在毫秒() - 并行起;

    IO.打印行("【并行】" + p.姓名 + "（" + p.年代 + "）—— " + p.代表作);
    IO.打印行("【并行】" + q.姓名 + "（" + q.年代 + "）—— " + q.代表作);
    大模型.关闭会话(会话1);
    大模型.关闭会话(会话2);

    // ===== 串行：同样两问逐个 询问::<T> =====
    变量 会话3: 整数 = 开会话();
    变量 会话4: 整数 = 开会话();

    变量 串行起: 整数 = 时间.现在毫秒();
    变量 a: 人物 = 询问::<人物>(会话3, "介绍鲁迅");
    变量 b: 人物 = 询问::<人物>(会话4, "介绍老舍");
    变量 串行耗时: 整数 = 时间.现在毫秒() - 串行起;

    IO.打印行("【串行】" + a.姓名 + "（" + a.年代 + "）—— " + a.代表作);
    IO.打印行("【串行】" + b.姓名 + "（" + b.年代 + "）—— " + b.代表作);
    大模型.关闭会话(会话3);
    大模型.关闭会话(会话4);

    IO.打印行("");
    IO.打印行("并行总耗时: " + 整数转字符串(并行耗时) + " ms");
    IO.打印行("串行总耗时: " + 整数转字符串(串行耗时) + " ms");
    如果 (并行耗时 * 10 < 串行耗时 * 7) {
        IO.打印行("PASS: 并行 < 串行 70%（真并行）");
    } 否则 {
        IO.打印行("WARN: 并行未达 70% 阈值（网络抖动或退化，请复跑）");
    }
}
