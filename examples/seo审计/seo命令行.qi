包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.HTTP;
导入 CLI::{
    应用, 命令, 参数, 上下文,
    创建应用, 创建命令, 创建参数, 执行,
    应用简介, 应用执行, 应用添加命令,
    命令简介, 命令执行, 命令添加参数,
    参数帮助, 值, 整数值
};

函数 执行检查(上下文值: 上下文) : 整数 {
    变量 网址: 字符串 = 值(上下文值, "url");
    如果 (字符串::字节长度(网址) == 0) {
        IO.打印行("用法: seo 检查 <url>");
        返回 1;
    }
    变量 服务地址: 字符串 = "http://127.0.0.1:43517";
    变量 主体: 字符串 = "{\"url\":\"" + 网址 + "\"}";
    变量 响应文本: 字符串 = HTTP.发送(服务地址 + "/api/audit", 主体);
    IO.打印行(响应文本);
    返回 0;
}

函数 执行服务(上下文值: 上下文) : 整数 {
    变量 服务地址: 字符串 = "http://127.0.0.1:43517";
    IO.打印行("请运行核心服务： QI_LLM_KEY=sk-... qi run 服务.qi");
    IO.打印行("它会监听 " + 服务地址);
    返回 0;
}

函数 根执行(上下文值: 上下文) : 整数 {
    IO.打印行("seo —— SEO/GEO 审计器 CLI。用 --help 看子命令");
    返回 0;
}

函数 入口() {
    变量 应用值: 应用 = 创建应用("seo");
    应用值 = 应用简介(应用值, "SEO/GEO 审计器瘦客户端");
    应用值 = 应用执行(应用值, 根执行);

    变量 检查命令: 命令 = 创建命令("检查");
    检查命令 = 命令简介(检查命令, "审计一个 URL（POST 到核心服务）");
    检查命令 = 命令执行(检查命令, 执行检查);
    变量 url参数: 参数 = 创建参数("url");
    url参数 = 参数帮助(url参数, "要审计的网址");
    检查命令 = 命令添加参数(检查命令, url参数);
    应用值 = 应用添加命令(应用值, 检查命令);

    变量 服务命令: 命令 = 创建命令("服务");
    服务命令 = 命令简介(服务命令, "如何启动核心 web 服务");
    服务命令 = 命令执行(服务命令, 执行服务);
    应用值 = 应用添加命令(应用值, 服务命令);

    执行(应用值);
}
