// 可评估 确定性自测（无需 LLM）：包含/精确/正则 三种打分器 + JSON 加载 + 基线回归。
// LLM 裁判（方式 3）见 评估_裁判.qi（需 LLM）。
// 跑：qi run examples/评估_打分测.qi

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 Harness.评估::{评估套件, 创建套件, 从JSON加载, 打分文本, 记录结果, 清空结果, 保存基线, 对比基线};

函数 断言(名: 字符串, 实际: 整数, 期望: 整数, 过: 整数) : 整数 {
    如果 (实际 == 期望) {
        IO.打印行("✅ " + 名);
        返回 过 + 1;
    }
    IO.打印行("❌ " + 名 + "（得 " + 整数转字符串(实际) + " 期望 " + 整数转字符串(期望) + "）");
    返回 过;
}

函数 入口() {
    变量 过: 整数 = 0;

    // 方式 0 包含（裁判会话传 0，方式 0/1/2 用不到）
    过 = 断言("包含命中", 打分文本("hello world", "world", 0, "", 0), 1, 过);
    过 = 断言("包含不中", 打分文本("hello", "world", 0, "", 0), 0, 过);
    // 方式 1 精确
    过 = 断言("精确命中", 打分文本("hello", "hello", 1, "", 0), 1, 过);
    过 = 断言("精确不中", 打分文本("hello!", "hello", 1, "", 0), 0, 过);
    // 方式 2 正则
    过 = 断言("正则命中数字", 打分文本("abc123", "[0-9]+", 2, "", 0), 1, 过);
    过 = 断言("正则无数字", 打分文本("abcdef", "[0-9]+", 2, "", 0), 0, 过);

    // JSON 数据集加载
    变量 套件: 评估套件 = 创建套件();
    变量 条数: 整数 = 从JSON加载(套件, "[{\"名字\":\"a\",\"提示\":\"p1\",\"期望\":\"x\",\"方式\":0},{\"名字\":\"b\",\"提示\":\"p2\",\"期望\":\"y\",\"方式\":2}]");
    过 = 断言("JSON加载2条", 条数, 2, 过);

    // 基线回归：记两条全过 → 存基线 → 清空重记（甲退化）→ 对比应报 1 回归
    变量 套件2: 评估套件 = 创建套件();
    套件2 = 记录结果(套件2, "用例甲", 1);
    套件2 = 记录结果(套件2, "用例乙", 1);
    保存基线(套件2, "/tmp/qi_eval基线.txt");
    套件2 = 清空结果(套件2);
    套件2 = 记录结果(套件2, "用例甲", 0);
    套件2 = 记录结果(套件2, "用例乙", 1);
    变量 回归: 整数 = 对比基线(套件2, "/tmp/qi_eval基线.txt");
    过 = 断言("检测到1个回归", 回归, 1, 过);

    IO.打印行("");
    如果 (过 == 8) {
        IO.打印行("✅ 全部 8 项通过：打分器 + JSON 加载 + 基线回归正确");
        系统.退出程序(0);
    } 否则 {
        IO.打印行("❌ 通过 " + 整数转字符串(过) + "/8");
        系统.退出程序(1);
    }
}
