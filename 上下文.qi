// 上下文 — 上下文窗口管理
//
// LLM 会话历史（Rust 侧 会话.历史）会随轮次无界增长：长对话迟早撑爆模型上下文窗口
// → 报错或天价 token。本模块给 harness 一层窗口管理，两种策略：
//
//   滑窗裁剪（机械、无 LLM、快）：只保留 system 消息 + 最近 N 条，丢掉更早的。
//   摘要压缩（智能、调一次 LLM）：把最早那批消息**摘要成一条 system 消息**，
//                                再接最近 M 条 —— 省 token 又不丢早期要点。
//
// 都靠 runtime 新增的两个口：
//   底层模型.历史JSON(会话)          → 读整段历史（OpenAI 消息数组 JSON）
//   底层模型.设置历史JSON(会话, 数组)  → 整体写回历史
// 于是「数 token / 决定丢谁 / 重建历史」全在 Qi，runtime 只管存取。
//
// ⚠ 令牌数是**估算**（无内置 tokenizer）：按字节数除以经验因子，偏保守（宁可高估
//   触发压缩，也别真撑爆）。用于「要不要压缩」的阈值判断足够，别当计费依据。
//
// 用法：
//   导入 Harness.上下文::{估算令牌, 历史令牌估算, 滑窗裁剪, 摘要压缩, 需要压缩};
//   如果 (需要压缩(会话, 3000) == 1) { 滑窗裁剪(会话, 8); }
//   // 或智能压缩（摘要会话是另开的一个同配置会话，仅供摘要调用，别和主会话混用）：
//   摘要压缩(会话, 摘要会话, 6);

包 Harness;

导入 标准库.字符串;
导入 标准库.大模型 作为 底层模型;
导入 标准库.JSON 作为 J;
导入 Harness.追踪::{事件};

// 每条消息除内容外的固定开销（role/分隔符等），token 估算里给每条加这么多。
变量 每条开销: 整数 = 4;

// 估算一段文本的 token 数（启发式，偏高估）。
// UTF-8 下 ASCII 1 字节、CJK 3 字节；粗略按「字节数 / 3」折算，中英文混排够用。
公开 函数 估算令牌(文本: 字符串) : 整数 {
    返回 字符串::字节长度(文本) / 3;
}

// 估算整段会话历史的 token 总数（逐条内容 + 每条固定开销）。
公开 函数 历史令牌估算(会话句柄: 整数) : 整数 {
    变量 历史JSON: 字符串 = 底层模型.历史JSON(会话句柄);
    变量 历史数组: 整数 = J.解码(历史JSON);
    如果 (历史数组 <= 0) { 返回 0; }
    变量 条数: 整数 = J.数组长度(历史数组);
    变量 合计: 整数 = 0;
    变量 i: 整数 = 0;
    当 (i < 条数) {
        变量 消息: 整数 = J.数组获取对象(历史数组, i);
        变量 内容: 字符串 = J.获取字符串(消息, "content");
        合计 = 合计 + 估算令牌(内容) + 每条开销;
        i = i + 1;
    }
    返回 合计;
}

// 历史 token 估算是否超过上限（1=需要压缩，0=不需要）。
公开 函数 需要压缩(会话句柄: 整数, 令牌上限: 整数) : 整数 {
    如果 (历史令牌估算(会话句柄) > 令牌上限) {
        返回 1;
    }
    返回 0;
}

// 滑窗裁剪 —— 保留所有 system 消息 + 最近 保留最近条数 条非 system 消息，丢掉更早的。
// 机械操作，不调 LLM。返回裁剪后历史条数；历史本就不超则原样返回。
公开 函数 滑窗裁剪(会话句柄: 整数, 保留最近条数: 整数) : 整数 {
    变量 历史JSON: 字符串 = 底层模型.历史JSON(会话句柄);
    变量 历史数组: 整数 = J.解码(历史JSON);
    如果 (历史数组 <= 0) { 返回 0; }
    变量 条数: 整数 = J.数组长度(历史数组);

    // 统计非 system 条数，算出「从第几条起保留」
    变量 非系统数: 整数 = 0;
    变量 i: 整数 = 0;
    当 (i < 条数) {
        变量 消息: 整数 = J.数组获取对象(历史数组, i);
        如果 (字符串::等于(J.获取字符串(消息, "role"), "system") == 0) {
            非系统数 = 非系统数 + 1;
        }
        i = i + 1;
    }
    如果 (非系统数 <= 保留最近条数) {
        返回 条数;   // 没超窗，不动
    }
    变量 丢弃阈值: 整数 = 非系统数 - 保留最近条数;   // 前这么多条非 system 丢掉

    // 重建：system 全留；非 system 只留后段
    变量 新数组: 整数 = J.创建数组();
    变量 已见非系统: 整数 = 0;
    变量 j: 整数 = 0;
    当 (j < 条数) {
        变量 消息: 整数 = J.数组获取对象(历史数组, j);
        如果 (字符串::等于(J.获取字符串(消息, "role"), "system") == 1) {
            J.数组添加对象(新数组, 消息);
        } 否则 {
            如果 (已见非系统 >= 丢弃阈值) {
                J.数组添加对象(新数组, 消息);
            }
            已见非系统 = 已见非系统 + 1;
        }
        j = j + 1;
    }

    变量 结果值: 整数 = 底层模型.设置历史JSON(会话句柄, J.转字符串(新数组));
    事件("context_trim", "上下文", "滑窗裁剪 " + 整数转字符串(条数) + " → " + 整数转字符串(结果值) + " 条");
    返回 结果值;
}

// 摘要压缩 —— 把最早那批非 system 消息摘要成**一条 system 消息**，再接最近
// 保留最近条数 条。摘要会话 是另开的、同配置的一个会话（仅供这次摘要调用；别传主会话，
// 否则摘要请求会污染它的历史）。
//
// 流程：读历史 → 分「待摘要段（早）」和「保留段（最近 M）」→ 把待摘要段拼成文本
// 让 摘要会话 压缩成要点 → 新历史 = 原 system 消息们 + 【摘要 system】 + 保留段。
// 待摘要段为空（历史还没超）则原样返回。返回压缩后历史条数。
公开 函数 摘要压缩(会话句柄: 整数, 摘要会话: 整数, 保留最近条数: 整数) : 整数 {
    变量 历史JSON: 字符串 = 底层模型.历史JSON(会话句柄);
    变量 历史数组: 整数 = J.解码(历史JSON);
    如果 (历史数组 <= 0) { 返回 0; }
    变量 条数: 整数 = J.数组长度(历史数组);

    // 统计非 system 条数
    变量 非系统数: 整数 = 0;
    变量 i: 整数 = 0;
    当 (i < 条数) {
        变量 消息: 整数 = J.数组获取对象(历史数组, i);
        如果 (字符串::等于(J.获取字符串(消息, "role"), "system") == 0) {
            非系统数 = 非系统数 + 1;
        }
        i = i + 1;
    }
    如果 (非系统数 <= 保留最近条数) {
        返回 条数;   // 没超窗，不动
    }
    变量 待摘要数: 整数 = 非系统数 - 保留最近条数;

    // 拼待摘要文本（早段非 system 消息，按 role: content 逐行）
    变量 待摘要文本: 字符串 = "";
    变量 见非系统: 整数 = 0;
    变量 k: 整数 = 0;
    当 (k < 条数) {
        变量 消息: 整数 = J.数组获取对象(历史数组, k);
        如果 (字符串::等于(J.获取字符串(消息, "role"), "system") == 0) {
            如果 (见非系统 < 待摘要数) {
                待摘要文本 = 待摘要文本 + J.获取字符串(消息, "role") + ": "
                    + J.获取字符串(消息, "content") + "\n";
            }
            见非系统 = 见非系统 + 1;
        }
        k = k + 1;
    }

    // 调摘要会话压缩
    变量 摘要提示: 字符串 = "把下面这段对话历史压缩成要点，保留关键事实、决定、用户偏好和未完成事项，"
        + "用简洁条目，不要寒暄：\n\n" + 待摘要文本;
    事件("context_summarize", "上下文", "摘要早段 " + 整数转字符串(待摘要数) + " 条");
    变量 摘要: 字符串 = 底层模型.对话(摘要会话, 摘要提示);

    // 重建历史：原 system 消息们 → 摘要 system → 保留段
    变量 新数组: 整数 = J.创建数组();
    // 1) 原 system 消息
    变量 s: 整数 = 0;
    当 (s < 条数) {
        变量 消息: 整数 = J.数组获取对象(历史数组, s);
        如果 (字符串::等于(J.获取字符串(消息, "role"), "system") == 1) {
            J.数组添加对象(新数组, 消息);
        }
        s = s + 1;
    }
    // 2) 摘要作为一条 system 消息
    变量 摘要消息: 整数 = J.创建对象();
    J.设置字符串(摘要消息, "role", "system");
    J.设置字符串(摘要消息, "content", "【早期对话摘要】\n" + 摘要);
    J.数组添加对象(新数组, 摘要消息);
    // 3) 保留段（最近的非 system）
    变量 见非系统2: 整数 = 0;
    变量 t: 整数 = 0;
    当 (t < 条数) {
        变量 消息: 整数 = J.数组获取对象(历史数组, t);
        如果 (字符串::等于(J.获取字符串(消息, "role"), "system") == 0) {
            如果 (见非系统2 >= 待摘要数) {
                J.数组添加对象(新数组, 消息);
            }
            见非系统2 = 见非系统2 + 1;
        }
        t = t + 1;
    }

    变量 结果值: 整数 = 底层模型.设置历史JSON(会话句柄, J.转字符串(新数组));
    事件("context_compact", "上下文", "摘要压缩 " + 整数转字符串(条数) + " → " + 整数转字符串(结果值) + " 条");
    返回 结果值;
}
