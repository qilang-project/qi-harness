// 预算 — token / 成本 硬上限（防跑飞烧钱）
//
// usage 现在能捕获（大模型.用量），但"捕获 ≠ 管控"：agent 循环跑飞照样烧钱。
// 本模块给一个预算账本：累加每次调用的真实 token、设上限、超限即判定停。
//
// 句柄式（进程内注册表，多 agent 各自独立预算）：
//   变量 预算 = 创建预算(100000, 0);        // 令牌上限 10 万，成本上限 0=不限
//   ...每次 LLM 调用后：
//   记入(预算, 会话);                        // 读 大模型.用量(会话) 累加
//   如果 (超预算(预算) == 1) { 停; }
//   打印行(预算报告(预算));
//
// 成本：无内置定价，用 记入成本(预算, 分) 手动加（按你自己的 $/token 折算成分）。

包 Harness;

导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 标准库.JSON 作为 J;
导入 标准库.大模型 作为 底层模型;
导入 标准库.同步 作为 同步;
导入 Harness.追踪::{事件};
导入 Harness.事件::{发出当前生命周期事件};

// 并行列表注册表：下标即预算句柄
变量 令牌上限表: 整数 = 0;
变量 成本上限表: 整数 = 0;
变量 已用令牌表: 整数 = 0;
变量 已用成本表: 整数 = 0;
变量 已预留令牌表: 整数 = 0;
变量 需对账表: 整数 = 0;
变量 超额令牌表: 整数 = 0;
变量 预算表已建: 整数 = 0;
变量 预算锁: 整数 = 同步.创建锁();

函数 确保表() {
    如果 (预算表已建 == 0) {
        令牌上限表 = 列表库::创建整数列表();
        成本上限表 = 列表库::创建整数列表();
        已用令牌表 = 列表库::创建整数列表();
        已用成本表 = 列表库::创建整数列表();
        已预留令牌表 = 列表库::创建整数列表();
        需对账表 = 列表库::创建整数列表();
        超额令牌表 = 列表库::创建整数列表();
        预算表已建 = 1;
    }
}

函数 发出预算更新(预算句柄: 整数, 种类: 字符串, 增量: 整数, 已用: 整数, 上限: 整数) {
    变量 根: 整数 = J.创建对象();
    J.设置整数(根, "budget_handle", 预算句柄);
    J.设置字符串(根, "kind", 种类);
    J.设置整数(根, "delta", 增量);
    J.设置整数(根, "used", 已用);
    J.设置整数(根, "limit", 上限);
    如果 (上限 > 0 && 已用 >= 上限) { J.设置布尔(根, "exceeded", 1); }
    否则 { J.设置布尔(根, "exceeded", 0); }
    变量 载荷: 字符串 = J.转字符串(根);
    J.删除(根);
    发出当前生命周期事件("budget_update", "预算", 载荷);
}

// 建一个预算账本，返回句柄。令牌上限/成本上限(分) <=0 表示该项不限。
公开 函数 创建预算(令牌上限: 整数, 成本上限分: 整数) : 整数 {
    同步.加锁(预算锁);
    确保表();
    变量 句柄: 整数 = 列表库::整数列表大小(令牌上限表);
    列表库::添加整数(令牌上限表, 令牌上限);
    列表库::添加整数(成本上限表, 成本上限分);
    列表库::添加整数(已用令牌表, 0);
    列表库::添加整数(已用成本表, 0);
    列表库::添加整数(已预留令牌表, 0);
    列表库::添加整数(需对账表, 0);
    列表库::添加整数(超额令牌表, 0);
    同步.解锁(预算锁);
    返回 句柄;
}

// Reliable calls reserve capacity before network dispatch. A limited budget rejects
// reservations that would make used + outstanding reservations exceed the limit.
公开 函数 预留令牌(预算句柄: 整数, 数量: 整数) : 整数 {
    如果 (预算句柄 < 0) { 返回 1; }
    同步.加锁(预算锁);
    确保表();
    如果 (数量 < 0 || 预算句柄 >= 列表库::整数列表大小(令牌上限表)) {
        同步.解锁(预算锁);
        返回 0;
    }
    变量 上限: 整数 = 列表库::获取整数(令牌上限表, 预算句柄);
    变量 已用: 整数 = 列表库::获取整数(已用令牌表, 预算句柄);
    变量 已留: 整数 = 列表库::获取整数(已预留令牌表, 预算句柄);
    如果 (列表库::获取整数(需对账表, 预算句柄) == 1) {
        同步.解锁(预算锁);
        返回 0;
    }
    如果 (上限 > 0 && 已用 + 已留 + 数量 > 上限) {
        同步.解锁(预算锁);
        返回 0;
    }
    列表库::设置整数(已预留令牌表, 预算句柄, 已留 + 数量);
    同步.解锁(预算锁);
    返回 1;
}

// usage_known=0 conservatively charges the full reservation. If a limited-budget
// provider reports more than the admitted reservation, retain the actual charge,
// mark reconciliation required, and reject all later reservations.
公开 函数 结算预留令牌(预算句柄: 整数, 预留数量: 整数, 实际数量: 整数,
                    usage_known: 整数) : 整数 {
    如果 (预算句柄 < 0) { 返回 0; }
    同步.加锁(预算锁);
    确保表();
    如果 (预留数量 < 0 || 实际数量 < 0 || 预算句柄 >= 列表库::整数列表大小(令牌上限表)) {
        同步.解锁(预算锁);
        返回 0 - 1;
    }
    变量 已留: 整数 = 列表库::获取整数(已预留令牌表, 预算句柄);
    如果 (已留 < 预留数量) {
        同步.解锁(预算锁);
        返回 0;
    }
    变量 计费: 整数 = 预留数量;
    如果 (usage_known == 1) { 计费 = 实际数量; }
    列表库::设置整数(已预留令牌表, 预算句柄, 已留 - 预留数量);
    变量 累计: 整数 = 列表库::获取整数(已用令牌表, 预算句柄) + 计费;
    列表库::设置整数(已用令牌表, 预算句柄, 累计);
    变量 上限: 整数 = 列表库::获取整数(令牌上限表, 预算句柄);
    变量 超额: 整数 = 0;
    如果 (上限 > 0 && usage_known == 1 && 实际数量 > 预留数量) {
        超额 = 实际数量 - 预留数量;
        列表库::设置整数(需对账表, 预算句柄, 1);
        列表库::设置整数(超额令牌表, 预算句柄,
            列表库::获取整数(超额令牌表, 预算句柄) + 超额);
    }
    同步.解锁(预算锁);
    发出预算更新(预算句柄, "tokens", 计费, 累计, 上限);
    如果 (超额 > 0) {
        变量 根: 整数 = J.创建对象();
        J.设置整数(根, "budget_handle", 预算句柄);
        J.设置整数(根, "reserved", 预留数量);
        J.设置整数(根, "actual", 实际数量);
        J.设置整数(根, "overrun", 超额);
        J.设置字符串(根, "status", "needs_reconciliation");
        变量 载荷: 字符串 = J.转字符串(根);
        J.删除(根);
        发出当前生命周期事件("budget_overrun", "预算", 载荷);
        返回 0 - 2;
    }
    返回 累计;
}

// 读会话最近一次请求的真实 token 用量，累加进预算。返回累计已用令牌。
公开 函数 记入(预算句柄: 整数, 会话句柄: 整数) : 整数 {
    如果 (预算句柄 < 0) { 返回 0; }
    变量 用量JSON: 字符串 = 底层模型.用量(会话句柄);
    变量 对象: 整数 = J.解码(用量JSON);
    变量 本次: 整数 = 0;
    如果 (对象 > 0) {
        本次 = J.获取整数(对象, "total");
    }
    同步.加锁(预算锁);
    确保表();
    如果 (预算句柄 >= 列表库::整数列表大小(令牌上限表)) {
        同步.解锁(预算锁);
        返回 0 - 1;
    }
    变量 累计: 整数 = 列表库::获取整数(已用令牌表, 预算句柄) + 本次;
    列表库::设置整数(已用令牌表, 预算句柄, 累计);
    变量 上限: 整数 = 列表库::获取整数(令牌上限表, 预算句柄);
    同步.解锁(预算锁);
    事件("budget", "预算", "本次 " + 整数转字符串(本次) + " 令牌，累计 " + 整数转字符串(累计));
    发出预算更新(预算句柄, "tokens", 本次, 累计, 上限);
    返回 累计;
}

// 手动加成本（分）。返回累计已用成本。
公开 函数 记入成本(预算句柄: 整数, 分: 整数) : 整数 {
    如果 (预算句柄 < 0) { 返回 0; }
    同步.加锁(预算锁);
    确保表();
    如果 (预算句柄 >= 列表库::整数列表大小(成本上限表)) {
        同步.解锁(预算锁);
        返回 0 - 1;
    }
    变量 累计: 整数 = 列表库::获取整数(已用成本表, 预算句柄) + 分;
    列表库::设置整数(已用成本表, 预算句柄, 累计);
    变量 上限: 整数 = 列表库::获取整数(成本上限表, 预算句柄);
    同步.解锁(预算锁);
    发出预算更新(预算句柄, "cost_cents", 分, 累计, 上限);
    返回 累计;
}

// 是否达到预算（令牌 或 成本任一达到上限 → 1）。上限 <=0 的项不参与判定。
公开 函数 超预算(预算句柄: 整数) : 整数 {
    如果 (预算句柄 < 0) { 返回 0; }
    同步.加锁(预算锁);
    确保表();
    如果 (预算句柄 >= 列表库::整数列表大小(令牌上限表)) {
        同步.解锁(预算锁);
        返回 0;
    }
    变量 令牌上限: 整数 = 列表库::获取整数(令牌上限表, 预算句柄);
    变量 成本上限: 整数 = 列表库::获取整数(成本上限表, 预算句柄);
    如果 (列表库::获取整数(需对账表, 预算句柄) == 1) {
        同步.解锁(预算锁);
        返回 1;
    }
    如果 (令牌上限 > 0) {
        如果 (列表库::获取整数(已用令牌表, 预算句柄) >= 令牌上限) {
            同步.解锁(预算锁);
            返回 1;
        }
    }
    如果 (成本上限 > 0) {
        如果 (列表库::获取整数(已用成本表, 预算句柄) >= 成本上限) {
            同步.解锁(预算锁);
            返回 1;
        }
    }
    同步.解锁(预算锁);
    返回 0;
}

// 剩余令牌（上限不限时返回 -1 表示无限）。
公开 函数 令牌余量(预算句柄: 整数) : 整数 {
    如果 (预算句柄 < 0) { 返回 0; }
    同步.加锁(预算锁);
    确保表();
    如果 (预算句柄 >= 列表库::整数列表大小(令牌上限表)) {
        同步.解锁(预算锁);
        返回 0;
    }
    变量 令牌上限: 整数 = 列表库::获取整数(令牌上限表, 预算句柄);
    如果 (令牌上限 <= 0) {
        同步.解锁(预算锁);
        返回 0 - 1;
    }
    变量 余量: 整数 = 令牌上限 - 列表库::获取整数(已用令牌表, 预算句柄);
    同步.解锁(预算锁);
    返回 余量;
}

公开 函数 已用令牌(预算句柄: 整数) : 整数 {
    如果 (预算句柄 < 0) { 返回 0; }
    同步.加锁(预算锁);
    确保表();
    如果 (预算句柄 >= 列表库::整数列表大小(已用令牌表)) {
        同步.解锁(预算锁);
        返回 0;
    }
    变量 已用: 整数 = 列表库::获取整数(已用令牌表, 预算句柄);
    同步.解锁(预算锁);
    返回 已用;
}

公开 函数 预算需对账(预算句柄: 整数) : 整数 {
    如果 (预算句柄 < 0) { 返回 0; }
    同步.加锁(预算锁);
    确保表();
    如果 (预算句柄 >= 列表库::整数列表大小(需对账表)) {
        同步.解锁(预算锁);
        返回 0;
    }
    变量 需对账: 整数 = 列表库::获取整数(需对账表, 预算句柄);
    同步.解锁(预算锁);
    返回 需对账;
}

公开 函数 预算超额令牌(预算句柄: 整数) : 整数 {
    如果 (预算句柄 < 0) { 返回 0; }
    同步.加锁(预算锁);
    确保表();
    如果 (预算句柄 >= 列表库::整数列表大小(超额令牌表)) {
        同步.解锁(预算锁);
        返回 0;
    }
    变量 超额: 整数 = 列表库::获取整数(超额令牌表, 预算句柄);
    同步.解锁(预算锁);
    返回 超额;
}

公开 函数 预算报告(预算句柄: 整数) : 字符串 {
    如果 (预算句柄 < 0) { 返回 "无效预算"; }
    同步.加锁(预算锁);
    确保表();
    如果 (预算句柄 >= 列表库::整数列表大小(令牌上限表)) {
        同步.解锁(预算锁);
        返回 "无效预算";
    }
    变量 令牌上限: 整数 = 列表库::获取整数(令牌上限表, 预算句柄);
    变量 已用: 整数 = 列表库::获取整数(已用令牌表, 预算句柄);
    变量 已用成本: 整数 = 列表库::获取整数(已用成本表, 预算句柄);
    变量 上限文本: 字符串 = "不限";
    如果 (令牌上限 > 0) { 上限文本 = 整数转字符串(令牌上限); }
    变量 报告: 字符串 = "预算[令牌 " + 整数转字符串(已用) + "/" + 上限文本
        + " 成本(分) " + 整数转字符串(已用成本) + "]";
    同步.解锁(预算锁);
    返回 报告;
}
