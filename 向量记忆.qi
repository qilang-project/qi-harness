// 向量记忆 — 语义检索的长期记忆（embedding + 余弦相似度）
//
// 记忆.qi 的回忆是 SQL `LIKE '%词%'` 词法匹配：同义不同词就召回不到
// （问「怎么优化性能」召不回存的「提高吞吐」）。本模块用**语义**检索替掉它：
//
//   写入：把内容送 embeddings API 拿到向量，连内容一起落 SQLite（向量存 JSON 列）
//   回忆：把查询也 embed，跟库里每条算**余弦相似度**，按相似度降序取 top-N
//
// 全程纯 Qi + 标准库.HTTP + 标准库.JSON，不动 runtime：
//   - embedding 走 HTTP POST {嵌入端点}/embeddings（OpenAI 兼容），响应向量用
//     J.数组获取浮点数 拆进 浮点列表；
//   - 余弦相似度**在 Qi 里手算**（点积 / 模长，牛顿法开方），不依赖 标准库.向量
//     的原生数组接口，也不需要数学模块。
//
// ⚠ 嵌入端点/模型跟对话模型**分开配**：DeepSeek 没有 /embeddings；OpenAI 用
//   text-embedding-3-small、智谱用 embedding-3、本地可用 ollama 的 nomic-embed-text。
//
// 用法：
//   导入 Harness.向量记忆::{打开向量库, 语义记住, 语义回忆, 关闭向量库};
//   变量 库: 整数 = 打开向量库("/tmp/agent向量记忆.db");
//   语义记住(库, 端点, 密钥, "text-embedding-3-small", "经验", "用连接池提高吞吐", "性能,吞吐", 4);
//   打印行(语义回忆(库, 端点, 密钥, "text-embedding-3-small", "怎么优化性能", 3));
//   关闭向量库(库);

包 Harness;

导入 标准库.数据库;
导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 标准库.JSON 作为 J;
导入 标准库.HTTP 作为 HTTP;
导入 标准库.时间 作为 时间;
导入 Harness.追踪::{事件};

// SQL 转义（单引号翻倍）—— 拼 SQL 唯一入口
函数 转义单引号(原文: 字符串) : 字符串 {
    返回 字符串::替换(原文, "'", "''");
}

// 牛顿法开方（无数学模块依赖）。x<=0 返回 0。40 轮足够 f64 收敛。
函数 平方根(x: 浮点数) : 浮点数 {
    如果 (x <= 0.0) {
        返回 0.0;
    }
    变量 猜: 浮点数 = x;
    变量 i: 整数 = 0;
    当 (i < 40) {
        猜 = (猜 + x / 猜) * 0.5;
        i = i + 1;
    }
    返回 猜;
}

// 打开/建库。向量列存 embedding 的 JSON 数组串。表不存在则建（重开不丢数据）。
公开 函数 打开向量库(库路径: 字符串) : 整数 {
    变量 库: 整数 = 数据库.连接(库路径);
    如果 (库 <= 0) { 返回 0; }
    数据库.执行(库, "CREATE TABLE IF NOT EXISTS 向量记忆 ("
        + "id INTEGER PRIMARY KEY AUTOINCREMENT, "
        + "类型 TEXT NOT NULL, "
        + "内容 TEXT NOT NULL, "
        + "关键词 TEXT NOT NULL DEFAULT '', "
        + "向量 TEXT NOT NULL DEFAULT '', "
        + "重要度 INTEGER NOT NULL DEFAULT 3, "
        + "创建 TEXT NOT NULL DEFAULT '', "
        + "使用次数 INTEGER NOT NULL DEFAULT 0)");
    返回 库;
}

// 调 embeddings API，返回该文本 embedding 的 JSON 数组串（如 "[0.1,-0.2,...]"）；
// 失败返回 ""。请求体用 J 构建（自动转义），带 Bearer 鉴权。
公开 函数 嵌入(嵌入端点: 字符串, 密钥: 字符串, 嵌入模型: 字符串, 文本: 字符串) : 字符串 {
    变量 请求对象: 整数 = J.创建对象();
    J.设置字符串(请求对象, "model", 嵌入模型);
    J.设置字符串(请求对象, "input", 文本);
    变量 请求体: 字符串 = J.转字符串(请求对象);

    变量 句柄: 整数 = HTTP.创建请求("POST", 嵌入端点);
    如果 (句柄 <= 0) { 返回 ""; }
    HTTP.设置请求头(句柄, "Content-Type", "application/json");
    HTTP.设置请求头(句柄, "Authorization", "Bearer " + 密钥);
    HTTP.设置请求体(句柄, 请求体);
    HTTP.设置超时(句柄, 30000);
    变量 响应: 字符串 = HTTP.执行请求(句柄);

    变量 根: 整数 = J.解码(响应);
    如果 (根 <= 0) { 返回 ""; }
    变量 数据: 整数 = J.获取数组(根, "data");
    如果 (数据 <= 0) { 返回 ""; }
    如果 (J.数组长度(数据) == 0) { 返回 ""; }
    变量 首条: 整数 = J.数组获取对象(数据, 0);
    变量 向量数组: 整数 = J.获取数组(首条, "embedding");
    如果 (向量数组 <= 0) { 返回 ""; }
    返回 J.转字符串(向量数组);
}

// 把 JSON 数组串解析成 浮点列表句柄（解析失败返回空列表）。
函数 解析向量(向量JSON: 字符串) : 整数 {
    变量 列: 整数 = 列表库::创建浮点列表();
    变量 数组句柄: 整数 = J.解码(向量JSON);
    如果 (数组句柄 <= 0) { 返回 列; }
    变量 n: 整数 = J.数组长度(数组句柄);
    变量 i: 整数 = 0;
    当 (i < n) {
        列表库::添加浮点数(列, J.数组获取浮点数(数组句柄, i));
        i = i + 1;
    }
    返回 列;
}

// 两个向量（JSON 数组串）的余弦相似度。维度不等/零向量 → 0.0。
公开 函数 余弦相似度(向量A: 字符串, 向量B: 字符串) : 浮点数 {
    变量 va: 整数 = 解析向量(向量A);
    变量 vb: 整数 = 解析向量(向量B);
    变量 na: 整数 = 列表库::浮点列表大小(va);
    变量 nb: 整数 = 列表库::浮点列表大小(vb);
    如果 (na != nb) { 返回 0.0; }
    如果 (na == 0) { 返回 0.0; }

    变量 点积: 浮点数 = 0.0;
    变量 模a: 浮点数 = 0.0;
    变量 模b: 浮点数 = 0.0;
    变量 i: 整数 = 0;
    当 (i < na) {
        变量 x: 浮点数 = 列表库::获取浮点数(va, i);
        变量 y: 浮点数 = 列表库::获取浮点数(vb, i);
        点积 = 点积 + x * y;
        模a = 模a + x * x;
        模b = 模b + y * y;
        i = i + 1;
    }
    如果 (模a <= 0.0) { 返回 0.0; }
    如果 (模b <= 0.0) { 返回 0.0; }
    返回 点积 / (平方根(模a) * 平方根(模b));
}

// 存一条带向量的记忆。先 embed 内容拿向量，连同内容落库。
// embed 失败仍存（向量列留空，退化为可被关键词命中但不参与语义排序）。
// 返回新条目 id；失败返回 0。
公开 函数 语义记住(库: 整数, 嵌入端点: 字符串, 密钥: 字符串, 嵌入模型: 字符串,
                  种类: 字符串, 内容: 字符串, 关键词: 字符串, 重要度: 整数) : 整数 {
    如果 (库 <= 0) { 返回 0; }
    变量 向量JSON: 字符串 = 嵌入(嵌入端点, 密钥, 嵌入模型, 内容);
    如果 (字符串::字节长度(向量JSON) == 0) {
        事件("embed_fail", "向量记忆", "内容未能向量化，仅词法存储: " + 内容);
    }
    变量 现: 字符串 = 时间.格式化本地(时间.现在(), "%Y-%m-%d %H:%M:%S");
    变量 影响: 整数 = 数据库.执行(库,
        "INSERT INTO 向量记忆 (类型, 内容, 关键词, 向量, 重要度, 创建, 使用次数) VALUES ('"
        + 转义单引号(种类) + "', '" + 转义单引号(内容) + "', '" + 转义单引号(关键词) + "', '"
        + 转义单引号(向量JSON) + "', " + 整数转字符串(重要度) + ", '" + 现 + "', 0)");
    如果 (影响 <= 0) { 返回 0; }
    变量 行JSON: 字符串 = 数据库.查询(库, "SELECT last_insert_rowid() AS id");
    变量 数组值: 整数 = J.解码(行JSON);
    如果 (数组值 <= 0) { 返回 0; }
    如果 (J.数组长度(数组值) == 0) { 返回 0; }
    返回 J.获取整数(J.数组获取对象(数组值, 0), "id");
}

// 语义回忆 —— embed 查询，跟库里每条有向量的记忆算余弦，取 top-N。
// 返回可直接注入提示词的文本块（每行 `-【类型】(相似度 0.87) 内容`）；无命中返回 ""。
// 命中条目 使用次数+1。
公开 函数 语义回忆(库: 整数, 嵌入端点: 字符串, 密钥: 字符串, 嵌入模型: 字符串,
                  查询: 字符串, 上限: 整数) : 字符串 {
    如果 (库 <= 0) { 返回 ""; }
    变量 条数上限: 整数 = 上限;
    如果 (条数上限 <= 0) { 条数上限 = 5; }

    变量 查询向量: 字符串 = 嵌入(嵌入端点, 密钥, 嵌入模型, 查询);
    如果 (字符串::字节长度(查询向量) == 0) {
        事件("embed_fail", "向量记忆", "查询未能向量化: " + 查询);
        返回 "";
    }

    // 拉出所有有向量的记忆到并行列表
    变量 行JSON: 字符串 = 数据库.查询(库,
        "SELECT id, 类型, 内容, 向量 FROM 向量记忆 WHERE 向量 != ''");
    变量 数组值: 整数 = J.解码(行JSON);
    如果 (数组值 <= 0) { 返回 ""; }
    变量 总数: 整数 = J.数组长度(数组值);
    如果 (总数 == 0) { 返回 ""; }

    变量 id表: 整数 = 列表库::创建整数列表();
    变量 类型表: 整数 = 列表库::创建字符串列表();
    变量 内容表: 整数 = 列表库::创建字符串列表();
    变量 相似表: 整数 = 列表库::创建浮点列表();
    变量 已取: 整数 = 列表库::创建整数列表();   // 0=未选,1=已选（top-N 选择用）

    变量 i: 整数 = 0;
    当 (i < 总数) {
        变量 行对象: 整数 = J.数组获取对象(数组值, i);
        列表库::添加整数(id表, J.获取整数(行对象, "id"));
        列表库::添加字符串(类型表, J.获取字符串(行对象, "类型"));
        列表库::添加字符串(内容表, J.获取字符串(行对象, "内容"));
        变量 相似: 浮点数 = 余弦相似度(查询向量, J.获取字符串(行对象, "向量"));
        列表库::添加浮点数(相似表, 相似);
        列表库::添加整数(已取, 0);
        i = i + 1;
    }

    // 反复取最大相似度（未选中的），最多取 条数上限 条 —— 简单选择法
    变量 块: 字符串 = "";
    变量 id串: 字符串 = "";
    变量 取数: 整数 = 0;
    当 (取数 < 条数上限) {
        变量 最佳: 整数 = -1;
        变量 最高: 浮点数 = 0.0 - 1.0;   // 相似度可能为负，起始设 -1
        变量 j: 整数 = 0;
        当 (j < 总数) {
            如果 (列表库::获取整数(已取, j) == 0) {
                变量 s: 浮点数 = 列表库::获取浮点数(相似表, j);
                如果 (s > 最高) {
                    最高 = s;
                    最佳 = j;
                }
            }
            j = j + 1;
        }
        如果 (最佳 < 0) {
            取数 = 条数上限;   // 没有更多可选，退出
        } 否则 {
            列表库::设置整数(已取, 最佳, 1);   // 标记已选
            如果 (取数 > 0) {
                块 = 块 + "\n";
                id串 = id串 + ",";
            }
            块 = 块 + "-【" + 列表库::获取字符串(类型表, 最佳) + "】(相似度 "
                + 浮点数转字符串(最高) + ") " + 列表库::获取字符串(内容表, 最佳);
            id串 = id串 + 整数转字符串(列表库::获取整数(id表, 最佳));
            取数 = 取数 + 1;
        }
    }

    如果 (字符串::字节长度(id串) > 0) {
        数据库.执行(库, "UPDATE 向量记忆 SET 使用次数 = 使用次数 + 1 WHERE id IN (" + id串 + ")");
    }
    返回 块;
}

// 库里向量记忆总条数
公开 函数 向量记忆条数(库: 整数) : 整数 {
    如果 (库 <= 0) { 返回 0; }
    变量 行JSON: 字符串 = 数据库.查询(库, "SELECT COUNT(*) AS 条数 FROM 向量记忆");
    变量 数组值: 整数 = J.解码(行JSON);
    如果 (数组值 <= 0) { 返回 0; }
    如果 (J.数组长度(数组值) == 0) { 返回 0; }
    返回 J.获取整数(J.数组获取对象(数组值, 0), "条数");
}

公开 函数 关闭向量库(库: 整数) : 整数 {
    如果 (库 <= 0) { 返回 0; }
    数据库.关闭(库);
    返回 1;
}
