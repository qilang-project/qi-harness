// 图 — 图式控制流（LangGraph-lite）
//
// 线性 agent 循环（代理.qi）只能「工具循环到出文本」，做不了「按中间结果决定走哪条分支」
// ——那正是 agentic workflow 的核心。本模块把执行建成一张**有向图**：
//
//   节点(node) = 一个状态转换：函数(状态JSON) -> 新状态JSON
//   边(edge)   = 从 A 到 B 的跳转，可带**条件**：函数(状态JSON) -> 1 命中 / 0 跳过
//   执行器      = 从起点开始，每步跑节点、按边选下一步，直到 终点() 或超步数
//
// 于是**分支 / 回环 / 循环**都能表达：
//   - 分支：从同一节点出多条条件边，选第一条命中的
//   - 回环：边可指回上游节点（配步数上限防死循环）
//   - 汇合：多个节点都连到同一下游节点
//
// 状态用 JSON 字符串当通用容器（跨节点传递任意结构，避免函数指针签名爆炸）。
// 节点内部想调 LLM / 工具，就在处理函数里用 代理.运行(...) —— 图负责编排，agent 负责干活。
//
// 用法：
//   导入 Harness.图::{图, 创建图, 添加节点, 添加边, 添加条件边, 运行图, 终点};
//   变量 g: 图 = 创建图();
//   g = 添加节点(g, "取数", 我的取数);        // 函数(字符串):字符串
//   g = 添加节点(g, "判断", 我的判断);
//   g = 添加边(g, "取数", "判断");             // 无条件
//   g = 添加条件边(g, "判断", 需要重试, "取数"); // 命中则回环
//   g = 添加边(g, "判断", 终点());             // 否则结束
//   变量 末态: 字符串 = 运行图(g, "取数", "{}", 20);

包 Harness;

导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 标准库.数据库;
导入 标准库.JSON 作为 J;
导入 标准库.时间 作为 时间;
导入 Harness.追踪::{事件};

// 特殊终点节点名 —— 边指向它即结束。用不常见串避免和真实节点名撞。
公开 函数 终点() : 字符串 {
    返回 "__END__";
}

// 图 = 并行列表表示。节点三元组下标对齐；边五元组（从/到/条件）下标对齐。
公开 类型 图 {
    节点名: 整数,        // 字符串列表：节点名字
    节点处理: 整数,      // 指针列表：函数(字符串):字符串（状态 -> 新状态）
    边从: 整数,          // 字符串列表：边的起点节点名
    边到: 整数,          // 字符串列表：边的终点节点名（可为 终点()）
    边条件: 整数,        // 指针列表：函数(字符串):整数（状态 -> 1 命中/0 跳过；无条件边填 恒真）
}

公开 函数 创建图() : 图 {
    返回 (图 {
        节点名: 列表库::创建字符串列表(),
        节点处理: 列表库::创建指针列表(),
        边从: 列表库::创建字符串列表(),
        边到: 列表库::创建字符串列表(),
        边条件: 列表库::创建指针列表(),
    });
}

// 无条件边的默认条件：恒真（永远命中）
函数 恒真(状态: 字符串) : 整数 {
    返回 1;
}

// 加一个节点。处理函数把当前状态 JSON 变成新状态 JSON。
公开 函数 添加节点(图值: 图, 名字: 字符串, 处理: 函数(字符串): 字符串) : 图 {
    列表库::添加字符串(图值.节点名, 名字);
    列表库::添加指针(图值.节点处理, 处理);
    返回 图值;
}

// 加一条无条件边：跑完 `源` 节点后无脑跳到 `目标`。
// （参数不用 从/到 —— `到` 已是区间关键字。）
公开 函数 添加边(图值: 图, 源: 字符串, 目标: 字符串) : 图 {
    列表库::添加字符串(图值.边从, 源);
    列表库::添加字符串(图值.边到, 目标);
    列表库::添加指针(图值.边条件, 恒真);
    返回 图值;
}

// 加一条条件边：跑完 `源` 节点后，若 条件(状态)==1 才跳到 `目标`。
// 同一起点的多条条件边按**添加顺序**取第一条命中的（所以把特例边加在前面、
// 兜底的无条件边加在最后）。
公开 函数 添加条件边(图值: 图, 源: 字符串, 条件: 函数(字符串): 整数, 目标: 字符串) : 图 {
    列表库::添加字符串(图值.边从, 源);
    列表库::添加字符串(图值.边到, 目标);
    列表库::添加指针(图值.边条件, 条件);
    返回 图值;
}

// 按名字找节点处理索引；找不到返回 -1。
函数 查找节点(图值: 图, 名字: 字符串) : 整数 {
    变量 总数: 整数 = 列表库::字符串列表大小(图值.节点名);
    变量 i: 整数 = 0;
    当 (i < 总数) {
        如果 (字符串::等于(列表库::获取字符串(图值.节点名, i), 名字) == 1) {
            返回 i;
        }
        i = i + 1;
    }
    返回 -1;
}

// 选下一步：遍历所有「边从 == 当前」的边，返回第一条 条件(状态)==1 的 边到；
// 都不命中 → 终点()（等价于「没有出边可走就结束」）。
函数 选择下一步(图值: 图, 当前: 字符串, 状态: 字符串) : 字符串 {
    变量 边数: 整数 = 列表库::字符串列表大小(图值.边从);
    变量 i: 整数 = 0;
    当 (i < 边数) {
        如果 (字符串::等于(列表库::获取字符串(图值.边从, i), 当前) == 1) {
            变量 条件: 函数(字符串): 整数 = 列表库::获取指针(图值.边条件, i);
            如果 (条件(状态) == 1) {
                返回 列表库::获取字符串(图值.边到, i);
            }
        }
        i = i + 1;
    }
    返回 终点();
}

// 运行图：从 起点 开始，每步跑 节点处理(状态)->新状态，再按边选下一步，
// 直到走到 终点() 或超过 最大步数。返回最终状态 JSON。每步打 trace（可观测）。
//
// 最大步数 是**防回环死循环**的硬闸：带回环的图必须给够大但有限的上限。
公开 函数 运行图(图值: 图, 起点: 字符串, 初始状态: 字符串, 最大步数: 整数) : 字符串 {
    变量 当前: 字符串 = 起点;
    变量 状态: 字符串 = 初始状态;
    变量 步: 整数 = 0;

    当 (字符串::等于(当前, 终点()) == 0) {
        如果 (步 >= 最大步数) {
            事件("graph_max_steps", "图", "达到步数上限 " + 整数转字符串(最大步数) + "，在节点 " + 当前 + " 处停止");
            返回 状态;
        }
        变量 idx: 整数 = 查找节点(图值, 当前);
        如果 (idx < 0) {
            事件("graph_error", "图", "找不到节点: " + 当前);
            返回 状态;
        }
        事件("graph_node", "图", "进入节点 " + 当前 + " [步 " + 整数转字符串(步) + "]");
        变量 处理: 函数(字符串): 字符串 = 列表库::获取指针(图值.节点处理, idx);
        状态 = 处理(状态);
        变量 下一步: 字符串 = 选择下一步(图值, 当前, 状态);
        事件("graph_edge", "图", 当前 + " → " + 下一步);
        当前 = 下一步;
        步 = 步 + 1;
    }

    事件("graph_done", "图", "终态: " + 状态);
    返回 状态;
}

// ============================================================
// 断点续跑（checkpointing）+ Human-in-the-loop（HITL）
// ============================================================
//
// 内存版 运行图 一崩全丢；长任务 / 要人工审批的流程需要：状态落库、崩溃可 resume、
// 节点可发起「中断」等人工输入。本节把这些做进图执行器，全 SQLite + 纯 Qi。
//
// 状态用 JSON 承载，保留几个下划线键当控制信号（避免引入跨包结构体）：
//   "__中断__"     节点想暂停等人工时，在返回状态里设它 = 给人看的问题文本
//   "__中断问题__" 执行器回填，调用方读它拿到问题
//   "__人工回复__" 恢复图 注入人工答复，下游节点读它
//   "__完成__"     执行器在正常抵达 终点 时设 = "1"
//
// 用法：
//   变量 库: 整数 = 数据库.连接("/tmp/流程.db");
//   变量 结果值: 字符串 = 运行图带检查点(g, 库, "任务001", "起点", "{}", 50);
//   如果 (是中断(结果值) == 1) {
//       打印行("需要人工：" + 中断问题(结果值));
//       // ……拿到人工答复后……
//       结果值 = 恢复图(g, 库, "任务001", 人工答复);
//   }
//   如果 (是完成(结果值) == 1) { 打印行("完成"); }

// 给状态 JSON 加/改一个字符串键，返回新 JSON。
函数 加标记(状态JSON: 字符串, 键: 字符串, 值文本: 字符串) : 字符串 {
    变量 obj: 整数 = J.解码(状态JSON);
    如果 (obj <= 0) { obj = J.创建对象(); }
    J.设置字符串(obj, 键, 值文本);
    返回 J.转字符串(obj);
}

// 读状态 JSON 里某字符串键，缺失返回 ""。
函数 读标记(状态JSON: 字符串, 键: 字符串) : 字符串 {
    变量 obj: 整数 = J.解码(状态JSON);
    如果 (obj <= 0) { 返回 ""; }
    返回 J.获取字符串(obj, 键);
}

// 建检查点表（幂等）。检查点：一个运行ID 一行，存「下一步节点 + 当前状态 + 步数」。
公开 函数 建检查点表(库: 整数) : 整数 {
    如果 (库 <= 0) { 返回 0; }
    数据库.执行(库, "CREATE TABLE IF NOT EXISTS 图检查点 ("
        + "运行ID TEXT PRIMARY KEY, "
        + "节点 TEXT NOT NULL, "
        + "状态 TEXT NOT NULL, "
        + "步 INTEGER NOT NULL DEFAULT 0, "
        + "更新 TEXT NOT NULL DEFAULT '')");
    返回 1;
}

函数 转义单引号(原文: 字符串) : 字符串 {
    返回 字符串::替换(原文, "'", "''");
}

// 存/覆盖一个运行的检查点。
函数 存检查点(库: 整数, 运行ID: 字符串, 节点: 字符串, 状态: 字符串, 步: 整数) {
    如果 (库 <= 0) { 返回; }
    变量 现: 字符串 = 时间.格式化本地(时间.现在(), "%Y-%m-%d %H:%M:%S");
    数据库.执行(库,
        "INSERT OR REPLACE INTO 图检查点 (运行ID, 节点, 状态, 步, 更新) VALUES ('"
        + 转义单引号(运行ID) + "', '" + 转义单引号(节点) + "', '"
        + 转义单引号(状态) + "', " + 整数转字符串(步) + ", '" + 现 + "')");
}

函数 删检查点(库: 整数, 运行ID: 字符串) {
    如果 (库 <= 0) { 返回; }
    数据库.执行(库, "DELETE FROM 图检查点 WHERE 运行ID = '" + 转义单引号(运行ID) + "'");
}

// 有无某运行的检查点（1 有 / 0 无）。
公开 函数 有检查点(库: 整数, 运行ID: 字符串) : 整数 {
    如果 (库 <= 0) { 返回 0; }
    变量 行JSON: 字符串 = 数据库.查询(库,
        "SELECT 节点 FROM 图检查点 WHERE 运行ID = '" + 转义单引号(运行ID) + "'");
    变量 数组值: 整数 = J.解码(行JSON);
    如果 (数组值 <= 0) { 返回 0; }
    如果 (J.数组长度(数组值) == 0) { 返回 0; }
    返回 1;
}

// 结果判定（结果值 = 运行图带检查点/恢复图 的返回状态 JSON）
公开 函数 是中断(结果值: 字符串) : 整数 {
    如果 (字符串::字节长度(读标记(结果值, "__中断问题__")) > 0) { 返回 1; }
    返回 0;
}
公开 函数 中断问题(结果值: 字符串) : 字符串 {
    返回 读标记(结果值, "__中断问题__");
}
公开 函数 是完成(结果值: 字符串) : 整数 {
    如果 (字符串::等于(读标记(结果值, "__完成__"), "1") == 1) { 返回 1; }
    返回 0;
}

// 执行核心：从 (当前, 状态, 步) 跑到 终点/中断/超步。每步存检查点。
// 返回状态 JSON：完成含 "__完成__"="1"；中断含 "__中断问题__"；超步都不含（检查点留着可续）。
函数 图执行循环(图值: 图, 库: 整数, 运行ID: 字符串,
              起始节点: 字符串, 起始状态: 字符串, 起始步: 整数, 最大步数: 整数) : 字符串 {
    变量 当前: 字符串 = 起始节点;
    变量 状态: 字符串 = 起始状态;
    变量 步: 整数 = 起始步;

    当 (字符串::等于(当前, 终点()) == 0) {
        如果 (步 >= 最大步数) {
            事件("graph_max_steps", "图", "达到步数上限 " + 整数转字符串(最大步数) + "（检查点保留，可续跑）");
            存检查点(库, 运行ID, 当前, 状态, 步);
            返回 状态;
        }
        变量 idx: 整数 = 查找节点(图值, 当前);
        如果 (idx < 0) {
            事件("graph_error", "图", "找不到节点: " + 当前);
            返回 状态;
        }
        事件("graph_node", "图", "进入节点 " + 当前 + " [步 " + 整数转字符串(步) + "]");
        变量 处理: 函数(字符串): 字符串 = 列表库::获取指针(图值.节点处理, idx);
        状态 = 处理(状态);

        // 中断检测：节点在返回状态里设了 "__中断__" → 暂停等人工
        变量 问: 字符串 = 读标记(状态, "__中断__");
        如果 (字符串::字节长度(问) > 0) {
            变量 下一步中断: 字符串 = 选择下一步(图值, 当前, 状态);
            存检查点(库, 运行ID, 下一步中断, 状态, 步 + 1);
            事件("graph_interrupt", "图", "在 " + 当前 + " 处中断，等待人工：" + 问);
            返回 加标记(状态, "__中断问题__", 问);
        }

        变量 下一步: 字符串 = 选择下一步(图值, 当前, 状态);
        存检查点(库, 运行ID, 下一步, 状态, 步 + 1);
        事件("graph_edge", "图", 当前 + " → " + 下一步);
        当前 = 下一步;
        步 = 步 + 1;
    }

    删检查点(库, 运行ID);
    事件("graph_done", "图", "终态: " + 状态);
    返回 加标记(状态, "__完成__", "1");
}

// 带检查点运行：若该运行ID已有检查点则从断点续跑，否则从 起点/初始状态 开跑。
// 返回状态 JSON（用 是完成/是中断/中断问题 判定结局）。
公开 函数 运行图带检查点(图值: 图, 库: 整数, 运行ID: 字符串,
                    起点: 字符串, 初始状态: 字符串, 最大步数: 整数) : 字符串 {
    建检查点表(库);
    如果 (有检查点(库, 运行ID) == 1) {
        事件("graph_resume", "图", "运行 " + 运行ID + " 存在检查点，续跑");
        返回 续跑(库, 图值, 运行ID, 最大步数, "");
    }
    返回 图执行循环(图值, 库, 运行ID, 起点, 初始状态, 0, 最大步数);
}

// 从检查点续跑（内部）。人工回复非空则注入状态 "__人工回复__" 并清掉中断标记。
函数 续跑(库: 整数, 图值: 图, 运行ID: 字符串, 最大步数: 整数, 人工回复: 字符串) : 字符串 {
    变量 行JSON: 字符串 = 数据库.查询(库,
        "SELECT 节点, 状态, 步 FROM 图检查点 WHERE 运行ID = '" + 转义单引号(运行ID) + "'");
    变量 数组值: 整数 = J.解码(行JSON);
    如果 (数组值 <= 0) { 返回 "{}"; }
    如果 (J.数组长度(数组值) == 0) { 返回 "{}"; }
    变量 行: 整数 = J.数组获取对象(数组值, 0);
    变量 节点: 字符串 = J.获取字符串(行, "节点");
    变量 状态: 字符串 = J.获取字符串(行, "状态");
    变量 步: 整数 = J.获取整数(行, "步");

    // 注入人工回复：设 __人工回复__，去掉 __中断__（避免刚续跑又被判成中断）
    如果 (字符串::字节长度(人工回复) > 0) {
        状态 = 加标记(状态, "__人工回复__", 人工回复);
        状态 = 加标记(状态, "__中断__", "");
    }
    返回 图执行循环(图值, 库, 运行ID, 节点, 状态, 步, 最大步数);
}

// 恢复图：给一个中断中的运行注入人工答复，从断点继续。返回新的结果状态 JSON。
公开 函数 恢复图(图值: 图, 库: 整数, 运行ID: 字符串, 人工回复: 字符串) : 字符串 {
    如果 (有检查点(库, 运行ID) == 0) {
        事件("graph_error", "图", "恢复失败：运行 " + 运行ID + " 无检查点");
        返回 "{}";
    }
    事件("graph_resume", "图", "运行 " + 运行ID + " 注入人工回复续跑");
    返回 续跑(库, 图值, 运行ID, 1000000, 人工回复);
}
