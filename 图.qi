// 图 — 图式控制流（LangGraph-lite）
//
// 线性 agent 循环（代理.qi）只能「工具循环到出文本」，做不了「按中间结果决定走哪条分支」
// ——那正是 agentic workflow 的核心。本模块把执行建成一张**有向图**：
//
//   节点(node) = 一个状态转换：函数(状态JSON) -> 新状态JSON
//   边(edge)   = 从 A 到 B 的跳转，可带**条件**：函数(状态JSON) -> 1 命中 / 0 跳过
//   执行器      = 从起点开始，每步跑节点、按边选下一步，直到 终点() 或超步数
//
// 于是**分支 / 回环 / 循环**都能表达：
//   - 分支：从同一节点出多条条件边，选第一条命中的
//   - 回环：边可指回上游节点（配步数上限防死循环）
//   - 汇合：多个节点都连到同一下游节点
//
// 状态用 JSON 字符串当通用容器（跨节点传递任意结构，避免函数指针签名爆炸）。
// 节点内部想调 LLM / 工具，就在处理函数里用 代理.运行(...) —— 图负责编排，agent 负责干活。
//
// 用法：
//   导入 Harness.图::{图, 创建图, 添加节点, 添加边, 添加条件边, 运行图, 终点};
//   变量 g: 图 = 创建图();
//   g = 添加节点(g, "取数", 我的取数);        // 函数(字符串):字符串
//   g = 添加节点(g, "判断", 我的判断);
//   g = 添加边(g, "取数", "判断");             // 无条件
//   g = 添加条件边(g, "判断", 需要重试, "取数"); // 命中则回环
//   g = 添加边(g, "判断", 终点());             // 否则结束
//   变量 末态: 字符串 = 运行图(g, "取数", "{}", 20);

包 Harness;

导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 Harness.追踪::{事件};

// 特殊终点节点名 —— 边指向它即结束。用不常见串避免和真实节点名撞。
公开 函数 终点() : 字符串 {
    返回 "__END__";
}

// 图 = 并行列表表示。节点三元组下标对齐；边五元组（从/到/条件）下标对齐。
公开 类型 图 {
    节点名: 整数,        // 字符串列表：节点名字
    节点处理: 整数,      // 指针列表：函数(字符串):字符串（状态 -> 新状态）
    边从: 整数,          // 字符串列表：边的起点节点名
    边到: 整数,          // 字符串列表：边的终点节点名（可为 终点()）
    边条件: 整数,        // 指针列表：函数(字符串):整数（状态 -> 1 命中/0 跳过；无条件边填 恒真）
}

公开 函数 创建图() : 图 {
    返回 (图 {
        节点名: 列表库::创建字符串列表(),
        节点处理: 列表库::创建指针列表(),
        边从: 列表库::创建字符串列表(),
        边到: 列表库::创建字符串列表(),
        边条件: 列表库::创建指针列表(),
    });
}

// 无条件边的默认条件：恒真（永远命中）
函数 恒真(状态: 字符串) : 整数 {
    返回 1;
}

// 加一个节点。处理函数把当前状态 JSON 变成新状态 JSON。
公开 函数 添加节点(图值: 图, 名字: 字符串, 处理: 函数(字符串): 字符串) : 图 {
    列表库::添加字符串(图值.节点名, 名字);
    列表库::添加指针(图值.节点处理, 处理);
    返回 图值;
}

// 加一条无条件边：跑完 `源` 节点后无脑跳到 `目标`。
// （参数不用 从/到 —— `到` 已是区间关键字。）
公开 函数 添加边(图值: 图, 源: 字符串, 目标: 字符串) : 图 {
    列表库::添加字符串(图值.边从, 源);
    列表库::添加字符串(图值.边到, 目标);
    列表库::添加指针(图值.边条件, 恒真);
    返回 图值;
}

// 加一条条件边：跑完 `源` 节点后，若 条件(状态)==1 才跳到 `目标`。
// 同一起点的多条条件边按**添加顺序**取第一条命中的（所以把特例边加在前面、
// 兜底的无条件边加在最后）。
公开 函数 添加条件边(图值: 图, 源: 字符串, 条件: 函数(字符串): 整数, 目标: 字符串) : 图 {
    列表库::添加字符串(图值.边从, 源);
    列表库::添加字符串(图值.边到, 目标);
    列表库::添加指针(图值.边条件, 条件);
    返回 图值;
}

// 按名字找节点处理索引；找不到返回 -1。
函数 查找节点(图值: 图, 名字: 字符串) : 整数 {
    变量 总数: 整数 = 列表库::字符串列表大小(图值.节点名);
    变量 i: 整数 = 0;
    当 (i < 总数) {
        如果 (字符串::等于(列表库::获取字符串(图值.节点名, i), 名字) == 1) {
            返回 i;
        }
        i = i + 1;
    }
    返回 -1;
}

// 选下一步：遍历所有「边从 == 当前」的边，返回第一条 条件(状态)==1 的 边到；
// 都不命中 → 终点()（等价于「没有出边可走就结束」）。
函数 选择下一步(图值: 图, 当前: 字符串, 状态: 字符串) : 字符串 {
    变量 边数: 整数 = 列表库::字符串列表大小(图值.边从);
    变量 i: 整数 = 0;
    当 (i < 边数) {
        如果 (字符串::等于(列表库::获取字符串(图值.边从, i), 当前) == 1) {
            变量 条件: 函数(字符串): 整数 = 列表库::获取指针(图值.边条件, i);
            如果 (条件(状态) == 1) {
                返回 列表库::获取字符串(图值.边到, i);
            }
        }
        i = i + 1;
    }
    返回 终点();
}

// 运行图：从 起点 开始，每步跑 节点处理(状态)->新状态，再按边选下一步，
// 直到走到 终点() 或超过 最大步数。返回最终状态 JSON。每步打 trace（可观测）。
//
// 最大步数 是**防回环死循环**的硬闸：带回环的图必须给够大但有限的上限。
公开 函数 运行图(图值: 图, 起点: 字符串, 初始状态: 字符串, 最大步数: 整数) : 字符串 {
    变量 当前: 字符串 = 起点;
    变量 状态: 字符串 = 初始状态;
    变量 步: 整数 = 0;

    当 (字符串::等于(当前, 终点()) == 0) {
        如果 (步 >= 最大步数) {
            事件("graph_max_steps", "图", "达到步数上限 " + 整数转字符串(最大步数) + "，在节点 " + 当前 + " 处停止");
            返回 状态;
        }
        变量 idx: 整数 = 查找节点(图值, 当前);
        如果 (idx < 0) {
            事件("graph_error", "图", "找不到节点: " + 当前);
            返回 状态;
        }
        事件("graph_node", "图", "进入节点 " + 当前 + " [步 " + 整数转字符串(步) + "]");
        变量 处理: 函数(字符串): 字符串 = 列表库::获取指针(图值.节点处理, idx);
        状态 = 处理(状态);
        变量 下一步: 字符串 = 选择下一步(图值, 当前, 状态);
        事件("graph_edge", "图", 当前 + " → " + 下一步);
        当前 = 下一步;
        步 = 步 + 1;
    }

    事件("graph_done", "图", "终态: " + 状态);
    返回 状态;
}
