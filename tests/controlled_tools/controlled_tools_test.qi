包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 标准库.JSON 作为 J;
导入 Harness.工具::{工具};
导入 Harness.受控工具::{工具执行策略, 工具调用上下文, 工具进度, 工具结果, 受控工具,
    默认工具执行策略, 并行只读工具策略, 创建受控工具, 适配旧工具,
    受控工具执行策略, 创建工具调用上下文, 执行受控工具,
    工具文本结果, 工具JSON结果, 工具失败结果, 工具结果转JSON, 工具结果模型文本,
    工具已取消, 请求工具取消, 工具取消原因, 报告工具进度, 工具进度列表JSON,
    标记工具控制终止, 规划工具波次};

函数 断言(条件: 整数, 名字: 字符串) : 整数 {
    如果 (条件 == 1) { IO.打印行("PASS " + 名字); 返回 1; }
    IO.打印行("FAIL " + 名字);
    返回 0;
}

函数 旧处理(参数JSON: 字符串) : 字符串 {
    返回 "legacy-visible:" + 参数JSON;
}

函数 新处理(ctx: 工具调用上下文, 参数JSON: 字符串) : 工具结果 {
    返回 工具文本结果("controlled:" + 参数JSON);
}

函数 新工具(名字: 字符串, 策略: 工具执行策略) : 受控工具 {
    返回 创建受控工具(名字, 名字, "{\"type\":\"object\"}", 新处理, 策略);
}

函数 入口() {
    变量 通过: 整数 = 0;

    变量 JSON结果: 工具结果 = 工具JSON结果("{\"answer\":42}");
    JSON结果.元数据JSON = "{\"source\":\"test\"}";
    变量 结果根: 整数 = J.解码(工具结果转JSON(JSON结果));
    通过 = 通过 + 断言(J.获取整数(结果根, "version") == 1
        && 字符串::等于(J.获取字符串(结果根, "status"), "success") == 1
        && 字符串::等于(J.获取字符串(结果根, "content_type"), "json") == 1
        && 字符串::等于(J.获取字符串(J.获取对象(结果根, "metadata"), "source"), "test") == 1,
        "result_serialization");
    J.删除(结果根);

    变量 旧值: 工具 = 新建 工具 {
        名字: "legacy", 描述: "legacy", 参数schema: "{\"type\":\"object\"}", 处理: 旧处理,
    };
    变量 旧适配: 受控工具 = 适配旧工具(旧值);
    变量 旧上下文: 工具调用上下文 = 创建工具调用上下文(旧适配, "r", "t", "s", "c", -1);
    变量 旧结果: 工具结果 = 执行受控工具(旧适配, 旧上下文, "{\"x\":1}");
    通过 = 通过 + 断言(字符串::等于(工具结果模型文本(旧适配, 旧结果),
        "legacy-visible:{\"x\":1}") == 1 && 受控工具执行策略(旧适配).模式 == 0,
        "legacy_projection_and_parallel_policy");

    通过 = 通过 + 断言(工具已取消(旧上下文) == 0
        && 请求工具取消(旧上下文.控制句柄, "operator") == 1
        && 工具已取消(旧上下文) == 1
        && 字符串::等于(工具取消原因(旧上下文.控制句柄), "operator") == 1,
        "cooperative_cancellation_state");

    变量 受控: 受控工具 = 新工具("progress", 默认工具执行策略());
    变量 ctx: 工具调用上下文 = 创建工具调用上下文(受控, "r", "t", "s", "p", -1);
    报告工具进度(ctx, 新建 工具进度 {
        阶段: "scan", 消息: "first", 当前: 1, 总数: 2, 数据JSON: "{}",
    });
    报告工具进度(ctx, 新建 工具进度 {
        阶段: "write", 消息: "second", 当前: 2, 总数: 2, 数据JSON: "{}",
    });
    标记工具控制终止(ctx.控制句柄);
    变量 终态后: 整数 = 报告工具进度(ctx, 新建 工具进度 {
        阶段: "late", 消息: "ignored", 当前: 3, 总数: 3, 数据JSON: "{}",
    });
    变量 进度组: 整数 = J.解码(工具进度列表JSON(ctx.控制句柄));
    通过 = 通过 + 断言(J.数组长度(进度组) == 2
        && J.获取整数(J.数组获取对象(进度组, 0), "sequence") == 1
        && J.获取整数(J.数组获取对象(进度组, 1), "sequence") == 2
        && 字符串::等于(J.获取字符串(J.数组获取对象(进度组, 0), "message"), "first") == 1
        && 字符串::等于(J.获取字符串(J.数组获取对象(进度组, 1), "message"), "second") == 1
        && 终态后 == 0, "progress_order_and_terminal_rejection");
    J.删除(进度组);

    变量 幂等策略: 工具执行策略 = 默认工具执行策略();
    幂等策略.执行器 = 3;
    幂等策略.副作用模式 = 1;
    幂等策略.幂等键模式 = 1;
    幂等策略.并发键 = "account:42";
    变量 幂等工具: 受控工具 = 新工具("idempotent", 幂等策略);
    变量 读回: 工具执行策略 = 受控工具执行策略(幂等工具);
    通过 = 通过 + 断言(读回.执行器 == 3 && 读回.副作用模式 == 1
        && 读回.幂等键模式 == 1
        && 字符串::等于(读回.并发键, "account:42") == 1,
        "side_effect_and_executor_metadata");

    变量 并行策略: 工具执行策略 = 并行只读工具策略();
    变量 甲: 受控工具 = 新工具("a", 并行策略);
    变量 乙: 受控工具 = 新工具("b", 并行策略);
    变量 串行: 受控工具 = 新工具("serial", 默认工具执行策略());
    变量 同键策略: 工具执行策略 = 并行只读工具策略();
    同键策略.并发键 = "shared";
    变量 同键: 受控工具 = 新工具("keyed", 同键策略);
    变量 调用表: 整数 = 列表库::创建整数列表();
    列表库::添加整数(调用表, 甲.句柄);
    列表库::添加整数(调用表, 乙.句柄);
    列表库::添加整数(调用表, 串行.句柄);
    列表库::添加整数(调用表, 同键.句柄);
    列表库::添加整数(调用表, 同键.句柄);
    变量 规划: 整数 = J.解码(规划工具波次(调用表, 5, 0));
    变量 阶段: 整数 = J.获取数组(规划, "stages");
    通过 = 通过 + 断言(J.数组长度(阶段) == 4
        && 字符串::等于(J.获取字符串(J.数组获取对象(阶段, 0), "kind"), "wave") == 1
        && J.数组长度(J.获取数组(J.数组获取对象(阶段, 0), "calls")) == 2
        && 字符串::等于(J.获取字符串(J.数组获取对象(阶段, 1), "kind"), "barrier") == 1
        && J.数组获取整数(J.获取数组(J.数组获取对象(阶段, 1), "calls"), 0) == 2
        && J.数组获取整数(J.获取数组(J.数组获取对象(阶段, 2), "calls"), 0) == 3
        && J.数组获取整数(J.获取数组(J.数组获取对象(阶段, 3), "calls"), 0) == 4,
        "deterministic_wave_barrier_and_concurrency_key_planning");
    J.删除(规划);

    如果 (通过 == 6) { IO.打印行("PASS controlled_tools_total_6"); }
    否则 { IO.打印行("FAIL controlled_tools_total=" + 整数转字符串(通过)); }
}
