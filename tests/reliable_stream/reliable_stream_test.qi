包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 标准库.字符串;
导入 标准库.JSON 作为 J;
导入 标准库.大模型 作为 底层模型;
导入 标准库.时间;
导入 标准库.数据库;
导入 Harness.模型::{大模型, 开启会话};
导入 Harness.代理::{代理, 创建代理, 关闭代理, 附加预算};
导入 Harness.运行日志::{打开运行日志, 关闭运行日志, 获取模型尝试JSON, 获取代理运行JSON,
    创建代理运行, 获取运行租约, 追加流运行事件, 列出运行事件, 获取运行预算JSON};
导入 Harness.预算::{创建预算, 已用令牌};
导入 Harness.安全上下文::{安全上下文, 安全会话绑定, 安全上下文配置,
    可信适配器创建安全上下文, 可信适配器绑定安全会话,
    释放安全会话绑定, 释放安全上下文};
导入 Harness.可靠流::{可靠流配置, 取消令牌, 流运行结果, 可靠流作用域, 默认可靠流配置,
    配置可靠流重试, 配置可靠流预算预留, 配置可靠流超时, 创建取消令牌, 创建可靠流作用域, 释放可靠流作用域,
    可靠流式运行, 重放流事件, 流结果状态, 流结果运行ID, 流结果文本,
    流结果错误JSON, 流结果最后序号, 恢复过期可靠流运行,
    释放流运行结果, 释放取消令牌, 释放可靠流配置};

变量 事件数: 整数 = 0;
变量 文本事件数: 整数 = 0;
变量 重放数: 整数 = 0;
变量 故障库: 整数 = 0;

函数 断言(条件: 整数, 名字: 字符串) : 整数 {
    如果 (条件 == 1) { IO.打印行("PASS " + 名字); 返回 1; }
    IO.打印行("FAIL " + 名字);
    返回 0;
}

函数 接受事件(事件JSON: 字符串) : 整数 {
    事件数 = 事件数 + 1;
    如果 (字符串::包含(事件JSON, "text.delta") == 1) { 文本事件数 = 文本事件数 + 1; }
    返回 1;
}

函数 文本后取消(事件JSON: 字符串) : 整数 {
    如果 (字符串::包含(事件JSON, "text.delta") == 1) { 返回 0; }
    返回 1;
}

函数 接受重放(事件JSON: 字符串) : 整数 {
    重放数 = 重放数 + 1;
    返回 1;
}

函数 抢占预留后栅栏(事件JSON: 字符串) : 整数 {
    如果 (字符串::包含(事件JSON, "budget.reserved") == 1) {
        变量 事件: 整数 = J.解码(事件JSON);
        变量 运行ID: 字符串 = J.获取字符串(事件, "run_id");
        数据库.执行(故障库, "UPDATE agent_runs SET lease_expires_at = 0 WHERE run_id = '" + 运行ID + "'");
        获取运行租约(故障库, 运行ID, "takeover", 时间.当前毫秒(), 时间.当前毫秒() + 30000);
    }
    返回 1;
}

函数 注入终态写失败(事件JSON: 字符串) : 整数 {
    如果 (字符串::包含(事件JSON, "run.committing_final") == 1) {
        变量 事件: 整数 = J.解码(事件JSON);
        变量 运行ID: 字符串 = J.获取字符串(事件, "run_id");
        数据库.执行(故障库, "CREATE TRIGGER terminal_commit_failure AFTER INSERT ON agent_run_events "
            + "WHEN NEW.run_id = '" + 运行ID + "' AND NEW.type = 'run.completed' "
            + "BEGIN INSERT INTO reliable_deferred_child(id) VALUES ('missing-terminal'); END");
    }
    返回 1;
}

函数 新安全上下文(租户ID: 字符串) : 安全上下文 {
    返回 可信适配器创建安全上下文(新建 安全上下文配置 {
        主体ID: "reliable-test", 租户ID: 租户ID, 角色: "operator",
        权限: "stream.execute,stream.replay,stream.recover", 认证方式: "trusted-test-adapter",
        到期毫秒: 时间.当前毫秒() + 600000, 追踪ID: "trace-reliable",
        请求配额: 100, 令牌配额: 100000, 策略引用: "reliable-test-policy",
    });
}

函数 新代理(路径: 字符串) : 代理 {
    变量 配置 = 大模型(系统.获取环境变量("QI_TEST_URL") + 路径, "fixture-key", "fixture-model");
    返回 创建代理("reliable-stream-test", 开启会话(配置));
}

函数 跑(作用域: 可靠流作用域, 代理值: 代理, 提示: 字符串, 请求ID: 字符串,
        配置值: 可靠流配置, 令牌: 取消令牌,
        回调: 函数(字符串): 整数) : 流运行结果 {
    返回 可靠流式运行(作用域, 代理值, 提示, 请求ID, 配置值, 令牌, 回调);
}

函数 入口() {
    变量 路径: 字符串 = 系统.获取环境变量("QI_STREAM_TEST_DB");
    变量 库: 整数 = 打开运行日志(路径);
    故障库 = 库;
    变量 上下文值: 安全上下文 = 新安全上下文("tenant-fixture");
    变量 会话绑定: 安全会话绑定 = 可信适配器绑定安全会话(上下文值, "session-fixture");
    变量 作用域: 可靠流作用域 = 创建可靠流作用域(会话绑定, 库);
    变量 配置值: 可靠流配置 = 配置可靠流重试(默认可靠流配置(), 2, 1, 2);
    变量 通过: 整数 = 0;

    变量 成功代理: 代理 = 新代理("/v1/success");
    变量 成功令牌: 取消令牌 = 创建取消令牌();
    变量 成功: 流运行结果 = 跑(作用域, 成功代理, "success", "req-success", 配置值, 成功令牌, 接受事件);
    通过 = 通过 + 断言(字符串::等于(流结果状态(成功), "completed") == 1
        && 字符串::等于(流结果文本(成功), "ok-success") == 1, "success_completed");
    通过 = 通过 + 断言(底层模型.历史版本(成功代理.会话句柄) == 1, "success_committed_revision");

    变量 重试预算: 整数 = 创建预算(12, 0);
    变量 重试配置: 可靠流配置 = 配置可靠流预算预留(
        配置可靠流重试(默认可靠流配置(), 2, 1, 2), 6);
    变量 重试代理: 代理 = 附加预算(新代理("/v1/retry"), 重试预算);
    变量 重试令牌: 取消令牌 = 创建取消令牌();
    变量 重试结果: 流运行结果 = 跑(作用域, 重试代理, "retry", "req-retry", 重试配置, 重试令牌, 接受事件);
    通过 = 通过 + 断言(字符串::等于(流结果状态(重试结果), "completed") == 1
        && J.数组长度(J.解码(获取模型尝试JSON(库, 流结果运行ID(重试结果)))) == 2
        && J.数组长度(J.解码(获取运行预算JSON(库, 流结果运行ID(重试结果)))) == 2
        && 已用令牌(重试预算) == 9,
        "pre_output_500_retried_once_and_each_attempt_reserved");

    变量 部分代理: 代理 = 新代理("/v1/partial");
    变量 部分令牌: 取消令牌 = 创建取消令牌();
    变量 部分结果: 流运行结果 = 跑(作用域, 部分代理, "partial", "req-partial", 配置值, 部分令牌, 接受事件);
    通过 = 通过 + 断言(字符串::等于(流结果状态(部分结果), "incomplete") == 1
        && 字符串::等于(流结果文本(部分结果), "partial") == 1
        && J.数组长度(J.解码(获取模型尝试JSON(库, 流结果运行ID(部分结果)))) == 1,
        "partial_eof_not_retried");
    通过 = 通过 + 断言(底层模型.历史版本(部分代理.会话句柄) == 0, "partial_aborted_history");

    变量 取消代理: 代理 = 新代理("/v1/cancel");
    变量 取消令牌值: 取消令牌 = 创建取消令牌();
    变量 取消结果: 流运行结果 = 跑(作用域, 取消代理, "cancel", "req-cancel", 配置值, 取消令牌值, 文本后取消);
    通过 = 通过 + 断言(字符串::等于(流结果状态(取消结果), "cancelled") == 1,
        "callback_zero_cancels");
    通过 = 通过 + 断言(底层模型.历史版本(取消代理.会话句柄) == 0, "cancel_does_not_commit");

    变量 首输出配置: 可靠流配置 = 配置可靠流超时(
        配置可靠流重试(默认可靠流配置(), 1, 0, 0), 60, 500, 1000);
    变量 首输出代理: 代理 = 新代理("/v1/stall-before-first");
    变量 首输出令牌: 取消令牌 = 创建取消令牌();
    变量 首输出开始: 整数 = 时间.当前毫秒();
    变量 首输出结果: 流运行结果 = 跑(作用域, 首输出代理, "stall-before-first",
        "req-stall-before-first", 首输出配置, 首输出令牌, 接受事件);
    变量 首输出事件: 字符串 = 列出运行事件(库, 流结果运行ID(首输出结果), 0);
    通过 = 通过 + 断言(字符串::等于(流结果状态(首输出结果), "failed") == 1
        && 字符串::包含(流结果错误JSON(首输出结果), "first_output_timeout") == 1
        && 字符串::包含(首输出事件, "attempt.timeout") == 1
        && 字符串::包含(获取模型尝试JSON(库, 流结果运行ID(首输出结果)), "timed_out") == 1
        && 时间.当前毫秒() - 首输出开始 < 500,
        "stall_before_first_enforces_and_persists_timeout");

    变量 空闲配置: 可靠流配置 = 配置可靠流超时(
        配置可靠流重试(默认可靠流配置(), 1, 0, 0), 500, 60, 1000);
    变量 空闲代理: 代理 = 新代理("/v1/stall-midstream");
    变量 空闲令牌: 取消令牌 = 创建取消令牌();
    变量 空闲开始: 整数 = 时间.当前毫秒();
    变量 空闲结果: 流运行结果 = 跑(作用域, 空闲代理, "stall-midstream",
        "req-stall-midstream", 空闲配置, 空闲令牌, 接受事件);
    变量 空闲事件: 字符串 = 列出运行事件(库, 流结果运行ID(空闲结果), 0);
    通过 = 通过 + 断言(字符串::等于(流结果状态(空闲结果), "incomplete") == 1
        && 字符串::等于(流结果文本(空闲结果), "before-stall") == 1
        && 字符串::包含(流结果错误JSON(空闲结果), "idle_timeout") == 1
        && 字符串::包含(空闲事件, "attempt.timeout") == 1
        && 时间.当前毫秒() - 空闲开始 < 500,
        "stall_midstream_enforces_idle_timeout");

    变量 总超时配置: 可靠流配置 = 配置可靠流超时(
        配置可靠流重试(默认可靠流配置(), 1, 0, 0), 500, 500, 120);
    变量 总超时代理: 代理 = 新代理("/v1/total-deadline");
    变量 总超时令牌: 取消令牌 = 创建取消令牌();
    变量 总超时结果: 流运行结果 = 跑(作用域, 总超时代理, "total-deadline",
        "req-total-deadline", 总超时配置, 总超时令牌, 接受事件);
    通过 = 通过 + 断言(字符串::等于(流结果状态(总超时结果), "incomplete") == 1
        && 字符串::包含(流结果错误JSON(总超时结果), "total_timeout") == 1
        && 字符串::包含(列出运行事件(库, 流结果运行ID(总超时结果), 0), "attempt.timeout") == 1,
        "total_deadline_enforced_while_reading");

    变量 幂等代理: 代理 = 新代理("/v1/idempotent");
    变量 幂等令牌一: 取消令牌 = 创建取消令牌();
    变量 首次: 流运行结果 = 跑(作用域, 幂等代理, "idempotent", "req-idempotent", 配置值, 幂等令牌一, 接受事件);
    变量 版本一: 整数 = 底层模型.历史版本(幂等代理.会话句柄);
    变量 幂等令牌二: 取消令牌 = 创建取消令牌();
    重放数 = 0;
    变量 重复: 流运行结果 = 跑(作用域, 幂等代理, "idempotent", "req-idempotent", 配置值, 幂等令牌二, 接受重放);
    通过 = 通过 + 断言(字符串::等于(流结果状态(重复), "completed") == 1
        && 字符串::等于(流结果运行ID(重复), 流结果运行ID(首次)) == 1
        && 重放数 == 流结果最后序号(首次), "duplicate_request_replays_events");
    通过 = 通过 + 断言(版本一 == 1 && 底层模型.历史版本(幂等代理.会话句柄) == 1,
        "duplicate_commits_history_once");
    变量 冲突令牌: 取消令牌 = 创建取消令牌();
    变量 冲突: 流运行结果 = 跑(作用域, 幂等代理, "different", "req-idempotent", 配置值, 冲突令牌, 接受事件);
    通过 = 通过 + 断言(字符串::等于(流结果状态(冲突), "failed") == 1
        && 字符串::包含(流结果错误JSON(冲突), "idempotency_conflict") == 1,
        "request_hash_conflict_before_provider");
    变量 增量重放: 整数 = 0;
    重放数 = 0;
    增量重放 = 重放流事件(作用域, 流结果运行ID(首次), 流结果最后序号(首次) - 1, 接受重放);
    通过 = 通过 + 断言(增量重放 == 1 && 重放数 == 1, "replay_after_seq");

    变量 伪造作用域: 可靠流作用域 = 新建 可靠流作用域 { 句柄: 作用域.句柄 + 99 };
    通过 = 通过 + 断言(重放流事件(伪造作用域, 流结果运行ID(首次), 0, 接受重放) == 0 - 1,
        "forged_scope_rejected");
    变量 猜测拒绝: 整数 = 1;
    变量 猜测: 整数 = 1000001;
    当 (猜测 <= 1000064) {
        变量 猜测作用域: 可靠流作用域 = 新建 可靠流作用域 { 句柄: 猜测 };
        如果 (重放流事件(猜测作用域, 流结果运行ID(首次), 0, 接受重放) != 0 - 1) {
            猜测拒绝 = 0;
        }
        猜测 = 猜测 + 1;
    }
    通过 = 通过 + 断言(猜测拒绝 == 1, "predictable_scope_guesses_rejected");
    变量 旧绑定: 安全会话绑定 = 可信适配器绑定安全会话(上下文值, "stale-session");
    变量 旧作用域: 可靠流作用域 = 创建可靠流作用域(旧绑定, 库);
    释放可靠流作用域(旧作用域);
    变量 新绑定: 安全会话绑定 = 可信适配器绑定安全会话(上下文值, "stale-session");
    变量 新作用域: 可靠流作用域 = 创建可靠流作用域(新绑定, 库);
    通过 = 通过 + 断言(旧作用域.句柄 != 新作用域.句柄
        && 重放流事件(旧作用域, 流结果运行ID(首次), 0, 接受重放) == 0 - 1,
        "released_scope_generation_is_stale");
    变量 其他租户上下文: 安全上下文 = 新安全上下文("tenant-other");
    变量 其他租户绑定: 安全会话绑定 = 可信适配器绑定安全会话(其他租户上下文, "session-fixture");
    变量 其他会话绑定: 安全会话绑定 = 可信适配器绑定安全会话(上下文值, "session-other");
    变量 其他租户作用域: 可靠流作用域 = 创建可靠流作用域(其他租户绑定, 库);
    变量 其他会话作用域: 可靠流作用域 = 创建可靠流作用域(其他会话绑定, 库);
    通过 = 通过 + 断言(重放流事件(其他租户作用域, 流结果运行ID(首次), 0, 接受重放) == 0 - 1
        && 重放流事件(其他会话作用域, 流结果运行ID(首次), 0, 接受重放) == 0 - 1,
        "cross_tenant_and_session_replay_rejected");

    变量 拒绝配置: 可靠流配置 = 配置可靠流预算预留(默认可靠流配置(), 9);
    变量 拒绝代理: 代理 = 附加预算(新代理("/v1/budget-denied"), 创建预算(8, 0));
    变量 拒绝令牌: 取消令牌 = 创建取消令牌();
    变量 拒绝结果: 流运行结果 = 跑(作用域, 拒绝代理, "budget-denied", "req-budget-denied",
        拒绝配置, 拒绝令牌, 接受事件);
    通过 = 通过 + 断言(字符串::等于(流结果状态(拒绝结果), "budget_exceeded") == 1,
        "budget_denied_before_dispatch");

    变量 不足配置: 可靠流配置 = 配置可靠流预算预留(默认可靠流配置(), 4);
    变量 不足代理: 代理 = 新代理("/v1/insufficient-reservation");
    变量 不足令牌: 取消令牌 = 创建取消令牌();
    变量 不足结果: 流运行结果 = 跑(作用域, 不足代理, "x", "req-insufficient-reservation",
        不足配置, 不足令牌, 接受事件);
    通过 = 通过 + 断言(字符串::等于(流结果状态(不足结果), "budget_exceeded") == 1,
        "insufficient_reservation_blocks_before_dispatch");

    变量 精确配置: 可靠流配置 = 配置可靠流预算预留(默认可靠流配置(), 5);
    变量 精确代理: 代理 = 新代理("/v1/exact-bound");
    变量 精确令牌: 取消令牌 = 创建取消令牌();
    变量 精确结果: 流运行结果 = 跑(作用域, 精确代理, "x", "req-exact-bound",
        精确配置, 精确令牌, 接受事件);
    通过 = 通过 + 断言(字符串::等于(流结果状态(精确结果), "completed") == 1,
        "exact_reservation_bound_succeeds");

    变量 未知预算: 整数 = 创建预算(20, 0);
    变量 未知配置: 可靠流配置 = 配置可靠流预算预留(默认可靠流配置(), 9);
    变量 未知代理: 代理 = 附加预算(新代理("/v1/unknown-usage"), 未知预算);
    变量 未知令牌: 取消令牌 = 创建取消令牌();
    变量 未知结果: 流运行结果 = 跑(作用域, 未知代理, "unknown-usage", "req-unknown-usage",
        未知配置, 未知令牌, 接受事件);
    变量 未知预留: 整数 = J.数组获取对象(J.解码(获取运行预算JSON(库, 流结果运行ID(未知结果))), 0);
    变量 未知事件: 整数 = J.解码(列出运行事件(库, 流结果运行ID(未知结果), 0));
    变量 未知事件数: 整数 = J.数组长度(未知事件);
    变量 未知重复令牌: 取消令牌 = 创建取消令牌();
    变量 未知重复: 流运行结果 = 跑(作用域, 未知代理, "unknown-usage", "req-unknown-usage",
        未知配置, 未知重复令牌, 接受重放);
    通过 = 通过 + 断言(字符串::等于(流结果状态(未知结果), "completed") == 1
        && 字符串::等于(流结果状态(未知重复), "completed") == 1
        && 字符串::等于(流结果运行ID(未知重复), 流结果运行ID(未知结果)) == 1
        && J.数组长度(J.解码(列出运行事件(库, 流结果运行ID(未知结果), 0))) == 未知事件数
        && 已用令牌(未知预算) == 9
        && J.获取整数(未知预留, "actual_tokens") == 9
        && 字符串::等于(J.获取字符串(未知预留, "status"), "retained") == 1
        && 字符串::等于(J.获取字符串(未知预留, "usage_status"), "usage_unknown") == 1
        && 字符串::等于(J.获取字符串(J.数组获取对象(未知事件, 未知事件数 - 2), "type"),
            "budget.usage_unknown") == 1
        && 字符串::等于(J.获取字符串(J.数组获取对象(未知事件, 未知事件数 - 1), "type"),
            "run.completed") == 1,
        "unknown_usage_retains_conservative_reservation");

    // Simulate a crash after a committed semantic event and expired lease.
    创建代理运行(库, "run-recovery", "tenant-fixture", "session-fixture", "req-recovery",
        "hash-recovery", "STREAMING", 100);
    变量 恢复旧栅栏: 整数 = 获取运行租约(库, "run-recovery", "dead-worker", 110, 200);
    追加流运行事件(库, "run-recovery", "dead-worker", 恢复旧栅栏, "STREAMING", "STREAMING",
        "text.delta", 120, "{\"text\":\"persisted\"}", 1);
    变量 恢复结果: 流运行结果 = 恢复过期可靠流运行(作用域, "run-recovery", 201, 接受事件);
    变量 恢复事件数: 整数 = J.数组长度(J.解码(列出运行事件(库, "run-recovery", 0)));
    变量 重复恢复: 流运行结果 = 恢复过期可靠流运行(作用域, "run-recovery", 202, 接受事件);
    通过 = 通过 + 断言(字符串::等于(流结果状态(恢复结果), "incomplete") == 1
        && 字符串::等于(流结果状态(重复恢复), "incomplete") == 1
        && 恢复事件数 == 2
        && J.数组长度(J.解码(列出运行事件(库, "run-recovery", 0))) == 2,
        "stale_run_recovery_is_terminal_and_idempotent");

    创建代理运行(库, "run-cross-recovery", "tenant-fixture", "session-fixture", "req-cross-recovery",
        "hash-cross-recovery", "STREAMING", 100);
    变量 跨恢复栅栏: 整数 = 获取运行租约(库, "run-cross-recovery", "dead-cross", 110, 200);
    追加流运行事件(库, "run-cross-recovery", "dead-cross", 跨恢复栅栏, "STREAMING", "STREAMING",
        "text.delta", 120, "{\"text\":\"persisted\"}", 1);
    变量 跨租户恢复: 流运行结果 = 恢复过期可靠流运行(其他租户作用域, "run-cross-recovery", 201, 接受事件);
    变量 跨会话恢复: 流运行结果 = 恢复过期可靠流运行(其他会话作用域, "run-cross-recovery", 201, 接受事件);
    通过 = 通过 + 断言(字符串::包含(流结果错误JSON(跨租户恢复), "run_not_found") == 1
        && 字符串::包含(流结果错误JSON(跨会话恢复), "run_not_found") == 1,
        "cross_tenant_and_session_recovery_rejected");

    变量 栅栏预算: 整数 = 创建预算(20, 0);
    变量 栅栏代理: 代理 = 附加预算(新代理("/v1/stale-fence"), 栅栏预算);
    变量 栅栏令牌: 取消令牌 = 创建取消令牌();
    变量 栅栏结果: 流运行结果 = 跑(作用域, 栅栏代理, "stale-fence", "req-stale-fence",
        未知配置, 栅栏令牌, 抢占预留后栅栏);
    变量 栅栏预留: 整数 = J.数组获取对象(J.解码(获取运行预算JSON(库, 流结果运行ID(栅栏结果))), 0);
    通过 = 通过 + 断言(字符串::等于(流结果状态(栅栏结果), "stale_writer") == 1
        && 已用令牌(栅栏预算) == 9
        && 字符串::等于(J.获取字符串(栅栏预留, "status"), "retained") == 1
        && 字符串::等于(J.获取字符串(栅栏预留, "usage_status"), "usage_unknown") == 1,
        "stale_fence_cleans_both_budget_ledgers");

    数据库.执行(库, "CREATE TABLE reliable_deferred_parent (id TEXT PRIMARY KEY)");
    数据库.执行(库, "CREATE TABLE reliable_deferred_child (id TEXT, FOREIGN KEY(id) REFERENCES reliable_deferred_parent(id) DEFERRABLE INITIALLY DEFERRED)");
    变量 终态代理: 代理 = 新代理("/v1/terminal-failure");
    变量 终态令牌: 取消令牌 = 创建取消令牌();
    变量 终态失败: 流运行结果 = 跑(作用域, 终态代理, "terminal-failure", "req-terminal-failure",
        配置值, 终态令牌, 注入终态写失败);
    通过 = 通过 + 断言(字符串::等于(流结果状态(终态失败), "needs_reconciliation") == 1
        && 字符串::等于(流结果状态(终态失败), "completed") == 0,
        "terminal_write_failure_never_reports_completed");

    如果 (通过 == 26) { IO.打印行("PASS reliable_stream_total_26"); }
    否则 { IO.打印行("FAIL reliable_stream_total=" + 整数转字符串(通过)); }

    关闭代理(成功代理); 关闭代理(重试代理); 关闭代理(部分代理); 关闭代理(取消代理);
    关闭代理(首输出代理); 关闭代理(空闲代理); 关闭代理(总超时代理); 关闭代理(幂等代理);
    关闭代理(拒绝代理); 关闭代理(不足代理); 关闭代理(精确代理); 关闭代理(未知代理);
    关闭代理(栅栏代理); 关闭代理(终态代理);
    释放取消令牌(成功令牌); 释放取消令牌(重试令牌); 释放取消令牌(部分令牌);
    释放取消令牌(取消令牌值); 释放取消令牌(首输出令牌); 释放取消令牌(空闲令牌);
    释放取消令牌(总超时令牌); 释放取消令牌(幂等令牌一); 释放取消令牌(幂等令牌二);
    释放取消令牌(冲突令牌); 释放取消令牌(拒绝令牌); 释放取消令牌(不足令牌);
    释放取消令牌(精确令牌); 释放取消令牌(未知令牌);
    释放取消令牌(未知重复令牌); 释放取消令牌(栅栏令牌); 释放取消令牌(终态令牌);
    释放流运行结果(成功); 释放流运行结果(重试结果); 释放流运行结果(部分结果);
    释放流运行结果(取消结果); 释放流运行结果(首输出结果); 释放流运行结果(空闲结果);
    释放流运行结果(总超时结果); 释放流运行结果(首次); 释放流运行结果(重复);
    释放流运行结果(冲突); 释放流运行结果(拒绝结果); 释放流运行结果(不足结果);
    释放流运行结果(精确结果); 释放流运行结果(未知结果);
    释放流运行结果(未知重复);
    释放流运行结果(恢复结果); 释放流运行结果(重复恢复);
    释放流运行结果(跨租户恢复); 释放流运行结果(跨会话恢复);
    释放流运行结果(栅栏结果); 释放流运行结果(终态失败);
    释放可靠流配置(配置值); 释放可靠流配置(首输出配置); 释放可靠流配置(空闲配置);
    释放可靠流配置(总超时配置); 释放可靠流配置(重试配置); 释放可靠流配置(拒绝配置);
    释放可靠流配置(不足配置); 释放可靠流配置(精确配置); 释放可靠流配置(未知配置);
    释放可靠流作用域(作用域); 释放可靠流作用域(新作用域);
    释放可靠流作用域(其他租户作用域); 释放可靠流作用域(其他会话作用域);
    释放安全会话绑定(会话绑定); 释放安全会话绑定(旧绑定); 释放安全会话绑定(新绑定);
    释放安全会话绑定(其他租户绑定); 释放安全会话绑定(其他会话绑定);
    释放安全上下文(上下文值); 释放安全上下文(其他租户上下文); 关闭运行日志(库);
}
