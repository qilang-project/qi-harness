包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.JSON 作为 J;
导入 Harness.报告::{
    创建报告, 开始报告步骤, 结束报告步骤, 报告步骤数,
    报告总令牌按句柄, 报告总成本按句柄, 报告JSON按句柄,
    开始报告, 开始步骤, 结束步骤, 步骤数, 报告总令牌,
    安装生命周期报告适配器按句柄, 释放生命周期报告适配器
};
导入 Harness.事件::{清空生命周期订阅者};

函数 断言(条件: 整数, 名字: 字符串) {
    如果 (条件 == 1) { IO.打印行("PASS " + 名字); }
    否则 { IO.打印行("FAIL " + 名字); }
}

函数 入口() {
    变量 报告甲: 整数 = 创建报告("report-a");
    变量 报告乙: 整数 = 创建报告("report-b");
    变量 甲步: 整数 = 开始报告步骤(报告甲, "tool", "alpha-step");
    变量 乙步: 整数 = 开始报告步骤(报告乙, "llm", "beta-step");
    结束报告步骤(报告乙, 乙步, "beta-detail", 22, 2);
    结束报告步骤(报告甲, 甲步, "alpha-detail", 11, 1);

    断言(报告步骤数(报告甲) == 1, "report_a_step_count");
    断言(报告步骤数(报告乙) == 1, "report_b_step_count");
    断言(报告总令牌按句柄(报告甲) == 11, "report_a_tokens");
    断言(报告总令牌按句柄(报告乙) == 22, "report_b_tokens");
    断言(报告总成本按句柄(报告甲) == 1, "report_a_cost");
    断言(报告总成本按句柄(报告乙) == 2, "report_b_cost");

    变量 甲根: 整数 = J.解码(报告JSON按句柄(报告甲));
    变量 乙根: 整数 = J.解码(报告JSON按句柄(报告乙));
    变量 甲步骤: 整数 = J.获取数组(甲根, "步骤");
    变量 乙步骤: 整数 = J.获取数组(乙根, "步骤");
    断言(字符串::等于(J.获取字符串(甲根, "标题"), "report-a"), "report_a_title");
    断言(字符串::等于(J.获取字符串(乙根, "标题"), "report-b"), "report_b_title");
    断言(字符串::等于(J.获取字符串(J.数组获取对象(甲步骤, 0), "名字"), "alpha-step"), "report_a_name_not_mixed");
    断言(字符串::等于(J.获取字符串(J.数组获取对象(乙步骤, 0), "名字"), "beta-step"), "report_b_name_not_mixed");
    J.删除(甲根);
    J.删除(乙根);

    // 旧 API 仍使用自己的默认句柄，不修改显式报告。
    开始报告("legacy");
    变量 旧步: 整数 = 开始步骤("tool", "legacy-step");
    结束步骤(旧步, "legacy-detail", 7, 0);
    断言(步骤数() == 1, "legacy_step_count");
    断言(报告总令牌() == 7, "legacy_tokens");
    断言(报告总令牌按句柄(报告甲) == 11, "legacy_does_not_modify_explicit");

    // 固定回调适配器槽可显式释放并复用，顺序安装超过 16 次不会耗尽。
    清空生命周期订阅者();
    变量 i: 整数 = 0;
    变量 复用成功: 整数 = 1;
    当 (i < 24) {
        变量 临时报告: 整数 = 创建报告("adapter-" + 整数转字符串(i));
        变量 订阅: 整数 = 安装生命周期报告适配器按句柄(临时报告);
        如果 (订阅 <= 0 || 释放生命周期报告适配器(订阅) != 1) { 复用成功 = 0; }
        i = i + 1;
    }
    断言(复用成功, "report_adapter_slots_reuse_beyond_16");
    清空生命周期订阅者();
}
