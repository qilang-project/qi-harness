包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.路径;
导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 标准库.大模型 作为 底层模型;
导入 Harness.代理::{代理, 创建代理, 添加工具, 关闭代理};
导入 Harness.工具::{派发, 查找索引, 工具执行模式, 设置执行模式, 设置工具钩子, 工具};
导入 Harness.文件工具::{创建文件沙箱, 允许写, 创建文件沙箱句柄,
    释放文件沙箱句柄, 装备文件工具按句柄};

函数 旧处理(参数: 字符串) : 字符串 { 返回 "old"; }
函数 新处理(参数: 字符串) : 字符串 { 返回 "new"; }
函数 原样钩子(工具名: 字符串, 值: 字符串) : 字符串 { 返回 值; }

函数 断言(条件: 整数, 名字: 字符串) {
    如果 (条件 == 1) { IO.打印行("PASS " + 名字); }
    否则 { IO.打印行("FAIL " + 名字); }
}

函数 入口() {
    变量 根甲: 字符串 = "/tmp/qi_harness_sandbox_isolation_a";
    变量 根乙: 字符串 = "/tmp/qi_harness_sandbox_isolation_b";
    如果 (路径.存在(根甲) == 0) { IO.创建目录(根甲); }
    如果 (路径.存在(根乙) == 0) { IO.创建目录(根乙); }
    IO.写入文件(根甲 + "/shared.txt", "alpha");
    IO.写入文件(根乙 + "/shared.txt", "beta");

    变量 会话甲: 整数 = 底层模型.创建会话("http://127.0.0.1:43510/v1", "test", "test");
    变量 会话乙: 整数 = 底层模型.创建会话("http://127.0.0.1:43510/v1", "test", "test");
    变量 代理甲: 代理 = 创建代理("sandbox-a", 会话甲);
    变量 代理乙: 代理 = 创建代理("sandbox-b", 会话乙);

    // 固定回调槽必须可释放复用，顺序创建超过 16 次不能耗尽。
    变量 i: 整数 = 0;
    变量 复用成功: 整数 = 1;
    当 (i < 24) {
        变量 临时句柄: 整数 = 创建文件沙箱句柄(允许写(创建文件沙箱(根甲)));
        如果 (临时句柄 < 0 || 释放文件沙箱句柄(临时句柄) != 1) { 复用成功 = 0; }
        i = i + 1;
    }
    断言(复用成功, "sandbox_slots_reuse_beyond_16");

    变量 句柄甲: 整数 = 创建文件沙箱句柄(允许写(创建文件沙箱(根甲)));
    变量 句柄乙: 整数 = 创建文件沙箱句柄(允许写(创建文件沙箱(根乙)));
    代理甲 = 装备文件工具按句柄(代理甲, 句柄甲);
    代理乙 = 装备文件工具按句柄(代理乙, 句柄乙);

    断言(工具执行模式(代理甲.工具表, "读文件") == 0, "filesystem_read_parallel_by_default");
    断言(工具执行模式(代理甲.工具表, "列目录") == 0, "filesystem_list_parallel_by_default");
    断言(工具执行模式(代理甲.工具表, "写文件") == 1, "filesystem_write_serial_by_default");
    断言(工具执行模式(代理甲.工具表, "追加文件") == 1, "filesystem_append_serial_by_default");
    断言(工具执行模式(代理甲.工具表, "建目录") == 1, "filesystem_mkdir_serial_by_default");

    // 乙在甲之后装备；甲仍必须读写自己的根，而不是被乙覆盖。
    断言(字符串::等于(派发(代理甲.工具表, "读文件", "{\"路径\":\"shared.txt\"}"), "alpha"), "sandbox_a_read");
    断言(字符串::等于(派发(代理乙.工具表, "读文件", "{\"路径\":\"shared.txt\"}"), "beta"), "sandbox_b_read");
    派发(代理甲.工具表, "写文件", "{\"路径\":\"only-a.txt\",\"内容\":\"from-a\"}");
    派发(代理乙.工具表, "写文件", "{\"路径\":\"only-b.txt\",\"内容\":\"from-b\"}");
    断言(IO.文件存在(根甲 + "/only-a.txt") == 1, "sandbox_a_write_local");
    断言(IO.文件存在(根乙 + "/only-a.txt") == 0, "sandbox_a_does_not_cross");
    断言(IO.文件存在(根乙 + "/only-b.txt") == 1, "sandbox_b_write_local");
    断言(IO.文件存在(根甲 + "/only-b.txt") == 0, "sandbox_b_does_not_cross");

    // 同名工具最后注册生效；公开索引、派发和元数据修改必须指向同一项。
    变量 元数据前: 整数 = 列表库::字符串列表大小(代理甲.工具表.名字列表);
    代理甲 = 添加工具(代理甲, 新建 工具 {
        名字: "重复工具", 描述: "old", 参数schema: "{\"type\":\"object\"}", 处理: 旧处理,
    });
    代理甲 = 添加工具(代理甲, 新建 工具 {
        名字: "重复工具", 描述: "new", 参数schema: "{\"type\":\"object\"}", 处理: 新处理,
    });
    变量 最新索引: 整数 = 查找索引(代理甲.工具表, "重复工具");
    断言(最新索引 == 列表库::字符串列表大小(代理甲.工具表.名字列表) - 1, "lookup_returns_latest_registration");
    断言(字符串::等于(派发(代理甲.工具表, "重复工具", "{}"), "new"), "dispatch_uses_latest_registration");
    变量 设置前: 整数 = 列表库::字符串列表大小(代理甲.工具表.名字列表);
    代理甲.工具表 = 设置执行模式(代理甲.工具表, "重复工具", 1);
    断言(列表库::字符串列表大小(代理甲.工具表.名字列表) == 设置前, "mode_setter_does_not_duplicate_entries");
    代理甲.工具表 = 设置工具钩子(代理甲.工具表, "重复工具", 原样钩子, 原样钩子);
    断言(查找索引(代理甲.工具表, "重复工具") == 设置前, "hook_overlay_becomes_latest_index");
    断言(元数据前 + 2 == 设置前, "duplicate_registration_count_expected");

    IO.删除文件(根甲 + "/shared.txt");
    IO.删除文件(根乙 + "/shared.txt");
    IO.删除文件(根甲 + "/only-a.txt");
    IO.删除文件(根乙 + "/only-b.txt");
    IO.删除目录(根甲);
    IO.删除目录(根乙);
    释放文件沙箱句柄(句柄甲);
    释放文件沙箱句柄(句柄乙);
    关闭代理(代理甲);
    关闭代理(代理乙);
}
