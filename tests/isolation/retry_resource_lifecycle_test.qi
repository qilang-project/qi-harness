包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.大模型 作为 底层模型;
导入 Harness.代理::{代理, 创建代理, 共享重试资源, 关闭代理};
导入 Harness.重试::{创建重试资源, 释放重试资源, 重试资源有效,
    配置资源熔断, 资源熔断记失败, 资源熔断状态};

函数 断言(条件: 整数, 名字: 字符串) {
    如果 (条件 == 1) { IO.打印行("PASS " + 名字); }
    否则 { IO.打印行("FAIL " + 名字); }
}

函数 入口() {
    变量 i: 整数 = 0;
    变量 复用成功: 整数 = 1;
    当 (i < 24) {
        变量 临时: 整数 = 创建重试资源();
        如果 (临时 <= 0 || 释放重试资源(临时) != 1) { 复用成功 = 0; }
        i = i + 1;
    }
    断言(复用成功, "retry_resources_reuse_beyond_16");

    变量 共享: 整数 = 创建重试资源();
    配置资源熔断(共享, 1, 60000);
    变量 会话甲: 整数 = 底层模型.创建会话("http://127.0.0.1:43510/v1", "test", "test");
    变量 会话乙: 整数 = 底层模型.创建会话("http://127.0.0.1:43510/v1", "test", "test");
    变量 代理甲: 代理 = 创建代理("retry-a", 会话甲);
    变量 代理乙: 代理 = 创建代理("retry-b", 会话乙);
    代理甲 = 共享重试资源(代理甲, 共享);
    代理乙 = 共享重试资源(代理乙, 共享);
    变量 替换后可分配: 整数 = 创建重试资源();
    断言(替换后可分配 > 0 && 释放重试资源(替换后可分配) == 1,
        "switching_to_shared_releases_owned_capacity");

    资源熔断记失败(共享);
    断言(资源熔断状态(共享) == "打开", "shared_retry_state_configured");
    关闭代理(代理甲);
    断言(重试资源有效(共享) == 1 && 资源熔断状态(共享) == "打开",
        "closing_first_agent_keeps_shared_retry_resource");
    关闭代理(代理乙);
    断言(重试资源有效(共享) == 1, "closing_all_agents_does_not_free_shared_retry_resource");
    断言(释放重试资源(共享) == 1 && 重试资源有效(共享) == 0,
        "shared_retry_resource_requires_explicit_release");
}
