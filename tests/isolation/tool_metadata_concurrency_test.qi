包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 标准库.大模型 作为 底层模型;
导入 Harness.工具::{注册表, 工具, 创建注册表, 注册, 设置执行模式,
    设置工具钩子, 工具执行模式, 派发};

变量 开始信号 = 通道<整数>(32);
变量 完成信号 = 通道<整数>(32);
变量 共享名字列表: 整数 = 0;
变量 共享处理列表: 整数 = 0;
变量 共享来源列表: 整数 = 0;
变量 共享连接列表: 整数 = 0;

函数 基础处理(参数: 字符串) : 字符串 { 返回 "base"; }
函数 共享甲处理(参数: 字符串) : 字符串 { 返回 "shared-a"; }
函数 共享乙处理(参数: 字符串) : 字符串 { 返回 "shared-b"; }
函数 原样前钩子(工具名: 字符串, 参数: 字符串) : 字符串 { 返回 参数; }
函数 甲后钩子(工具名: 字符串, 输出: 字符串) : 字符串 { 返回 "agent-a:" + 输出; }
函数 乙后钩子(工具名: 字符串, 输出: 字符串) : 字符串 { 返回 "agent-b:" + 输出; }

函数 甲工人() : 未来<整数> {
    变量 表: 注册表 = 创建注册表();
    变量 会话: 整数 = 底层模型.创建会话("http://127.0.0.1:43510/v1", "test", "test");
    变量 信号: 整数 = <- 开始信号;
    表 = 注册(表, 会话, 新建 工具 {
        名字: "并发工具", 描述: "a", 参数schema: "{\"type\":\"object\"}", 处理: 基础处理,
    });
    表 = 设置执行模式(表, "并发工具", 0);
    表 = 设置工具钩子(表, "并发工具", 原样前钩子, 甲后钩子);
    变量 成功: 整数 = 工具执行模式(表, "并发工具") == 0
        && 字符串::等于(派发(表, "并发工具", "{}"), "agent-a:base") == 1;
    底层模型.关闭会话(会话);
    完成信号 <- 成功;
    返回 成功;
}

函数 乙工人() : 未来<整数> {
    变量 表: 注册表 = 创建注册表();
    变量 会话: 整数 = 底层模型.创建会话("http://127.0.0.1:43510/v1", "test", "test");
    变量 信号: 整数 = <- 开始信号;
    表 = 注册(表, 会话, 新建 工具 {
        名字: "并发工具", 描述: "b", 参数schema: "{\"type\":\"object\"}", 处理: 基础处理,
    });
    表 = 设置执行模式(表, "并发工具", 1);
    表 = 设置工具钩子(表, "并发工具", 原样前钩子, 乙后钩子);
    变量 成功: 整数 = 工具执行模式(表, "并发工具") == 1
        && 字符串::等于(派发(表, "并发工具", "{}"), "agent-b:base") == 1;
    底层模型.关闭会话(会话);
    完成信号 <- 成功;
    返回 成功;
}

函数 共享表() : 注册表 {
    返回 新建 注册表 {
        名字列表: 共享名字列表,
        处理列表: 共享处理列表,
        来源列表: 共享来源列表,
        连接列表: 共享连接列表,
    };
}

函数 共享甲工人() : 未来<整数> {
    变量 表: 注册表 = 共享表();
    变量 会话: 整数 = 底层模型.创建会话("http://127.0.0.1:43510/v1", "test", "test");
    变量 信号: 整数 = <- 开始信号;
    表 = 注册(表, 会话, 新建 工具 {
        名字: "共享甲", 描述: "shared-a",
        参数schema: "{\"type\":\"object\",\"required\":[\"a\"],\"properties\":{\"a\":{\"type\":\"string\"}},\"additionalProperties\":false}",
        处理: 共享甲处理,
    });
    底层模型.关闭会话(会话);
    完成信号 <- 1;
    返回 1;
}

函数 共享乙工人() : 未来<整数> {
    变量 表: 注册表 = 共享表();
    变量 会话: 整数 = 底层模型.创建会话("http://127.0.0.1:43510/v1", "test", "test");
    变量 信号: 整数 = <- 开始信号;
    表 = 注册(表, 会话, 新建 工具 {
        名字: "共享乙", 描述: "shared-b",
        参数schema: "{\"type\":\"object\",\"required\":[\"b\"],\"properties\":{\"b\":{\"type\":\"integer\"}},\"additionalProperties\":false}",
        处理: 共享乙处理,
    });
    底层模型.关闭会话(会话);
    完成信号 <- 1;
    返回 1;
}

函数 入口() {
    变量 i: 整数 = 0;
    当 (i < 32) {
        如果 (i % 2 == 0) { 启动 甲工人(); }
        否则 { 启动 乙工人(); }
        i = i + 1;
    }
    i = 0;
    当 (i < 32) {
        开始信号 <- 1;
        i = i + 1;
    }
    执行器运行全部();
    变量 成功数: 整数 = 0;
    i = 0;
    当 (i < 32) {
        成功数 = 成功数 + (<- 完成信号);
        i = i + 1;
    }
    如果 (成功数 == 32) {
        IO.打印行("PASS concurrent_metadata_registration_isolated");
    } 否则 {
        IO.打印行("FAIL concurrent_metadata_registration_isolated");
        系统.退出程序(1);
    }

    变量 共享值: 注册表 = 创建注册表();
    共享名字列表 = 共享值.名字列表;
    共享处理列表 = 共享值.处理列表;
    共享来源列表 = 共享值.来源列表;
    共享连接列表 = 共享值.连接列表;
    i = 0;
    当 (i < 32) {
        如果 (i % 2 == 0) { 启动 共享甲工人(); }
        否则 { 启动 共享乙工人(); }
        i = i + 1;
    }
    i = 0;
    当 (i < 32) {
        开始信号 <- 1;
        i = i + 1;
    }
    执行器运行全部();
    i = 0;
    当 (i < 32) {
        变量 已完成: 整数 = <- 完成信号;
        i = i + 1;
    }
    变量 共享通过: 整数 = 字符串::等于(派发(共享值, "共享甲", "{\"a\":\"ok\"}"), "shared-a") == 1
        && 字符串::等于(派发(共享值, "共享乙", "{\"b\":7}"), "shared-b") == 1
        && 字符串::查找(派发(共享值, "共享甲", "{\"b\":7}"), "invalid_arguments") >= 0
        && 字符串::查找(派发(共享值, "共享乙", "{\"a\":\"bad\"}"), "invalid_arguments") >= 0
        && 列表库::字符串列表大小(共享值.名字列表) == 32;
    如果 (共享通过 == 1) {
        IO.打印行("PASS concurrent_shared_registry_alignment");
        系统.退出程序(0);
    }
    IO.打印行("FAIL concurrent_shared_registry_alignment");
    系统.退出程序(1);
}
