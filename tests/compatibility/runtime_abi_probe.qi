包 主程序;

导入 标准库.大模型 作为 底层模型;
导入 标准库.Web运行时 作为 Web运行时;
导入 标准库.工具控制 作为 工具控制;
导入 Harness.可靠流::{默认可靠流配置};

函数 入口() {
    变量 控制: 整数 = 工具控制.创建(0 - 1, 2);
    工具控制.是否已取消(控制);
    工具控制.取消原因(控制);
    工具控制.剩余毫秒(控制);
    工具控制.发送进度(控制, "probe");
    工具控制.下一进度(控制);
    工具控制.已丢弃进度(控制);
    工具控制.是否已完成(控制);
    工具控制.完成代码(控制);
    工具控制.完成结果(控制);
    工具控制.等待状态(控制, 0);
    工具控制.取消(控制, "probe");
    工具控制.完成(控制, 0, "probe");
    工具控制.释放控制(控制);

    默认可靠流配置();
    底层模型.能力版本("stream_v2");
    底层模型.打开流V2(0 - 1, "{}");
    底层模型.读取流事件V2(0 - 1);
    底层模型.限时读取流事件V2(0 - 1, 0);
    底层模型.取消流V2(0 - 1, "probe");
    底层模型.流快照V2(0 - 1);
    底层模型.提交流V2(0 - 1, 0);
    底层模型.放弃流V2(0 - 1);
    底层模型.关闭流V2(0 - 1);
    底层模型.历史版本(0 - 1);

    Web运行时.请求主体超过上限(0 - 1, 1);
}
