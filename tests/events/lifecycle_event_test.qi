包 主程序;

导入 标准库.JSON 作为 J;
导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 Harness.事件::{生命周期事件, 新运行ID, 创建生命周期事件, 生命周期事件转JSON,
                     生命周期事件转追踪JSON, 订阅生命周期事件, 清空生命周期订阅者,
                     发出生命周期事件, 创建生命周期事件总线,
                     订阅生命周期事件按总线, 清空生命周期订阅者按总线,
                     发出生命周期事件按总线};

变量 调用顺序: 字符串 = "";
变量 收到事件: 字符串 = "";
变量 总线甲次数: 整数 = 0;
变量 总线乙次数: 整数 = 0;

函数 订阅甲(事件JSON: 字符串) : 整数 {
    调用顺序 = 调用顺序 + "A";
    收到事件 = 事件JSON;
    返回 1;
}

函数 隔离失败订阅者(事件JSON: 字符串) : 整数 {
    调用顺序 = 调用顺序 + "B";
    返回 0;
}

函数 订阅丙(事件JSON: 字符串) : 整数 {
    调用顺序 = 调用顺序 + "C";
    返回 1;
}

函数 非隔离失败订阅者(事件JSON: 字符串) : 整数 {
    调用顺序 = 调用顺序 + "X";
    返回 0;
}

函数 不应调用(事件JSON: 字符串) : 整数 {
    调用顺序 = 调用顺序 + "Z";
    返回 1;
}

函数 总线甲订阅者(事件JSON: 字符串) : 整数 {
    总线甲次数 = 总线甲次数 + 1;
    返回 1;
}

函数 总线乙订阅者(事件JSON: 字符串) : 整数 {
    总线乙次数 = 总线乙次数 + 1;
    返回 1;
}

函数 断言(条件: 整数, 名字: 字符串) : 整数 {
    如果 (条件 == 1) {
        IO.打印行("PASS " + 名字);
        返回 1;
    }
    IO.打印行("FAIL " + 名字);
    返回 0;
}

函数 入口() {
    变量 通过: 整数 = 0;
    变量 run: 字符串 = 新运行ID();
    如果 (字符串::字节长度(run) > 0) { 通过 = 通过 + 断言(1, "run_id_created"); }
    否则 { 断言(0, "run_id_created"); }

    清空生命周期订阅者();
    订阅生命周期事件(订阅甲, 0);
    订阅生命周期事件(隔离失败订阅者, 1);
    订阅生命周期事件(订阅丙, 0);
    变量 发布结果: 整数 = 发出生命周期事件(
        run, "turn-2", "step-3", "step.started", "tester", "{\"answer\":42}");
    通过 = 通过 + 断言(发布结果 == 1, "isolated_failure_continues");
    通过 = 通过 + 断言(字符串::等于(调用顺序, "ABC"), "subscriber_order");

    变量 根: 整数 = J.解码(收到事件);
    变量 载荷: 整数 = J.获取对象(根, "payload");
    通过 = 通过 + 断言(J.获取整数(根, "version") == 1, "protocol_version");
    通过 = 通过 + 断言(字符串::等于(J.获取字符串(根, "run_id"), run), "run_field");
    通过 = 通过 + 断言(字符串::等于(J.获取字符串(根, "turn_id"), "turn-2"), "turn_field");
    通过 = 通过 + 断言(字符串::等于(J.获取字符串(根, "step_id"), "step-3"), "step_field");
    通过 = 通过 + 断言(字符串::等于(J.获取字符串(根, "type"), "step.started"), "type_field");
    通过 = 通过 + 断言(字符串::等于(J.获取字符串(根, "agent"), "tester"), "agent_field");
    通过 = 通过 + 断言(J.获取整数(载荷, "answer") == 42, "payload_field");
    J.删除(根);

    变量 事件值: 生命周期事件 = 创建生命周期事件(
        "run-fixed", "turn-fixed", "step-fixed", "tool.completed", "adapter", "{\"ok\":1}");
    变量 标准JSON: 字符串 = 生命周期事件转JSON(事件值);
    变量 标准根: 整数 = J.解码(标准JSON);
    通过 = 通过 + 断言(J.获取对象(标准根, "payload") > 0, "canonical_payload_object");
    J.删除(标准根);

    变量 追踪JSON: 字符串 = 生命周期事件转追踪JSON(事件值);
    变量 追踪根: 整数 = J.解码(追踪JSON);
    通过 = 通过 + 断言(字符串::等于(J.获取字符串(追踪根, "trace"), "run-fixed"), "trace_adapter_run");
    通过 = 通过 + 断言(字符串::等于(J.获取字符串(追踪根, "detail"), "{\"ok\":1}"), "trace_adapter_detail");
    J.删除(追踪根);

    变量 清除数: 整数 = 清空生命周期订阅者();
    通过 = 通过 + 断言(清除数 == 3, "clear_returns_count");
    调用顺序 = "";
    订阅生命周期事件(非隔离失败订阅者, 0);
    订阅生命周期事件(不应调用, 0);
    发布结果 = 发出生命周期事件(run, "", "", "run.failed", "tester", "{}");
    通过 = 通过 + 断言(发布结果 == 0, "non_isolated_failure_stops");
    通过 = 通过 + 断言(字符串::等于(调用顺序, "X"), "subscriber_stop_order");

    变量 总线甲: 整数 = 创建生命周期事件总线();
    变量 总线乙: 整数 = 创建生命周期事件总线();
    变量 总线甲订阅号: 整数 = 订阅生命周期事件按总线(总线甲, 总线甲订阅者, 0);
    变量 总线乙订阅号: 整数 = 订阅生命周期事件按总线(总线乙, 总线乙订阅者, 0);
    通过 = 通过 + 断言(总线甲订阅号 == 1, "bus_a_subscription_sequence");
    通过 = 通过 + 断言(总线乙订阅号 == 1, "bus_b_subscription_sequence");
    发出生命周期事件按总线(总线甲, "bus-a", "", "", "test", "tester", "{}");
    通过 = 通过 + 断言(总线甲次数 == 1, "bus_a_receives_own_event");
    通过 = 通过 + 断言(总线乙次数 == 0, "bus_b_does_not_receive_bus_a_event");
    发出生命周期事件按总线(总线乙, "bus-b", "", "", "test", "tester", "{}");
    通过 = 通过 + 断言(总线甲次数 == 1, "bus_a_does_not_receive_bus_b_event");
    通过 = 通过 + 断言(总线乙次数 == 1, "bus_b_receives_own_event");
    通过 = 通过 + 断言(清空生命周期订阅者按总线(总线甲) == 1, "bus_a_clear_count");
    发出生命周期事件按总线(总线乙, "bus-b-2", "", "", "test", "tester", "{}");
    通过 = 通过 + 断言(总线乙次数 == 2, "bus_a_clear_does_not_clear_bus_b");

    清空生命周期订阅者();
    如果 (通过 == 24) { IO.打印行("PASS lifecycle_event_total_24"); }
    否则 { IO.打印行("FAIL lifecycle_event_total=" + 整数转字符串(通过)); }
}
