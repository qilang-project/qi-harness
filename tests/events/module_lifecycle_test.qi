包 主程序;

导入 标准库.JSON 作为 J;
导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 标准库.数据库;
导入 Harness.事件::{订阅生命周期事件, 清空生命周期订阅者};
导入 Harness.运行上下文::{创建运行上下文, 进入运行上下文, 退出运行上下文,
    清理运行上下文, 推进轮次, 推进步骤};
导入 Harness.重试::{重试策略, 重试调用};
导入 Harness.预算::{创建预算, 记入成本};
导入 Harness.图::{图, 创建图, 添加节点, 添加边, 运行图带检查点, 恢复图, 终点};

变量 事件类型表: 整数 = 0;
变量 事件JSON表: 整数 = 0;
变量 重试调用数: 整数 = 0;

函数 收集事件(事件JSON: 字符串) : 整数 {
    变量 根: 整数 = J.解码(事件JSON);
    列表库::添加字符串(事件类型表, J.获取字符串(根, "type"));
    列表库::添加字符串(事件JSON表, 事件JSON);
    J.删除(根);
    返回 1;
}

函数 两败一成() : 字符串 {
    重试调用数 = 重试调用数 + 1;
    如果 (重试调用数 < 3) { 返回 "[harness] transient"; }
    返回 "ok";
}

函数 中断节点(状态: 字符串) : 字符串 {
    变量 根: 整数 = J.解码(状态);
    如果 (根 <= 0) { 根 = J.创建对象(); }
    J.设置字符串(根, "__中断__", "continue?");
    变量 结果值: 字符串 = J.转字符串(根);
    J.删除(根);
    返回 结果值;
}

函数 完成节点(状态: 字符串) : 字符串 {
    变量 根: 整数 = J.解码(状态);
    J.设置字符串(根, "done", "yes");
    变量 结果值: 字符串 = J.转字符串(根);
    J.删除(根);
    返回 结果值;
}

函数 断言(条件: 整数, 名字: 字符串) : 整数 {
    如果 (条件 == 1) { IO.打印行("PASS " + 名字); 返回 1; }
    IO.打印行("FAIL " + 名字);
    返回 0;
}

函数 入口() {
    变量 通过: 整数 = 0;
    事件类型表 = 列表库::创建字符串列表();
    事件JSON表 = 列表库::创建字符串列表();

    清空生命周期订阅者();
    变量 策略: 重试策略 = 新建 重试策略 {
        最大次数: 3,
        起始延迟毫秒: 0,
        最大延迟毫秒: 0,
        倍数: 2,
    };
    重试调用数 = 0;
    通过 = 通过 + 断言(字符串::等于(重试调用(策略, "retry-agent", 两败一成), "ok"),
        "retry_no_subscriber_preserves_result");

    订阅生命周期事件(收集事件, 0);
    变量 上下文: 整数 = 创建运行上下文("run-context");
    进入运行上下文(上下文);
    推进轮次(上下文);
    推进步骤(上下文);

    重试调用数 = 0;
    通过 = 通过 + 断言(字符串::等于(重试调用(策略, "retry-agent", 两败一成), "ok"),
        "retry_result_preserved");
    通过 = 通过 + 断言(列表库::字符串列表大小(事件类型表) == 4,
        "retry_event_count");
    通过 = 通过 + 断言(
        字符串::等于(列表库::获取字符串(事件类型表, 0), "retry_start")
        && 字符串::等于(列表库::获取字符串(事件类型表, 1), "retry_end")
        && 字符串::等于(列表库::获取字符串(事件类型表, 2), "retry_start")
        && 字符串::等于(列表库::获取字符串(事件类型表, 3), "retry_end"),
        "retry_event_order");
    变量 重试开始根: 整数 = J.解码(列表库::获取字符串(事件JSON表, 0));
    变量 重试开始载荷: 整数 = J.获取对象(重试开始根, "payload");
    变量 重试结束根: 整数 = J.解码(列表库::获取字符串(事件JSON表, 3));
    变量 重试结束载荷: 整数 = J.获取对象(重试结束根, "payload");
    通过 = 通过 + 断言(
        字符串::等于(J.获取字符串(重试开始根, "run_id"), "run-context")
        && 字符串::等于(J.获取字符串(重试开始根, "turn_id"), "turn-1")
        && 字符串::等于(J.获取字符串(重试开始根, "step_id"), "step-1"),
        "retry_current_context_ids");
    通过 = 通过 + 断言(J.获取整数(重试开始载荷, "attempt") == 2
        && J.获取整数(重试开始载荷, "delay_ms") == 0,
        "retry_start_payload");
    通过 = 通过 + 断言(J.获取整数(重试结束载荷, "attempt") == 3
        && 字符串::等于(J.获取字符串(重试结束载荷, "result"), "success"),
        "retry_end_payload");
    J.删除(重试开始根);
    J.删除(重试结束根);

    事件类型表 = 列表库::创建字符串列表();
    事件JSON表 = 列表库::创建字符串列表();
    变量 预算: 整数 = 创建预算(0, 500);
    通过 = 通过 + 断言(记入成本(预算, 125) == 125, "budget_result_preserved");
    通过 = 通过 + 断言(列表库::字符串列表大小(事件类型表) == 1
        && 字符串::等于(列表库::获取字符串(事件类型表, 0), "budget_update"),
        "budget_update_emitted");
    变量 预算根: 整数 = J.解码(列表库::获取字符串(事件JSON表, 0));
    变量 预算载荷: 整数 = J.获取对象(预算根, "payload");
    通过 = 通过 + 断言(字符串::等于(J.获取字符串(预算载荷, "kind"), "cost_cents")
        && J.获取整数(预算载荷, "delta") == 125
        && J.获取整数(预算载荷, "used") == 125
        && J.获取整数(预算载荷, "limit") == 500
        && J.获取布尔(预算载荷, "exceeded") == 0,
        "budget_update_payload");
    J.删除(预算根);

    退出运行上下文(上下文);
    清理运行上下文(上下文);
    事件类型表 = 列表库::创建字符串列表();
    事件JSON表 = 列表库::创建字符串列表();

    变量 路径: 字符串 = "/tmp/qi_module_lifecycle_graph.db";
    如果 (IO.文件存在(路径) == 1) { IO.删除文件(路径); }
    变量 库: 整数 = 数据库.连接(路径);
    变量 g: 图 = 创建图();
    g = 添加节点(g, "pause", 中断节点);
    g = 添加节点(g, "finish", 完成节点);
    g = 添加边(g, "pause", "finish");
    g = 添加边(g, "finish", 终点());
    运行图带检查点(g, 库, "graph-run", "pause", "{}", 10);
    恢复图(g, 库, "graph-run", "yes");
    通过 = 通过 + 断言(列表库::字符串列表大小(事件类型表) == 3,
        "graph_lifecycle_event_count");
    通过 = 通过 + 断言(
        字符串::等于(列表库::获取字符串(事件类型表, 0), "checkpoint_saved")
        && 字符串::等于(列表库::获取字符串(事件类型表, 1), "run_resumed")
        && 字符串::等于(列表库::获取字符串(事件类型表, 2), "checkpoint_saved"),
        "graph_lifecycle_event_order");
    变量 检查点根: 整数 = J.解码(列表库::获取字符串(事件JSON表, 0));
    变量 检查点载荷: 整数 = J.获取对象(检查点根, "payload");
    变量 恢复根: 整数 = J.解码(列表库::获取字符串(事件JSON表, 1));
    变量 恢复载荷: 整数 = J.获取对象(恢复根, "payload");
    通过 = 通过 + 断言(字符串::等于(J.获取字符串(检查点根, "run_id"), "graph-run")
        && 字符串::等于(J.获取字符串(检查点根, "step_id"), "step-1")
        && 字符串::等于(J.获取字符串(检查点载荷, "node"), "finish")
        && J.获取整数(检查点载荷, "step") == 1,
        "checkpoint_payload");
    通过 = 通过 + 断言(字符串::等于(J.获取字符串(恢复根, "run_id"), "graph-run")
        && 字符串::等于(J.获取字符串(恢复载荷, "reason"), "human_input"),
        "run_resumed_payload");
    J.删除(检查点根);
    J.删除(恢复根);
    数据库.关闭(库);
    IO.删除文件(路径);

    清空生命周期订阅者();
    如果 (通过 == 14) { IO.打印行("PASS module_lifecycle_total_14"); }
    否则 { IO.打印行("FAIL module_lifecycle_total=" + 整数转字符串(通过)); }
}
