包 主程序;

导入 标准库.JSON 作为 J;
导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 标准库.字符串;
导入 Harness::{大模型, 配置超时, 开启会话, 创建代理, 设置重试策略, 添加工具, 运行, 关闭代理, 工具};
导入 Harness.代理::{代理};
导入 Harness.事件::{订阅生命周期事件, 清空生命周期订阅者};
导入 Harness.重试::{重试策略, 错误类别};

变量 事件顺序: 字符串 = "";
变量 首运行ID: 字符串 = "";
变量 元数据正确: 整数 = 1;
变量 事件数: 整数 = 0;
变量 重试错误正确: 整数 = 0;

函数 记录事件(事件JSON: 字符串) : 整数 {
    变量 根: 整数 = J.解码(事件JSON);
    变量 类型值: 字符串 = J.获取字符串(根, "type");
    变量 运行ID: 字符串 = J.获取字符串(根, "run_id");
    变量 轮次ID: 字符串 = J.获取字符串(根, "turn_id");
    变量 步骤ID: 字符串 = J.获取字符串(根, "step_id");
    如果 (事件数 > 0) { 事件顺序 = 事件顺序 + ","; }
    事件顺序 = 事件顺序 + 类型值;
    如果 (事件数 == 0) { 首运行ID = 运行ID; }
    如果 (字符串::字节长度(运行ID) == 0 || 字符串::等于(运行ID, 首运行ID) == 0) {
        元数据正确 = 0;
    }
    如果 (字符串::等于(轮次ID, "turn-1") == 0) { 元数据正确 = 0; }
    如果 (字符串::等于(J.获取字符串(根, "agent"), "agent-lifecycle-test") == 0) {
        元数据正确 = 0;
    }
    如果 (字符串::等于(类型值, "llm_start") == 1 || 字符串::等于(类型值, "llm_end") == 1) {
        如果 (字符串::等于(步骤ID, "step-0") == 0 && 字符串::等于(步骤ID, "step-1") == 0) {
            元数据正确 = 0;
        }
    }
    如果 (字符串::等于(类型值, "tool_start") == 1 || 字符串::等于(类型值, "tool_end") == 1) {
        如果 (字符串::等于(步骤ID, "step-0-tool-0") == 0) { 元数据正确 = 0; }
    }
    如果 (字符串::等于(类型值, "error") == 1) {
        变量 载荷: 整数 = J.获取对象(根, "payload");
        如果 (载荷 > 0
            && 字符串::等于(J.获取字符串(载荷, "source"), "retry") == 1
            && 字符串::等于(J.获取字符串(载荷, "reason"), "exhausted") == 1
            && J.获取整数(载荷, "attempt") == 1
            && J.获取整数(载荷, "max_attempts") == 1) {
            重试错误正确 = 1;
        }
    }
    事件数 = 事件数 + 1;
    J.删除(根);
    返回 1;
}

函数 fixture_echo(参数: 字符串) : 字符串 {
    返回 "fixture-result";
}

函数 断言(条件: 整数, 名字: 字符串) {
    如果 (条件 == 1) { IO.打印行("PASS " + 名字); }
    否则 { IO.打印行("FAIL " + 名字); }
}

函数 入口() {
    清空生命周期订阅者();
    订阅生命周期事件(记录事件, 0);

    变量 配置 = 大模型(系统.获取环境变量("QI_TEST_URL") + "/v1/tool", "fixture-key", "fixture-model");
    配置 = 配置超时(配置, 2);
    变量 代理值: 代理 = 创建代理("agent-lifecycle-test", 开启会话(配置));
    代理值 = 添加工具(代理值, 新建 工具 {
        名字: "fixture_echo",
        描述: "return the deterministic fixture result",
        参数schema: "{\"type\":\"object\",\"properties\":{\"text\":{\"type\":\"string\"}},\"required\":[\"text\"]}",
        处理: fixture_echo,
    });

    变量 回复: 字符串 = 运行(代理值, "call the fixture tool");
    变量 期望: 字符串 = "agent_start,turn_start,llm_start,llm_end,tool_start,tool_end,llm_start,llm_end,turn_end,agent_end";
    断言(字符串::等于(回复, "tool-finished"), "agent_lifecycle_result");
    断言(字符串::等于(事件顺序, 期望), "agent_lifecycle_order");
    断言(事件数 == 10, "agent_lifecycle_count");
    断言(元数据正确, "agent_lifecycle_metadata");

    清空生命周期订阅者();
    关闭代理(代理值);

    事件顺序 = "";
    首运行ID = "";
    元数据正确 = 1;
    事件数 = 0;
    重试错误正确 = 0;
    订阅生命周期事件(记录事件, 0);
    变量 错误配置 = 大模型(系统.获取环境变量("QI_TEST_URL") + "/v1/slow", "fixture-key", "fixture-model");
    错误配置 = 配置超时(错误配置, 1);
    变量 错误代理: 代理 = 创建代理("agent-lifecycle-test", 开启会话(错误配置));
    变量 单次策略: 重试策略 = 新建 重试策略 {
        最大次数: 1,
        起始延迟毫秒: 0,
        最大延迟毫秒: 0,
        倍数: 2,
    };
    错误代理 = 设置重试策略(错误代理, 单次策略);
    变量 错误回复: 字符串 = 运行(错误代理, "timeout fixture");
    变量 错误期望: 字符串 = "agent_start,turn_start,llm_start,error,llm_end,turn_end,agent_end";
    断言(错误类别(错误回复) != 0, "agent_lifecycle_error_result");
    断言(字符串::等于(事件顺序, 错误期望), "agent_lifecycle_error_balanced");
    断言(事件数 == 7, "agent_lifecycle_error_count");
    断言(元数据正确, "agent_lifecycle_error_metadata");
    断言(重试错误正确, "agent_lifecycle_retry_error_payload");
    清空生命周期订阅者();
    关闭代理(错误代理);
}
