包 主程序;

导入 标准库.字符串;
导入 标准库.输入输出 作为 IO;
导入 Harness::{当前时间上下文};

函数 断言(条件: 整数, 名字: 字符串) : 整数 {
    如果 (条件 == 1) { IO.打印行("PASS " + 名字); 返回 1; }
    IO.打印行("FAIL " + 名字);
    返回 0;
}

函数 入口() {
    变量 文本: 字符串 = 当前时间上下文("Asia/Shanghai（北京时间）");
    变量 通过: 整数 = 0;
    通过 = 通过 + 断言(字符串::包含(文本, "【真实当前时间】") == 1, "time_header");
    通过 = 通过 + 断言(字符串::包含(文本, "Asia/Shanghai") == 1, "timezone");
    通过 = 通过 + 断言(字符串::包含(文本, "星期") == 1, "weekday");
    通过 = 通过 + 断言(字符串::包含(文本, "不得凭训练知识猜测") == 1, "relative_time_rule");
    IO.打印行(文本);
    IO.打印行("time_awareness_total_" + 整数转字符串(通过));
}
