包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 标准库.字符串;
导入 Harness::{大模型, 开启会话, 创建代理, 添加工具, 运行, 简单问, 关闭代理, 工具};
导入 Harness.代理::{代理};
导入 Harness.运行上下文::{创建运行上下文, 运行上下文有效, 取运行ID,
    进入运行上下文, 退出运行上下文, 当前运行上下文, 推进轮次, 当前轮次,
    推进步骤, 当前步骤, 设置追踪元数据, 取追踪元数据,
    设置运行工具上下文, 取运行工具上下文, 清理运行上下文,
    运行上下文作用域, 开始代理运行上下文, 结束代理运行上下文};
导入 Harness.工具上下文::{设置工具上下文, 取工具上下文};

变量 内层代理: 代理;
变量 嵌套前句柄: 整数 = 0 - 1;
变量 嵌套后句柄: 整数 = 0 - 1;
变量 嵌套外层保持: 整数 = 0;

函数 调内层代理(参数: 字符串) : 字符串 {
    嵌套前句柄 = 当前运行上下文();
    设置运行工具上下文(嵌套前句柄, "outer-marker", "alive");
    变量 内层回复: 字符串 = 简单问(内层代理, "inner request");
    嵌套后句柄 = 当前运行上下文();
    如果 (嵌套后句柄 == 嵌套前句柄
        && 运行上下文有效(嵌套前句柄) == 1
        && 字符串::等于(取运行工具上下文(嵌套前句柄, "outer-marker"), "alive") == 1) {
        嵌套外层保持 = 1;
    }
    返回 内层回复;
}

函数 断言(条件: 整数, 名字: 字符串) : 整数 {
    如果 (条件 == 1) {
        IO.打印行("PASS " + 名字);
        返回 1;
    }
    IO.打印行("FAIL " + 名字);
    返回 0;
}

函数 入口() {
    变量 通过: 整数 = 0;
    变量 甲: 整数 = 创建运行上下文("run-a");
    变量 乙: 整数 = 创建运行上下文("run-b");

    设置运行工具上下文(甲, "tenant", "alpha");
    设置运行工具上下文(乙, "tenant", "beta");
    设置追踪元数据(甲, "traceparent", "trace-a");
    设置追踪元数据(乙, "traceparent", "trace-b");
    通过 = 通过 + 断言(字符串::等于(取运行ID(甲), "run-a"), "run_id_by_handle");
    通过 = 通过 + 断言(字符串::等于(取运行工具上下文(甲, "tenant"), "alpha"), "context_a_isolated");
    通过 = 通过 + 断言(字符串::等于(取运行工具上下文(乙, "tenant"), "beta"), "context_b_isolated");
    通过 = 通过 + 断言(字符串::等于(取追踪元数据(甲, "traceparent"), "trace-a"), "trace_a_isolated");
    通过 = 通过 + 断言(字符串::等于(取追踪元数据(乙, "traceparent"), "trace-b"), "trace_b_isolated");

    推进轮次(甲);
    推进轮次(甲);
    推进步骤(甲);
    通过 = 通过 + 断言(当前轮次(甲) == 2, "turn_counter");
    通过 = 通过 + 断言(当前步骤(甲) == 1, "step_counter");
    通过 = 通过 + 断言(当前轮次(乙) == 0 && 当前步骤(乙) == 0, "counters_isolated");

    进入运行上下文(甲);
    通过 = 通过 + 断言(当前运行上下文() == 甲, "current_outer");
    通过 = 通过 + 断言(字符串::等于(取工具上下文("tenant"), "alpha"), "legacy_api_outer");
    进入运行上下文(乙);
    通过 = 通过 + 断言(当前运行上下文() == 乙, "current_nested");
    设置工具上下文("nested", "yes");
    通过 = 通过 + 断言(字符串::等于(取运行工具上下文(乙, "nested"), "yes"), "legacy_api_nested");
    退出运行上下文(乙);
    通过 = 通过 + 断言(当前运行上下文() == 甲, "current_restored");
    退出运行上下文(甲);

    变量 外层: 整数 = 创建运行上下文("run-outer");
    变量 内层: 整数 = 创建运行上下文("run-inner");
    进入运行上下文(外层);
    进入运行上下文(内层);
    清理运行上下文(外层);
    通过 = 通过 + 断言(当前运行上下文() == 内层, "cleanup_compacts_nested_stack");
    清理运行上下文(内层);

    清理运行上下文(甲);
    通过 = 通过 + 断言(运行上下文有效(甲) == 0, "cleanup_invalidates");
    通过 = 通过 + 断言(字符串::等于(取运行工具上下文(甲, "tenant"), ""), "cleanup_tool_data");
    通过 = 通过 + 断言(字符串::等于(取追踪元数据(甲, "traceparent"), ""), "cleanup_trace_data");
    清理运行上下文(乙);

    // 预先设置工具上下文会创建空 run-ID 环境上下文。Agent 借用它，但结束后必须
    // 恢复为空且保留调用方数据，不能把调用方上下文一起销毁。
    设置工具上下文("request", "caller");
    变量 环境: 整数 = 当前运行上下文();
    推进轮次(环境);
    推进步骤(环境);
    变量 借用作用域: 运行上下文作用域 = 开始代理运行上下文("agent-borrowed");
    通过 = 通过 + 断言(借用作用域.是否自有 == 0 && 借用作用域.句柄 == 环境, "agent_borrows_ambient_context");
    结束代理运行上下文(借用作用域);
    通过 = 通过 + 断言(运行上下文有效(环境) == 1
        && 当前运行上下文() == 环境
        && 字符串::等于(取运行ID(环境), "") == 1
        && 当前轮次(环境) == 1
        && 当前步骤(环境) == 1
        && 字符串::等于(取工具上下文("request"), "caller") == 1,
        "borrowed_context_restored_not_destroyed");

    // 外层 Agent 已有 run ID 时，内层 Agent 必须拥有新上下文；内层结束只销毁自己，
    // 并把当前上下文恢复到仍然有效的外层。
    变量 外层作用域: 运行上下文作用域 = 开始代理运行上下文("agent-outer");
    变量 外层句柄: 整数 = 外层作用域.句柄;
    变量 内层作用域: 运行上下文作用域 = 开始代理运行上下文("agent-inner");
    变量 内层句柄: 整数 = 内层作用域.句柄;
    通过 = 通过 + 断言(内层作用域.是否自有 == 1 && 内层句柄 != 外层句柄,
        "nested_agent_owns_fresh_context");
    结束代理运行上下文(内层作用域);
    通过 = 通过 + 断言(运行上下文有效(内层句柄) == 0
        && 运行上下文有效(外层句柄) == 1
        && 当前运行上下文() == 外层句柄
        && 字符串::等于(取运行ID(外层句柄), "agent-outer") == 1,
        "nested_agent_restores_outer_context");
    结束代理运行上下文(外层作用域);

    // Qi 当前栈是进程级，无法证明真正线程隔离；这里覆盖并发调用可能产生的交错：
    // 先结束非栈顶 owned 作用域时，只移除自己，另一个调用仍保持当前且数据不泄漏。
    变量 并行基座: 整数 = 创建运行上下文("parallel-base");
    进入运行上下文(并行基座);
    变量 并行甲: 运行上下文作用域 = 开始代理运行上下文("parallel-a");
    设置运行工具上下文(并行甲.句柄, "lane", "a");
    变量 并行乙: 运行上下文作用域 = 开始代理运行上下文("parallel-b");
    设置运行工具上下文(并行乙.句柄, "lane", "b");
    结束代理运行上下文(并行甲);
    通过 = 通过 + 断言(运行上下文有效(并行甲.句柄) == 0
        && 运行上下文有效(并行乙.句柄) == 1
        && 当前运行上下文() == 并行乙.句柄
        && 字符串::等于(取运行工具上下文(并行乙.句柄, "lane"), "b") == 1,
        "overlapping_agent_cleanup_keeps_active_context");
    结束代理运行上下文(并行乙);
    通过 = 通过 + 断言(当前运行上下文() == 并行基座
        && 字符串::等于(取运行工具上下文(并行基座, "lane"), "") == 1
        && 字符串::等于(取运行工具上下文(环境, "lane"), "") == 1,
        "overlapping_agent_contexts_do_not_leak");
    清理运行上下文(并行基座);
    清理运行上下文(环境);

    // 真实嵌套 Agent：外层工具处理器调用内层 Agent。内层结束后必须回到原外层句柄。
    变量 端点: 字符串 = 系统.获取环境变量("QI_TEST_URL");
    变量 内层配置 = 大模型(端点 + "/v1/inner", "fixture-key", "fixture-model");
    内层代理 = 创建代理("inner-agent", 开启会话(内层配置));
    变量 外层配置 = 大模型(端点 + "/v1/outer", "fixture-key", "fixture-model");
    变量 外层代理: 代理 = 创建代理("outer-agent", 开启会话(外层配置));
    外层代理 = 添加工具(外层代理, 新建 工具 {
        名字: "call_inner",
        描述: "invoke the nested agent",
        参数schema: "{\"type\":\"object\"}",
        处理: 调内层代理,
    });
    变量 外层回复: 字符串 = 运行(外层代理, "outer request");
    通过 = 通过 + 断言(字符串::等于(外层回复, "outer-finished") == 1,
        "nested_agent_invocation_result");
    通过 = 通过 + 断言(嵌套外层保持 == 1 && 嵌套前句柄 == 嵌套后句柄,
        "nested_agent_invocation_restores_outer");
    通过 = 通过 + 断言(当前运行上下文() < 0, "agent_invocations_leave_no_owned_context");
    关闭代理(外层代理);
    关闭代理(内层代理);

    如果 (通过 == 26) { IO.打印行("PASS run_context_total_26"); }
    否则 { IO.打印行("FAIL run_context_total=" + 整数转字符串(通过)); }
}
