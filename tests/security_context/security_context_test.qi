包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.时间;
导入 Harness.安全上下文::{安全上下文, 安全会话绑定, 安全上下文配置, 委派配置,
    可信适配器创建安全上下文, 安全上下文有效, 安全上下文未过期,
    安全上下文主体ID, 安全上下文租户ID, 安全上下文认证方式,
    安全上下文请求配额, 安全上下文令牌配额, 安全上下文具有角色,
    安全上下文具有权限, 安全上下文绑定租户, 委派安全上下文,
    可信适配器绑定安全会话, 安全会话绑定有效, 安全会话绑定会话ID,
    安全会话绑定上下文, 释放安全会话绑定, 释放安全上下文, 安全审计决定信封};

函数 断言(条件: 整数, 名字: 字符串) : 整数 {
    如果 (条件 == 1) {
        IO.打印行("PASS " + 名字);
        返回 1;
    }
    IO.打印行("FAIL " + 名字);
    返回 0;
}

函数 根配置(到期: 整数) : 安全上下文配置 {
    返回 新建 安全上下文配置 {
        主体ID: "user-42",
        租户ID: "tenant-a",
        角色: "admin,operator",
        权限: "session.read,session.write,tool.run",
        认证方式: "trusted-test-adapter",
        到期毫秒: 到期,
        追踪ID: "trace-7",
        请求配额: 100,
        令牌配额: 10000,
        策略引用: "policy-v3",
    };
}

函数 可预测上下文猜测均失败(实际句柄: 整数) : 整数 {
    变量 i: 整数 = 1;
    当 (i <= 64) {
        变量 顺序猜测: 安全上下文 = 新建 安全上下文 { 句柄: i * 1000000 + 1 };
        变量 相邻猜测: 安全上下文 = 新建 安全上下文 { 句柄: 实际句柄 + i };
        如果 (安全上下文有效(顺序猜测) == 1 || 安全上下文有效(相邻猜测) == 1) { 返回 0; }
        i = i + 1;
    }
    返回 1;
}

函数 可预测绑定猜测均失败(实际句柄: 整数, 当前毫秒: 整数) : 整数 {
    变量 i: 整数 = 1;
    当 (i <= 64) {
        变量 顺序猜测: 安全会话绑定 = 新建 安全会话绑定 { 句柄: i * 1000000 + 1 };
        变量 相邻猜测: 安全会话绑定 = 新建 安全会话绑定 { 句柄: 实际句柄 + i };
        如果 (安全会话绑定有效(顺序猜测, 当前毫秒) == 1
            || 安全会话绑定有效(相邻猜测, 当前毫秒) == 1) { 返回 0; }
        i = i + 1;
    }
    返回 1;
}

函数 入口() {
    变量 通过: 整数 = 0;
    变量 现时: 整数 = 时间.当前毫秒();
    变量 根: 安全上下文 = 可信适配器创建安全上下文(根配置(现时 + 60000));

    变量 伪造: 安全上下文 = 新建 安全上下文 { 句柄: 42 };
    通过 = 通过 + 断言(安全上下文有效(伪造) == 0
        && 字符串::等于(安全上下文主体ID(伪造), "") == 1, "forged_handle_rejected");

    通过 = 通过 + 断言(安全上下文有效(根) == 1
        && 字符串::等于(安全上下文主体ID(根), "user-42") == 1
        && 字符串::等于(安全上下文租户ID(根), "tenant-a") == 1,
        "trusted_adapter_context_metadata");
    变量 相邻上下文: 安全上下文 = 新建 安全上下文 { 句柄: 根.句柄 + 1 };
    通过 = 通过 + 断言(可预测上下文猜测均失败(根.句柄) == 1
        && 安全上下文有效(相邻上下文) == 0,
        "predictable_context_guesses_rejected");
    变量 会话绑定: 安全会话绑定 = 可信适配器绑定安全会话(根, "session-server-bound");
    通过 = 通过 + 断言(安全会话绑定有效(会话绑定, 现时) == 1
        && 字符串::等于(安全会话绑定会话ID(会话绑定, 现时), "session-server-bound") == 1,
        "trusted_adapter_session_binding");
    变量 相邻绑定: 安全会话绑定 = 新建 安全会话绑定 { 句柄: 会话绑定.句柄 + 1 };
    通过 = 通过 + 断言(可预测绑定猜测均失败(会话绑定.句柄, 现时) == 1
        && 安全会话绑定有效(相邻绑定, 现时) == 0
        && 安全会话绑定上下文(相邻绑定, 现时).句柄 == 0,
        "predictable_session_binding_guesses_rejected");
    通过 = 通过 + 断言(安全上下文绑定租户(根, "tenant-a", 现时) == 1
        && 安全上下文绑定租户(根, "tenant-b", 现时) == 0, "tenant_binding_mismatch");
    通过 = 通过 + 断言(安全上下文具有角色(根, "admin", 现时) == 1
        && 安全上下文具有角色(根, "auditor", 现时) == 0, "role_decisions");
    通过 = 通过 + 断言(安全上下文具有权限(根, "tool.run", 现时) == 1
        && 安全上下文具有权限(根, "tenant.delete", 现时) == 0, "permission_decisions");

    变量 已过期: 安全上下文 = 可信适配器创建安全上下文(根配置(现时 + 10000));
    通过 = 通过 + 断言(安全上下文有效(已过期) == 1
        && 安全上下文未过期(已过期, 现时 + 10000) == 0
        && 安全上下文具有权限(已过期, "tool.run", 现时 + 10000) == 0,
        "expiry_denies_authority");

    变量 子: 安全上下文 = 委派安全上下文(根, 新建 委派配置 {
        角色: "operator",
        权限: "session.read,tool.run",
        到期毫秒: 现时 + 30000,
        请求配额: 20,
        令牌配额: 2000,
        策略引用: "policy-v3/delegated",
    });
    通过 = 通过 + 断言(安全上下文有效(子) == 1
        && 安全上下文具有角色(子, "admin", 现时) == 0
        && 安全上下文具有角色(子, "operator", 现时) == 1
        && 安全上下文具有权限(子, "session.write", 现时) == 0
        && 安全上下文具有权限(子, "tool.run", 现时) == 1
        && 安全上下文请求配额(子) == 20
        && 安全上下文令牌配额(子) == 2000
        && 字符串::包含(安全上下文认证方式(子), "delegated:") == 1,
        "delegation_strictly_reduced");

    变量 扩权: 安全上下文 = 委派安全上下文(根, 新建 委派配置 {
        角色: "admin,operator",
        权限: "session.read,session.write,tool.run,tenant.delete",
        到期毫秒: 现时 + 30000,
        请求配额: 20,
        令牌配额: 2000,
        策略引用: "policy-v3",
    });
    通过 = 通过 + 断言(安全上下文有效(扩权) == 0, "delegation_cannot_expand_permissions");

    变量 未缩配额: 安全上下文 = 委派安全上下文(根, 新建 委派配置 {
        角色: "operator",
        权限: "session.read,tool.run",
        到期毫秒: 现时 + 30000,
        请求配额: 100,
        令牌配额: 10000,
        策略引用: "policy-v3",
    });
    通过 = 通过 + 断言(安全上下文有效(未缩配额) == 0, "delegation_requires_reduced_quota");

    变量 越界到期: 安全上下文 = 委派安全上下文(根, 新建 委派配置 {
        角色: "operator",
        权限: "session.read,tool.run",
        到期毫秒: 现时 + 60001,
        请求配额: 20,
        令牌配额: 2000,
        策略引用: "policy-v3",
    });
    通过 = 通过 + 断言(安全上下文有效(越界到期) == 0, "delegation_expiry_bounded_by_parent");

    变量 审计: 字符串 = 安全审计决定信封(根, "tool.invoke", "tool", "search", 1,
        "allowlisted", "decision-9", 现时);
    通过 = 通过 + 断言(字符串::包含(审计, "decision-9") == 1
        && 字符串::包含(审计, "trusted-test-adapter") == 0
        && 字符串::包含(审计, "10000") == 0, "audit_envelope_omits_sensitive_details");

    变量 旧句柄: 安全上下文 = 根;
    释放安全上下文(根);
    变量 复用: 安全上下文 = 可信适配器创建安全上下文(根配置(现时 + 60000));
    通过 = 通过 + 断言(安全上下文有效(旧句柄) == 0
        && 安全上下文有效(复用) == 1
        && 旧句柄.句柄 != 复用.句柄, "released_handle_stays_stale_after_reuse");

    变量 旧绑定: 安全会话绑定 = 会话绑定;
    释放安全会话绑定(会话绑定);
    变量 复用绑定: 安全会话绑定 = 可信适配器绑定安全会话(复用, "session-reused-slot");
    通过 = 通过 + 断言(安全会话绑定有效(旧绑定, 现时) == 0
        && 安全会话绑定有效(复用绑定, 现时) == 1
        && 旧绑定.句柄 != 复用绑定.句柄,
        "released_binding_stays_stale_after_reuse");
    释放安全会话绑定(复用绑定);
    释放安全上下文(复用);
    释放安全上下文(子);
    释放安全上下文(已过期);
    如果 (通过 == 16) { IO.打印行("PASS security_context_total_16"); }
    否则 { IO.打印行("FAIL security_context_total=" + 整数转字符串(通过)); }
}
