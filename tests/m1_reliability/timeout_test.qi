包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 标准库.时间;
导入 标准库.字符串;
导入 Harness::{大模型, 配置超时, 开启会话, 创建代理, 设置重试策略, 运行, 关闭代理};
导入 Harness.代理::{代理};
导入 Harness.重试::{重试策略, 错误类别};

函数 入口() {
    变量 配置 = 大模型(系统.获取环境变量("QI_TEST_URL") + "/v1/slow", "fixture-key", "fixture-model");
    配置 = 配置超时(配置, 1);
    变量 会话: 整数 = 开启会话(配置);
    变量 代理值: 代理 = 创建代理("timeout-test", 会话);
    变量 单次策略: 重试策略 = 新建 重试策略 {
        最大次数: 1,
        起始延迟毫秒: 0,
        最大延迟毫秒: 0,
        倍数: 2,
    };
    代理值 = 设置重试策略(代理值, 单次策略);

    变量 开始: 整数 = 时间.当前毫秒();
    变量 响应: 字符串 = 运行(代理值, "timeout fixture");
    变量 耗时: 整数 = 时间.当前毫秒() - 开始;

    如果 (耗时 < 4000) { IO.打印行("PASS timeout_prompt_ms_lt_4000"); }
    否则 { IO.打印行("FAIL timeout_prompt_ms=" + 整数转字符串(耗时)); }
    如果 (错误类别(响应) == 1) { IO.打印行("PASS timeout_error_retryable"); }
    否则 { IO.打印行("FAIL timeout_error_class=" + 整数转字符串(错误类别(响应)) + " response=" + 响应); }
    如果 (字符串::包含(响应, "失败") == 1 || 字符串::包含(响应, "timeout") == 1 || 字符串::包含(响应, "超时") == 1) {
        IO.打印行("PASS timeout_returned_error");
    } 否则 {
        IO.打印行("FAIL timeout_response=" + 响应);
    }
    IO.打印行("INFO timeout_elapsed_ms=" + 整数转字符串(耗时));
    关闭代理(代理值);
}
