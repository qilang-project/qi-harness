包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 Harness.预算::{创建预算, 预留令牌, 结算预留令牌,
    已用令牌, 预算需对账, 预算超额令牌};

变量 并发预算: 整数 = 0 - 1;
变量 并发结果 = 通道<整数>(32);

函数 并发预留工人() : 未来<整数> {
    变量 预留结果值: 整数 = 预留令牌(并发预算, 1);
    并发结果 <- 预留结果值;
    返回 预留结果值;
}

函数 入口() {
    并发预算 = 创建预算(1, 0);
    变量 索引: 整数 = 0;
    当 (索引 < 32) {
        启动 并发预留工人();
        索引 = 索引 + 1;
    }
    执行器运行全部();

    变量 成功数: 整数 = 0;
    索引 = 0;
    当 (索引 < 32) {
        成功数 = 成功数 + (<- 并发结果);
        索引 = 索引 + 1;
    }
    如果 (成功数 == 1) {
        IO.打印行("PASS concurrent_reservation_atomic");
    } 否则 {
        IO.打印行("FAIL concurrent_reservation_successes=" + 整数转字符串(成功数));
        系统.退出程序(1);
    }

    变量 精确预算: 整数 = 创建预算(5, 0);
    如果 (预留令牌(精确预算, 5) == 1
        && 结算预留令牌(精确预算, 5, 5, 1) == 5
        && 已用令牌(精确预算) == 5
        && 预算需对账(精确预算) == 0) {
        IO.打印行("PASS exact_reservation_settles_at_limit");
    } 否则 {
        IO.打印行("FAIL exact_reservation_settlement");
        系统.退出程序(1);
    }

    变量 超额预算: 整数 = 创建预算(5, 0);
    如果 (预留令牌(超额预算, 5) == 1
        && 结算预留令牌(超额预算, 5, 6, 1) == 0 - 2
        && 已用令牌(超额预算) == 6
        && 预算需对账(超额预算) == 1
        && 预算超额令牌(超额预算) == 1
        && 预留令牌(超额预算, 1) == 0) {
        IO.打印行("PASS provider_overrun_requires_reconciliation");
    } 否则 {
        IO.打印行("FAIL provider_overrun_reconciliation");
        系统.退出程序(1);
    }
    系统.退出程序(0);
}
