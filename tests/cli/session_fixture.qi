包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 标准库.字符串;
导入 Harness.会话存储::{打开会话存储, 关闭会话存储, 创建持久会话,
    追加用户消息, 追加助手消息};

函数 入口() {
    变量 路径: 字符串 = 系统.获取环境变量("QI_CLI_FIXTURE_DB");
    如果 (IO.文件存在(路径) == 1) { IO.删除文件(路径); }
    变量 库: 整数 = 打开会话存储(路径);
    如果 (库 <= 0 || 创建持久会话(库, "cli-session") <= 0) { 系统.退出程序(1); }
    如果 (字符串::字节长度(追加用户消息(库, "cli-session", "deterministic user payload")) == 0) {
        关闭会话存储(库);
        系统.退出程序(1);
    }
    如果 (字符串::字节长度(追加助手消息(库, "cli-session", "deterministic assistant payload")) == 0) {
        关闭会话存储(库);
        系统.退出程序(1);
    }
    关闭会话存储(库);
}
