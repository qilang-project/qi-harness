// 目标监控 — Goal Setting & Monitoring（目标设定与进度跟踪）
//
// 给 agent 一个显式的「目标 + 验收标准 + 里程碑」结构，把「做到哪了」变成可量化、
// 可断言的确定性状态，而不是全凭模型自述。核心全部 LLM-free、纯计算：进度百分比、
// 是否达成、人读报告都由已完成里程碑数 / 总数直接算出；仅 评估进度 一个函数可选
// 调用一次 LLM，让模型对照当前状态给出「达成了吗 / 下一步推哪个里程碑」的判断。
//
// 里程碑存法：里程碑们 用换行 "\n" 连接的平行串；完成标记 用逗号连接的 "0"/"1"
// 平行标志位，与里程碑一一对应（下标对齐）。都是分隔串，不引入列表字段。
//
// opt-in：不在 Harness.qi 核心自动导入。用法：
//   导入 Harness.目标监控::{目标, 创建目标, 添加里程碑, 标记完成, 进度, 是否达成, 目标报告};

包 Harness;

导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 Harness.模型::{模型配置, 一次对话};
导入 Harness.追踪::{事件};

公开 类型 目标 {
    描述: 字符串,
    验收标准: 字符串,
    里程碑们: 字符串,     // "\n" 连接的里程碑文本
    完成标记: 字符串,     // "," 连接的 "0"/"1" 标志，与里程碑下标对齐
    状态: 字符串,         // "进行中" / "已达成"
}

公开 函数 创建目标(描述: 字符串, 验收标准: 字符串) : 目标 {
    事件("goal_create", "目标监控", 描述);
    返回 新建 目标 {
        描述: 描述,
        验收标准: 验收标准,
        里程碑们: "",
        完成标记: "",
        状态: "进行中",
    };
}

// 追加一个里程碑，初始未完成（标志位 "0"）。
公开 函数 添加里程碑(目标值: 目标, 里程碑: 字符串) : 目标 {
    如果 (字符串::字节长度(目标值.里程碑们) == 0) {
        目标值.里程碑们 = 里程碑;
        目标值.完成标记 = "0";
    } 否则 {
        目标值.里程碑们 = 目标值.里程碑们 + "\n" + 里程碑;
        目标值.完成标记 = 目标值.完成标记 + ",0";
    }
    事件("goal_milestone", "目标监控", 里程碑);
    返回 目标值;
}

// 里程碑总数（= 标志位个数）。
公开 函数 里程碑数(目标值: 目标) : 整数 {
    如果 (字符串::字节长度(目标值.完成标记) == 0) { 返回 0; }
    变量 表: 整数 = 字符串::分割(目标值.完成标记, ",");
    返回 列表库::字符串列表大小(表);
}

// 已完成里程碑数（标志位 == "1" 的个数）。
公开 函数 已完成数(目标值: 目标) : 整数 {
    如果 (字符串::字节长度(目标值.完成标记) == 0) { 返回 0; }
    变量 表: 整数 = 字符串::分割(目标值.完成标记, ",");
    变量 n: 整数 = 列表库::字符串列表大小(表);
    变量 计: 整数 = 0;
    变量 i: 整数 = 0;
    当 (i < n) {
        如果 (字符串::等于(列表库::获取字符串(表, i), "1") == 1) { 计 = 计 + 1; }
        i = i + 1;
    }
    返回 计;
}

// 把标志串里第 索引 位设为 值（"0"/"1"），越界则原样返回。
函数 设标志(标记串: 字符串, 索引: 整数, 值: 字符串) : 字符串 {
    变量 表: 整数 = 字符串::分割(标记串, ",");
    变量 n: 整数 = 列表库::字符串列表大小(表);
    如果 (索引 < 0 || 索引 >= n) { 返回 标记串; }
    变量 结果值: 字符串 = "";
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 片: 字符串 = 列表库::获取字符串(表, i);
        如果 (i == 索引) { 片 = 值; }
        如果 (i > 0) { 结果值 = 结果值 + ","; }
        结果值 = 结果值 + 片;
        i = i + 1;
    }
    返回 结果值;
}

// 标记第 里程碑索引 个里程碑为已完成（0 基）。越界安全忽略。
公开 函数 标记完成(目标值: 目标, 里程碑索引: 整数) : 目标 {
    目标值.完成标记 = 设标志(目标值.完成标记, 里程碑索引, "1");
    如果 (是否达成(目标值) == 1) { 目标值.状态 = "已达成"; }
    事件("goal_progress", "目标监控",
        "里程碑 #" + 整数转字符串(里程碑索引) + " 完成 · " + 目标报告(目标值));
    返回 目标值;
}

// 进度 0.0–1.0 = 已完成里程碑 / 总里程碑。无里程碑时返回 0.0。
公开 函数 进度(目标值: 目标) : 浮点数 {
    变量 总: 整数 = 里程碑数(目标值);
    如果 (总 == 0) { 返回 0.0; }
    返回 整数转浮点数(已完成数(目标值)) / 整数转浮点数(总);
}

// 是否全部里程碑都已完成（至少要有 1 个里程碑）。
公开 函数 是否达成(目标值: 目标) : 整数 {
    变量 总: 整数 = 里程碑数(目标值);
    如果 (总 == 0) { 返回 0; }
    如果 (已完成数(目标值) == 总) { 返回 1; }
    返回 0;
}

// 人读进度摘要：✓/○ 列表 + 百分比。
公开 函数 目标报告(目标值: 目标) : 字符串 {
    变量 总: 整数 = 里程碑数(目标值);
    变量 完: 整数 = 已完成数(目标值);
    变量 百分: 整数 = 0;
    如果 (总 > 0) { 百分 = (完 * 100) / 总; }
    变量 文本: 字符串 = "目标：" + 目标值.描述 + "\n"
        + "进度：" + 整数转字符串(完) + "/" + 整数转字符串(总)
        + "（" + 整数转字符串(百分) + "%）· 状态：" + 目标值.状态 + "\n";
    如果 (总 > 0) {
        变量 里程表: 整数 = 字符串::分割(目标值.里程碑们, "\n");
        变量 标记表: 整数 = 字符串::分割(目标值.完成标记, ",");
        变量 i: 整数 = 0;
        当 (i < 总) {
            变量 前缀: 字符串 = "○ ";
            如果 (字符串::等于(列表库::获取字符串(标记表, i), "1") == 1) { 前缀 = "✓ "; }
            文本 = 文本 + "  " + 前缀 + 列表库::获取字符串(里程表, i) + "\n";
            i = i + 1;
        }
    }
    返回 文本;
}

// 可选 LLM：让模型对照 当前状态 判断是否达成目标、该推进到哪个里程碑。
// 纯只读一次对话，不改目标结构；无 LLM/网络失败时返回底层错误串，不崩。
公开 函数 评估进度(目标值: 目标, 当前状态: 字符串, 配置值: 模型配置) : 字符串 {
    变量 提示: 字符串 = "目标：" + 目标值.描述
        + "\n验收标准：" + 目标值.验收标准
        + "\n里程碑清单：\n" + 目标值.里程碑们
        + "\n\n当前进展状态：\n" + 当前状态
        + "\n\n请判断：目标是否已达成？若未达成，下一步应推进哪个里程碑、为什么？用两三句话回答。";
    事件("goal_assess", "目标监控", 目标值.描述);
    返回 一次对话(配置值, 提示);
}
