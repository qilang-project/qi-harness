// 评估 — Eval harness
//
// agent 改 prompt / 加 tool / 换模型，必须有「跑一遍标准用例 + 对比期望」的回归网。
// 四种打分器：包含 / 精确 / 正则 / LLM-as-judge；数据集 JSON 加载；跑批通过率；基线回归。
// 打分方式常量：0=包含（默认）1=精确 2=正则 3=LLM裁判

包 Harness;

导入 标准库.字符串;
导入 标准库.输入输出 作为 IO;
导入 标准库.列表 作为 列表库;
导入 标准库.正则 作为 正则;
导入 标准库.JSON 作为 J;
导入 标准库.大模型 作为 底层模型;
导入 Harness.代理::{代理, 运行};

公开 类型 测例 {
    名字: 字符串,
    提示: 字符串,
    期望子串: 字符串,
    方式: 整数,
    裁判标准: 字符串,
}

公开 类型 评估套件 {
    测例列表: 整数,
    通过数: 整数,
    失败数: 整数,
    结果列表: 整数,
}

公开 函数 创建套件() : 评估套件 {
    返回 (评估套件 {
        测例列表: 列表库::创建指针列表(),
        通过数: 0,
        失败数: 0,
        结果列表: 列表库::创建字符串列表(),
    });
}

公开 函数 创建测例(名字: 字符串, 提示: 字符串, 期望: 字符串, 方式: 整数, 裁判标准: 字符串) : 测例 {
    返回 (测例 { 名字: 名字, 提示: 提示, 期望子串: 期望, 方式: 方式, 裁判标准: 裁判标准 });
}

公开 函数 添加测例(套件值: 评估套件, 名字: 字符串, 提示: 字符串, 期望子串: 字符串) : 评估套件 {
    列表库::添加指针(套件值.测例列表, 创建测例(名字, 提示, 期望子串, 0, ""));
    返回 套件值;
}

公开 函数 添加测例带方式(套件值: 评估套件, 名字: 字符串, 提示: 字符串, 期望: 字符串, 方式: 整数) : 评估套件 {
    列表库::添加指针(套件值.测例列表, 创建测例(名字, 提示, 期望, 方式, ""));
    返回 套件值;
}

公开 函数 添加裁判测例(套件值: 评估套件, 名字: 字符串, 提示: 字符串, 裁判标准: 字符串) : 评估套件 {
    列表库::添加指针(套件值.测例列表, 创建测例(名字, 提示, "", 3, 裁判标准));
    返回 套件值;
}

// 从 JSON 数组批量加载：[{"名字":..,"提示":..,"期望":..,"方式":0}, ...]
公开 函数 从JSON加载(套件值: 评估套件, JSON文本: 字符串) : 整数 {
    变量 数组句柄: 整数 = J.解码(JSON文本);
    如果 (数组句柄 <= 0) { 返回 0; }
    变量 n: 整数 = J.数组长度(数组句柄);
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 项: 整数 = J.数组获取对象(数组句柄, i);
        套件值 = 添加测例带方式(套件值,
            J.获取字符串(项, "名字"), J.获取字符串(项, "提示"),
            J.获取字符串(项, "期望"), J.获取整数(项, "方式"));
        i = i + 1;
    }
    返回 n;
}

// 单条打分（核心）：吃原语，方式 3 用会话句柄直接调模型判 PASS/FAIL。返回 1 通过 / 0 失败。
// 注：本模块的跑批函数叫 运行套件（不叫 运行）—— 避免与导入的 代理.运行 同名；
//     Qi 目前对「本地函数与导入函数同名」不按签名解析会绑错，必须避开重名。
公开 函数 打分文本(实际: 字符串, 期望: 字符串, 方式: 整数, 裁判标准: 字符串, 裁判会话: 整数) : 整数 {
    如果 (方式 == 1) {
        如果 (字符串::等于(实际, 期望) == 1) { 返回 1; }
        返回 0;
    }
    如果 (方式 == 2) {
        返回 正则.是否匹配(期望, 实际);
    }
    如果 (方式 == 3) {
        变量 提示: 字符串 = "你是严格的评估裁判。评分标准：" + 裁判标准
            + "\n\n候选回答：\n" + 实际
            + "\n\n只回一个词：PASS（满足标准）或 FAIL（不满足）。";
        // 每次判定前清空裁判会话历史 —— 否则逐例复用同一会话，前例上下文会污染后例判断
        底层模型.清空历史(裁判会话);
        变量 裁决: 字符串 = 底层模型.对话(裁判会话, 提示);
        // 放宽匹配：小模型未必只吐一个词
        如果 (字符串::包含(裁决, "PASS") == 1) { 返回 1; }
        如果 (字符串::包含(裁决, "通过") == 1) { 返回 1; }
        如果 (字符串::包含(裁决, "符合") == 1) { 返回 1; }
        如果 (字符串::包含(裁决, "满足") == 1) { 返回 1; }
        返回 0;
    }
    如果 (字符串::包含(实际, 期望) == 1) { 返回 1; }
    返回 0;
}

// 手动记一条结果（跨包不便直接戳字段时用）。
公开 函数 记录结果(套件值: 评估套件, 名字: 字符串, 通过: 整数) : 评估套件 {
    列表库::添加字符串(套件值.结果列表, 名字 + "\t" + 整数转字符串(通过));
    返回 套件值;
}

公开 函数 清空结果(套件值: 评估套件) : 评估套件 {
    套件值.结果列表 = 列表库::创建字符串列表();
    返回 套件值;
}

// 跑全部测例（带裁判代理）。逐例打分 + 累计 + 记结果。
公开 函数 运行套件(套件值: 评估套件, 代理值: 代理, 裁判会话: 整数) : 评估套件 {
    变量 总数: 整数 = 列表库::指针列表大小(套件值.测例列表);
    套件值.通过数 = 0;
    套件值.失败数 = 0;
    套件值.结果列表 = 列表库::创建字符串列表();

    IO.打印行("===== Eval Harness =====");
    IO.打印行("套件含 " + 整数转字符串(总数) + " 个测例");

    变量 索引: 整数 = 0;
    当 (索引 < 总数) {
        变量 t: 测例 = 列表库::获取指针(套件值.测例列表, 索引);
        变量 用例名: 字符串 = t.名字;
        IO.打印("[" + 整数转字符串(索引 + 1) + "/" + 整数转字符串(总数) + "] " + 用例名 + " ... ");
        变量 实际: 字符串 = 运行(代理值, t.提示);
        变量 过: 整数 = 打分文本(实际, t.期望子串, t.方式, t.裁判标准, 裁判会话);
        如果 (过 == 1) {
            IO.打印行("PASS");
            套件值.通过数 = 套件值.通过数 + 1;
            列表库::添加字符串(套件值.结果列表, 用例名 + "\t1");
        } 否则 {
            IO.打印行("FAIL");
            IO.打印行("  实际: " + 实际);
            套件值.失败数 = 套件值.失败数 + 1;
            列表库::添加字符串(套件值.结果列表, 用例名 + "\t0");
        }
        索引 = 索引 + 1;
    }

    变量 通过率: 整数 = 0;
    如果 (总数 > 0) { 通过率 = 套件值.通过数 * 100 / 总数; }
    IO.打印行("===== 结果: " + 整数转字符串(套件值.通过数) + " PASS / "
              + 整数转字符串(套件值.失败数) + " FAIL（通过率 " + 整数转字符串(通过率) + "%）=====");
    返回 套件值;
}

公开 函数 保存基线(套件值: 评估套件, 路径: 字符串) : 整数 {
    变量 内容: 字符串 = "";
    变量 n: 整数 = 列表库::字符串列表大小(套件值.结果列表);
    变量 i: 整数 = 0;
    当 (i < n) {
        内容 = 内容 + 列表库::获取字符串(套件值.结果列表, i) + "\n";
        i = i + 1;
    }
    返回 IO.写入文件(路径, 内容);
}

函数 查结果(结果列表: 整数, 名字: 字符串) : 字符串 {
    变量 n: 整数 = 列表库::字符串列表大小(结果列表);
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 行: 字符串 = 列表库::获取字符串(结果列表, i);
        变量 制表位: 整数 = 字符串::查找(行, "\t");
        如果 (制表位 > 0) {
            如果 (字符串::等于(字符串::子串(行, 0, 制表位), 名字) == 1) {
                返回 字符串::子串从位置(行, 制表位 + 1);
            }
        }
        i = i + 1;
    }
    返回 "";
}

// ===== 数据集驱动评估 + 基线门禁（可 CI 化）=====
//
// 用法（配合 LLM 磁带，见 examples/磁带测.qi / 评估套件测.qi）：
//   1. 真跑一次录磁带：QI_LLM_RECORD=1 QI_LLM_TAPE=t.json qi run eval.qi
//      —— 同时 基线门禁 发现基线文件不存在，自动建立基线（写 JSON）。
//   2. 之后 CI 里回放：QI_LLM_REPLAY=1 QI_LLM_TAPE=t.json qi run eval.qi
//      —— 离线、免费、确定性：同请求→同响应→同分数，门禁判定可复现。
//   3. 基线门禁 若本次平均分 < 基线平均分 - 容差 → 返回 1（回归），CI 据此 exit 非 0。

// 直接用一个 LLM 会话跑整套用例（无需组装代理）。
// 每个用例前清空会话历史（用例间互不污染）；方式 3（LLM 裁判）复用同一会话判定。
公开 函数 运行评估集(套件值: 评估套件, 会话: 整数) : 评估套件 {
    变量 总数: 整数 = 列表库::指针列表大小(套件值.测例列表);
    套件值.通过数 = 0;
    套件值.失败数 = 0;
    套件值.结果列表 = 列表库::创建字符串列表();

    IO.打印行("===== 评估集 =====");
    IO.打印行("共 " + 整数转字符串(总数) + " 个用例");

    变量 索引: 整数 = 0;
    当 (索引 < 总数) {
        变量 t: 测例 = 列表库::获取指针(套件值.测例列表, 索引);
        变量 用例名: 字符串 = t.名字;
        IO.打印("[" + 整数转字符串(索引 + 1) + "/" + 整数转字符串(总数) + "] " + 用例名 + " ... ");
        底层模型.清空历史(会话);
        变量 实际: 字符串 = 底层模型.对话(会话, t.提示);
        变量 过: 整数 = 打分文本(实际, t.期望子串, t.方式, t.裁判标准, 会话);
        如果 (过 == 1) {
            IO.打印行("PASS");
            套件值.通过数 = 套件值.通过数 + 1;
            列表库::添加字符串(套件值.结果列表, 用例名 + "\t1");
        } 否则 {
            IO.打印行("FAIL");
            IO.打印行("  实际: " + 实际);
            套件值.失败数 = 套件值.失败数 + 1;
            列表库::添加字符串(套件值.结果列表, 用例名 + "\t0");
        }
        索引 = 索引 + 1;
    }

    变量 本次分: 整数 = 平均分百分(套件值);
    IO.打印行("===== 结果: " + 整数转字符串(套件值.通过数) + " PASS / "
              + 整数转字符串(套件值.失败数) + " FAIL（平均分 " + 整数转字符串(本次分) + "）=====");
    返回 套件值;
}

// 平均分（0~100 整数）—— 按 结果列表 统计（运行套件 / 运行评估集 / 记录结果 均可）。
// 打分器都是 0/1 制，平均分即通过率百分比。
公开 函数 平均分百分(套件值: 评估套件) : 整数 {
    变量 n: 整数 = 列表库::字符串列表大小(套件值.结果列表);
    如果 (n <= 0) { 返回 0; }
    变量 过数: 整数 = 0;
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 行: 字符串 = 列表库::获取字符串(套件值.结果列表, i);
        变量 制表位: 整数 = 字符串::查找(行, "\t");
        如果 (制表位 > 0) {
            如果 (字符串::等于(字符串::子串从位置(行, 制表位 + 1), "1") == 1) {
                过数 = 过数 + 1;
            }
        }
        i = i + 1;
    }
    返回 过数 * 100 / n;
}

// 把本次结果持久化成 JSON 基线：{"平均分":..,"总数":..,"通过":..,"明细":[{"名字":..,"通过":0/1}]}
公开 函数 保存基线JSON(套件值: 评估套件, 路径: 字符串) : 整数 {
    变量 根: 整数 = J.创建对象();
    变量 n: 整数 = 列表库::字符串列表大小(套件值.结果列表);
    变量 过数: 整数 = 0;
    变量 明细: 整数 = J.创建数组();
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 行: 字符串 = 列表库::获取字符串(套件值.结果列表, i);
        变量 制表位: 整数 = 字符串::查找(行, "\t");
        变量 名字: 字符串 = 字符串::子串(行, 0, 制表位);
        变量 通过值: 整数 = 0;
        如果 (字符串::等于(字符串::子串从位置(行, 制表位 + 1), "1") == 1) {
            通过值 = 1;
            过数 = 过数 + 1;
        }
        变量 项: 整数 = J.创建对象();
        J.设置字符串(项, "名字", 名字);
        J.设置整数(项, "通过", 通过值);
        J.数组添加对象(明细, 项);
        i = i + 1;
    }
    J.设置整数(根, "平均分", 平均分百分(套件值));
    J.设置整数(根, "总数", n);
    J.设置整数(根, "通过", 过数);
    J.设置数组(根, "明细", 明细);
    返回 IO.写入文件(路径, J.转字符串(根));
}

// 读基线 JSON 的平均分；文件不存在/解析失败返回 -1。
公开 函数 读基线平均分(路径: 字符串) : 整数 {
    如果 (IO.文件存在(路径) == 0) { 返回 0 - 1; }
    变量 文本: 字符串 = IO.读取文件(路径);
    变量 对象: 整数 = J.解码(文本);
    如果 (对象 <= 0) { 返回 0 - 1; }
    返回 J.获取整数(对象, "平均分");
}

// 基线门禁（CI 用）：
//   - 基线文件不存在 → 用本次结果建立基线，返回 0（首跑通过）
//   - 本次平均分 < 基线平均分 - 容差百分 → 打印「回归 ✗」，返回 1（CI 应 exit 非 0）
//   - 否则打印「无回归 ✓」，返回 0。基线不自动覆盖（想刷新用 保存基线JSON）。
公开 函数 基线门禁(套件值: 评估套件, 基线路径: 字符串, 容差百分: 整数) : 整数 {
    变量 本次分: 整数 = 平均分百分(套件值);
    变量 基线分: 整数 = 读基线平均分(基线路径);
    如果 (基线分 < 0) {
        保存基线JSON(套件值, 基线路径);
        IO.打印行("[门禁] 基线不存在，已建立基线（平均分 " + 整数转字符串(本次分)
                  + "）→ " + 基线路径);
        返回 0;
    }
    变量 底线: 整数 = 基线分 - 容差百分;
    IO.打印行("[门禁] 本次 " + 整数转字符串(本次分) + " vs 基线 " + 整数转字符串(基线分)
              + "（容差 " + 整数转字符串(容差百分) + "）");
    如果 (本次分 < 底线) {
        IO.打印行("[门禁] 回归 ✗ —— 平均分跌破 基线-容差=" + 整数转字符串(底线));
        返回 1;
    }
    IO.打印行("[门禁] 无回归 ✓");
    返回 0;
}

// 对比基线：返回回归数（>0 说明有 PASS→FAIL，CI 应据此失败）。
公开 函数 对比基线(套件值: 评估套件, 路径: 字符串) : 整数 {
    变量 基线文本: 字符串 = IO.读取文件(路径);
    变量 基线列表: 整数 = 列表库::创建字符串列表();
    变量 行表: 整数 = 字符串::分割(基线文本, "\n");
    变量 行数: 整数 = 列表库::字符串列表大小(行表);
    变量 r: 整数 = 0;
    当 (r < 行数) {
        变量 行: 字符串 = 字符串::去空白(列表库::获取字符串(行表, r));
        如果 (字符串::字节长度(行) > 0) {
            列表库::添加字符串(基线列表, 行);
        }
        r = r + 1;
    }

    IO.打印行("===== 基线对比 =====");
    变量 回归数: 整数 = 0;
    变量 修复数: 整数 = 0;
    变量 新增数: 整数 = 0;
    变量 n: 整数 = 列表库::字符串列表大小(套件值.结果列表);
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 本行: 字符串 = 列表库::获取字符串(套件值.结果列表, i);
        变量 制表位: 整数 = 字符串::查找(本行, "\t");
        变量 名字: 字符串 = 字符串::子串(本行, 0, 制表位);
        变量 今: 字符串 = 字符串::子串从位置(本行, 制表位 + 1);
        变量 昨: 字符串 = 查结果(基线列表, 名字);
        如果 (字符串::字节长度(昨) == 0) {
            IO.打印行("  [新增] " + 名字);
            新增数 = 新增数 + 1;
        } 否则 {
            如果 (字符串::等于(昨, "1") == 1) {
                如果 (字符串::等于(今, "0") == 1) {
                    IO.打印行("  [回归] " + 名字 + " PASS -> FAIL");
                    回归数 = 回归数 + 1;
                }
            } 否则 {
                如果 (字符串::等于(今, "1") == 1) {
                    IO.打印行("  [修复] " + 名字 + " FAIL -> PASS");
                    修复数 = 修复数 + 1;
                }
            }
        }
        i = i + 1;
    }
    IO.打印行("回归 " + 整数转字符串(回归数) + " · 修复 " + 整数转字符串(修复数)
              + " · 新增 " + 整数转字符串(新增数));
    返回 回归数;
}
