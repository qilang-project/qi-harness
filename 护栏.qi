// 护栏 — 输入/输出/工具的安全层
//
// 文件沙箱只管住了文件工具。面向用户的 agent 还需要：挡提示注入、脱敏 PII、
// 守住输出结构、限制工具参数。本模块给这几道纯 Qi 护栏（工具层强制，模型绕不过）。
//
//   检测注入   —— 用户输入里有没有"忽略以上指令/你现在是…"这类越权改写企图
//   脱敏       —— 把邮箱/手机号/长数字串等 PII 替成 ***（正则）
//   校验输出   —— 输出必须是含指定字段的合法 JSON（输出 schema 守卫）
//   工具参数放行 —— 按拒绝词表挡危险工具参数（如 SQL/路径/命令注入片段）
//   守卫运行   —— 把上面几道套在 代理.运行 外：入口挡注入、出口脱敏

包 Harness;

导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 标准库.JSON 作为 J;
导入 标准库.正则 作为 正则;
导入 Harness.代理::{代理, 运行};
导入 Harness.追踪::{事件, 错误事件};

// —— 输入：提示注入检测 ——
// 命中已知越权改写模式返回 1（可疑），否则 0。保守集：只挡"改写系统/越权"类，
// 不误伤正常的"扮演角色"业务需求。大小写不敏感。
公开 函数 检测注入(文本: 字符串) : 整数 {
    变量 低: 字符串 = 字符串::转小写(文本);
    如果 (字符串::包含(低, "ignore previous") == 1) { 返回 1; }
    如果 (字符串::包含(低, "ignore above") == 1) { 返回 1; }
    如果 (字符串::包含(低, "disregard the above") == 1) { 返回 1; }
    如果 (字符串::包含(低, "disregard previous") == 1) { 返回 1; }
    如果 (字符串::包含(低, "reveal your system") == 1) { 返回 1; }
    如果 (字符串::包含(低, "your system prompt") == 1) { 返回 1; }
    如果 (字符串::包含(低, "ignore your instructions") == 1) { 返回 1; }
    如果 (字符串::包含(文本, "忽略以上") == 1) { 返回 1; }
    如果 (字符串::包含(文本, "忽略之前") == 1) { 返回 1; }
    如果 (字符串::包含(文本, "忽略前面") == 1) { 返回 1; }
    如果 (字符串::包含(文本, "忽略上述") == 1) { 返回 1; }
    如果 (字符串::包含(文本, "泄露你的系统") == 1) { 返回 1; }
    如果 (字符串::包含(文本, "泄露系统提示") == 1) { 返回 1; }
    如果 (字符串::包含(文本, "重复你的指令") == 1) { 返回 1; }
    如果 (字符串::包含(文本, "你的系统提示") == 1) { 返回 1; }
    返回 0;
}

// —— PII 脱敏 ——
// 邮箱、手机号(中国11位)、长数字串(≥13位，含卡号/身份证)替成掩码。返回脱敏后文本。
公开 函数 脱敏(文本: 字符串) : 字符串 {
    变量 s: 字符串 = 文本;
    // 邮箱
    s = 正则.全部替换("[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}", s, "[邮箱]");
    // 长数字串（≥13 位：银行卡/身份证等）——必须先于手机号，否则 11 位手机正则
    // 会先咬掉长号码里的一截，导致卡号残缺。
    s = 正则.全部替换("[0-9]{13,}", s, "[号码]");
    // 中国手机号（1 开头 11 位）
    s = 正则.全部替换("1[0-9]{10}", s, "[手机]");
    返回 s;
}

// —— 输出 schema 守卫 ——
// 输出必须是合法 JSON 且含 必需字段（字符串列表句柄）。合规 1 / 不合规 0。
公开 函数 校验输出(输出: 字符串, 必需字段: 整数) : 整数 {
    变量 对象: 整数 = J.解码(输出);
    如果 (对象 <= 0) { 返回 0; }
    变量 n: 整数 = 列表库::字符串列表大小(必需字段);
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 键: 字符串 = 列表库::获取字符串(必需字段, i);
        如果 (J.是否包含键(对象, 键) == 0) { 返回 0; }
        i = i + 1;
    }
    返回 1;
}

// —— 工具参数策略 ——
// 参数 JSON 里含任一拒绝词（拒绝词列表：字符串列表句柄）→ 拦截返回 0（放行 1）。
// 用于挡 SQL/命令/路径 注入片段，如 "DROP TABLE" / "rm -rf" / "../" / "/etc"。
公开 函数 工具参数放行(参数JSON: 字符串, 拒绝词列表: 整数) : 整数 {
    变量 n: 整数 = 列表库::字符串列表大小(拒绝词列表);
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 词: 字符串 = 列表库::获取字符串(拒绝词列表, i);
        如果 (字符串::包含(参数JSON, 词) == 1) {
            错误事件("护栏", "工具参数命中拒绝词「" + 词 + "」，已拦截: " + 参数JSON);
            返回 0;
        }
        i = i + 1;
    }
    返回 1;
}

// —— 守卫运行 ——
// 把入口注入检测 + 出口 PII 脱敏套在 代理.运行 外。
// 检测到注入直接拒绝、不喂给模型；正常则运行并对回复脱敏。
公开 函数 守卫运行(代理值: 代理, 提示: 字符串) : 字符串 {
    如果 (检测注入(提示) == 1) {
        错误事件("护栏", "检测到疑似提示注入，已拒绝: " + 提示);
        返回 "[护栏] 输入疑似提示注入，已拒绝处理。";
    }
    变量 回复: 字符串 = 运行(代理值, 提示);
    变量 脱敏回复: 字符串 = 脱敏(回复);
    如果 (字符串::等于(脱敏回复, 回复) == 0) {
        事件("guardrail_redact", 代理值.名字, "输出已脱敏");
    }
    返回 脱敏回复;
}
