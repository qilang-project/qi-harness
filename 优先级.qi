// 优先级 — Prioritization（任务优先级队列）
//
// 给 agent 一个「先做什么」的确定性调度器：任务带一个整数优先级，出队总是取当前
// 优先级最高的那个。核心全部 LLM-free、纯计算：入队/出队/大小/报告都不碰模型；仅
// 评优先级 一个函数可选调用一次 LLM，让模型给一批任务打分并回填优先级。
//
// 存法：任务们 用换行 "\n" 连接的平行串；优先级们 用逗号连接的整数平行串，与任务
// 下标一一对齐。都是分隔串，不引入列表字段。优先级数越大越紧急；出队取最大；相等
// 时取先入队的（稳定）。
//
// opt-in：不在 Harness.qi 核心自动导入。用法：
//   导入 Harness.优先级::{优先队列, 创建队列, 入队, 出队, 队列大小, 队列报告};

包 Harness;

导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 Harness.模型::{模型配置, 一次对话};
导入 标准库.JSON 作为 J;
导入 Harness.追踪::{事件};

公开 类型 优先队列 {
    任务们: 字符串,       // "\n" 连接的任务文本
    优先级们: 字符串,     // "," 连接的整数，与任务下标对齐
}

公开 函数 创建队列() : 优先队列 {
    返回 新建 优先队列 {
        任务们: "",
        优先级们: "",
    };
}

// 入队：追加一个任务及其优先级（越大越紧急）。
公开 函数 入队(队列值: 优先队列, 任务文本: 字符串, 优先级: 整数) : 优先队列 {
    如果 (字符串::字节长度(队列值.任务们) == 0) {
        队列值.任务们 = 任务文本;
        队列值.优先级们 = 整数转字符串(优先级);
    } 否则 {
        队列值.任务们 = 队列值.任务们 + "\n" + 任务文本;
        队列值.优先级们 = 队列值.优先级们 + "," + 整数转字符串(优先级);
    }
    事件("prio_enqueue", "优先级", 任务文本 + " (p=" + 整数转字符串(优先级) + ")");
    返回 队列值;
}

// 队列大小 = 任务个数。
公开 函数 队列大小(队列值: 优先队列) : 整数 {
    如果 (字符串::字节长度(队列值.任务们) == 0) { 返回 0; }
    变量 表: 整数 = 字符串::分割(队列值.任务们, "\n");
    返回 列表库::字符串列表大小(表);
}

// 找当前最高优先级的下标（相等取更早入队的）。空队返回 -1。
函数 最高下标(队列值: 优先队列) : 整数 {
    变量 大小: 整数 = 队列大小(队列值);
    如果 (大小 == 0) { 返回 0 - 1; }
    变量 优先表: 整数 = 字符串::分割(队列值.优先级们, ",");
    变量 最好: 整数 = 0;
    变量 最好分: 整数 = 字符串转整数(列表库::获取字符串(优先表, 0));
    变量 i: 整数 = 1;
    当 (i < 大小) {
        变量 分: 整数 = 字符串转整数(列表库::获取字符串(优先表, i));
        如果 (分 > 最好分) {
            最好分 = 分;
            最好 = i;
        }
        i = i + 1;
    }
    返回 最好;
}

// 把某个分隔串里第 索引 段删掉后重新拼回（分隔符可为 "\n" 或 ","）。
函数 删段(串: 字符串, 分隔符: 字符串, 索引: 整数) : 字符串 {
    变量 表: 整数 = 字符串::分割(串, 分隔符);
    变量 n: 整数 = 列表库::字符串列表大小(表);
    变量 结果值: 字符串 = "";
    变量 首: 整数 = 1;
    变量 i: 整数 = 0;
    当 (i < n) {
        如果 (i != 索引) {
            如果 (首 == 1) {
                结果值 = 列表库::获取字符串(表, i);
                首 = 0;
            } 否则 {
                结果值 = 结果值 + 分隔符 + 列表库::获取字符串(表, i);
            }
        }
        i = i + 1;
    }
    返回 结果值;
}

// 出队：返回并移除当前最高优先级的任务；空队返回 ""。
// （原地改写 任务们/优先级们 —— 结构体是堆对象，字段改动对调用方可见。）
公开 函数 出队(队列值: 优先队列) : 字符串 {
    变量 下标: 整数 = 最高下标(队列值);
    如果 (下标 < 0) { 返回 ""; }
    变量 任务表: 整数 = 字符串::分割(队列值.任务们, "\n");
    变量 取出: 字符串 = 列表库::获取字符串(任务表, 下标);
    队列值.任务们 = 删段(队列值.任务们, "\n", 下标);
    队列值.优先级们 = 删段(队列值.优先级们, ",", 下标);
    事件("prio_dequeue", "优先级", 取出);
    返回 取出;
}

// 队列报告：按优先级降序列出（不改动队列）。
公开 函数 队列报告(队列值: 优先队列) : 字符串 {
    变量 大小: 整数 = 队列大小(队列值);
    如果 (大小 == 0) { 返回 "（队列为空）"; }
    变量 任务表: 整数 = 字符串::分割(队列值.任务们, "\n");
    变量 优先表: 整数 = 字符串::分割(队列值.优先级们, ",");
    // 简单选择排序取下标降序（队列一般不长）。
    变量 已用: 字符串 = "";       // 逗号包裹的已输出下标集合
    变量 文本: 字符串 = "优先队列（共 " + 整数转字符串(大小) + " 项，优先级降序）：\n";
    变量 输出数: 整数 = 0;
    当 (输出数 < 大小) {
        变量 最好: 整数 = 0 - 1;
        变量 最好分: 整数 = 0;
        变量 i: 整数 = 0;
        当 (i < 大小) {
            变量 已选: 整数 = 0;
            如果 (字符串::包含("," + 已用 + ",", "," + 整数转字符串(i) + ",") == 1) { 已选 = 1; }
            如果 (已选 == 0) {
                变量 分: 整数 = 字符串转整数(列表库::获取字符串(优先表, i));
                如果 (最好 < 0 || 分 > 最好分) {
                    最好 = i;
                    最好分 = 分;
                }
            }
            i = i + 1;
        }
        文本 = 文本 + "  [" + 整数转字符串(最好分) + "] "
            + 列表库::获取字符串(任务表, 最好) + "\n";
        已用 = 已用 + 整数转字符串(最好) + ",";
        输出数 = 输出数 + 1;
    }
    返回 文本;
}

// 可选 LLM：让模型给队列里每个任务打 0–100 优先级分并回填。
// 模型须回严格 JSON 数组 [{"任务":"…","分":N}, …]；解析失败则原样返回原队列，不崩。
公开 函数 评优先级(队列值: 优先队列, 配置值: 模型配置) : 优先队列 {
    变量 大小: 整数 = 队列大小(队列值);
    如果 (大小 == 0) { 返回 队列值; }
    变量 提示: 字符串 = "给下列任务按紧急/重要程度打 0–100 的优先级分（越大越优先）。"
        + "只输出严格 JSON 数组，每项形如 {\"序\":下标整数,\"分\":分数整数}，不要多余文字。\n任务清单：\n";
    变量 任务表: 整数 = 字符串::分割(队列值.任务们, "\n");
    变量 i: 整数 = 0;
    当 (i < 大小) {
        提示 = 提示 + 整数转字符串(i) + ". " + 列表库::获取字符串(任务表, i) + "\n";
        i = i + 1;
    }
    事件("prio_score", "优先级", "请模型为 " + 整数转字符串(大小) + " 个任务打分");
    变量 回复: 字符串 = 一次对话(配置值, 提示);
    变量 数: 整数 = J.解码(回复);
    如果 (数 <= 0) { 返回 队列值; }   // 非 JSON（LLM 不可用等）→ 保持原样
    变量 条数: 整数 = J.数组长度(数);
    变量 新优先: 字符串 = 队列值.优先级们;
    变量 k: 整数 = 0;
    当 (k < 条数) {
        变量 项: 整数 = J.数组获取对象(数, k);
        变量 序: 整数 = J.获取整数(项, "序");
        变量 分: 整数 = J.获取整数(项, "分");
        新优先 = 设分(新优先, 序, 分);
        k = k + 1;
    }
    队列值.优先级们 = 新优先;
    返回 队列值;
}

// 把逗号整数串第 索引 段设为 值（越界忽略）。
函数 设分(优先串: 字符串, 索引: 整数, 值: 整数) : 字符串 {
    变量 表: 整数 = 字符串::分割(优先串, ",");
    变量 n: 整数 = 列表库::字符串列表大小(表);
    如果 (索引 < 0 || 索引 >= n) { 返回 优先串; }
    变量 结果值: 字符串 = "";
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 片: 字符串 = 列表库::获取字符串(表, i);
        如果 (i == 索引) { 片 = 整数转字符串(值); }
        如果 (i > 0) { 结果值 = 结果值 + ","; }
        结果值 = 结果值 + 片;
        i = i + 1;
    }
    返回 结果值;
}
