// 代理 — Agent loop
//
// 这是 harness 的核心。底层 大模型::工具对话 / 继续工具对话 让模型在一轮里
// 要么给文本要么给 tool_call；本模块封装那个循环：
//   while assistant_msg.has_tool_call:
//       result = 派发(name, args_json)
//       回写 tool_result
//       assistant_msg = 继续工具对话()
//   return assistant_msg.文本
//
// 加上限步数（避免无限 tool loop）+ trace + retry。

包 Harness;

导入 标准库.字符串;
导入 标准库.大模型 作为 底层模型;
导入 Harness.对话::{助手消息, 解析助手消息, 工具调用ID, 工具调用名, 工具调用参数, 回写工具结果, 校验JSON对象};
导入 Harness.工具::{工具, 注册表, 创建注册表, 注册, 注册MCP工具, 注册受控工具项,
    派发, 并发派发, 工具执行模式, 受控工具句柄, 验证工具调用参数};
导入 Harness.受控工具::{受控工具, 工具执行策略, 工具结果, 受控工具有效,
    受控工具名字, 受控工具描述, 受控工具参数schema, 受控工具执行策略,
    工具调用上下文, 创建工具调用上下文, 执行受控工具, 工具失败结果,
    工具结果转JSON, 工具结果模型文本, 工具进度列表JSON, 规划工具波次,
    释放工具控制};
导入 标准库.列表 作为 列表库;
导入 标准库.哈希表 作为 哈希表;
导入 标准库.同步 作为 同步;
导入 Harness.MCP客户端::{ MCP列出工具 };
导入 标准库.JSON 作为 J;
导入 标准库.时间;
导入 标准库.加密 作为 加密;
导入 标准库.随机 作为 随机;
导入 Harness.追踪::{事件, LLM调用事件, LLM响应事件, 工具调用事件, 工具结果事件, 错误事件, 完成事件, 流开始事件, 流块事件, 流结束事件, 工具被拒事件};
导入 Harness.事件::{新运行ID, 发出生命周期事件, 发出当前生命周期事件};
导入 Harness.记忆::{打开记忆, 回忆, 记住};
导入 Harness.重试::{重试策略, 默认策略, 创建重试资源, 释放重试资源,
    资源熔断允许, 资源熔断记成功, 资源熔断记失败, 资源限流获取, 错误类别};
导入 Harness.预算::{预留令牌, 结算预留令牌, 超预算, 令牌余量, 预算需对账};
导入 Harness.上下文::{估算令牌, 历史令牌估算, 需要压缩, 滑窗裁剪};
导入 Harness.运行配置::{运行配置};
导入 Harness.运行上下文::{运行上下文作用域, 开始代理运行上下文,
    结束代理运行上下文, 推进步骤};
导入 Harness.运行日志::{创建工具执行, 更新工具执行, 标记工具执行不确定,
    处置重复工具执行JSON};
导入 Harness.会话存储::{创建持久会话, 会话存在, 追加用户消息,
    追加助手原始消息, 追加助手最终消息, 追加工具结果条目, 追加会话错误,
    开始会话轮, 完成会话轮, 失败会话轮, 恢复会话到运行时,
    追加会话条目, 按写栅栏追加会话条目};

公开 类型 代理 {
    名字: 字符串,          // trace 用
    会话句柄: 整数,
    工具表: 注册表,
    最大步数: 整数,         // 防 tool 死循环；默认 10
}

变量 代理创建锁: 整数 = 同步.创建锁();

类型 代理状态 {
    记忆库: 整数,
    工具白名单: 字符串,
    重试策略值: 重试策略,
    重试资源句柄: 整数,
    拥有重试资源: 整数,
    预算句柄: 整数,
    持久会话库: 整数,
    持久会话ID: 字符串,
    运行配置值: 运行配置,
    运行日志库: 整数,
    运行日志运行ID: 字符串,
    运行日志所有者: 字符串,
    运行日志栅栏: 整数,
    运行日志状态: 字符串,
}

变量 代理状态表: 整数 = 0;
变量 代理状态锁: 整数 = 同步.创建锁();

函数 代理身份键(代理值: 代理) : 字符串 {
    // 注册表的名字列表句柄在代理生命周期内稳定且每次创建唯一；与 runtime 会话
    // 组合后，同会话上的多个代理及后来复用的会话句柄都不会串写私有状态。
    返回 整数转字符串(代理值.会话句柄) + ":"
        + 整数转字符串(代理值.工具表.名字列表);
}

函数 默认代理状态(重试资源值: 整数) : 代理状态 {
    返回 新建 代理状态 {
        记忆库: 0,
        工具白名单: "",
        重试策略值: 默认策略(),
        重试资源句柄: 重试资源值,
        拥有重试资源: 1,
        预算句柄: 0 - 1,
        持久会话库: 0,
        持久会话ID: "",
        运行配置值: 新建 运行配置 {
            最大工具步数: 10,
            重试策略值: 默认策略(),
            预算句柄: 0 - 1,
            上下文压缩阈值: 0,
            上下文压缩策略: 0,
            滑窗保留条数: 8,
            记录用量事件: 1,
            发出生命周期事件: 1,
        },
        运行日志库: 0,
        运行日志运行ID: "",
        运行日志所有者: "",
        运行日志栅栏: 0,
        运行日志状态: "",
    };
}

函数 代理状态转JSON(状态值: 代理状态) : 字符串 {
    变量 根: 整数 = J.创建对象();
    J.设置整数(根, "memory", 状态值.记忆库);
    J.设置字符串(根, "allowlist", 状态值.工具白名单);
    J.设置整数(根, "retry_max", 状态值.重试策略值.最大次数);
    J.设置整数(根, "retry_initial_ms", 状态值.重试策略值.起始延迟毫秒);
    J.设置整数(根, "retry_max_ms", 状态值.重试策略值.最大延迟毫秒);
    J.设置整数(根, "retry_multiplier", 状态值.重试策略值.倍数);
    J.设置整数(根, "retry_resource", 状态值.重试资源句柄);
    J.设置整数(根, "owns_retry_resource", 状态值.拥有重试资源);
    J.设置整数(根, "budget", 状态值.预算句柄);
    J.设置整数(根, "session_store", 状态值.持久会话库);
    J.设置字符串(根, "session_id", 状态值.持久会话ID);
    J.设置整数(根, "config_max_steps", 状态值.运行配置值.最大工具步数);
    J.设置整数(根, "config_compact_threshold", 状态值.运行配置值.上下文压缩阈值);
    J.设置整数(根, "config_compact_strategy", 状态值.运行配置值.上下文压缩策略);
    J.设置整数(根, "config_window_keep", 状态值.运行配置值.滑窗保留条数);
    J.设置整数(根, "config_usage_events", 状态值.运行配置值.记录用量事件);
    J.设置整数(根, "config_lifecycle_events", 状态值.运行配置值.发出生命周期事件);
    J.设置整数(根, "journal_store", 状态值.运行日志库);
    J.设置字符串(根, "journal_run_id", 状态值.运行日志运行ID);
    J.设置字符串(根, "journal_owner", 状态值.运行日志所有者);
    J.设置整数(根, "journal_fence", 状态值.运行日志栅栏);
    J.设置字符串(根, "journal_status", 状态值.运行日志状态);
    变量 文本: 字符串 = J.转字符串(根);
    J.删除(根);
    返回 文本;
}

函数 JSON转代理状态(文本: 字符串) : 代理状态 {
    变量 根: 整数 = J.解码(文本);
    变量 状态值: 代理状态 = 默认代理状态(0);
    状态值.记忆库 = J.获取整数(根, "memory");
    状态值.工具白名单 = J.获取字符串(根, "allowlist");
    状态值.重试策略值 = 新建 重试策略 {
        最大次数: J.获取整数(根, "retry_max"),
        起始延迟毫秒: J.获取整数(根, "retry_initial_ms"),
        最大延迟毫秒: J.获取整数(根, "retry_max_ms"),
        倍数: J.获取整数(根, "retry_multiplier"),
    };
    状态值.重试资源句柄 = J.获取整数(根, "retry_resource");
    状态值.拥有重试资源 = J.获取整数(根, "owns_retry_resource");
    状态值.预算句柄 = J.获取整数(根, "budget");
    状态值.持久会话库 = J.获取整数(根, "session_store");
    状态值.持久会话ID = J.获取字符串(根, "session_id");
    状态值.运行配置值 = 新建 运行配置 {
        最大工具步数: J.获取整数(根, "config_max_steps"),
        重试策略值: 状态值.重试策略值,
        预算句柄: 状态值.预算句柄,
        上下文压缩阈值: J.获取整数(根, "config_compact_threshold"),
        上下文压缩策略: J.获取整数(根, "config_compact_strategy"),
        滑窗保留条数: J.获取整数(根, "config_window_keep"),
        记录用量事件: J.获取整数(根, "config_usage_events"),
        发出生命周期事件: J.获取整数(根, "config_lifecycle_events"),
    };
    状态值.运行日志库 = J.获取整数(根, "journal_store");
    状态值.运行日志运行ID = J.获取字符串(根, "journal_run_id");
    状态值.运行日志所有者 = J.获取字符串(根, "journal_owner");
    状态值.运行日志栅栏 = J.获取整数(根, "journal_fence");
    状态值.运行日志状态 = J.获取字符串(根, "journal_status");
    J.删除(根);
    返回 状态值;
}

函数 保存代理状态(代理值: 代理, 状态值: 代理状态) {
    同步.加锁(代理状态锁);
    如果 (代理状态表 == 0) { 代理状态表 = 哈希表::创建字符串表(); }
    哈希表::设置字符串(代理状态表, 代理身份键(代理值), 代理状态转JSON(状态值));
    同步.解锁(代理状态锁);
}

函数 读取代理状态(代理值: 代理) : 代理状态 {
    同步.加锁(代理状态锁);
    如果 (代理状态表 == 0) { 代理状态表 = 哈希表::创建字符串表(); }
    变量 文本: 字符串 = 哈希表::获取字符串(代理状态表, 代理身份键(代理值));
    同步.解锁(代理状态锁);
    如果 (字符串::字节长度(文本) > 0) { 返回 JSON转代理状态(文本); }

    // 兼容历史四字段字面量：第一次使用新增能力时再补齐私有默认状态。
    // 资源分配放在状态锁外，随后双检，避免并发首次读取泄漏重复句柄。
    同步.加锁(代理创建锁);
    变量 新资源: 整数 = 创建重试资源();
    同步.解锁(代理创建锁);
    变量 新状态: 代理状态 = 默认代理状态(新资源);
    同步.加锁(代理状态锁);
    文本 = 哈希表::获取字符串(代理状态表, 代理身份键(代理值));
    如果 (字符串::字节长度(文本) == 0) {
        哈希表::设置字符串(代理状态表, 代理身份键(代理值), 代理状态转JSON(新状态));
        同步.解锁(代理状态锁);
        返回 新状态;
    }
    同步.解锁(代理状态锁);
    释放重试资源(新资源);
    返回 JSON转代理状态(文本);
}

函数 清理代理状态(代理值: 代理) {
    同步.加锁(代理状态锁);
    如果 (代理状态表 == 0) { 代理状态表 = 哈希表::创建字符串表(); }
    哈希表::设置字符串(代理状态表, 代理身份键(代理值), "");
    同步.解锁(代理状态锁);
}

公开 函数 创建代理(名字: 字符串, 会话句柄: 整数) : 代理 {
    // 标准库列表和资源句柄分配是进程级状态；服务 handler 可并发创建代理。
    同步.加锁(代理创建锁);
    变量 工具表值: 注册表 = 创建注册表();
    变量 重试资源值: 整数 = 创建重试资源();
    同步.解锁(代理创建锁);
    变量 代理值: 代理 = 新建 代理 {
        名字: 名字,
        会话句柄: 会话句柄,
        工具表: 工具表值,
        最大步数: 10,
    };
    保存代理状态(代理值, 默认代理状态(重试资源值));
    返回 代理值;
}

类型 请求令牌策略 {
    有效: 整数,
    输入估算: 整数,
    最大输出: 整数,
    安全余量: 整数,
}

类型 会话写栅栏 {
    有效: 整数,
    所有者令牌: 字符串,
    栅栏: 整数,
}

变量 请求令牌策略表: 整数 = 0;
变量 会话写栅栏表: 整数 = 0;
变量 请求令牌策略锁: 整数 = 同步.创建锁();

函数 请求令牌策略键(代理值: 代理) : 字符串 {
    返回 代理身份键(代理值);
}

函数 确保请求令牌策略表() {
    如果 (请求令牌策略表 == 0) {
        请求令牌策略表 = 哈希表::创建字符串表();
    }
}

函数 确保会话写栅栏表() {
    如果 (会话写栅栏表 == 0) {
        会话写栅栏表 = 哈希表::创建字符串表();
    }
}

函数 保存请求令牌策略(代理值: 代理, 输入估算: 整数,
                    最大输出: 整数, 安全余量: 整数) {
    同步.加锁(请求令牌策略锁);
    确保请求令牌策略表();
    哈希表::设置字符串(请求令牌策略表, 请求令牌策略键(代理值),
        整数转字符串(输入估算) + "," + 整数转字符串(最大输出)
            + "," + 整数转字符串(安全余量));
    同步.解锁(请求令牌策略锁);
}

函数 清理请求令牌策略(代理值: 代理) {
    同步.加锁(请求令牌策略锁);
    确保请求令牌策略表();
    哈希表::设置字符串(请求令牌策略表, 请求令牌策略键(代理值), "");
    同步.解锁(请求令牌策略锁);
}

函数 保存会话写栅栏(代理值: 代理, 所有者令牌: 字符串, 栅栏: 整数) {
    同步.加锁(请求令牌策略锁);
    确保会话写栅栏表();
    哈希表::设置字符串(会话写栅栏表, 请求令牌策略键(代理值),
        所有者令牌 + "\n" + 整数转字符串(栅栏));
    同步.解锁(请求令牌策略锁);
}

函数 清理会话写栅栏(代理值: 代理) {
    同步.加锁(请求令牌策略锁);
    确保会话写栅栏表();
    哈希表::设置字符串(会话写栅栏表, 请求令牌策略键(代理值), "");
    同步.解锁(请求令牌策略锁);
}

函数 读取会话写栅栏(代理值: 代理) : 会话写栅栏 {
    变量 写栅栏: 会话写栅栏 = 新建 会话写栅栏 {
        有效: 0,
        所有者令牌: "",
        栅栏: 0,
    };
    同步.加锁(请求令牌策略锁);
    确保会话写栅栏表();
    变量 编码: 字符串 = 哈希表::获取字符串(会话写栅栏表, 请求令牌策略键(代理值));
    同步.解锁(请求令牌策略锁);
    变量 分隔: 整数 = 字符串::查找(编码, "\n");
    如果 (分隔 <= 0) { 返回 写栅栏; }
    写栅栏.所有者令牌 = 字符串::子串(编码, 0, 分隔);
    写栅栏.栅栏 = 字符串转整数(字符串::子串从位置(编码, 分隔 + 1));
    如果 (字符串::字节长度(写栅栏.所有者令牌) > 0 && 写栅栏.栅栏 > 0) {
        写栅栏.有效 = 1;
    }
    返回 写栅栏;
}

函数 读取请求令牌策略(代理值: 代理) : 请求令牌策略 {
    变量 策略: 请求令牌策略 = 新建 请求令牌策略 {
        有效: 0,
        输入估算: 0,
        最大输出: 0,
        安全余量: 0,
    };
    同步.加锁(请求令牌策略锁);
    确保请求令牌策略表();
    变量 编码: 字符串 = 哈希表::获取字符串(请求令牌策略表, 请求令牌策略键(代理值));
    同步.解锁(请求令牌策略锁);
    如果 (字符串::字节长度(编码) == 0) { 返回 策略; }
    变量 第一分隔: 整数 = 字符串::查找(编码, ",");
    如果 (第一分隔 < 0) { 返回 策略; }
    变量 其余: 字符串 = 字符串::子串从位置(编码, 第一分隔 + 1);
    变量 第二分隔: 整数 = 字符串::查找(其余, ",");
    如果 (第二分隔 < 0) { 返回 策略; }
    策略.有效 = 1;
    策略.输入估算 = 字符串转整数(字符串::子串(编码, 0, 第一分隔));
    策略.最大输出 = 字符串转整数(字符串::子串(其余, 0, 第二分隔));
    策略.安全余量 = 字符串转整数(字符串::子串从位置(其余, 第二分隔 + 1));
    返回 策略;
}

// 附加一个已由上层创建并持有有效租约的 run journal 上下文。Agent 不创建运行或
// 获取租约，只在工具执行时写入该上下文；空上下文保持原行为。
公开 函数 附加运行日志上下文(代理值: 代理, 库: 整数, 运行ID: 字符串,
                         所有者: 字符串, 栅栏: 整数, 期望状态: 字符串) : 代理 {
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    状态值.运行日志库 = 库;
    状态值.运行日志运行ID = 运行ID;
    状态值.运行日志所有者 = 所有者;
    状态值.运行日志栅栏 = 栅栏;
    状态值.运行日志状态 = 期望状态;
    保存代理状态(代理值, 状态值);
    返回 代理值;
}

// 附加已打开的会话存储。不存在的 session 会自动创建；不接管 storage 的关闭。
公开 函数 附加会话存储(代理值: 代理, 库: 整数, 会话ID: 字符串) : 代理 {
    如果 (库 <= 0 || 字符串::字节长度(会话ID) == 0) { 返回 代理值; }
    如果 (会话存在(库, 会话ID) == 0) {
        创建持久会话(库, 会话ID);
    }
    如果 (会话存在(库, 会话ID) == 1) {
        变量 状态值: 代理状态 = 读取代理状态(代理值);
        状态值.持久会话库 = 库;
        状态值.持久会话ID = 会话ID;
        保存代理状态(代理值, 状态值);
    }
    返回 代理值;
}

// 服务请求可附加其会话租约 fence。之后每个 append 和 leaf 更新都会在同一事务中
// 验证 owner/fence/未过期；standalone Agent 不调用时完全保持原行为。
函数 附加会话写栅栏(代理值: 代理, 所有者令牌: 字符串, 栅栏: 整数) : 代理 {
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    如果 (状态值.持久会话库 > 0 && 字符串::字节长度(所有者令牌) > 0 && 栅栏 > 0) {
        保存会话写栅栏(代理值, 所有者令牌, 栅栏);
    }
    返回 代理值;
}

// 显式恢复而非每轮自动恢复：runtime 历史继续作为热执行缓存，调用方切换 leaf 后
// 再调用本函数即可让所选分支覆盖当前缓存。
公开 函数 恢复持久会话(代理值: 代理) : 整数 {
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    如果 (状态值.持久会话库 <= 0 || 字符串::字节长度(状态值.持久会话ID) == 0) { 返回 0 - 1; }
    返回 恢复会话到运行时(状态值.持久会话库, 状态值.持久会话ID, 代理值.会话句柄);
}

函数 持久消息载荷(角色: 字符串, 内容: 字符串) : 字符串 {
    变量 对象: 整数 = J.创建对象();
    J.设置字符串(对象, "role", 角色);
    J.设置字符串(对象, "content", 内容);
    变量 文本: 字符串 = J.转字符串(对象);
    J.删除(对象);
    返回 文本;
}

函数 持久追加(代理值: 代理, 类型值: 字符串, 载荷JSON: 字符串) : 字符串 {
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    如果 (状态值.持久会话库 <= 0) { 返回 ""; }
    变量 写栅栏: 会话写栅栏 = 读取会话写栅栏(代理值);
    如果 (写栅栏.有效 == 1) {
        返回 按写栅栏追加会话条目(状态值.持久会话库, 状态值.持久会话ID,
            写栅栏.所有者令牌, 写栅栏.栅栏, 类型值, 载荷JSON);
    }
    如果 (字符串::等于(类型值, "message.user") == 1) {
        变量 用户对象: 整数 = J.解码(载荷JSON);
        变量 用户内容: 字符串 = J.获取字符串(用户对象, "content");
        J.删除(用户对象);
        返回 追加用户消息(状态值.持久会话库, 状态值.持久会话ID, 用户内容);
    }
    返回 追加会话条目(状态值.持久会话库, 状态值.持久会话ID,
        类型值, 载荷JSON);
}

函数 持久记录用户(代理值: 代理, 内容: 字符串) {
    持久追加(代理值, "message.user", 持久消息载荷("user", 内容));
}

函数 持久记录原始(代理值: 代理, 原始响应: 字符串) {
    变量 对象: 整数 = J.创建对象();
    J.设置字符串(对象, "role", "assistant");
    J.设置字符串(对象, "raw", 原始响应);
    持久追加(代理值, "message.assistant.raw", J.转字符串(对象));
    J.删除(对象);
}

函数 持久记录最终(代理值: 代理, 内容: 字符串) {
    持久追加(代理值, "message.assistant.final", 持久消息载荷("assistant", 内容));
}

函数 持久记录框架错误(代理值: 代理, 内容: 字符串) {
    变量 对象: 整数 = J.创建对象();
    J.设置字符串(对象, "source", "framework");
    J.设置字符串(对象, "message", 内容);
    J.设置整数(对象, "category", 错误类别(内容));
    持久追加(代理值, "error.framework", J.转字符串(对象));
    J.删除(对象);
}

函数 持久记录工具(代理值: 代理, 调用ID: 字符串, 工具名: 字符串, 结果文本: 字符串) {
    变量 对象: 整数 = J.创建对象();
    J.设置字符串(对象, "tool_call_id", 调用ID);
    J.设置字符串(对象, "name", 工具名);
    J.设置字符串(对象, "result", 结果文本);
    持久追加(代理值, "tool.result", J.转字符串(对象));
    J.删除(对象);
}

函数 持久记录模型错误(代理值: 代理, 内容: 字符串) {
    变量 对象: 整数 = J.创建对象();
    J.设置字符串(对象, "source", "model");
    J.设置字符串(对象, "message", 内容);
    J.设置整数(对象, "category", 错误类别(内容));
    持久追加(代理值, "error.model", J.转字符串(对象));
    J.删除(对象);
}

函数 持久开始轮(代理值: 代理) : 字符串 {
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    如果 (状态值.持久会话库 > 0) {
        如果 (读取会话写栅栏(代理值).有效 == 0) {
            返回 开始会话轮(状态值.持久会话库, 状态值.持久会话ID);
        }
        变量 轮ID: 字符串 = 随机.UUID();
        变量 对象: 整数 = J.创建对象();
        J.设置字符串(对象, "turn_id", 轮ID);
        变量 条目ID: 字符串 = 持久追加(代理值, "turn.start", J.转字符串(对象));
        J.删除(对象);
        如果 (字符串::字节长度(条目ID) > 0) { 返回 轮ID; }
    }
    返回 "";
}

函数 持久完成轮(代理值: 代理, 轮ID: 字符串) {
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    如果 (状态值.持久会话库 > 0 && 字符串::字节长度(轮ID) > 0) {
        如果 (读取会话写栅栏(代理值).有效 == 0) {
            完成会话轮(状态值.持久会话库, 状态值.持久会话ID, 轮ID);
        } 否则 {
            变量 对象: 整数 = J.创建对象();
            J.设置字符串(对象, "turn_id", 轮ID);
            持久追加(代理值, "turn.complete", J.转字符串(对象));
            J.删除(对象);
        }
    }
}

函数 持久失败轮(代理值: 代理, 轮ID: 字符串) {
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    如果 (状态值.持久会话库 > 0 && 字符串::字节长度(轮ID) > 0) {
        如果 (读取会话写栅栏(代理值).有效 == 0) {
            失败会话轮(状态值.持久会话库, 状态值.持久会话ID, 轮ID);
        } 否则 {
            变量 对象: 整数 = J.创建对象();
            J.设置字符串(对象, "turn_id", 轮ID);
            持久追加(代理值, "turn.failed", J.转字符串(对象));
            J.删除(对象);
        }
    }
}

// 设置代理的 LLM 重试策略。流式调用只重试尚未产生输出或工具副作用的首次连接。
公开 函数 设置重试策略(代理值: 代理, 策略: 重试策略) : 代理 {
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    状态值.重试策略值 = 策略;
    状态值.运行配置值.重试策略值 = 策略;
    保存代理状态(代理值, 状态值);
    返回 代理值;
}

// 让多个代理共用熔断器和令牌桶。默认不调用时，每个 创建代理 都有独立资源。
公开 函数 共享重试资源(代理值: 代理, 资源句柄: 整数) : 代理 {
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    如果 (状态值.拥有重试资源 == 1 && 状态值.重试资源句柄 != 资源句柄) {
        释放重试资源(状态值.重试资源句柄);
    }
    状态值.重试资源句柄 = 资源句柄;
    状态值.拥有重试资源 = 0;
    保存代理状态(代理值, 状态值);
    返回 代理值;
}

// 接入 Harness 跨会话预算账本。每个非流式 provider attempt 都先预留并在返回后结算；
// 达到上限后返回 budget_exceeded，不再调用 provider。
公开 函数 附加预算(代理值: 代理, 预算句柄: 整数) : 代理 {
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    状态值.预算句柄 = 预算句柄;
    状态值.运行配置值.预算句柄 = 预算句柄;
    保存代理状态(代理值, 状态值);
    返回 代理值;
}

公开 函数 取消自动预算(代理值: 代理) : 代理 {
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    状态值.预算句柄 = 0 - 1;
    状态值.运行配置值.预算句柄 = 0 - 1;
    保存代理状态(代理值, 状态值);
    返回 代理值;
}

// Configure the worst-case token envelope for every provider attempt. Input is an
// estimate because providers expose no preflight tokenizer; max output is enforced
// through max_tokens. Each retry independently reserves the full envelope.
公开 函数 设置请求令牌预算(代理值: 代理, 输入估算: 整数,
                         最大输出: 整数, 安全余量: 整数) : 代理 {
    保存请求令牌策略(代理值, 输入估算, 最大输出, 安全余量);
    返回 代理值;
}

公开 函数 取消请求令牌预算(代理值: 代理) : 代理 {
    清理请求令牌策略(代理值);
    返回 代理值;
}

公开 函数 设置最大步数(代理值: 代理, 上限: 整数) : 代理 {
    代理值.最大步数 = 上限;
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    状态值.运行配置值.最大工具步数 = 上限;
    保存代理状态(代理值, 状态值);
    返回 代理值;
}

// 把运行配置设为代理后续调用的默认值。
公开 函数 应用运行配置(代理值: 代理, 配置值: 运行配置) : 代理 {
    代理值.最大步数 = 配置值.最大工具步数;
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    状态值.重试策略值 = 配置值.重试策略值;
    状态值.预算句柄 = 配置值.预算句柄;
    状态值.运行配置值 = 新建 运行配置 {
        最大工具步数: 配置值.最大工具步数,
        重试策略值: 配置值.重试策略值,
        预算句柄: 配置值.预算句柄,
        上下文压缩阈值: 配置值.上下文压缩阈值,
        上下文压缩策略: 配置值.上下文压缩策略,
        滑窗保留条数: 配置值.滑窗保留条数,
        记录用量事件: 配置值.记录用量事件,
        发出生命周期事件: 配置值.发出生命周期事件,
    };
    保存代理状态(代理值, 状态值);
    返回 代理值;
}

函数 当前运行配置(代理值: 代理) : 运行配置 {
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    返回 新建 运行配置 {
        最大工具步数: 代理值.最大步数,
        重试策略值: 状态值.重试策略值,
        预算句柄: 状态值.预算句柄,
        上下文压缩阈值: 状态值.运行配置值.上下文压缩阈值,
        上下文压缩策略: 状态值.运行配置值.上下文压缩策略,
        滑窗保留条数: 状态值.运行配置值.滑窗保留条数,
        记录用量事件: 状态值.运行配置值.记录用量事件,
        发出生命周期事件: 状态值.运行配置值.发出生命周期事件,
    };
}

// 包内桥接给可靠流协调器；状态仍由代理模块私有注册表持有。
函数 代理预算句柄(代理值: 代理) : 整数 {
    返回 读取代理状态(代理值).预算句柄;
}

// ===== 每代理工具白名单（精细权限治理）=====
//
// 给单个代理限定只能调用其已注册工具的一个子集 —— 即使会话里注册了 N 个工具，
// 不在白名单里的工具在 dispatch 阶段被拒绝执行（返回错误串给模型，让它换招或如实告知）。
// 白名单为空（默认）= 全放行，与原行为完全一致，现有代理不受影响。
//
// 工具名们：逗号分隔，如 "查天气,查时间"（空格会被忽略）。
公开 函数 设置工具白名单(代理值: 代理, 工具名们: 字符串) : 代理 {
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    状态值.工具白名单 = 工具名们;
    保存代理状态(代理值, 状态值);
    返回 代理值;
}

// 判断某工具名是否被该代理放行。
//   白名单为空 → 恒放行（1）。
//   否则用 ,名, 包裹做整词匹配，避免「天气」误配「天气查询」这类子串命中。
公开 函数 工具是否放行(代理值: 代理, 工具名: 字符串) : 整数 {
    变量 白名单: 字符串 = 读取代理状态(代理值).工具白名单;
    如果 (字符串::字节长度(白名单) == 0) {
        返回 1;
    }
    变量 规整: 字符串 = 字符串::替换(白名单, " ", "");
    规整 = 字符串::替换(规整, "\n", ",");
    变量 垛: 字符串 = "," + 规整 + ",";
    变量 针: 字符串 = "," + 字符串::去空白(工具名) + ",";
    如果 (字符串::包含(垛, 针) == 1) {
        返回 1;
    }
    返回 0;
}

// 生成被拒工具的观测结果串（回写给模型，让它据此调整）。
函数 拒绝结果(工具名: 字符串) : 字符串 {
    返回 "{\"error\":\"tool_not_allowed\",\"name\":\"" + 工具名
        + "\",\"detail\":\"该工具不在本代理的工具白名单内，已被拒绝执行\"}";
}

// 注册一个工具到代理上
公开 函数 添加工具(代理值: 代理, 工具值: 工具) : 代理 {
    代理值.工具表 = 注册(代理值.工具表, 代理值.会话句柄, 工具值);
    返回 代理值;
}

公开 函数 添加受控工具(代理值: 代理, 工具值: 受控工具) : 代理 {
    如果 (受控工具有效(工具值) == 0) { 返回 代理值; }
    变量 策略值: 工具执行策略 = 受控工具执行策略(工具值);
    代理值.工具表 = 注册受控工具项(代理值.工具表, 代理值.会话句柄,
        受控工具名字(工具值), 受控工具描述(工具值), 受控工具参数schema(工具值),
        工具值.句柄, 策略值.模式);
    返回 代理值;
}

函数 受控结果查找(编码表: 整数, 索引: 整数) : 字符串 {
    变量 i: 整数 = 0;
    当 (i < 列表库::字符串列表大小(编码表)) {
        变量 条目: 字符串 = 列表库::获取字符串(编码表, i);
        变量 分隔: 整数 = 字符串::查找(条目, "|");
        如果 (分隔 >= 0 && 字符串转整数(字符串::子串(条目, 0, 分隔)) == 索引) {
            返回 字符串::子串从位置(条目, 分隔 + 1);
        }
        i = i + 1;
    }
    返回 "";
}

函数 工具事件载荷(工具名: 字符串, 调用ID: 字符串, 状态: 字符串,
                 标准结果: 字符串, 进度JSON: 字符串) : 字符串 {
    变量 根: 整数 = J.创建对象();
    J.设置字符串(根, "tool", 工具名);
    J.设置字符串(根, "call_id", 调用ID);
    J.设置字符串(根, "status", 状态);
    变量 结果对象: 整数 = J.解码(标准结果);
    如果 (结果对象 > 0) { J.设置对象(根, "result", 结果对象); }
    变量 进度: 整数 = J.解码(进度JSON);
    如果 (进度 > 0) { J.设置数组(根, "progress", 进度); }
    变量 文本: 字符串 = J.转字符串(根);
    J.删除(根);
    返回 文本;
}

函数 受控工具幂等键(工具值: 受控工具, 调用ID: 字符串, 参数JSON: 字符串) : 字符串 {
    变量 策略值: 工具执行策略 = 受控工具执行策略(工具值);
    变量 幂等键: 字符串 = "";
    如果 (策略值.幂等键模式 == 1) { 幂等键 = 调用ID; }
    如果 (策略值.幂等键模式 == 2) {
        变量 参数对象: 整数 = J.解码(参数JSON);
        如果 (参数对象 > 0) {
            幂等键 = J.获取字符串(参数对象, "idempotency_key");
            J.删除(参数对象);
        }
    }
    返回 幂等键;
}

函数 日志标准结果模型文本(工具值: 受控工具, 标准结果: 字符串) : 字符串 {
    变量 策略值: 工具执行策略 = 受控工具执行策略(工具值);
    如果 (策略值.模型结果格式 != 0) { 返回 标准结果; }
    变量 根: 整数 = J.解码(标准结果);
    如果 (根 > 0 && 字符串::等于(J.获取字符串(根, "status"), "success") == 1) {
        变量 内容: 字符串 = J.获取字符串(根, "content");
        J.删除(根);
        返回 内容;
    }
    如果 (根 > 0) { J.删除(根); }
    返回 标准结果;
}

函数 日志处置执行JSON(工具值: 受控工具, 处置JSON: 字符串) : 字符串 {
    变量 处置对象: 整数 = J.解码(处置JSON);
    变量 处置: 字符串 = "rejected";
    如果 (处置对象 > 0) { 处置 = J.获取字符串(处置对象, "disposition"); }
    变量 标准结果: 字符串 = "";
    如果 (字符串::等于(处置, "replay") == 1) {
        标准结果 = J.获取字符串(处置对象, "result_json");
    } 否则 {
        变量 结果值: 工具结果 = 工具失败结果("dispatch_not_started",
            "controlled tool dispatch was not newly recorded", 0);
        如果 (字符串::等于(处置, "existing") == 1) {
            结果值.状态 = "existing";
            结果值.错误代码 = "dispatch_in_progress";
            结果值.错误消息 = "an existing idempotent dispatch has not completed";
        } 否则如果 (字符串::等于(处置, "needs_reconciliation") == 1) {
            结果值.状态 = "needs_reconciliation";
            结果值.错误代码 = "ambiguous_outcome";
            结果值.错误消息 = "duplicate non-idempotent dispatch requires reconciliation";
        }
        标准结果 = 工具结果转JSON(结果值);
    }
    变量 根: 整数 = J.创建对象();
    J.设置整数(根, "control_handle", 0 - 1);
    J.设置整数(根, "started_at_ms", 0);
    J.设置整数(根, "completed_at_ms", 0);
    变量 标准对象: 整数 = J.解码(标准结果);
    变量 状态: 字符串 = "failed";
    如果 (标准对象 > 0) { 状态 = J.获取字符串(标准对象, "status"); J.删除(标准对象); }
    J.设置字符串(根, "status", 状态);
    J.设置字符串(根, "standard_result", 标准结果);
    J.设置字符串(根, "model_result", 日志标准结果模型文本(工具值, 标准结果));
    J.设置字符串(根, "progress", "[]");
    J.设置布尔(根, "journal_replay", 1);
    变量 文本: 字符串 = J.转字符串(根);
    J.删除(根);
    如果 (处置对象 > 0) { J.删除(处置对象); }
    返回 文本;
}

函数 开始受控工具日志(代理值: 代理, 工具值: 受控工具, 步骤ID: 字符串,
                   调用ID: 字符串, 参数JSON: 字符串) : 字符串 {
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    如果 (状态值.运行日志库 <= 0 || 字符串::字节长度(状态值.运行日志运行ID) == 0) {
        返回 "{\"disposition\":\"new\"}";
    }
    变量 幂等键: 字符串 = 受控工具幂等键(工具值, 调用ID, 参数JSON);
    变量 执行键: 字符串 = 状态值.运行日志运行ID + ":" + 调用ID;
    变量 当前: 整数 = 时间.当前毫秒();
    变量 创建结果: 整数 = 创建工具执行(状态值.运行日志库, 状态值.运行日志运行ID,
        状态值.运行日志所有者, 状态值.运行日志栅栏, 状态值.运行日志状态,
        当前, 执行键, 步骤ID, 调用ID, 受控工具名字(工具值),
        加密.SHA256哈希(参数JSON), 幂等键, "dispatching");
    如果 (创建结果 == 1) { 返回 "{\"disposition\":\"new\"}"; }
    返回 处置重复工具执行JSON(状态值.运行日志库, 状态值.运行日志运行ID,
        状态值.运行日志所有者, 状态值.运行日志栅栏, 状态值.运行日志状态,
        时间.当前毫秒(), 执行键, 受控工具名字(工具值), 加密.SHA256哈希(参数JSON), 幂等键);
}

函数 完成受控工具日志(代理值: 代理, 工具值: 受控工具, 调用ID: 字符串,
                   参数JSON: 字符串, 状态: 字符串, 标准结果: 字符串,
                   开始时间: 整数, 完成时间: 整数) : 整数 {
    变量 代理状态值: 代理状态 = 读取代理状态(代理值);
    如果 (代理状态值.运行日志库 <= 0 || 字符串::字节长度(代理状态值.运行日志运行ID) == 0) { 返回 1; }
    变量 策略值: 工具执行策略 = 受控工具执行策略(工具值);
    变量 幂等键: 字符串 = 受控工具幂等键(工具值, 调用ID, 参数JSON);
    变量 执行键: 字符串 = 代理状态值.运行日志运行ID + ":" + 调用ID;
    变量 当前: 整数 = 时间.当前毫秒();
    如果 (字符串::等于(状态, "needs_reconciliation") == 1
        && 策略值.副作用模式 == 2 && 字符串::字节长度(幂等键) == 0) {
        返回 标记工具执行不确定(代理状态值.运行日志库, 代理状态值.运行日志运行ID,
            代理状态值.运行日志所有者, 代理状态值.运行日志栅栏, 代理状态值.运行日志状态,
            当前, 执行键, 标准结果);
    }
    变量 外部状态: 字符串 = "not_committed";
    如果 (字符串::等于(状态, "success") == 1) { 外部状态 = "committed"; }
    返回 更新工具执行(代理状态值.运行日志库, 代理状态值.运行日志运行ID,
        代理状态值.运行日志所有者, 代理状态值.运行日志栅栏, 代理状态值.运行日志状态,
        当前, 执行键, 状态, 开始时间, 外部状态, "not_required",
        标准结果, "", 开始时间, 完成时间);
}

函数 执行单个受控调用(代理值: 代理, 工具句柄值: 整数, 运行ID: 字符串,
                   轮次ID: 字符串, 步骤ID: 字符串, 调用ID: 字符串,
                   参数JSON: 字符串, 运行上下文句柄: 整数) : 字符串 {
    变量 工具值: 受控工具 = 新建 受控工具 { 句柄: 工具句柄值 };
    变量 日志处置: 字符串 = 开始受控工具日志(代理值, 工具值, 步骤ID, 调用ID, 参数JSON);
    变量 日志对象: 整数 = J.解码(日志处置);
    如果 (日志对象 <= 0 || 字符串::等于(J.获取字符串(日志对象, "disposition"), "new") == 0) {
        如果 (日志对象 > 0) { J.删除(日志对象); }
        返回 日志处置执行JSON(工具值, 日志处置);
    }
    J.删除(日志对象);
    变量 ctx = 创建工具调用上下文(工具值, 运行ID, 轮次ID, 步骤ID,
        调用ID, 运行上下文句柄);
    变量 结果值: 工具结果 = 执行受控工具(工具值, ctx, 参数JSON);
    变量 根: 整数 = J.创建对象();
    J.设置整数(根, "control_handle", ctx.控制句柄);
    J.设置整数(根, "started_at_ms", ctx.开始时间毫秒);
    J.设置整数(根, "completed_at_ms", 时间.当前毫秒());
    J.设置字符串(根, "status", 结果值.状态);
    J.设置字符串(根, "standard_result", 工具结果转JSON(结果值));
    J.设置字符串(根, "model_result", 工具结果模型文本(工具值, 结果值));
    J.设置字符串(根, "progress", 工具进度列表JSON(ctx.控制句柄));
    变量 文本: 字符串 = J.转字符串(根);
    J.删除(根);
    返回 文本;
}

函数 完成受控调用(代理值: 代理, 运行ID: 字符串, 轮次ID: 字符串,
                步骤ID: 字符串, 工具名: 字符串, 调用ID: 字符串,
                参数JSON: 字符串, 工具句柄值: 整数, 执行JSON: 字符串) : 字符串 {
    变量 执行对象: 整数 = J.解码(执行JSON);
    如果 (执行对象 <= 0) { 返回 ""; }
    变量 状态: 字符串 = J.获取字符串(执行对象, "status");
    变量 标准结果: 字符串 = J.获取字符串(执行对象, "standard_result");
    变量 模型结果: 字符串 = J.获取字符串(执行对象, "model_result");
    变量 进度JSON: 字符串 = J.获取字符串(执行对象, "progress");
    变量 开始时间: 整数 = J.获取整数(执行对象, "started_at_ms");
    变量 完成时间: 整数 = J.获取整数(执行对象, "completed_at_ms");
    变量 控制句柄: 整数 = J.获取整数(执行对象, "control_handle");
    变量 日志回放: 整数 = J.获取布尔(执行对象, "journal_replay");
    // Completion must cross the fenced durable boundary before the result is exposed to
    // lifecycle subscribers or returned to the model.
    如果 (日志回放 == 0 && 完成受控工具日志(代理值,
        新建 受控工具 { 句柄: 工具句柄值 }, 调用ID, 参数JSON, 状态,
        标准结果, 开始时间, 完成时间) != 1) {
        变量 未持久化: 工具结果 = 工具失败结果("journal_completion_failed",
            "tool completed but its fenced journal completion was rejected", 0);
        未持久化.状态 = "needs_reconciliation";
        状态 = 未持久化.状态;
        标准结果 = 工具结果转JSON(未持久化);
        模型结果 = 工具结果模型文本(新建 受控工具 { 句柄: 工具句柄值 }, 未持久化);
    }
    工具结果事件(代理值.名字, 工具名, 模型结果);
    变量 进度组: 整数 = J.解码(进度JSON);
    如果 (进度组 > 0) {
        变量 pi: 整数 = 0;
        当 (pi < J.数组长度(进度组)) {
            发运行生命周期(代理值, 运行ID, 轮次ID, 步骤ID, "tool_update",
                J.转字符串(J.数组获取对象(进度组, pi)));
            pi = pi + 1;
        }
        J.删除(进度组);
    }
    如果 (字符串::等于(状态, "timeout") == 1) {
        发运行生命周期(代理值, 运行ID, 轮次ID, 步骤ID, "tool_timeout",
            工具事件载荷(工具名, 调用ID, 状态, 标准结果, 进度JSON));
    }
    如果 (字符串::等于(状态, "cancelled") == 1) {
        发运行生命周期(代理值, 运行ID, 轮次ID, 步骤ID, "tool_cancel_requested",
            工具事件载荷(工具名, 调用ID, 状态, 标准结果, 进度JSON));
    }
    发运行生命周期(代理值, 运行ID, 轮次ID, 步骤ID, "tool_end",
        工具事件载荷(工具名, 调用ID, 状态, 标准结果, 进度JSON));
    如果 (控制句柄 >= 0) { 释放工具控制(控制句柄); }
    J.删除(执行对象);
    返回 模型结果;
}

// 并发波次 worker。结果编码进共享列表，完成信道只承担 join 和实际完成顺序。
函数 代理受控工具工人(代理值: 代理, 工具句柄值: 整数, 序号: 整数, 运行ID: 字符串,
                       轮次ID: 字符串, 步骤ID: 字符串, 调用ID: 字符串,
                       运行上下文句柄: 整数, 参数JSON: 字符串,
                       结果表: 整数, 完成信道: 通道<整数>) {
    变量 执行JSON: 字符串 = 执行单个受控调用(代理值, 工具句柄值, 运行ID,
        轮次ID, 步骤ID, 调用ID, 参数JSON, 运行上下文句柄);
    列表库::添加字符串(结果表, 整数转字符串(序号) + "|" + 执行JSON);
    完成信道 <- 序号;
}

// 把一个已连接的 MCP server(连接描述符) 的全部工具装备到代理上。
// 调 tools/list 解析 result.tools[]，逐个注册为 MCP-backed 工具。
公开 函数 装备MCP(代理值: 代理, 连接描述符: 字符串) : 代理 {
    变量 响应行: 字符串 = MCP列出工具(连接描述符);
    变量 响应对象: 整数 = J.解码(响应行);
    如果 (响应对象 <= 0) {
        错误事件(代理值.名字, "MCP tools/list 解析失败");
        返回 代理值;
    }
    变量 结果对象: 整数 = J.获取对象(响应对象, "result");
    变量 工具数组: 整数 = J.获取数组(结果对象, "tools");
    变量 数量: 整数 = J.数组长度(工具数组);
    变量 i: 整数 = 0;
    当 (i < 数量) {
        变量 工具对象: 整数 = J.数组获取对象(工具数组, i);
        变量 名字: 字符串 = J.获取字符串(工具对象, "name");
        变量 描述: 字符串 = J.获取字符串(工具对象, "description");
        变量 schema对象: 整数 = J.获取对象(工具对象, "inputSchema");
        变量 schema串: 字符串 = J.转字符串(schema对象);
        代理值.工具表 = 注册MCP工具(代理值.工具表, 代理值.会话句柄, 名字, 描述, schema串, 连接描述符);
        i = i + 1;
    }
    完成事件(代理值.名字, "装备 MCP 工具 " + 整数转字符串(数量) + " 个");
    返回 代理值;
}

// 打一条真实 token 用量事件（读 runtime 记录的最近一次请求 usage）。
// 供成本/预算统计 —— 之前 span 里 tokens 是手填假值，这里是 provider 返回的真值。
公开 函数 记用量(代理值: 代理) {
    如果 (读取代理状态(代理值).运行配置值.记录用量事件 == 1) {
        事件("usage", 代理值.名字, 底层模型.用量(代理值.会话句柄));
    }
}

// ===== 统一非流式 LLM 调用 =====
// 三种调用都使用显式 (会话, 提示) 参数，以便交给带参数重试器安全执行。
函数 普通模型调用(会话: 整数, 提示: 字符串) : 字符串 {
    返回 底层模型.对话(会话, 提示);
}

函数 工具模型调用(会话: 整数, 提示: 字符串) : 字符串 {
    返回 底层模型.工具对话(会话, 提示);
}

函数 继续工具模型调用(会话: 整数, 忽略提示: 字符串) : 字符串 {
    返回 底层模型.继续工具对话(会话);
}

函数 结算非流式尝试(预算句柄: 整数, 预留数: 整数,
                    会话: 整数, 回复: 字符串) : 整数 {
    如果 (预算句柄 < 0) { 返回 0; }
    如果 (错误类别(回复) != 0) {
        // 调用已经进入 runtime/provider 边界，但失败响应没有可靠 usage。
        返回 结算预留令牌(预算句柄, 预留数, 0, 0);
    }
    变量 用量JSON: 字符串 = 底层模型.用量(会话);
    变量 用量对象: 整数 = J.解码(用量JSON);
    如果 (用量对象 > 0 && 字符串::包含(用量JSON, "total") == 1) {
        变量 结果值: 整数 = 结算预留令牌(
            预算句柄, 预留数, J.获取整数(用量对象, "total"), 1);
        J.删除(用量对象);
        返回 结果值;
    } 否则 {
        如果 (用量对象 > 0) { J.删除(用量对象); }
        返回 结算预留令牌(预算句柄, 预留数, 0, 0);
    }
}

函数 预算普通模型调用(会话: 整数, 提示: 字符串, 预算句柄: 整数,
                    预留数: 整数, 最大输出: 整数) : 字符串 {
    如果 (预算句柄 >= 0 && 预留令牌(预算句柄, 预留数) == 0) { 返回 "[harness] budget_exceeded"; }
    如果 (最大输出 > 0) { 底层模型.设置配置(会话, "max_tokens", 整数转字符串(最大输出)); }
    变量 回复: 字符串 = 普通模型调用(会话, 提示);
    如果 (结算非流式尝试(预算句柄, 预留数, 会话, 回复) == 0 - 2) {
        返回 "[harness] budget_overrun needs_reconciliation";
    }
    返回 回复;
}

函数 预算工具模型调用(会话: 整数, 提示: 字符串, 预算句柄: 整数,
                    预留数: 整数, 最大输出: 整数) : 字符串 {
    如果 (预算句柄 >= 0 && 预留令牌(预算句柄, 预留数) == 0) { 返回 "[harness] budget_exceeded"; }
    如果 (最大输出 > 0) { 底层模型.设置配置(会话, "max_tokens", 整数转字符串(最大输出)); }
    变量 回复: 字符串 = 工具模型调用(会话, 提示);
    如果 (结算非流式尝试(预算句柄, 预留数, 会话, 回复) == 0 - 2) {
        返回 "[harness] budget_overrun needs_reconciliation";
    }
    返回 回复;
}

函数 预算继续工具模型调用(会话: 整数, 提示: 字符串, 预算句柄: 整数,
                        预留数: 整数, 最大输出: 整数) : 字符串 {
    如果 (预算句柄 >= 0 && 预留令牌(预算句柄, 预留数) == 0) { 返回 "[harness] budget_exceeded"; }
    如果 (最大输出 > 0) { 底层模型.设置配置(会话, "max_tokens", 整数转字符串(最大输出)); }
    变量 回复: 字符串 = 继续工具模型调用(会话, 提示);
    如果 (结算非流式尝试(预算句柄, 预留数, 会话, 回复) == 0 - 2) {
        返回 "[harness] budget_overrun needs_reconciliation";
    }
    返回 回复;
}

函数 代理重试载荷(试次: 整数, 最大次数: 整数, 延迟毫秒: 整数,
                 结果值: 字符串, 类别: 整数) : 字符串 {
    变量 根: 整数 = J.创建对象();
    J.设置整数(根, "attempt", 试次);
    J.设置整数(根, "max_attempts", 最大次数);
    J.设置整数(根, "delay_ms", 延迟毫秒);
    如果 (字符串::字节长度(结果值) > 0) { J.设置字符串(根, "result", 结果值); }
    如果 (类别 >= 0) { J.设置整数(根, "category", 类别); }
    变量 文本: 字符串 = J.转字符串(根);
    J.删除(根);
    返回 文本;
}

函数 代理发出重试开始(代理名: 字符串, 下一试次: 整数, 策略: 重试策略,
                    延迟毫秒: 整数) {
    发出当前生命周期事件("retry_start", 代理名,
        代理重试载荷(下一试次, 策略.最大次数, 延迟毫秒, "", 0 - 1));
}

函数 代理发出重试结束(代理名: 字符串, 试次: 整数, 策略: 重试策略, 类别: 整数) {
    变量 结果值: 字符串 = "failed";
    如果 (类别 == 0) { 结果值 = "success"; }
    否则如果 (类别 == 2) { 结果值 = "fatal"; }
    发出当前生命周期事件("retry_end", 代理名,
        代理重试载荷(试次, 策略.最大次数, 0, 结果值, 类别));
}

函数 代理发出重试错误(代理名: 字符串, 原因: 字符串, 试次: 整数, 最大次数: 整数) {
    变量 根: 整数 = J.创建对象();
    J.设置字符串(根, "source", "retry");
    J.设置字符串(根, "reason", 原因);
    J.设置整数(根, "attempt", 试次);
    J.设置整数(根, "max_attempts", 最大次数);
    变量 载荷: 字符串 = J.转字符串(根);
    J.删除(根);
    发出当前生命周期事件("error", 代理名, 载荷);
}

函数 预算重试调用(代理值: 代理, 提示: 字符串,
                调用: 函数(整数, 字符串, 整数, 整数, 整数): 字符串) : 字符串 {
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    变量 试次: 整数 = 0;
    变量 延迟: 整数 = 状态值.重试策略值.起始延迟毫秒;
    变量 上次响应: 字符串 = "";
    变量 重试进行中: 整数 = 0;
    当 (试次 < 状态值.重试策略值.最大次数) {
        如果 (资源熔断允许(状态值.重试资源句柄) == 0) {
            错误事件(代理值.名字, "熔断打开，快失败（冷却中）");
            如果 (重试进行中 == 1) {
                代理发出重试结束(代理值.名字, 试次 + 1, 状态值.重试策略值, 1);
            }
            代理发出重试错误(代理值.名字, "circuit_open", 试次 + 1,
                状态值.重试策略值.最大次数);
            返回 "[harness] 熔断打开，请求被快失败";
        }
        资源限流获取(状态值.重试资源句柄);
        变量 输入估算: 整数 = 历史令牌估算(代理值.会话句柄)
            + 估算令牌(提示) + 4;
        变量 最大输出: 整数 = 0;
        变量 安全余量: 整数 = 0;
        变量 请求策略: 请求令牌策略 = 读取请求令牌策略(代理值);
        如果 (请求策略.有效 == 1) {
            输入估算 = 请求策略.输入估算;
            最大输出 = 请求策略.最大输出;
            安全余量 = 请求策略.安全余量;
        }
        如果 (输入估算 < 0 || 最大输出 < 0 || 安全余量 < 0) {
            如果 (重试进行中 == 1) {
                代理发出重试结束(代理值.名字, 试次 + 1, 状态值.重试策略值, 2);
            }
            返回 "[harness] budget_exceeded invalid_request_token_budget";
        }
        变量 预留数: 整数 = 0;
        如果 (状态值.预算句柄 >= 0) {
            变量 余量: 整数 = 令牌余量(状态值.预算句柄);
            如果 (余量 >= 0) {
                如果 (请求策略.有效 == 0) {
                    最大输出 = 余量 - 输入估算;
                }
                预留数 = 输入估算 + 最大输出 + 安全余量;
                如果 (最大输出 <= 0 || 预留数 > 余量) {
                    如果 (重试进行中 == 1) {
                        代理发出重试结束(代理值.名字, 试次 + 1, 状态值.重试策略值, 2);
                    }
                    返回 "[harness] budget_exceeded";
                }
            } 否则如果 (请求策略.有效 == 1) {
                预留数 = 输入估算 + 最大输出 + 安全余量;
            }
        } 否则如果 (请求策略.有效 == 1) {
            最大输出 = 请求策略.最大输出;
        }
        上次响应 = 调用(代理值.会话句柄, 提示, 状态值.预算句柄,
            预留数, 最大输出);
        变量 类别: 整数 = 错误类别(上次响应);
        如果 (类别 == 0) {
            资源熔断记成功(状态值.重试资源句柄);
            如果 (重试进行中 == 1) {
                代理发出重试结束(代理值.名字, 试次 + 1, 状态值.重试策略值, 0);
            }
            如果 (试次 > 0) {
                事件("retry_ok", 代理值.名字, "成功于试次 " + 整数转字符串(试次 + 1));
            }
            返回 上次响应;
        }
        如果 (字符串::包含(上次响应, "budget_exceeded") == 1
            || 字符串::包含(上次响应, "needs_reconciliation") == 1) {
            如果 (重试进行中 == 1) {
                代理发出重试结束(代理值.名字, 试次 + 1, 状态值.重试策略值, 2);
            }
            返回 上次响应;
        }
        资源熔断记失败(状态值.重试资源句柄);
        如果 (重试进行中 == 1) {
            代理发出重试结束(代理值.名字, 试次 + 1, 状态值.重试策略值, 类别);
            重试进行中 = 0;
        }
        如果 (类别 == 2) {
            错误事件(代理值.名字, "致命错误，不重试: " + 上次响应);
            代理发出重试错误(代理值.名字, "fatal", 试次 + 1,
                状态值.重试策略值.最大次数);
            返回 上次响应;
        }
        试次 = 试次 + 1;
        如果 (试次 < 状态值.重试策略值.最大次数) {
            代理发出重试开始(代理值.名字, 试次 + 1, 状态值.重试策略值, 延迟);
            重试进行中 = 1;
            事件("retry", 代理值.名字, "试次 " + 整数转字符串(试次)
                + " 可重试错误，延迟 " + 整数转字符串(延迟) + " ms");
            时间.睡眠毫秒(延迟);
            延迟 = 延迟 * 状态值.重试策略值.倍数;
            如果 (延迟 > 状态值.重试策略值.最大延迟毫秒) {
                延迟 = 状态值.重试策略值.最大延迟毫秒;
            }
        }
    }
    错误事件(代理值.名字, "智能重试 "
        + 整数转字符串(状态值.重试策略值.最大次数) + " 次全部失败");
    代理发出重试错误(代理值.名字, "exhausted", 状态值.重试策略值.最大次数,
        状态值.重试策略值.最大次数);
    返回 上次响应;
}

函数 预算是否阻止(代理值: 代理) : 整数 {
    变量 预算句柄: 整数 = 读取代理状态(代理值).预算句柄;
    如果 (预算句柄 < 0) { 返回 0; }
    如果 (预算需对账(预算句柄) == 1) { 返回 2; }
    返回 超预算(预算句柄);
}

函数 发运行生命周期(代理值: 代理, 运行ID: 字符串, 轮次ID: 字符串,
                    步骤ID: 字符串, 事件类型: 字符串, 载荷: 字符串) {
    如果 (读取代理状态(代理值).运行配置值.发出生命周期事件 == 1) {
        发出生命周期事件(运行ID, 轮次ID, 步骤ID, 事件类型, 代理值.名字, 载荷);
    }
}

函数 开始代理轮(代理值: 代理, 运行ID: 字符串, 轮次ID: 字符串) {
    发运行生命周期(代理值, 运行ID, 轮次ID, "", "agent_start", "{}");
    发运行生命周期(代理值, 运行ID, 轮次ID, "", "turn_start", "{}");
}

函数 结束代理轮(代理值: 代理, 运行ID: 字符串, 轮次ID: 字符串) {
    发运行生命周期(代理值, 运行ID, 轮次ID, "", "turn_end", "{}");
    发运行生命周期(代理值, 运行ID, 轮次ID, "", "agent_end", "{}");
}

// 在本轮初始 provider 请求前整理历史。工具续调期间不裁剪，避免拆散当前
// assistant tool_call 与对应 tool result。
函数 自动压缩上下文(代理值: 代理, 运行ID: 字符串, 轮次ID: 字符串) {
    变量 配置值: 运行配置 = 读取代理状态(代理值).运行配置值;
    变量 阈值: 整数 = 配置值.上下文压缩阈值;
    如果 (阈值 <= 0 || 需要压缩(代理值.会话句柄, 阈值) == 0) { 返回; }
    如果 (配置值.上下文压缩策略 == 1) {
        变量 压缩前令牌: 整数 = 历史令牌估算(代理值.会话句柄);
        变量 压缩后条数: 整数 = 滑窗裁剪(
            代理值.会话句柄, 配置值.滑窗保留条数);
        发运行生命周期(代理值, 运行ID, 轮次ID, "", "context_compact", "{\"strategy\":\"sliding_window\",\"tokens_before\":"
            + 整数转字符串(压缩前令牌) + ",\"messages_after\":"
            + 整数转字符串(压缩后条数) + "}");
    }
}

函数 统一非流式调用(
    代理值: 代理,
    提示: 字符串,
    调用: 函数(整数, 字符串, 整数, 整数, 整数): 字符串,
    运行ID: 字符串,
    轮次ID: 字符串,
    步骤ID: 字符串
) : 字符串 {
    如果 (字符串::字节长度(提示) > 0) {
        持久记录用户(代理值, 提示);
    }
    变量 预算阻止状态: 整数 = 预算是否阻止(代理值);
    如果 (预算阻止状态 > 0) {
        如果 (预算阻止状态 == 2) {
            事件("budget_overrun", 代理值.名字, "预算需对账，未发出模型请求");
            持久记录框架错误(代理值, "[harness] budget_overrun needs_reconciliation");
            返回 "[harness] budget_overrun needs_reconciliation";
        }
        事件("budget_exceeded", 代理值.名字, "预算已达到上限，未发出模型请求");
        持久记录框架错误(代理值, "[harness] budget_exceeded");
        返回 "[harness] budget_exceeded";
    }

    发运行生命周期(代理值, 运行ID, 轮次ID, 步骤ID, "llm_start", "{}");
    变量 回复: 字符串 = 预算重试调用(代理值, 提示, 调用);
    发运行生命周期(代理值, 运行ID, 轮次ID, 步骤ID, "llm_end", "{}");
    如果 (读取代理状态(代理值).持久会话库 > 0) {
        如果 (错误类别(回复) == 0) {
            持久记录原始(代理值, 回复);
        } 否则 {
            持久记录模型错误(代理值, 回复);
        }
    }
    返回 回复;
}

// 跑一轮：用户给 prompt，agent 自动 dispatch tool_call 直到模型给最终文本。
// 返回最终文字回复。
公开 函数 运行(代理值: 代理, 提示: 字符串) : 字符串 {
    变量 持久轮ID: 字符串 = 持久开始轮(代理值);
    变量 运行ID: 字符串 = 新运行ID();
    变量 运行作用域: 运行上下文作用域 = 开始代理运行上下文(运行ID);
    变量 运行上下文句柄: 整数 = 运行作用域.句柄;
    变量 轮次ID: 字符串 = "turn-1";
    开始代理轮(代理值, 运行ID, 轮次ID);
    自动压缩上下文(代理值, 运行ID, 轮次ID);
    LLM调用事件(代理值.名字, 提示);
    变量 原始: 字符串 = 统一非流式调用(
        代理值, 提示, 预算工具模型调用, 运行ID, 轮次ID, "step-0");
    如果 (错误类别(原始) != 0) {
        持久失败轮(代理值, 持久轮ID);
        LLM响应事件(代理值.名字, 原始);
        结束代理轮(代理值, 运行ID, 轮次ID);
        结束代理运行上下文(运行作用域);
        返回 原始;
    }
    变量 消息: 助手消息 = 解析助手消息(代理值.会话句柄, 原始);
    LLM响应事件(代理值.名字, 消息.文本);

    变量 步: 整数 = 0;
    当 (消息.工具调用数 > 0) {
        如果 (步 >= 代理值.最大步数) {
            错误事件(代理值.名字,
                "tool loop 超过 " + 整数转字符串(代理值.最大步数) + " 步上限");
            持久记录框架错误(代理值, "[harness] tool 循环达到上限");
            持久失败轮(代理值, 持久轮ID);
            结束代理轮(代理值, 运行ID, 轮次ID);
            结束代理运行上下文(运行作用域);
            返回 "[harness] tool 循环达到上限";
        }
        // 先收集本轮所有 tool_calls，再按整批能力选择执行路径：只有全部放行且
        // 全部声明为可并发的本地工具才并发；串行工具、MCP、未知或被拒调用都会
        // 让整批按输入顺序串行，避免并发 worker 与有顺序约束的工具发生重叠。
        变量 调用数: 整数 = 消息.工具调用数;
        变量 ID表: 整数 = 列表库::创建字符串列表();
        变量 名表: 整数 = 列表库::创建字符串列表();
        变量 参表: 整数 = 列表库::创建字符串列表();
        变量 索引: 整数 = 0;
        当 (索引 < 调用数) {
            变量 工具ID值: 字符串 = 工具调用ID(消息, 索引);
            变量 工具名值: 字符串 = 工具调用名(消息, 索引);
            变量 参数JSON: 字符串 = 工具调用参数(消息, 索引);
            列表库::添加字符串(ID表, 工具ID值);
            列表库::添加字符串(名表, 工具名值);
            列表库::添加字符串(参表, 参数JSON);
            索引 = 索引 + 1;
        }
        变量 可整批并发: 整数 = 1;
        变量 扫: 整数 = 0;
        当 (扫 < 调用数) {
            变量 扫描名: 字符串 = 列表库::获取字符串(名表, 扫);
            如果 (工具是否放行(代理值, 扫描名) == 0
                || 工具执行模式(代理值.工具表, 扫描名) != 0) {
                可整批并发 = 0;
            }
            扫 = 扫 + 1;
        }
        变量 含受控工具: 整数 = 0;
        变量 受控句柄表值: 整数 = 列表库::创建整数列表();
        扫 = 0;
        当 (扫 < 调用数) {
            变量 h: 整数 = 受控工具句柄(代理值.工具表, 列表库::获取字符串(名表, 扫));
            列表库::添加整数(受控句柄表值, h);
            如果 (h >= 0) { 含受控工具 = 1; }
            扫 = 扫 + 1;
        }
        如果 (含受控工具 == 1) {
            变量 对齐结果: 整数 = 哈希表::创建字符串表();
            变量 队列索引: 整数 = 0;
            当 (队列索引 < 调用数) {
                变量 队列名: 字符串 = 列表库::获取字符串(名表, 队列索引);
                变量 队列ID: 字符串 = 列表库::获取字符串(ID表, 队列索引);
                发运行生命周期(代理值, 运行ID, 轮次ID,
                    "step-" + 整数转字符串(步) + "-tool-" + 整数转字符串(队列索引),
                    "tool_queued", "{\"tool\":\"" + 队列名 + "\",\"call_id\":\"" + 队列ID + "\"}");
                队列索引 = 队列索引 + 1;
            }
            变量 规划对象: 整数 = J.解码(规划工具波次(受控句柄表值, 调用数, 0));
            变量 阶段组: 整数 = J.获取数组(规划对象, "stages");
            变量 阶段索引: 整数 = 0;
            当 (阶段索引 < J.数组长度(阶段组)) {
                变量 阶段对象: 整数 = J.数组获取对象(阶段组, 阶段索引);
                变量 阶段类型: 字符串 = J.获取字符串(阶段对象, "kind");
                变量 阶段调用: 整数 = J.获取数组(阶段对象, "calls");
                如果 (字符串::等于(阶段类型, "wave") == 1) {
                    变量 编码结果: 整数 = 列表库::创建字符串列表();
                    变量 完成信道: 通道<整数> = 通道<整数>(J.数组长度(阶段调用) + 1);
                    变量 启动数: 整数 = 0;
                    变量 wi: 整数 = 0;
                    当 (wi < J.数组长度(阶段调用)) {
                        变量 调用索引: 整数 = J.数组获取整数(阶段调用, wi);
                        变量 波名: 字符串 = 列表库::获取字符串(名表, 调用索引);
                        变量 波ID: 字符串 = 列表库::获取字符串(ID表, 调用索引);
                        变量 波参: 字符串 = 列表库::获取字符串(参表, 调用索引);
                        变量 波步骤: 字符串 = "step-" + 整数转字符串(步) + "-tool-" + 整数转字符串(调用索引);
                        变量 参数错误: 字符串 = 验证工具调用参数(代理值.工具表, 波名, 波参);
                        如果 (工具是否放行(代理值, 波名) == 0 || 字符串::字节长度(参数错误) > 0) {
                            变量 失败结果: 工具结果 = 工具失败结果("invalid_arguments", 参数错误, 0);
                            如果 (工具是否放行(代理值, 波名) == 0) {
                                工具被拒事件(代理值.名字, 波名);
                                失败结果 = 工具失败结果("tool_not_allowed", "tool is not allowed", 0);
                            }
                            变量 标准失败: 字符串 = 工具结果转JSON(失败结果);
                            变量 失败文本: 字符串 = 标准失败;
                            工具结果事件(代理值.名字, 波名, 失败文本);
                            发运行生命周期(代理值, 运行ID, 轮次ID, 波步骤, "tool_end",
                                工具事件载荷(波名, 波ID, "failed", 标准失败, "[]"));
                            哈希表::设置字符串(对齐结果, 整数转字符串(调用索引), 失败文本);
                        } 否则 {
                            发运行生命周期(代理值, 运行ID, 轮次ID, 波步骤, "tool_start", "{}");
                            工具调用事件(代理值.名字, 波名, 波参);
                            启动 代理受控工具工人(代理值,
                                列表库::获取整数(受控句柄表值, 调用索引),
                                调用索引, 运行ID, 轮次ID, 波步骤, 波ID, 运行上下文句柄,
                                波参, 编码结果, 完成信道);
                            启动数 = 启动数 + 1;
                        }
                        wi = wi + 1;
                    }
                    变量 完成数: 整数 = 0;
                    当 (完成数 < 启动数) {
                        变量 完成索引: 整数 = <- 完成信道;
                        变量 完成名: 字符串 = 列表库::获取字符串(名表, 完成索引);
                        变量 完成ID: 字符串 = 列表库::获取字符串(ID表, 完成索引);
                        变量 完成参: 字符串 = 列表库::获取字符串(参表, 完成索引);
                        变量 完成步骤: 字符串 = "step-" + 整数转字符串(步) + "-tool-" + 整数转字符串(完成索引);
                        变量 模型文本: 字符串 = 完成受控调用(代理值, 运行ID, 轮次ID,
                            完成步骤, 完成名, 完成ID, 完成参,
                            列表库::获取整数(受控句柄表值, 完成索引),
                            受控结果查找(编码结果, 完成索引));
                        哈希表::设置字符串(对齐结果, 整数转字符串(完成索引), 模型文本);
                        完成数 = 完成数 + 1;
                    }
                } 否则 {
                    变量 bi: 整数 = 0;
                    当 (bi < J.数组长度(阶段调用)) {
                        变量 调用索引2: 整数 = J.数组获取整数(阶段调用, bi);
                        变量 屏名: 字符串 = 列表库::获取字符串(名表, 调用索引2);
                        变量 屏ID: 字符串 = 列表库::获取字符串(ID表, 调用索引2);
                        变量 屏参: 字符串 = 列表库::获取字符串(参表, 调用索引2);
                        变量 屏步骤: 字符串 = "step-" + 整数转字符串(步) + "-tool-" + 整数转字符串(调用索引2);
                        变量 屏结果: 字符串 = "";
                        变量 屏句柄: 整数 = 列表库::获取整数(受控句柄表值, 调用索引2);
                        变量 屏参数错误: 字符串 = 验证工具调用参数(代理值.工具表, 屏名, 屏参);
                        如果 (工具是否放行(代理值, 屏名) == 0) {
                            工具被拒事件(代理值.名字, 屏名);
                            屏结果 = 拒绝结果(屏名);
                            工具结果事件(代理值.名字, 屏名, 屏结果);
                            发运行生命周期(代理值, 运行ID, 轮次ID, 屏步骤, "tool_end", "{}");
                        } 否则如果 (字符串::字节长度(屏参数错误) > 0) {
                            屏结果 = 工具结果转JSON(工具失败结果("invalid_arguments", 屏参数错误, 0));
                            工具结果事件(代理值.名字, 屏名, 屏结果);
                            发运行生命周期(代理值, 运行ID, 轮次ID, 屏步骤, "tool_end", "{}");
                        } 否则如果 (屏句柄 >= 0) {
                            发运行生命周期(代理值, 运行ID, 轮次ID, 屏步骤, "tool_start", "{}");
                            工具调用事件(代理值.名字, 屏名, 屏参);
                            屏结果 = 完成受控调用(代理值, 运行ID, 轮次ID, 屏步骤,
                                屏名, 屏ID, 屏参, 屏句柄,
                                执行单个受控调用(代理值, 屏句柄, 运行ID, 轮次ID,
                                    屏步骤, 屏ID, 屏参, 运行上下文句柄));
                        } 否则 {
                            发运行生命周期(代理值, 运行ID, 轮次ID, 屏步骤, "tool_start", "{}");
                            工具调用事件(代理值.名字, 屏名, 屏参);
                            屏结果 = 派发(代理值.工具表, 屏名, 屏参);
                            工具结果事件(代理值.名字, 屏名, 屏结果);
                            发运行生命周期(代理值, 运行ID, 轮次ID, 屏步骤, "tool_end", "{}");
                        }
                        哈希表::设置字符串(对齐结果, 整数转字符串(调用索引2), 屏结果);
                        bi = bi + 1;
                    }
                }
                阶段索引 = 阶段索引 + 1;
            }
            J.删除(规划对象);
            变量 回写索引: 整数 = 0;
            当 (回写索引 < 调用数) {
                变量 回写ID: 字符串 = 列表库::获取字符串(ID表, 回写索引);
                变量 回写名: 字符串 = 列表库::获取字符串(名表, 回写索引);
                变量 回写值: 字符串 = 哈希表::获取字符串(对齐结果, 整数转字符串(回写索引));
                回写工具结果(代理值.会话句柄, 回写ID, 回写名, 回写值);
                如果 (读取代理状态(代理值).持久会话库 > 0) {
                    持久记录工具(代理值, 回写ID, 回写名, 回写值);
                }
                回写索引 = 回写索引 + 1;
            }
        } 否则如果 (可整批并发 == 1) {
            变量 启动索引: 整数 = 0;
            当 (启动索引 < 调用数) {
                变量 启动名: 字符串 = 列表库::获取字符串(名表, 启动索引);
                变量 启动参: 字符串 = 列表库::获取字符串(参表, 启动索引);
                发运行生命周期(代理值, 运行ID, 轮次ID,
                    "step-" + 整数转字符串(步) + "-tool-" + 整数转字符串(启动索引),
                    "tool_start", "{}");
                工具调用事件(代理值.名字, 启动名, 启动参);
                启动索引 = 启动索引 + 1;
            }
            变量 结果表: 整数 = 并发派发(代理值.工具表, 名表, 参表, 调用数);
            变量 写索引: 整数 = 0;
            当 (写索引 < 调用数) {
                变量 名: 字符串 = 列表库::获取字符串(名表, 写索引);
                变量 ID: 字符串 = 列表库::获取字符串(ID表, 写索引);
                变量 返回值: 字符串 = 列表库::获取字符串(结果表, 写索引);
                工具结果事件(代理值.名字, 名, 返回值);
                发运行生命周期(代理值, 运行ID, 轮次ID,
                    "step-" + 整数转字符串(步) + "-tool-" + 整数转字符串(写索引),
                    "tool_end", "{}");
                回写工具结果(代理值.会话句柄, ID, 名, 返回值);
                如果 (读取代理状态(代理值).持久会话库 > 0) {
                    持久记录工具(代理值, ID, 名, 返回值);
                }
                写索引 = 写索引 + 1;
            }
        } 否则 {
            变量 写索引2: 整数 = 0;
            当 (写索引2 < 调用数) {
                变量 名2: 字符串 = 列表库::获取字符串(名表, 写索引2);
                变量 ID2: 字符串 = 列表库::获取字符串(ID表, 写索引2);
                变量 参2: 字符串 = 列表库::获取字符串(参表, 写索引2);
                变量 返回值2: 字符串 = "";
                发运行生命周期(代理值, 运行ID, 轮次ID,
                    "step-" + 整数转字符串(步) + "-tool-" + 整数转字符串(写索引2),
                    "tool_start", "{}");
                工具调用事件(代理值.名字, 名2, 参2);
                如果 (工具是否放行(代理值, 名2) == 1) {
                    返回值2 = 派发(代理值.工具表, 名2, 参2);
                } 否则 {
                    工具被拒事件(代理值.名字, 名2);
                    返回值2 = 拒绝结果(名2);
                }
                工具结果事件(代理值.名字, 名2, 返回值2);
                发运行生命周期(代理值, 运行ID, 轮次ID,
                    "step-" + 整数转字符串(步) + "-tool-" + 整数转字符串(写索引2),
                    "tool_end", "{}");
                回写工具结果(代理值.会话句柄, ID2, 名2, 返回值2);
                如果 (读取代理状态(代理值).持久会话库 > 0) {
                    持久记录工具(代理值, ID2, 名2, 返回值2);
                }
                写索引2 = 写索引2 + 1;
            }
        }
        // 未结束
        变量 原始2: 字符串 = 统一非流式调用(
            代理值, "", 预算继续工具模型调用, 运行ID, 轮次ID,
            "step-" + 整数转字符串(步 + 1));
        推进步骤(运行上下文句柄);
        如果 (错误类别(原始2) != 0) {
            持久失败轮(代理值, 持久轮ID);
            LLM响应事件(代理值.名字, 原始2);
            结束代理轮(代理值, 运行ID, 轮次ID);
            结束代理运行上下文(运行作用域);
            返回 原始2;
        }
        消息 = 解析助手消息(代理值.会话句柄, 原始2);
        LLM响应事件(代理值.名字, 消息.文本);
        步 = 步 + 1;
    }
    记用量(代理值);
    完成事件(代理值.名字, 消息.文本);
    持久记录最终(代理值, 消息.文本);
    持久完成轮(代理值, 持久轮ID);
    结束代理轮(代理值, 运行ID, 轮次ID);
    结束代理运行上下文(运行作用域);
    返回 消息.文本;
}

// 给同包模块提供无名称冲突的调用入口；公开保留以便独立模块导入。
公开 函数 运行代理(代理值: 代理, 提示: 字符串) : 字符串 {
    返回 运行(代理值, 提示);
}

// 单次覆盖：同步调用结束前恢复原配置，不改变代理后续调用的默认值。
公开 函数 运行使用配置(代理值: 代理, 提示: 字符串, 配置值: 运行配置) : 字符串 {
    变量 原配置: 运行配置 = 当前运行配置(代理值);
    应用运行配置(代理值, 配置值);
    变量 回复: 字符串 = 运行(代理值, 提示);
    应用运行配置(代理值, 原配置);
    返回 回复;
}

// 把必需字段列表拼成人类可读串，如 `"name", "age"`，给模型当指令。
函数 字段清单文本(必需字段: 整数) : 字符串 {
    变量 数: 整数 = 列表库::字符串列表大小(必需字段);
    变量 文本: 字符串 = "";
    变量 i: 整数 = 0;
    当 (i < 数) {
        变量 键: 字符串 = 列表库::获取字符串(必需字段, i);
        如果 (i > 0) {
            文本 = 文本 + ", ";
        }
        文本 = 文本 + "\"" + 键 + "\"";
        i = i + 1;
    }
    返回 文本;
}

// 结构化运行 —— schema 约束 + 自动重试。
//   提示：业务问题
//   必需字段：标准库.列表 的字符串列表句柄，列出输出 JSON 必须含的顶层键
// 循环到 最大步数：给模型「只输出 JSON 且必须包含字段 …」的指令 → 取回文本 →
// 校验JSON对象 通过则返回该 JSON；否则带纠正提示重试；超限返回 [harness] 前缀错误串。
// 每次尝试都记录 追踪 事件，可观测。
公开 函数 结构化运行(代理值: 代理, 提示: 字符串, 必需字段: 整数) : 字符串 {
    变量 持久轮ID: 字符串 = 持久开始轮(代理值);
    变量 运行ID: 字符串 = 新运行ID();
    变量 运行作用域: 运行上下文作用域 = 开始代理运行上下文(运行ID);
    变量 轮次ID: 字符串 = "turn-1";
    开始代理轮(代理值, 运行ID, 轮次ID);
    自动压缩上下文(代理值, 运行ID, 轮次ID);
    变量 清单: 字符串 = 字段清单文本(必需字段);
    变量 指令: 字符串 = 提示
        + "\n\n严格要求：只输出一个 JSON 对象，不要任何解释、不要代码块标记（``` 也不要）。"
        + "该 JSON 对象必须包含以下字段：" + 清单 + "。";

    // 开启 provider 端 JSON 模式（response_format=json_object）——从"求模型自觉"升级为
    // "服务端约束只能吐合法 JSON"，大幅降低解析失败。仍保留字段校验 + 重试兜底
    // （JSON 模式只保证合法 JSON，不保证含齐字段）。结束后复原，不污染同一会话的后续普通对话。
    底层模型.设置配置(代理值.会话句柄, "response_format", "json_object");

    变量 尝试次: 整数 = 0;
    变量 当前提示: 字符串 = 指令;
    变量 结果值: 字符串 = "[harness] 结构化输出校验在达到最大步数后失败";
    变量 成功: 整数 = 0;
    变量 调用错误: 整数 = 0;
    当 (尝试次 < 代理值.最大步数 && 成功 == 0 && 调用错误 == 0) {
        LLM调用事件(代理值.名字, 当前提示);
        变量 回复: 字符串 = 统一非流式调用(
            代理值, 当前提示, 预算普通模型调用, 运行ID, 轮次ID,
            "step-" + 整数转字符串(尝试次));
        LLM响应事件(代理值.名字, 回复);

        如果 (错误类别(回复) != 0) {
            结果值 = 回复;
            调用错误 = 1;
        } 否则如果 (校验JSON对象(回复, 必需字段) == 1) {
            完成事件(代理值.名字, 回复);
            结果值 = 回复;
            成功 = 1;
        } 否则 {
            错误事件(代理值.名字,
                "第 " + 整数转字符串(尝试次 + 1) + " 次结构化输出校验失败");
            持久记录框架错误(代理值,
                "[harness] 第 " + 整数转字符串(尝试次 + 1) + " 次结构化输出校验失败");
            当前提示 = "你上一次的输出不是包含字段 " + 清单
                + " 的合法 JSON 对象。请重新只输出符合要求的 JSON 对象。";
            尝试次 = 尝试次 + 1;
        }
    }

    // 复原：关掉 JSON 模式，避免影响该会话后续的普通对话
    底层模型.设置配置(代理值.会话句柄, "response_format", "");
    如果 (成功 == 0 && 调用错误 == 0) {
        错误事件(代理值.名字,
            "结构化输出在 " + 整数转字符串(代理值.最大步数) + " 次尝试后仍不合规");
        持久记录框架错误(代理值, 结果值);
    }
    如果 (成功 == 1) {
        持久记录最终(代理值, 结果值);
        持久完成轮(代理值, 持久轮ID);
    } 否则 {
        持久失败轮(代理值, 持久轮ID);
    }
    结束代理轮(代理值, 运行ID, 轮次ID);
    结束代理运行上下文(运行作用域);
    返回 结果值;
}

公开 函数 结构化运行使用配置(代理值: 代理, 提示: 字符串, 必需字段: 整数,
                            配置值: 运行配置) : 字符串 {
    变量 原配置: 运行配置 = 当前运行配置(代理值);
    应用运行配置(代理值, 配置值);
    变量 回复: 字符串 = 结构化运行(代理值, 提示, 必需字段);
    应用运行配置(代理值, 原配置);
    返回 回复;
}

// 严格结构化：传完整 JSON Schema，走 provider 的 json_schema strict 模式（支持的 provider
// 才有效，如新版 OpenAI；不支持的会退化为普通请求）。schema串 = 完整 response_format 对象，
// 形如 {"type":"json_schema","json_schema":{"name":"x","schema":{...},"strict":true}}。
公开 函数 结构化运行严格(代理值: 代理, 提示: 字符串, schema串: 字符串) : 字符串 {
    变量 持久轮ID: 字符串 = 持久开始轮(代理值);
    变量 运行ID: 字符串 = 新运行ID();
    变量 运行作用域: 运行上下文作用域 = 开始代理运行上下文(运行ID);
    变量 轮次ID: 字符串 = "turn-1";
    开始代理轮(代理值, 运行ID, 轮次ID);
    自动压缩上下文(代理值, 运行ID, 轮次ID);
    底层模型.设置配置(代理值.会话句柄, "response_format", schema串);
    LLM调用事件(代理值.名字, 提示);
    变量 回复: 字符串 = 统一非流式调用(
        代理值, 提示, 预算普通模型调用, 运行ID, 轮次ID, "step-0");
    LLM响应事件(代理值.名字, 回复);
    底层模型.设置配置(代理值.会话句柄, "response_format", "");
    完成事件(代理值.名字, 回复);
    如果 (错误类别(回复) == 0) {
        持久记录最终(代理值, 回复);
        持久完成轮(代理值, 持久轮ID);
    } 否则 {
        持久失败轮(代理值, 持久轮ID);
    }
    结束代理轮(代理值, 运行ID, 轮次ID);
    结束代理运行上下文(运行作用域);
    返回 回复;
}

公开 函数 结构化运行严格使用配置(代理值: 代理, 提示: 字符串, schema串: 字符串,
                                配置值: 运行配置) : 字符串 {
    变量 原配置: 运行配置 = 当前运行配置(代理值);
    应用运行配置(代理值, 配置值);
    变量 回复: 字符串 = 结构化运行严格(代理值, 提示, schema串);
    应用运行配置(代理值, 原配置);
    返回 回复;
}

// 只跑一次纯对话（不带工具）— 用于简单 chatbot 场景
公开 函数 简单问(代理值: 代理, 提示: 字符串) : 字符串 {
    变量 持久轮ID: 字符串 = 持久开始轮(代理值);
    变量 运行ID: 字符串 = 新运行ID();
    变量 运行作用域: 运行上下文作用域 = 开始代理运行上下文(运行ID);
    变量 轮次ID: 字符串 = "turn-1";
    开始代理轮(代理值, 运行ID, 轮次ID);
    自动压缩上下文(代理值, 运行ID, 轮次ID);
    LLM调用事件(代理值.名字, 提示);
    变量 回复: 字符串 = 统一非流式调用(
        代理值, 提示, 预算普通模型调用, 运行ID, 轮次ID, "step-0");
    LLM响应事件(代理值.名字, 回复);
    如果 (错误类别(回复) == 0) {
        记用量(代理值);
    }
    完成事件(代理值.名字, 回复);
    如果 (错误类别(回复) == 0) {
        持久记录最终(代理值, 回复);
        持久完成轮(代理值, 持久轮ID);
    } 否则 {
        持久失败轮(代理值, 持久轮ID);
    }
    结束代理轮(代理值, 运行ID, 轮次ID);
    结束代理运行上下文(运行作用域);
    返回 回复;
}

公开 函数 简单问使用配置(代理值: 代理, 提示: 字符串, 配置值: 运行配置) : 字符串 {
    变量 原配置: 运行配置 = 当前运行配置(代理值);
    应用运行配置(代理值, 配置值);
    变量 回复: 字符串 = 简单问(代理值, 提示);
    应用运行配置(代理值, 原配置);
    返回 回复;
}

// 流式问答 — 每收到一个 chunk 就调 块回调(片段)，
// 同时 emit `stream_chunk` trace 事件，结束后返回拼装好的完整回复。
// 块回调 签名固定 函数(字符串): 整数（返回 1 继续；预留 0 中止位）。
公开 函数 流式问(代理值: 代理, 提示: 字符串, 块回调: 函数(字符串): 整数) : 字符串 {
    变量 运行作用域: 运行上下文作用域 = 开始代理运行上下文(新运行ID());
    流开始事件(代理值.名字, 提示);
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    变量 流句柄: 整数 = 0;
    变量 试次: 整数 = 0;
    变量 延迟: 整数 = 状态值.重试策略值.起始延迟毫秒;
    当 (流句柄 <= 0 && 试次 < 状态值.重试策略值.最大次数) {
        流句柄 = 底层模型.流式对话(代理值.会话句柄, 提示);
        试次 = 试次 + 1;
        如果 (流句柄 <= 0 && 试次 < 状态值.重试策略值.最大次数) {
            事件("retry", 代理值.名字, "流连接失败，延迟 " + 整数转字符串(延迟) + " ms 后重试");
            时间.睡眠毫秒(延迟);
            延迟 = 延迟 * 状态值.重试策略值.倍数;
            如果 (延迟 > 状态值.重试策略值.最大延迟毫秒) { 延迟 = 状态值.重试策略值.最大延迟毫秒; }
        }
    }
    如果 (流句柄 <= 0) {
        错误事件(代理值.名字, "打开流失败");
        结束代理运行上下文(运行作用域);
        返回 "";
    }
    变量 累积: 字符串 = "";
    变量 未结束: 整数 = 1;
    当 (未结束 == 1) {
        变量 片段: 字符串 = 底层模型.读取流(流句柄);
        如果 (字符串::字节长度(片段) == 0) {
            未结束 = 0;
        } 否则 {
            流块事件(代理值.名字, 片段);
            块回调(片段);
            累积 = 累积 + 片段;
        }
    }
    底层模型.关闭流(流句柄);
    流结束事件(代理值.名字, 累积);
    结束代理运行上下文(运行作用域);
    返回 累积;
}

// 流式运行 —— 既流式输出文本，又自动 dispatch tool_call。
// 把「流式」和「工具循环」合到一起：
//   每轮开一条带 tools 的流 → 文本片段实时 块回调 流出 → 流读完后取 assistant 消息；
//   若含 tool_call：派发 + 回写结果 + 流式继续工具对话，进入下一轮；
//   若无 tool_call：结束，返回累计文本。
// 工具调用阶段会往 块回调 注入 `[调用工具 …]` 提示行，让前端能显示「正在用工具」。
// 块回调 签名固定 函数(字符串): 整数。
公开 函数 流式运行(代理值: 代理, 提示: 字符串, 块回调: 函数(字符串): 整数) : 字符串 {
    变量 运行作用域: 运行上下文作用域 = 开始代理运行上下文(新运行ID());
    流开始事件(代理值.名字, 提示);
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    变量 流: 整数 = 0;
    变量 试次: 整数 = 0;
    变量 延迟: 整数 = 状态值.重试策略值.起始延迟毫秒;
    当 (流 <= 0 && 试次 < 状态值.重试策略值.最大次数) {
        流 = 底层模型.流式工具对话(代理值.会话句柄, 提示);
        试次 = 试次 + 1;
        如果 (流 <= 0 && 试次 < 状态值.重试策略值.最大次数) {
            事件("retry", 代理值.名字, "流连接失败，延迟 " + 整数转字符串(延迟) + " ms 后重试");
            时间.睡眠毫秒(延迟);
            延迟 = 延迟 * 状态值.重试策略值.倍数;
            如果 (延迟 > 状态值.重试策略值.最大延迟毫秒) { 延迟 = 状态值.重试策略值.最大延迟毫秒; }
        }
    }
    如果 (流 <= 0) {
        错误事件(代理值.名字, "打开流失败");
        结束代理运行上下文(运行作用域);
        返回 "";
    }
    变量 累积: 字符串 = "";
    变量 走: 整数 = 1;
    变量 步: 整数 = 0;
    当 (走 == 1) {
        // 1) 把本轮流读到底，文本片段实时流出
        变量 未结束: 整数 = 1;
        当 (未结束 == 1) {
            变量 片段: 字符串 = 底层模型.读取流(流);
            如果 (字符串::字节长度(片段) == 0) {
                未结束 = 0;
            } 否则 {
                流块事件(代理值.名字, 片段);
                块回调(片段);
                累积 = 累积 + 片段;
            }
        }
        // 2) 取本轮拼好的 assistant 消息（含 content + tool_calls）
        变量 助手JSON: 字符串 = 底层模型.流取助手消息(流);
        底层模型.关闭流(流);
        变量 消息: 助手消息 = 解析助手消息(代理值.会话句柄, 助手JSON);

        如果 (消息.工具调用数 == 0) {
            走 = 0;
        } 否则 {
            如果 (步 >= 代理值.最大步数) {
                错误事件(代理值.名字,
                    "tool loop 超过 " + 整数转字符串(代理值.最大步数) + " 步上限");
                走 = 0;
            } 否则 {
                // 3) 串行派发所有 tool_calls + 回写结果
                变量 调用数: 整数 = 消息.工具调用数;
                变量 i: 整数 = 0;
                当 (i < 调用数) {
                    变量 工具ID值: 字符串 = 工具调用ID(消息, i);
                    变量 工具名值: 字符串 = 工具调用名(消息, i);
                    变量 参数JSON: 字符串 = 工具调用参数(消息, i);
                    工具调用事件(代理值.名字, 工具名值, 参数JSON);
                    块回调("\n[调用工具 " + 工具名值 + " " + 参数JSON + "]\n");
                    变量 返回值: 字符串 = "";
                    如果 (工具是否放行(代理值, 工具名值) == 1) {
                        返回值 = 派发(代理值.工具表, 工具名值, 参数JSON);
                    } 否则 {
                        工具被拒事件(代理值.名字, 工具名值);
                        返回值 = 拒绝结果(工具名值);
                    }
                    工具结果事件(代理值.名字, 工具名值, 返回值);
                    回写工具结果(代理值.会话句柄, 工具ID值, 工具名值, 返回值);
                    i = i + 1;
                }
                // 4) 流式继续推理，进入下一轮
                流 = 底层模型.流式继续工具对话(代理值.会话句柄);
                如果 (流 <= 0) {
                    错误事件(代理值.名字, "流式继续失败");
                    走 = 0;
                } 否则 {
                    步 = 步 + 1;
                }
            }
        }
    }
    完成事件(代理值.名字, 累积);
    流结束事件(代理值.名字, 累积);
    结束代理运行上下文(运行作用域);
    返回 累积;
}

// ===== 记忆集成（存储层见 记忆.qi）=====

// 给代理接上持久记忆库（SQLite）。路径不存在会自动建库建表。
// 返回更新后的 代理；打开失败时 记忆库 保持 0（带记忆运行 自动退化为普通 运行）。
公开 函数 启用记忆(代理值: 代理, 库路径: 字符串) : 代理 {
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    状态值.记忆库 = 打开记忆(库路径);
    保存代理状态(代理值, 状态值);
    如果 (状态值.记忆库 <= 0) {
        错误事件(代理值.名字, "记忆库打开失败: " + 库路径);
    }
    返回 代理值;
}

// 带记忆运行 —— 先按关键词 回忆，命中则把记忆块拼在提示前，再走既有 运行
// （工具循环照常）。注入拼在用户提示前而非覆写会话 system 配置：底层 设置配置
// 是整体覆盖，会冲掉用户已设的系统提示。未启用记忆/无命中时与 运行 完全等价。
公开 函数 带记忆运行(代理值: 代理, 提示: 字符串, 查询关键词: 字符串) : 字符串 {
    变量 最终提示: 字符串 = 提示;
    变量 记忆库: 整数 = 读取代理状态(代理值).记忆库;
    如果 (记忆库 > 0) {
        变量 记忆块: 字符串 = 回忆(记忆库, 查询关键词, 5);
        如果 (字符串::字节长度(记忆块) > 0) {
            事件("memory_recall", 代理值.名字, 记忆块);
            最终提示 = "## 相关记忆与过往经验\n" + 记忆块
                + "\n(参考以上背景作答)\n\n" + 提示;
        }
    }
    返回 运行(代理值, 最终提示);
}

// 提炼经验 —— 用模型把（任务，结果）蒸馏成一条可复用经验（一句话 + 3 个关键词），
// 存成 类型="经验"。走 结构化运行（schema 约束 + 自动重试）保证字段齐全；
// LLM 不可用/输出不合规时返回 0 不崩。成功返回新记忆 id。
公开 函数 提炼经验(代理值: 代理, 任务描述: 字符串, 结果文本: 字符串) : 整数 {
    变量 记忆库: 整数 = 读取代理状态(代理值).记忆库;
    如果 (记忆库 <= 0) { 返回 0; }
    变量 必需: 整数 = 列表库::创建字符串列表();
    列表库::添加字符串(必需, "经验");
    列表库::添加字符串(必需, "关键词");
    变量 提示: 字符串 = "任务：" + 任务描述 + "\n结果：" + 结果文本
        + "\n\n请把这次执行提炼成一条今后可复用的经验：限一句话，说明什么做法有效或什么坑要避开；"
        + "并给出 3 个逗号分隔的检索关键词。"
        + "字段：\"经验\"（字符串，一句话）、\"关键词\"（字符串，3 个词逗号分隔）。";
    变量 回复: 字符串 = 结构化运行(代理值, 提示, 必需);
    变量 对象: 整数 = J.解码(回复);
    如果 (对象 <= 0) { 返回 0; }   // LLM 不可用 → "[harness] …" 错误串，解不出 JSON
    变量 经验文本: 字符串 = J.获取字符串(对象, "经验");
    如果 (字符串::字节长度(经验文本) == 0) { 返回 0; }
    变量 新id: 整数 = 记住(记忆库, "经验", 经验文本, J.获取字符串(对象, "关键词"), 3);
    如果 (新id > 0) {
        事件("memory_store", 代理值.名字, "经验 #" + 整数转字符串(新id) + ": " + 经验文本);
    }
    返回 新id;
}

// 关闭 agent 的会话
公开 函数 关闭代理(代理值: 代理) : 整数 {
    变量 状态值: 代理状态 = 读取代理状态(代理值);
    清理请求令牌策略(代理值);
    清理会话写栅栏(代理值);
    如果 (状态值.拥有重试资源 == 1) {
        释放重试资源(状态值.重试资源句柄);
    }
    清理代理状态(代理值);
    返回 底层模型.关闭会话(代理值.会话句柄);
}
