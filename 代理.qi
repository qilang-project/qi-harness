// 代理 — Agent loop
//
// 这是 harness 的核心。底层 大模型::工具对话 / 继续工具对话 让模型在一轮里
// 要么给文本要么给 tool_call；本模块封装那个循环：
//   while assistant_msg.has_tool_call:
//       result = 派发(name, args_json)
//       回写 tool_result
//       assistant_msg = 继续工具对话()
//   return assistant_msg.文本
//
// 加上限步数（避免无限 tool loop）+ trace + retry。

包 Harness;

导入 标准库.字符串;
导入 标准库.大模型 作为 大模型;
导入 Harness.对话::{助手消息, 解析助手消息, 回写工具结果};
导入 Harness.工具::{工具, 注册表, 创建注册表, 注册, 派发};
导入 Harness.追踪::{LLM调用事件, LLM响应事件, 工具调用事件, 工具结果事件, 错误事件, 完成事件};

公开 类型 代理 {
    名字: 字符串,          // trace 用
    会话句柄: 整数,
    工具表: 注册表,
    最大步数: 整数,         // 防 tool 死循环；默认 10
}

公开 函数 创建代理(名字: 字符串, 会话句柄: 整数) : 代理 {
    返回 (代理 {
        名字: 名字,
        会话句柄: 会话句柄,
        工具表: 创建注册表(),
        最大步数: 10,
    });
}

公开 函数 设置最大步数(代理值: 代理, 上限: 整数) : 代理 {
    代理值.最大步数 = 上限;
    返回 代理值;
}

// 注册一个工具到代理上
公开 函数 添加工具(代理值: 代理, 工具值: 工具) : 代理 {
    代理值.工具表 = 注册(代理值.工具表, 代理值.会话句柄, 工具值);
    返回 代理值;
}

// 跑一轮：用户给 prompt，agent 自动 dispatch tool_call 直到模型给最终文本。
// 返回最终文字回复。
公开 函数 运行(代理值: 代理, 提示: 字符串) : 字符串 {
    LLM调用事件(代理值.名字, 提示);
    变量 原始: 字符串 = 大模型.工具对话(代理值.会话句柄, 提示);
    变量 消息: 助手消息 = 解析助手消息(代理值.会话句柄, 原始);
    LLM响应事件(代理值.名字, 消息.文本);

    变量 步: 整数 = 0;
    当 (消息.有工具调用 == 1) {
        如果 (步 >= 代理值.最大步数) {
            错误事件(代理值.名字,
                "tool loop 超过 " + 整数转字符串(代理值.最大步数) + " 步上限");
            返回 "[harness] tool 循环达到上限";
        }
        // 派发
        工具调用事件(代理值.名字, 消息.工具名, 消息.工具参数JSON);
        变量 返回值: 字符串 = 派发(代理值.工具表, 消息.工具名, 消息.工具参数JSON);
        工具结果事件(代理值.名字, 消息.工具名, 返回值);
        // 回写
        回写工具结果(代理值.会话句柄, 消息.工具ID, 返回值);
        // 继续
        变量 原始2: 字符串 = 大模型.继续工具对话(代理值.会话句柄);
        消息 = 解析助手消息(代理值.会话句柄, 原始2);
        LLM响应事件(代理值.名字, 消息.文本);
        步 = 步 + 1;
    }
    完成事件(代理值.名字, 消息.文本);
    返回 消息.文本;
}

// 只跑一次纯对话（不带工具）— 用于简单 chatbot 场景
公开 函数 简单问(代理值: 代理, 提示: 字符串) : 字符串 {
    LLM调用事件(代理值.名字, 提示);
    变量 回复: 字符串 = 大模型.对话(代理值.会话句柄, 提示);
    LLM响应事件(代理值.名字, 回复);
    完成事件(代理值.名字, 回复);
    返回 回复;
}

// 关闭 agent 的会话
公开 函数 关闭代理(代理值: 代理) : 整数 {
    返回 大模型.关闭会话(代理值.会话句柄);
}
