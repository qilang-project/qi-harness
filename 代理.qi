// 代理 — Agent loop
//
// 这是 harness 的核心。底层 大模型::工具对话 / 继续工具对话 让模型在一轮里
// 要么给文本要么给 tool_call；本模块封装那个循环：
//   while assistant_msg.has_tool_call:
//       result = 派发(name, args_json)
//       回写 tool_result
//       assistant_msg = 继续工具对话()
//   return assistant_msg.文本
//
// 加上限步数（避免无限 tool loop）+ trace + retry。

包 Harness;

导入 标准库.字符串;
导入 标准库.大模型 作为 底层模型;
导入 Harness.对话::{助手消息, 解析助手消息, 工具调用ID, 工具调用名, 工具调用参数, 回写工具结果};
导入 Harness.工具::{工具, 注册表, 创建注册表, 注册, 注册MCP工具, 派发};
导入 Harness.MCP客户端::{ MCP列出工具 };
导入 标准库.JSON 作为 J;
导入 Harness.追踪::{LLM调用事件, LLM响应事件, 工具调用事件, 工具结果事件, 错误事件, 完成事件, 流开始事件, 流块事件, 流结束事件};

公开 类型 代理 {
    名字: 字符串,          // trace 用
    会话句柄: 整数,
    工具表: 注册表,
    最大步数: 整数,         // 防 tool 死循环；默认 10
}

公开 函数 创建代理(名字: 字符串, 会话句柄: 整数) : 代理 {
    返回 (代理 {
        名字: 名字,
        会话句柄: 会话句柄,
        工具表: 创建注册表(),
        最大步数: 10,
    });
}

公开 函数 设置最大步数(代理值: 代理, 上限: 整数) : 代理 {
    代理值.最大步数 = 上限;
    返回 代理值;
}

// 注册一个工具到代理上
公开 函数 添加工具(代理值: 代理, 工具值: 工具) : 代理 {
    代理值.工具表 = 注册(代理值.工具表, 代理值.会话句柄, 工具值);
    返回 代理值;
}

// 把一个已连接的 MCP server(连接描述符) 的全部工具装备到代理上。
// 调 tools/list 解析 result.tools[]，逐个注册为 MCP-backed 工具。
公开 函数 装备MCP(代理值: 代理, 连接描述符: 字符串) : 代理 {
    变量 响应行: 字符串 = MCP列出工具(连接描述符);
    变量 响应对象: 整数 = J.解码(响应行);
    如果 (响应对象 <= 0) {
        错误事件(代理值.名字, "MCP tools/list 解析失败");
        返回 代理值;
    }
    变量 结果对象: 整数 = J.获取对象(响应对象, "result");
    变量 工具数组: 整数 = J.获取数组(结果对象, "tools");
    变量 数量: 整数 = J.数组长度(工具数组);
    变量 i: 整数 = 0;
    当 (i < 数量) {
        变量 工具对象: 整数 = J.数组获取对象(工具数组, i);
        变量 名字: 字符串 = J.获取字符串(工具对象, "name");
        变量 描述: 字符串 = J.获取字符串(工具对象, "description");
        变量 schema对象: 整数 = J.获取对象(工具对象, "inputSchema");
        变量 schema串: 字符串 = J.转字符串(schema对象);
        代理值.工具表 = 注册MCP工具(代理值.工具表, 代理值.会话句柄, 名字, 描述, schema串, 连接描述符);
        i = i + 1;
    }
    完成事件(代理值.名字, "装备 MCP 工具 " + 整数转字符串(数量) + " 个");
    返回 代理值;
}

// 跑一轮：用户给 prompt，agent 自动 dispatch tool_call 直到模型给最终文本。
// 返回最终文字回复。
公开 函数 运行(代理值: 代理, 提示: 字符串) : 字符串 {
    LLM调用事件(代理值.名字, 提示);
    变量 原始: 字符串 = 底层模型.工具对话(代理值.会话句柄, 提示);
    变量 消息: 助手消息 = 解析助手消息(代理值.会话句柄, 原始);
    LLM响应事件(代理值.名字, 消息.文本);

    变量 步: 整数 = 0;
    当 (消息.工具调用数 > 0) {
        如果 (步 >= 代理值.最大步数) {
            错误事件(代理值.名字,
                "tool loop 超过 " + 整数转字符串(代理值.最大步数) + " 步上限");
            返回 "[harness] tool 循环达到上限";
        }
        // 派发所有 parallel tool_calls
        变量 索引: 整数 = 0;
        当 (索引 < 消息.工具调用数) {
            变量 工具ID值: 字符串 = 工具调用ID(消息, 索引);
            变量 工具名值: 字符串 = 工具调用名(消息, 索引);
            变量 参数JSON: 字符串 = 工具调用参数(消息, 索引);
            工具调用事件(代理值.名字, 工具名值, 参数JSON);
            变量 返回值: 字符串 = 派发(代理值.工具表, 工具名值, 参数JSON);
            工具结果事件(代理值.名字, 工具名值, 返回值);
            回写工具结果(代理值.会话句柄, 工具ID值, 工具名值, 返回值);
            索引 = 索引 + 1;
        }
        // 未结束
        变量 原始2: 字符串 = 底层模型.继续工具对话(代理值.会话句柄);
        消息 = 解析助手消息(代理值.会话句柄, 原始2);
        LLM响应事件(代理值.名字, 消息.文本);
        步 = 步 + 1;
    }
    完成事件(代理值.名字, 消息.文本);
    返回 消息.文本;
}

// 只跑一次纯对话（不带工具）— 用于简单 chatbot 场景
公开 函数 简单问(代理值: 代理, 提示: 字符串) : 字符串 {
    LLM调用事件(代理值.名字, 提示);
    变量 回复: 字符串 = 底层模型.对话(代理值.会话句柄, 提示);
    LLM响应事件(代理值.名字, 回复);
    完成事件(代理值.名字, 回复);
    返回 回复;
}

// 流式问答 — 每收到一个 chunk 就调 块回调(片段)，
// 同时 emit `stream_chunk` trace 事件，结束后返回拼装好的完整回复。
// 块回调 签名固定 函数(字符串): 整数（返回 1 继续；预留 0 中止位）。
公开 函数 流式问(代理值: 代理, 提示: 字符串, 块回调: 函数(字符串): 整数) : 字符串 {
    流开始事件(代理值.名字, 提示);
    变量 流句柄: 整数 = 底层模型.流式对话(代理值.会话句柄, 提示);
    如果 (流句柄 <= 0) {
        错误事件(代理值.名字, "打开流失败");
        返回 "";
    }
    变量 累积: 字符串 = "";
    变量 未结束: 整数 = 1;
    当 (未结束 == 1) {
        变量 片段: 字符串 = 底层模型.读取流(流句柄);
        如果 (字符串::字节长度(片段) == 0) {
            未结束 = 0;
        } 否则 {
            流块事件(代理值.名字, 片段);
            块回调(片段);
            累积 = 累积 + 片段;
        }
    }
    底层模型.关闭流(流句柄);
    流结束事件(代理值.名字, 累积);
    返回 累积;
}

// 关闭 agent 的会话
公开 函数 关闭代理(代理值: 代理) : 整数 {
    返回 底层模型.关闭会话(代理值.会话句柄);
}
