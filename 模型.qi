// 模型 — provider 抽象 + 会话配置
//
// 设计原则：任何 OpenAI 兼容 API 都通过 LLM(端点, 密钥, 模型) 一行配置完事。
// 不内置 provider 常量 — 端点 URL 跟模型名是真值，用户自己写最清楚。

包 Harness;

导入 标准库.字符串;
// 别名 底层模型 — 避免跟我们公开的 大模型(端点, 密钥, 模型) builder 冲突
导入 标准库.大模型 作为 底层模型;

// ===== 模型配置 =====
公开 类型 模型配置 {
    端点: 字符串,
    模型: 字符串,
    密钥: 字符串,
    系统提示: 字符串,
    温度: 字符串,        // 用字符串而不是 浮点数 — 跟 大模型::设置配置 一致
    最大令牌: 整数,
    超时秒: 整数,
}

// 一站式 builder — 任何 OpenAI 兼容 API 一行配置
//   大模型("https://api.deepseek.com", 密钥, "deepseek-chat")
//   大模型("https://api.openai.com/v1", 密钥, "gpt-4o-mini")
//   大模型("http://127.0.0.1:11434/v1", "ollama", "llama3.1")  // ollama 本地
公开 函数 大模型(端点: 字符串, 密钥: 字符串, 模型: 字符串) : 模型配置 {
    返回 (模型配置 {
        端点: 端点,
        模型: 模型,
        密钥: 密钥,
        系统提示: "",
        温度: "0.7",
        最大令牌: 2048,
        超时秒: 60,
    });
}

// 默认配置 — 给「先建后填」工作流；推荐直接用 大模型(...)
公开 函数 默认配置() : 模型配置 {
    返回 大模型("https://api.openai.com/v1", "", "gpt-4o-mini");
}

公开 函数 配置端点(配置: 模型配置, 端点: 字符串) : 模型配置 {
    配置.端点 = 端点;
    返回 配置;
}

公开 函数 配置模型(配置: 模型配置, 模型: 字符串) : 模型配置 {
    配置.模型 = 模型;
    返回 配置;
}

公开 函数 配置密钥(配置: 模型配置, 密钥: 字符串) : 模型配置 {
    配置.密钥 = 密钥;
    返回 配置;
}

公开 函数 配置系统提示(配置: 模型配置, 提示: 字符串) : 模型配置 {
    配置.系统提示 = 提示;
    返回 配置;
}

公开 函数 配置温度(配置: 模型配置, 温度文本: 字符串) : 模型配置 {
    配置.温度 = 温度文本;
    返回 配置;
}

公开 函数 配置最大令牌(配置: 模型配置, 最大: 整数) : 模型配置 {
    配置.最大令牌 = 最大;
    返回 配置;
}

// ===== 会话生命周期 =====

// 用配置开会话；返回会话句柄（>0），失败返回 0
公开 函数 开启会话(配置: 模型配置) : 整数 {
    变量 句柄: 整数 = 底层模型.创建会话(配置.端点, 配置.模型, 配置.密钥);
    如果 (句柄 <= 0) {
        返回 0;
    }
    // 设置可选配置
    如果 (字符串::字节长度(配置.系统提示) > 0) {
        底层模型.设置配置(句柄, "system", 配置.系统提示);
    }
    如果 (字符串::字节长度(配置.温度) > 0) {
        底层模型.设置配置(句柄, "temperature", 配置.温度);
    }
    如果 (配置.最大令牌 > 0) {
        底层模型.设置配置(句柄, "max_tokens", 整数转字符串(配置.最大令牌));
    }
    返回 句柄;
}

公开 函数 关闭会话Harness(句柄: 整数) : 整数 {
    返回 底层模型.关闭会话(句柄);
}

// 一站式：开会话 + 跑一条 prompt + 关会话。适合 one-shot 场景。
公开 函数 一次对话(配置: 模型配置, 提示: 字符串) : 字符串 {
    变量 句柄: 整数 = 开启会话(配置);
    如果 (句柄 <= 0) {
        返回 "[harness] 会话开启失败";
    }
    变量 回复: 字符串 = 底层模型.对话(句柄, 提示);
    关闭会话Harness(句柄);
    返回 回复;
}
