// 模型 — provider 抽象 + 会话配置
//
// 底层调用大模型 FFI；这层加：
//   - 几个常见 provider 端点常量（OpenAI / Anthropic / 国产）
//   - 配置 builder 模式（温度 / max_tokens / top_p）
//   - 会话池（手动关闭烦人 — 用 创建模型 一站式开启）

包 Harness;

导入 标准库.字符串;
导入 标准库.大模型 作为 大模型;

// ===== Provider 端点常量 =====
公开 函数 OpenAI端点() : 字符串 {
    返回 "https://api.openai.com/v1";
}

公开 函数 Anthropic端点() : 字符串 {
    返回 "https://api.anthropic.com/v1";
}

公开 函数 DeepSeek端点() : 字符串 {
    返回 "https://api.deepseek.com/v1";
}

公开 函数 Moonshot端点() : 字符串 {
    返回 "https://api.moonshot.cn/v1";
}

公开 函数 智谱端点() : 字符串 {
    返回 "https://open.bigmodel.cn/api/paas/v4";
}

公开 函数 本地端点(端口: 整数) : 字符串 {
    // ollama / llama.cpp / vllm 等本地服务
    返回 "http://127.0.0.1:" + 整数转字符串(端口) + "/v1";
}

// ===== 模型配置 =====
公开 类型 模型配置 {
    端点: 字符串,
    模型: 字符串,
    密钥: 字符串,
    系统提示: 字符串,
    温度: 字符串,        // 用字符串而不是 浮点数 — 跟 大模型::设置配置 一致
    最大令牌: 整数,
    超时秒: 整数,
}

公开 函数 默认配置() : 模型配置 {
    返回 (模型配置 {
        端点: OpenAI端点(),
        模型: "gpt-4o-mini",
        密钥: "",
        系统提示: "",
        温度: "0.7",
        最大令牌: 2048,
        超时秒: 60,
    });
}

公开 函数 配置端点(配置: 模型配置, 端点: 字符串) : 模型配置 {
    配置.端点 = 端点;
    返回 配置;
}

公开 函数 配置模型(配置: 模型配置, 模型: 字符串) : 模型配置 {
    配置.模型 = 模型;
    返回 配置;
}

公开 函数 配置密钥(配置: 模型配置, 密钥: 字符串) : 模型配置 {
    配置.密钥 = 密钥;
    返回 配置;
}

公开 函数 配置系统提示(配置: 模型配置, 提示: 字符串) : 模型配置 {
    配置.系统提示 = 提示;
    返回 配置;
}

公开 函数 配置温度(配置: 模型配置, 温度文本: 字符串) : 模型配置 {
    配置.温度 = 温度文本;
    返回 配置;
}

公开 函数 配置最大令牌(配置: 模型配置, 最大: 整数) : 模型配置 {
    配置.最大令牌 = 最大;
    返回 配置;
}

// ===== 会话生命周期 =====

// 用配置开会话；返回会话句柄（>0），失败返回 0
公开 函数 开启会话(配置: 模型配置) : 整数 {
    变量 句柄: 整数 = 大模型.创建会话(配置.端点, 配置.模型, 配置.密钥);
    如果 (句柄 <= 0) {
        返回 0;
    }
    // 设置可选配置
    如果 (字符串::字节长度(配置.系统提示) > 0) {
        大模型.设置配置(句柄, "system", 配置.系统提示);
    }
    如果 (字符串::字节长度(配置.温度) > 0) {
        大模型.设置配置(句柄, "temperature", 配置.温度);
    }
    如果 (配置.最大令牌 > 0) {
        大模型.设置配置(句柄, "max_tokens", 整数转字符串(配置.最大令牌));
    }
    返回 句柄;
}

公开 函数 关闭会话Harness(句柄: 整数) : 整数 {
    返回 大模型.关闭会话(句柄);
}

// 一站式：开会话 + 跑一条 prompt + 关会话。适合 one-shot 场景。
公开 函数 一次对话(配置: 模型配置, 提示: 字符串) : 字符串 {
    变量 句柄: 整数 = 开启会话(配置);
    如果 (句柄 <= 0) {
        返回 "[harness] 会话开启失败";
    }
    变量 回复: 字符串 = 大模型.对话(句柄, 提示);
    关闭会话Harness(句柄);
    返回 回复;
}
