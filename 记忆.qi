// 记忆 — agent 的长期记忆与经验库（SQLite 持久化）
//
// LLM 会话是易失的：进程一退，用户偏好、任务打法全忘。本模块给 harness 一个
// 落盘的记忆层，三种类型约定：
//   "事实" — 用户/世界知识（如「用户在深圳工作」）
//   "经验" — 任务打法（什么有效、什么踩坑，跨任务可复用）
//   "偏好" — 用户偏好（如「回答尽量简短」）
//
// 存储 = 单表 记忆(id 自增主键, 类型, 内容, 关键词, 重要度, 创建, 使用次数)，
// 建表用 IF NOT EXISTS —— 重开旧库不丢数据（持久化升级安全）。
// 回忆 = 逗号分隔的查询关键词逐个 LIKE 匹配 内容+关键词 两列 → 按 重要度 降序、
// 新近（id 降序）排序取前 N（单条 SQL 天然去重）→ 格式化成可直接拼进提示词的
// 文本块（带类型标签），命中条目 使用次数+1（后续可据此做遗忘曲线）。
// 安全 = 所有拼进 SQL 的外部字符串都过 SQL转义（单引号翻倍，qi-todo-web 同款先例），
// 数字一律走 整数转字符串 —— 内容含单引号/伪 SQL 的毒串只会被原样存取，不会改写语句。
//
// 代理集成（启用记忆 / 带记忆运行 / 提炼经验）见 代理.qi；循环收官提炼见 循环.qi。
//
// 用法：
//   导入 Harness.记忆::{打开记忆, 记住, 回忆, 遗忘, 记忆条数, 关闭记忆};
//   变量 库: 整数 = 打开记忆("/tmp/agent记忆.db");
//   记住(库, "偏好", "用户喜欢简短回答", "回答,风格,简短", 4);
//   打印行(回忆(库, "回答,风格", 5));
//   关闭记忆(库);

包 Harness;

导入 标准库.数据库;
导入 标准库.字符串;
导入 标准库.时间 作为 时间;
导入 标准库.JSON 作为 J;
导入 标准库.列表 作为 列表库;

// SQL 转义（单引号翻倍）—— 拼 SQL 的唯一入口，防注入
函数 SQL转义(原文: 字符串) : 字符串 {
    返回 字符串::替换(原文, "'", "''");
}

// 打开/建库。表不存在则建（IF NOT EXISTS，重开不丢数据）。
// 返回库句柄（>0）；失败返回 0。
公开 函数 打开记忆(库路径: 字符串) : 整数 {
    变量 库: 整数 = 数据库.连接(库路径);
    如果 (库 <= 0) { 返回 0; }
    数据库.执行(库, "CREATE TABLE IF NOT EXISTS 记忆 ("
        + "id INTEGER PRIMARY KEY AUTOINCREMENT, "
        + "类型 TEXT NOT NULL, "
        + "内容 TEXT NOT NULL, "
        + "关键词 TEXT NOT NULL DEFAULT '', "
        + "重要度 INTEGER NOT NULL DEFAULT 3, "
        + "创建 TEXT NOT NULL DEFAULT '', "
        + "使用次数 INTEGER NOT NULL DEFAULT 0)");
    返回 库;
}

// 存一条记忆。种类 ∈ {"事实","经验","偏好"}（约定，不强校验）；
// 关键词逗号分隔；重要度越大越优先被回忆。返回新条目 id；失败返回 0。
公开 函数 记住(库: 整数, 种类: 字符串, 内容: 字符串, 关键词: 字符串, 重要度: 整数) : 整数 {
    如果 (库 <= 0) { 返回 0; }
    变量 现: 字符串 = 时间.格式化本地(时间.现在(), "%Y-%m-%d %H:%M:%S");
    变量 影响: 整数 = 数据库.执行(库,
        "INSERT INTO 记忆 (类型, 内容, 关键词, 重要度, 创建, 使用次数) VALUES ('"
        + SQL转义(种类) + "', '" + SQL转义(内容) + "', '" + SQL转义(关键词) + "', "
        + 整数转字符串(重要度) + ", '" + 现 + "', 0)");
    如果 (影响 <= 0) { 返回 0; }
    变量 行JSON: 字符串 = 数据库.查询(库, "SELECT last_insert_rowid() AS id");
    变量 数组值: 整数 = J.解码(行JSON);
    如果 (数组值 <= 0) { 返回 0; }
    如果 (J.数组长度(数组值) == 0) { 返回 0; }
    返回 J.获取整数(J.数组获取对象(数组值, 0), "id");
}

// 按关键词回忆。查询关键词逗号分隔（中英文逗号都认），逐词 LIKE 匹配
// 内容 与 关键词 两列，按 重要度 降序 + 新近（id 降序）取前 上限 条。
// 返回可直接注入提示词的文本块（每行 -【类型】内容）；无命中返回 ""。
// 命中条目 使用次数+1。
公开 函数 回忆(库: 整数, 查询关键词: 字符串, 上限: 整数) : 字符串 {
    如果 (库 <= 0) { 返回 ""; }
    变量 条数上限: 整数 = 上限;
    如果 (条数上限 <= 0) { 条数上限 = 5; }

    // 拆词：中文逗号归一成英文逗号再分割，逐词去空白，拼 OR 条件
    变量 规整: 字符串 = 字符串::替换(查询关键词, "，", ",");
    变量 词表: 整数 = 字符串::分割(规整, ",");
    变量 词数: 整数 = 列表库::字符串列表大小(词表);
    变量 条件: 字符串 = "";
    变量 有条件: 整数 = 0;
    变量 i: 整数 = 0;
    当 (i < 词数) {
        变量 词: 字符串 = 字符串::去空白(列表库::获取字符串(词表, i));
        如果 (字符串::字节长度(词) > 0) {
            如果 (有条件 == 1) { 条件 = 条件 + " OR "; }
            变量 安全词: 字符串 = SQL转义(词);
            条件 = 条件 + "内容 LIKE '%" + 安全词 + "%' OR 关键词 LIKE '%" + 安全词 + "%'";
            有条件 = 1;
        }
        i = i + 1;
    }
    如果 (有条件 == 0) { 返回 ""; }

    变量 行JSON: 字符串 = 数据库.查询(库,
        "SELECT id, 类型, 内容 FROM 记忆 WHERE (" + 条件
        + ") ORDER BY 重要度 DESC, id DESC LIMIT " + 整数转字符串(条数上限));
    变量 数组值: 整数 = J.解码(行JSON);
    如果 (数组值 <= 0) { 返回 ""; }
    变量 命中数: 整数 = J.数组长度(数组值);
    如果 (命中数 == 0) { 返回 ""; }

    // 格式化文本块 + 收集命中 id（数字自拼，安全）
    变量 块: 字符串 = "";
    变量 id串: 字符串 = "";
    变量 k: 整数 = 0;
    当 (k < 命中数) {
        变量 行对象: 整数 = J.数组获取对象(数组值, k);
        如果 (k > 0) {
            块 = 块 + "\n";
            id串 = id串 + ",";
        }
        块 = 块 + "-【" + J.获取字符串(行对象, "类型") + "】" + J.获取字符串(行对象, "内容");
        id串 = id串 + 整数转字符串(J.获取整数(行对象, "id"));
        k = k + 1;
    }
    数据库.执行(库, "UPDATE 记忆 SET 使用次数 = 使用次数 + 1 WHERE id IN (" + id串 + ")");
    返回 块;
}

// 删掉一条记忆。返回删除条数（0 = 没这条）。
公开 函数 遗忘(库: 整数, 记忆id: 整数) : 整数 {
    如果 (库 <= 0) { 返回 0; }
    返回 数据库.执行(库, "DELETE FROM 记忆 WHERE id = " + 整数转字符串(记忆id));
}

// 库里的记忆总条数
公开 函数 记忆条数(库: 整数) : 整数 {
    如果 (库 <= 0) { 返回 0; }
    变量 行JSON: 字符串 = 数据库.查询(库, "SELECT COUNT(*) AS 条数 FROM 记忆");
    变量 数组值: 整数 = J.解码(行JSON);
    如果 (数组值 <= 0) { 返回 0; }
    如果 (J.数组长度(数组值) == 0) { 返回 0; }
    返回 J.获取整数(J.数组获取对象(数组值, 0), "条数");
}

// 关闭记忆库连接。成功返回 1。
公开 函数 关闭记忆(库: 整数) : 整数 {
    如果 (库 <= 0) { 返回 0; }
    数据库.关闭(库);
    返回 1;
}
