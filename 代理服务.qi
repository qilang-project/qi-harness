// 代理服务 — 把 代理 变成常驻 HTTP agent 服务（代理 × qi-web 打通）。
//
// 别的语言框架给不了这个组合：qilang 自带 122k RPS 的 web 框架，harness 的 代理
// 直接挂上去就是一个能上线、带多轮会话的 agent 服务，无需另起 Python/Node 服务层。
//
// 路由（路径只能 ASCII，内容随意中文）：
//   POST /chat    body {"提示":"...","会话号":N?}  → {"会话号":N,"回复":"...","已用":tokens}
//                 会话号>0 复用该会话（多轮记忆——runtime 会话池整进程存活）；缺省/≤0 新建。
//   GET  /health                                   → {"状态":"ok","模型":"..."}
//   POST /json    body {"提示":"...","字段":"a,b"} → 结构化：强约束模型只输出含这些字段的 JSON
//
// 用法：
//   导入 Harness.代理服务::{配置服务, 启动代理服务};
//   函数 入口() {
//       配置服务(系统.获取环境变量("QI_CHAT_URL"), 系统.获取环境变量("QI_CHAT_KEY"),
//                系统.获取环境变量("QI_CHAT_MODEL"), "你是简洁的中文助手。");
//       启动代理服务("127.0.0.1", 6798);   // 阻塞常驻
//   }
//
// 会话生命周期：多轮对话靠客户端回传 会话号（= runtime LLM 会话句柄，整进程存活）。
// 无状态单轮：客户端每次不传 会话号 即可（每次新建、答完即弃，句柄留在池里但不复用）。

包 Harness;

导入 标准库.字符串;
导入 标准库.JSON 作为 J;
导入 标准库.列表 作为 列表库;
导入 标准库.大模型 作为 底层模型;

导入 Web::{
    应用, 上下文, 响应,
    创建应用, 配置, 获取, 提交,
    请求主体, JSON,
    运行应用
};

导入 Harness.代理::{代理, 创建代理, 简单问, 结构化运行, 添加工具, 关闭代理};
导入 Harness.工具::{工具};

// ── 模块级服务配置（启动时写一次，各 handler 只读）──
// 全局串跨函数读写已验证可靠（RC 0）。
变量 服务端点: 字符串 = "";
变量 服务密钥: 字符串 = "";
变量 服务模型: 字符串 = "";
变量 服务系统: 字符串 = "";
// 服务级工具：注册后每个新建会话都装备（会话号复用时沿用其已装工具）。
变量 服务工具数: 整数 = 0;
变量 服务工具表: 整数 = 0;   // 标准库.列表 指针列表句柄；0=未初始化

// 配置服务模型（端点/密钥/模型/系统提示）。启动前调用。
公开 函数 配置服务(端点: 字符串, 密钥: 字符串, 模型: 字符串, 系统提示: 字符串) {
    服务端点 = 端点;
    服务密钥 = 密钥;
    服务模型 = 模型;
    服务系统 = 系统提示;
}

// 按服务配置新建一个会话（含系统提示注入）。返回会话句柄。
函数 新建服务会话() : 整数 {
    变量 会话: 整数 = 底层模型.创建会话(服务端点, 服务模型, 服务密钥);
    如果 (字符串::字节长度(服务系统) > 0) {
        底层模型.设置配置(会话, "system", 服务系统);
    }
    返回 会话;
}

// 取或建会话：会话号>0 视为已有 runtime 会话句柄直接复用（多轮）；否则新建。
函数 取会话(会话号: 整数) : 整数 {
    如果 (会话号 > 0) {
        返回 会话号;
    }
    返回 新建服务会话();
}

// 构 JSON 响应对象 → 字符串（用 J 构建，绝不手拼——手拼会被回复里的引号/换行破坏）。
函数 应答(会话号: 整数, 回复: 字符串) : 字符串 {
    变量 出: 整数 = J.创建对象();
    J.设置整数(出, "会话号", 会话号);
    J.设置字符串(出, "回复", 回复);
    变量 s: 字符串 = J.转字符串(出);
    J.删除(出);
    返回 s;
}

函数 错误应答(消息: 字符串) : 字符串 {
    变量 出: 整数 = J.创建对象();
    J.设置字符串(出, "错误", 消息);
    变量 s: 字符串 = J.转字符串(出);
    J.删除(出);
    返回 s;
}

// POST /chat —— 多轮对话。body {"提示":"...","会话号":N?}
函数 对话处理器(上下文值: 上下文) : 响应 {
    变量 主体: 字符串 = 请求主体(上下文值);
    变量 o: 整数 = J.解码(主体);
    如果 (o <= 0) {
        返回 JSON(错误应答("请求体不是合法 JSON"));
    }
    变量 提示: 字符串 = J.获取字符串(o, "提示");
    变量 入会话号: 整数 = J.获取整数(o, "会话号");
    J.删除(o);
    如果 (字符串::字节长度(提示) == 0) {
        返回 JSON(错误应答("缺少 提示 字段"));
    }

    变量 会话号: 整数 = 取会话(入会话号);
    变量 代理值: 代理 = 创建代理("服务代理", 会话号);
    装备服务工具(代理值);
    变量 回复: 字符串 = 简单问(代理值, 提示);
    返回 JSON(应答(会话号, 回复));
}

// POST /json —— 结构化输出。body {"提示":"...","字段":"城市,人口"}
函数 结构化处理器(上下文值: 上下文) : 响应 {
    变量 主体: 字符串 = 请求主体(上下文值);
    变量 o: 整数 = J.解码(主体);
    如果 (o <= 0) {
        返回 JSON(错误应答("请求体不是合法 JSON"));
    }
    变量 提示: 字符串 = J.获取字符串(o, "提示");
    变量 字段串: 字符串 = J.获取字符串(o, "字段");
    变量 入会话号: 整数 = J.获取整数(o, "会话号");
    J.删除(o);
    如果 (字符串::字节长度(提示) == 0) {
        返回 JSON(错误应答("缺少 提示 字段"));
    }

    变量 会话号: 整数 = 取会话(入会话号);
    变量 代理值: 代理 = 创建代理("服务代理", 会话号);
    // 必需字段列表：把逗号分隔的字段串拆进字符串列表
    变量 字段表: 整数 = 拆字段(字段串);
    变量 结果值: 字符串 = 结构化运行(代理值, 提示, 字段表);
    返回 JSON(应答(会话号, 结果值));
}

// GET /health
函数 健康处理器(上下文值: 上下文) : 响应 {
    变量 出: 整数 = J.创建对象();
    J.设置字符串(出, "状态", "ok");
    J.设置字符串(出, "模型", 服务模型);
    变量 s: 字符串 = J.转字符串(出);
    J.删除(出);
    返回 JSON(s);
}

// 逗号分隔字段串 → 标准库.列表 字符串列表句柄（供 结构化运行 的必需字段参数）。
函数 拆字段(字段串: 字符串) : 整数 {
    变量 表: 整数 = 列表库::创建字符串列表();
    变量 段: 整数 = 字符串::分割(字段串, ",");
    变量 n: 整数 = 列表库::字符串列表大小(段);
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 f: 字符串 = 字符串::去空白(列表库::获取字符串(段, i));
        如果 (字符串::字节长度(f) > 0) {
            列表库::添加字符串(表, f);
        }
        i = i + 1;
    }
    返回 表;
}

// 给会话装备服务级工具（若注册过）。
函数 装备服务工具(代理值: 代理) {
    如果 (服务工具数 <= 0) {
        返回;
    }
    变量 i: 整数 = 0;
    当 (i < 服务工具数) {
        变量 t: 工具 = 列表库::获取指针(服务工具表, i);
        添加工具(代理值, t);
        i = i + 1;
    }
}

// 注册一个服务级工具（所有新会话都装备）。启动前调用。
公开 函数 服务注册工具(工具值: 工具) {
    如果 (服务工具表 == 0) {
        服务工具表 = 列表库::创建指针列表();
    }
    列表库::添加指针(服务工具表, 工具值);
    服务工具数 = 服务工具数 + 1;
}

// 启动常驻 agent 服务（阻塞）。
公开 函数 启动代理服务(主机: 字符串, 端口: 整数) {
    变量 应用值: 应用 = 创建应用();
    应用值 = 配置(应用值, 主机, 端口);
    应用值 = 提交(应用值, "/chat", 对话处理器);
    应用值 = 提交(应用值, "/json", 结构化处理器);
    应用值 = 获取(应用值, "/health", 健康处理器);
    运行应用(应用值);
}
