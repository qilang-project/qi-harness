// 代理服务 — 把 代理 变成常驻 HTTP agent 服务（代理 × qi-web 打通）。
//
// 别的语言框架给不了这个组合：qilang 自带 122k RPS 的 web 框架，harness 的 代理
// 直接挂上去就是一个能上线、带多轮会话的 agent 服务，无需另起 Python/Node 服务层。
//
// 路由（路径只能 ASCII，内容随意中文）：
//   POST /chat    持久模式 body {"提示":"...","会话ID":"..."?}
//                 → {"会话ID":"...","回复":"..."}
//                 注册过服务工具时走 agent tool loop；未注册工具时保持一次纯对话。
//                 未传 会话ID 时创建；传入未知 ID 时拒绝，不会按客户端指定值创建。
//                 仅显式匿名开发模式可在未配置持久化时保留旧协议
//                 {"会话号":N?} → {"会话号":N,...}；Bearer 认证始终拒绝 raw handle。
//   GET  /health                                   → {"状态":"ok","模型":"..."}
//   POST /json    body {"提示":"...","字段":"a,b"} → 结构化：强约束模型只输出含这些字段的 JSON
//                 始终走结构化输出，不装备或执行服务工具。
//
// 用法：
//   导入 Harness.代理服务::{配置服务, 启动代理服务};
//   函数 入口() {
//       配置服务(系统.获取环境变量("QI_CHAT_URL"), 系统.获取环境变量("QI_CHAT_KEY"),
//                系统.获取环境变量("QI_CHAT_MODEL"), "你是简洁的中文助手。");
//       启动代理服务("127.0.0.1", 6798);   // 阻塞常驻
//   }
//
// 持久模式每次请求都新建 runtime 会话，从 SQLite 恢复后执行，响应只暴露不透明 UUID。
// 旧 runtime 整数句柄协议只在显式匿名开发且未配置持久化时启用。

包 Harness;

导入 标准库.字符串;
导入 标准库.JSON 作为 J;
导入 标准库.列表 作为 列表库;
导入 标准库.哈希表 作为 哈希表;
导入 标准库.大模型 作为 底层模型;
导入 标准库.数据库;
导入 标准库.随机 作为 随机;
导入 标准库.时间;
导入 标准库.输入输出 作为 IO;
导入 标准库.同步 作为 同步;

导入 Web::{
    应用, 上下文, 响应,
    创建应用, 配置, 获取, 提交,
    请求主体, 请求头, JSON,
    限制请求大小, 运行应用
};

导入 Harness.代理::{代理, 创建代理, 运行, 简单问, 结构化运行, 添加工具, 关闭代理,
    附加会话存储, 附加会话写栅栏, 恢复持久会话};
导入 Harness.工具::{工具};
导入 Harness.会话存储::{打开会话存储, 关闭会话存储, 创建持久会话, 会话存在,
    当前会话叶, 按写栅栏及期望叶追加会话条目, 回退未完成写栅栏请求};
导入 Harness.安全上下文::{安全上下文, 安全上下文配置, 可信适配器创建安全上下文,
    安全上下文有效, 安全上下文未过期, 安全上下文主体ID, 安全上下文租户ID,
    安全上下文具有角色, 安全上下文具有权限, 安全上下文请求配额,
    安全审计决定信封, 释放安全上下文};

// ── 模块级服务配置（启动时写一次，各 handler 只读）──
// 全局串跨函数读写已验证可靠（RC 0）。
变量 服务端点: 字符串 = "";
变量 服务密钥: 字符串 = "";
变量 服务模型: 字符串 = "";
变量 服务系统: 字符串 = "";
变量 服务会话库: 整数 = 0;       // >0 = 持久模式；0 = 隔离的旧 runtime 句柄模式
变量 服务配额库: 整数 = 0;       // 独立于持久会话库；认证配置后必须可用
变量 服务安全上下文锁: 整数 = 0;
变量 服务活跃会话表: 整数 = 0;
变量 服务最大主体字节: 整数 = 1048576;
变量 服务最大提示字节: 整数 = 262144;
变量 服务认证令牌表: 整数 = 0;
变量 服务认证主体表: 整数 = 0;
变量 服务认证租户表: 整数 = 0;
变量 服务认证角色表: 整数 = 0;
变量 服务认证权限表: 整数 = 0;
变量 服务认证到期表: 整数 = 0;
变量 服务认证请求配额表: 整数 = 0;
变量 服务认证并发配额表: 整数 = 0;
变量 服务允许匿名开发: 整数 = 0;
变量 服务匿名开发租户: 字符串 = "";
变量 服务匿名开发请求配额: 整数 = 0;
变量 服务匿名开发并发配额: 整数 = 0;
变量 服务配额窗口毫秒: 整数 = 60000;
变量 服务审计路径: 字符串 = "";
// 模型调用显式限制为 60 秒；会话租约留出 5 倍余量，并在模型运行前后续租。
// 工具处理没有可抢占回调，因此若整个工具循环超过租约，完成时的栅栏校验会拒绝旧请求。
变量 服务模型请求超时秒: 整数 = 60;
变量 服务会话租约毫秒: 整数 = 300000;
// 服务级工具：注册后每个新建会话都装备（会话号复用时沿用其已装工具）。
变量 服务工具数: 整数 = 0;
变量 服务工具表: 整数 = 0;   // 标准库.列表 指针列表句柄；0=未初始化

函数 标记活跃服务会话(会话ID: 字符串, 所有者令牌: 字符串) {
    同步.加锁(服务安全上下文锁);
    哈希表::设置字符串(服务活跃会话表, 会话ID, 所有者令牌);
    同步.解锁(服务安全上下文锁);
}

函数 活跃服务会话所有者(会话ID: 字符串) : 字符串 {
    同步.加锁(服务安全上下文锁);
    变量 所有者: 字符串 = 哈希表::获取字符串(服务活跃会话表, 会话ID);
    同步.解锁(服务安全上下文锁);
    返回 所有者;
}

函数 清理活跃服务会话(会话ID: 字符串, 所有者令牌: 字符串) {
    同步.加锁(服务安全上下文锁);
    如果 (字符串::等于(哈希表::获取字符串(服务活跃会话表, 会话ID), 所有者令牌) == 1) {
        哈希表::设置字符串(服务活跃会话表, 会话ID, "");
    }
    同步.解锁(服务安全上下文锁);
}

// 配置服务模型（端点/密钥/模型/系统提示）。启动前调用。
公开 函数 配置服务(端点: 字符串, 密钥: 字符串, 模型: 字符串, 系统提示: 字符串) {
    服务端点 = 端点;
    服务密钥 = 密钥;
    服务模型 = 模型;
    服务系统 = 系统提示;
}

// 主体上限同时配置 Web 传输层；提示上限仍由应用层在 JSON 解码后独立执行。
// 非正数保持现有上限。提示上限不得超过主体上限。
公开 函数 配置服务请求上限(最大主体字节: 整数, 最大提示字节: 整数) : 整数 {
    如果 (最大主体字节 <= 0 || 最大提示字节 <= 0 || 最大提示字节 > 最大主体字节) { 返回 0; }
    服务最大主体字节 = 最大主体字节;
    服务最大提示字节 = 最大提示字节;
    返回 1;
}

公开 函数 配置服务会话租约(租约毫秒: 整数) : 整数 {
    如果 (租约毫秒 <= 0) { 返回 0; }
    服务会话租约毫秒 = 租约毫秒;
    返回 1;
}

函数 确保服务认证表() {
    如果 (服务认证令牌表 != 0) { 返回; }
    服务认证令牌表 = 列表库::创建字符串列表();
    服务认证主体表 = 列表库::创建字符串列表();
    服务认证租户表 = 列表库::创建字符串列表();
    服务认证角色表 = 列表库::创建字符串列表();
    服务认证权限表 = 列表库::创建字符串列表();
    服务认证到期表 = 列表库::创建整数列表();
    服务认证请求配额表 = 列表库::创建整数列表();
    服务认证并发配额表 = 列表库::创建整数列表();
}

函数 确保服务配额库() : 整数 {
    如果 (服务配额库 > 0) { 返回 1; }
    变量 库: 整数 = 数据库.连接(":memory:");
    如果 (库 <= 0) { 返回 0; }
    如果 (数据库.执行(库, "CREATE TABLE IF NOT EXISTS 服务安全配额 ("
        + "主体ID TEXT NOT NULL, 租户ID TEXT NOT NULL, 窗口开始 INTEGER NOT NULL, "
        + "请求数 INTEGER NOT NULL, 并发数 INTEGER NOT NULL, PRIMARY KEY (主体ID, 租户ID))") < 0) {
        数据库.关闭(库);
        返回 0;
    }
    服务配额库 = 库;
    返回 1;
}

函数 服务字符串索引(表: 整数, 值: 字符串) : 整数 {
    变量 i: 整数 = 0;
    当 (i < 列表库::字符串列表大小(表)) {
        如果 (字符串::等于(列表库::获取字符串(表, i), 值) == 1) { 返回 i; }
        i = i + 1;
    }
    返回 0 - 1;
}

// 静态 Bearer 映射是确定性基线适配器；身份字段只在服务启动配置中出现。
公开 函数 配置服务静态Bearer(令牌: 字符串, 主体ID: 字符串, 租户ID: 字符串,
                         角色: 字符串, 权限: 字符串, 到期毫秒: 整数,
                         请求配额: 整数, 并发运行配额: 整数) : 整数 {
    如果 (字符串::字节长度(令牌) == 0 || 字符串::字节长度(主体ID) == 0
        || 字符串::字节长度(租户ID) == 0 || 字符串::字节长度(权限) == 0
        || 请求配额 <= 0 || 并发运行配额 <= 0) { 返回 0; }
    如果 (确保服务配额库() == 0) { 返回 0; }
    确保服务认证表();
    如果 (服务字符串索引(服务认证令牌表, 令牌) >= 0) { 返回 0; }
    列表库::添加字符串(服务认证令牌表, 令牌);
    列表库::添加字符串(服务认证主体表, 主体ID);
    列表库::添加字符串(服务认证租户表, 租户ID);
    列表库::添加字符串(服务认证角色表, 角色);
    列表库::添加字符串(服务认证权限表, 权限);
    列表库::添加整数(服务认证到期表, 到期毫秒);
    列表库::添加整数(服务认证请求配额表, 请求配额);
    列表库::添加整数(服务认证并发配额表, 并发运行配额);
    返回 1;
}

// 仅供本地开发和测试显式启用；生产默认始终要求可信认证适配器。
公开 函数 配置服务匿名开发模式(启用: 整数, 租户ID: 字符串,
                             请求配额: 整数, 并发运行配额: 整数) : 整数 {
    服务允许匿名开发 = 0;
    如果 (启用 != 1) { 返回 1; }
    如果 (字符串::字节长度(租户ID) == 0 || 请求配额 <= 0 || 并发运行配额 <= 0) { 返回 0; }
    如果 (确保服务配额库() == 0) { 返回 0; }
    服务匿名开发租户 = 租户ID;
    服务匿名开发请求配额 = 请求配额;
    服务匿名开发并发配额 = 并发运行配额;
    服务允许匿名开发 = 1;
    返回 1;
}

公开 函数 配置服务安全记录(审计JSONL路径: 字符串, 配额窗口毫秒: 整数) : 整数 {
    如果 (配额窗口毫秒 <= 0) { 返回 0; }
    服务审计路径 = 审计JSONL路径;
    服务配额窗口毫秒 = 配额窗口毫秒;
    返回 1;
}

// 启用服务持久会话。默认所有者参数仅为旧调用签名保留，不参与 HTTP 身份解析；
// 会话租户始终来自服务端创建的安全上下文。
公开 函数 配置服务持久会话(SQLite路径: 字符串, 默认所有者: 字符串) : 整数 {
    如果 (服务会话库 > 0) {
        关闭会话存储(服务会话库);
        服务会话库 = 0;
    }
    如果 (字符串::字节长度(SQLite路径) == 0) { 返回 0; }
    变量 库: 整数 = 打开会话存储(SQLite路径);
    如果 (库 <= 0) { 返回 0; }
    如果 (数据库.执行(库, "CREATE TABLE IF NOT EXISTS 服务会话所有者 ("
        + "会话ID TEXT PRIMARY KEY, 所有者 TEXT NOT NULL)") < 0
        || 数据库.执行(库, "CREATE TABLE IF NOT EXISTS 服务会话请求锁 ("
        + "会话ID TEXT PRIMARY KEY, 所有者令牌 TEXT NOT NULL, "
        + "租约到期毫秒 INTEGER NOT NULL, 栅栏 INTEGER NOT NULL)") < 0) {
        关闭会话存储(库);
        返回 0;
    }
    变量 锁列: 整数 = J.解码(数据库.查询(库, "PRAGMA table_info('服务会话请求锁')"));
    变量 有租约列: 整数 = 0;
    变量 列索引: 整数 = 0;
    当 (锁列 > 0 && 列索引 < J.数组长度(锁列)) {
        如果 (字符串::等于(J.获取字符串(J.数组获取对象(锁列, 列索引), "name"),
            "所有者令牌") == 1) { 有租约列 = 1; }
        列索引 = 列索引 + 1;
    }
    如果 (锁列 > 0) { J.删除(锁列); }
    // 旧版永久锁迁移成已过期租约；首次请求可立即栅栏接管。
    如果 (有租约列 == 0) {
        如果 (数据库.执行(库, "BEGIN IMMEDIATE") < 0
            || 数据库.执行(库, "DROP TABLE IF EXISTS 服务会话请求锁_租约迁移") < 0
            || 数据库.执行(库, "CREATE TABLE 服务会话请求锁_租约迁移 ("
                + "会话ID TEXT PRIMARY KEY, 所有者令牌 TEXT NOT NULL, "
                + "租约到期毫秒 INTEGER NOT NULL, 栅栏 INTEGER NOT NULL)") < 0
            || 数据库.执行(库, "INSERT INTO 服务会话请求锁_租约迁移 "
                + "(会话ID, 所有者令牌, 租约到期毫秒, 栅栏) "
                + "SELECT 会话ID, 锁令牌, 0, 0 FROM 服务会话请求锁") < 0
            || 数据库.执行(库, "DROP TABLE 服务会话请求锁") < 0
            || 数据库.执行(库, "ALTER TABLE 服务会话请求锁_租约迁移 "
                + "RENAME TO 服务会话请求锁") < 0
            || 数据库.执行(库, "COMMIT") < 0) {
            数据库.执行(库, "ROLLBACK");
            关闭会话存储(库);
            返回 0;
        }
    }
    变量 表检查: 整数 = J.解码(数据库.查询(库,
        "SELECT name FROM sqlite_master WHERE type = 'table' "
        + "AND name IN ('服务会话所有者', '服务会话请求锁')"));
    如果 (表检查 <= 0 || J.数组长度(表检查) != 2) {
        关闭会话存储(库);
        返回 0;
    }
    J.删除(表检查);
    服务会话库 = 库;
    返回 1;
}

// 按服务配置新建一个会话（含系统提示注入）。返回会话句柄。
函数 新建服务会话() : 整数 {
    变量 会话: 整数 = 底层模型.创建会话(服务端点, 服务模型, 服务密钥);
    如果 (会话 > 0) {
        底层模型.设置配置(会话, "timeout_secs", 整数转字符串(服务模型请求超时秒));
    }
    如果 (会话 > 0 && 字符串::字节长度(服务系统) > 0) {
        底层模型.设置配置(会话, "system", 服务系统);
    }
    返回 会话;
}

// 旧模式专用：会话号>0 视为已有 runtime 会话句柄直接复用；否则新建。
函数 取旧会话(会话号: 整数) : 整数 {
    如果 (会话号 > 0) {
        返回 会话号;
    }
    返回 新建服务会话();
}

函数 服务SQL文本(原文: 字符串) : 字符串 {
    返回 "'" + 字符串::替换(原文, "'", "''") + "'";
}

函数 是十六进制字符(字符值: 字符串) : 整数 {
    如果 (字符串::包含("0123456789abcdefABCDEF", 字符值) == 1) { 返回 1; }
    返回 0;
}

// 服务只签发规范 UUID，拒绝任意文本进入持久会话查询。
函数 是有效服务会话ID(会话ID: 字符串) : 整数 {
    如果 (字符串::字节长度(会话ID) != 36) { 返回 0; }
    变量 i: 整数 = 0;
    当 (i < 36) {
        变量 字符值: 字符串 = 字符串::子串(会话ID, i, 1);
        如果 (i == 8 || i == 13 || i == 18 || i == 23) {
            如果 (字符串::等于(字符值, "-") == 0) { 返回 0; }
        } 否则 {
            如果 (是十六进制字符(字符值) == 0) { 返回 0; }
        }
        i = i + 1;
    }
    返回 1;
}

// 1=匹配，0=不匹配或服务映射缺失。调用方统一响应，避免枚举会话所有者。
函数 校验会话所有者(会话ID: 字符串, 所有者: 字符串) : 整数 {
    变量 行集: 整数 = J.解码(数据库.查询(服务会话库,
        "SELECT 所有者 FROM 服务会话所有者 WHERE 会话ID = " + 服务SQL文本(会话ID)));
    如果 (行集 <= 0 || J.数组长度(行集) == 0) { 返回 0; }
    变量 已绑定: 字符串 = J.获取字符串(J.数组获取对象(行集, 0), "所有者");
    如果 (字符串::等于(已绑定, 所有者) == 1) { 返回 1; }
    返回 0;
}

函数 创建服务持久会话并加锁(所有者: 字符串, 所有者令牌: 字符串) : 字符串 {
    变量 会话ID: 字符串 = 随机.UUID();
    如果 (数据库.执行(服务会话库, "BEGIN IMMEDIATE") < 0) { 返回 ""; }
    如果 (创建持久会话(服务会话库, 会话ID) <= 0) {
        数据库.执行(服务会话库, "ROLLBACK");
        返回 "";
    }
    变量 写所有者: 整数 = 数据库.执行(服务会话库,
        "INSERT INTO 服务会话所有者 (会话ID, 所有者) VALUES ("
        + 服务SQL文本(会话ID) + ", " + 服务SQL文本(所有者) + ")");
    如果 (写所有者 <= 0) {
        数据库.执行(服务会话库, "ROLLBACK");
        返回 "";
    }
    变量 写锁: 整数 = 数据库.执行(服务会话库,
        "INSERT INTO 服务会话请求锁 (会话ID, 所有者令牌, 租约到期毫秒, 栅栏) VALUES ("
        + 服务SQL文本(会话ID) + ", " + 服务SQL文本(所有者令牌) + ", "
        + 整数转字符串(时间.当前毫秒() + 服务会话租约毫秒) + ", 1)");
    如果 (写锁 <= 0) {
        数据库.执行(服务会话库, "ROLLBACK");
        返回 "";
    }
    如果 (数据库.执行(服务会话库, "COMMIT") < 0) {
        数据库.执行(服务会话库, "ROLLBACK");
        返回 "";
    }
    标记活跃服务会话(会话ID, 所有者令牌);
    返回 会话ID;
}

函数 获取服务会话锁(会话ID: 字符串, 所有者令牌: 字符串) : 整数 {
    变量 现: 整数 = 时间.当前毫秒();
    // 进程内 handler 可能已越过租约但仍在执行外部副作用。此时禁止接管；
    // 进程崩溃后该内存标记自然消失，持久租约恢复路径仍可接管。
    如果 (字符串::字节长度(活跃服务会话所有者(会话ID)) > 0) { 返回 0; }
    如果 (数据库.执行(服务会话库, "BEGIN IMMEDIATE") < 0) { 返回 0 - 1; }
    变量 行集: 整数 = J.解码(数据库.查询(服务会话库,
        "SELECT 所有者令牌 AS owner, 租约到期毫秒 AS expires, 栅栏 AS fence "
        + "FROM 服务会话请求锁 WHERE 会话ID = " + 服务SQL文本(会话ID)));
    如果 (行集 <= 0 || J.数组长度(行集) == 0) {
        如果 (行集 > 0) { J.删除(行集); }
        变量 新写: 整数 = 数据库.执行(服务会话库,
            "INSERT INTO 服务会话请求锁 (会话ID, 所有者令牌, 租约到期毫秒, 栅栏) VALUES ("
            + 服务SQL文本(会话ID) + ", " + 服务SQL文本(所有者令牌) + ", "
            + 整数转字符串(现 + 服务会话租约毫秒) + ", 1)");
        如果 (新写 != 1 || 数据库.执行(服务会话库, "COMMIT") < 0) {
            数据库.执行(服务会话库, "ROLLBACK");
            返回 0 - 1;
        }
        标记活跃服务会话(会话ID, 所有者令牌);
        返回 1;
    }
    变量 旧行: 整数 = J.数组获取对象(行集, 0);
    变量 旧所有者: 字符串 = J.获取字符串(旧行, "owner");
    变量 旧到期: 整数 = J.获取整数(旧行, "expires");
    变量 旧栅栏: 整数 = J.获取整数(旧行, "fence");
    J.删除(行集);
    如果 (旧到期 > 现) {
        数据库.执行(服务会话库, "ROLLBACK");
        返回 0;
    }
    // 一旦未完成分支已经持久记录 tool_calls，外部副作用可能正在执行或已执行。
    // 该边界跨进程持久化，不能自动接管或重放；必须由人工对账后处理。
    变量 工具边界: 整数 = J.解码(数据库.查询(服务会话库,
        "WITH RECURSIVE 当前分支(序号, 条目ID, 父条目ID, 类型, 载荷JSON) AS ("
        + "SELECT e.序号, e.条目ID, e.父条目ID, e.类型, e.载荷JSON FROM 会话条目 e "
        + "JOIN 持久会话 s ON s.会话ID = e.会话ID AND s.当前叶 = e.条目ID "
        + "WHERE e.会话ID = " + 服务SQL文本(会话ID)
        + " UNION ALL SELECT p.序号, p.条目ID, p.父条目ID, p.类型, p.载荷JSON "
        + "FROM 会话条目 p JOIN 当前分支 c ON p.条目ID = c.父条目ID "
        + "WHERE p.会话ID = " + 服务SQL文本(会话ID) + ") "
        + "SELECT COUNT(*) AS count FROM 当前分支 raw WHERE raw.类型 = 'message.assistant.raw' "
        + "AND raw.载荷JSON LIKE '%\"tool_calls\"%' "
        + "AND EXISTS (SELECT 1 FROM 当前分支 start WHERE start.类型 = 'request.started' "
        + "AND start.载荷JSON = " + 服务SQL文本("{\"source\":\"service\",\"owner_token\":\""
            + 旧所有者 + "\",\"fence\":" + 整数转字符串(旧栅栏) + "}")
        + " AND start.序号 < raw.序号) "
        + "AND NOT EXISTS (SELECT 1 FROM 当前分支 terminal WHERE terminal.序号 > raw.序号 "
        + "AND terminal.类型 IN ('turn.complete', 'turn.failed'))"));
    如果 (工具边界 > 0) {
        变量 工具边界数: 整数 = 0;
        如果 (J.数组长度(工具边界) > 0) {
            工具边界数 = J.获取整数(J.数组获取对象(工具边界, 0), "count");
        }
        J.删除(工具边界);
        如果 (工具边界数 > 0) {
            数据库.执行(服务会话库, "ROLLBACK");
            返回 0;
        }
    }
    如果 (回退未完成写栅栏请求(服务会话库, 会话ID, 旧所有者, 旧栅栏) != 1) {
        数据库.执行(服务会话库, "ROLLBACK");
        返回 0 - 1;
    }
    变量 接管: 整数 = 数据库.执行(服务会话库,
        "UPDATE 服务会话请求锁 SET 所有者令牌 = " + 服务SQL文本(所有者令牌)
        + ", 租约到期毫秒 = " + 整数转字符串(现 + 服务会话租约毫秒)
        + ", 栅栏 = 栅栏 + 1 WHERE 会话ID = " + 服务SQL文本(会话ID)
        + " AND 所有者令牌 = " + 服务SQL文本(旧所有者)
        + " AND 栅栏 = " + 整数转字符串(旧栅栏)
        + " AND 租约到期毫秒 <= " + 整数转字符串(现));
    如果 (接管 != 1 || 数据库.执行(服务会话库, "COMMIT") < 0) {
        数据库.执行(服务会话库, "ROLLBACK");
        返回 0 - 1;
    }
    标记活跃服务会话(会话ID, 所有者令牌);
    返回 1;
}

函数 服务会话锁栅栏(会话ID: 字符串, 所有者令牌: 字符串) : 整数 {
    变量 行集: 整数 = J.解码(数据库.查询(服务会话库,
        "SELECT 栅栏 AS fence FROM 服务会话请求锁 WHERE 会话ID = "
        + 服务SQL文本(会话ID) + " AND 所有者令牌 = " + 服务SQL文本(所有者令牌)));
    如果 (行集 <= 0 || J.数组长度(行集) == 0) { 返回 0; }
    变量 栅栏: 整数 = J.获取整数(J.数组获取对象(行集, 0), "fence");
    J.删除(行集);
    返回 栅栏;
}

函数 续租服务会话锁(会话ID: 字符串, 所有者令牌: 字符串, 栅栏: 整数) : 整数 {
    变量 现: 整数 = 时间.当前毫秒();
    返回 数据库.执行(服务会话库,
        "UPDATE 服务会话请求锁 SET 租约到期毫秒 = "
        + 整数转字符串(现 + 服务会话租约毫秒) + " WHERE 会话ID = "
        + 服务SQL文本(会话ID) + " AND 所有者令牌 = " + 服务SQL文本(所有者令牌)
        + " AND 栅栏 = " + 整数转字符串(栅栏) + " AND 租约到期毫秒 > "
        + 整数转字符串(现));
}

函数 释放服务会话锁(会话ID: 字符串, 所有者令牌: 字符串, 栅栏: 整数) {
    数据库.执行(服务会话库, "DELETE FROM 服务会话请求锁 WHERE 会话ID = "
        + 服务SQL文本(会话ID) + " AND 所有者令牌 = " + 服务SQL文本(所有者令牌)
        + " AND 栅栏 = " + 整数转字符串(栅栏));
    清理活跃服务会话(会话ID, 所有者令牌);
}

// 构 JSON 响应对象 → 字符串（用 J 构建，绝不手拼——手拼会被回复里的引号/换行破坏）。
函数 应答(会话号: 整数, 回复: 字符串) : 字符串 {
    变量 出: 整数 = J.创建对象();
    J.设置整数(出, "会话号", 会话号);
    J.设置字符串(出, "回复", 回复);
    变量 s: 字符串 = J.转字符串(出);
    J.删除(出);
    返回 s;
}

函数 持久应答(会话ID: 字符串, 回复: 字符串) : 字符串 {
    变量 出: 整数 = J.创建对象();
    J.设置字符串(出, "会话ID", 会话ID);
    J.设置字符串(出, "回复", 回复);
    变量 s: 字符串 = J.转字符串(出);
    J.删除(出);
    返回 s;
}

函数 错误应答(消息: 字符串) : 字符串 {
    变量 出: 整数 = J.创建对象();
    J.设置字符串(出, "错误", 消息);
    变量 s: 字符串 = J.转字符串(出);
    J.删除(出);
    返回 s;
}

函数 错误JSON(状态码: 整数, 状态文本: 字符串, 消息: 字符串) : 响应 {
    返回 新建 响应 {
        状态码: 状态码,
        状态文本: 状态文本,
        头部: "Content-Type: application/json; charset=utf-8",
        主体: 错误应答(消息),
    };
}

// 持久模式请求准备：返回 JSON 对象，含 ok/session_id/runtime/expected_leaf/owner_token/fence/error/status。
函数 准备持久请求(入会话ID: 字符串, 所有者: 字符串) : 整数 {
    变量 准备值: 整数 = J.创建对象();
    变量 会话ID: 字符串 = 入会话ID;
    变量 新会话: 整数 = 0;
    如果 (字符串::字节长度(会话ID) == 0) {
        新会话 = 1;
    } 否则 {
        如果 (是有效服务会话ID(会话ID) == 0) {
            J.设置字符串(准备值, "error", "会话ID格式无效");
            J.设置整数(准备值, "status", 400);
            返回 准备值;
        }
        变量 所有者校验: 整数 = 校验会话所有者(会话ID, 所有者);
        如果 (所有者校验 != 1) {
            J.设置字符串(准备值, "error", "会话不可用");
            J.设置整数(准备值, "status", 404);
            返回 准备值;
        }
        // 所有权映射和持久会话必须同时存在，且都在创建 runtime 之前验证。
        如果 (会话存在(服务会话库, 会话ID) == 0) {
            J.设置字符串(准备值, "error", "会话不可用");
            J.设置整数(准备值, "status", 404);
            返回 准备值;
        }
    }

    变量 runtime: 整数 = 新建服务会话();
    如果 (runtime <= 0) {
        J.设置字符串(准备值, "error", "创建 runtime 会话失败");
        J.设置整数(准备值, "status", 500);
        返回 准备值;
    }
    变量 所有者令牌: 字符串 = 随机.UUID();
    如果 (新会话 == 1) {
        会话ID = 创建服务持久会话并加锁(所有者, 所有者令牌);
        如果 (字符串::字节长度(会话ID) == 0) {
            底层模型.关闭会话(runtime);
            J.设置字符串(准备值, "error", "创建持久会话失败");
            J.设置整数(准备值, "status", 500);
            返回 准备值;
        }
    } 否则如果 (获取服务会话锁(会话ID, 所有者令牌) <= 0) {
        底层模型.关闭会话(runtime);
        J.设置字符串(准备值, "error", "会话正由另一个请求更新，请重试");
        J.设置整数(准备值, "status", 409);
        返回 准备值;
    }
    J.设置整数(准备值, "ok", 1);
    J.设置字符串(准备值, "session_id", 会话ID);
    J.设置整数(准备值, "runtime", runtime);
    J.设置字符串(准备值, "expected_leaf", 当前会话叶(服务会话库, 会话ID));
    J.设置字符串(准备值, "owner_token", 所有者令牌);
    J.设置整数(准备值, "fence", 服务会话锁栅栏(会话ID, 所有者令牌));
    返回 准备值;
}

函数 写服务审计(上下文值: 安全上下文, 动作: 字符串, 资源类型: 字符串,
             资源ID: 字符串, 允许: 整数, 原因: 字符串) {
    如果 (字符串::字节长度(服务审计路径) == 0 || 安全上下文有效(上下文值) == 0) { 返回; }
    IO.追加文件(服务审计路径, 安全审计决定信封(上下文值, 动作, 资源类型,
        资源ID, 允许, 原因, 随机.UUID(), 时间.当前毫秒()) + "\n");
}

函数 服务Bearer令牌(上下文值: 上下文) : 字符串 {
    变量 头: 字符串 = 请求头(上下文值, "Authorization");
    如果 (字符串::开始于(头, "Bearer ") == 0) { 返回 ""; }
    返回 字符串::子串从位置(头, 7);
}

函数 创建服务安全上下文(主体: 字符串, 租户: 字符串, 角色: 字符串, 权限: 字符串,
                     认证方式: 字符串, 到期: 整数, 请求配额: 整数,
                     策略: 字符串) : 安全上下文 {
    同步.加锁(服务安全上下文锁);
    变量 安全值: 安全上下文 = 可信适配器创建安全上下文(新建 安全上下文配置 {
        主体ID: 主体, 租户ID: 租户, 角色: 角色, 权限: 权限,
        认证方式: 认证方式, 到期毫秒: 到期, 追踪ID: 随机.UUID(),
        请求配额: 请求配额, 令牌配额: 1, 策略引用: 策略,
    });
    同步.解锁(服务安全上下文锁);
    返回 安全值;
}

函数 服务释放安全上下文(安全值: 安全上下文) {
    同步.加锁(服务安全上下文锁);
    释放安全上下文(安全值);
    同步.解锁(服务安全上下文锁);
}

// 返回 JSON：ok/context/concurrent_limit/legacy_allowed/status/error。凭据从不写入结果或审计。
函数 认证服务请求(上下文值: 上下文) : 整数 {
    变量 认证值: 整数 = J.创建对象();
    变量 令牌: 字符串 = 服务Bearer令牌(上下文值);
    变量 索引: 整数 = 0 - 1;
    如果 (服务认证令牌表 != 0 && 字符串::字节长度(令牌) > 0) {
        索引 = 服务字符串索引(服务认证令牌表, 令牌);
    }
    变量 安全值: 安全上下文 = 新建 安全上下文 { 句柄: 0 };
    变量 并发配额: 整数 = 0;
    如果 (索引 >= 0) {
        安全值 = 创建服务安全上下文(列表库::获取字符串(服务认证主体表, 索引),
            列表库::获取字符串(服务认证租户表, 索引),
            列表库::获取字符串(服务认证角色表, 索引),
            列表库::获取字符串(服务认证权限表, 索引), "static_bearer",
            列表库::获取整数(服务认证到期表, 索引),
            列表库::获取整数(服务认证请求配额表, 索引), "service-static-v1");
        并发配额 = 列表库::获取整数(服务认证并发配额表, 索引);
        J.设置整数(认证值, "legacy_allowed", 0);
    } 否则如果 (字符串::字节长度(令牌) == 0 && 服务允许匿名开发 == 1) {
        安全值 = 创建服务安全上下文("anonymous-dev", 服务匿名开发租户, "agent_user",
            "service.create,service.chat,service.json,service.replay,service.cancel",
            "anonymous_dev", 时间.当前毫秒() + 3600000, 服务匿名开发请求配额,
            "service-dev-opt-in-v1");
        并发配额 = 服务匿名开发并发配额;
        J.设置整数(认证值, "legacy_allowed", 1);
    } 否则 {
        J.设置整数(认证值, "status", 401);
        J.设置字符串(认证值, "error", "需要有效的 Bearer 凭据");
        返回 认证值;
    }
    如果 (安全上下文有效(安全值) == 0 || 安全上下文未过期(安全值, 时间.当前毫秒()) == 0) {
        服务释放安全上下文(安全值);
        J.设置整数(认证值, "status", 401);
        J.设置字符串(认证值, "error", "Bearer 凭据已失效");
        返回 认证值;
    }
    J.设置整数(认证值, "ok", 1);
    J.设置整数(认证值, "context", 安全值.句柄);
    J.设置整数(认证值, "concurrent_limit", 并发配额);
    返回 认证值;
}

函数 安全上下文从句柄(句柄: 整数) : 安全上下文 { 返回 新建 安全上下文 { 句柄: 句柄 }; }

函数 占用服务配额(安全值: 安全上下文, 并发上限: 整数) : 整数 {
    如果 (服务配额库 <= 0) { 返回 0 - 1; }
    变量 主体: 字符串 = 安全上下文主体ID(安全值);
    变量 租户: 字符串 = 安全上下文租户ID(安全值);
    变量 现: 整数 = 时间.当前毫秒();
    变量 现串: 字符串 = 整数转字符串(现);
    变量 窗口串: 字符串 = 整数转字符串(服务配额窗口毫秒);
    变量 写: 整数 = 数据库.执行(服务配额库,
        "INSERT INTO 服务安全配额 (主体ID, 租户ID, 窗口开始, 请求数, 并发数) VALUES ("
        + 服务SQL文本(主体) + ", " + 服务SQL文本(租户) + ", " + 现串 + ", 1, 1) "
        + "ON CONFLICT(主体ID, 租户ID) DO UPDATE SET "
        + "窗口开始 = CASE WHEN " + 现串 + " - 窗口开始 >= " + 窗口串
        + " THEN " + 现串 + " ELSE 窗口开始 END, "
        + "请求数 = CASE WHEN " + 现串 + " - 窗口开始 >= " + 窗口串
        + " THEN 1 ELSE 请求数 + 1 END, 并发数 = 并发数 + 1 "
        + "WHERE (CASE WHEN " + 现串 + " - 窗口开始 >= " + 窗口串
        + " THEN 0 ELSE 请求数 END) < " + 整数转字符串(安全上下文请求配额(安全值))
        + " AND 并发数 < " + 整数转字符串(并发上限));
    如果 (写 < 0) { 返回 0 - 1; }
    如果 (写 == 0) { 返回 0; }
    返回 1;
}

函数 释放服务配额(主体: 字符串, 租户: 字符串) {
    如果 (服务配额库 <= 0) { 返回; }
    数据库.执行(服务配额库, "UPDATE 服务安全配额 SET 并发数 = CASE WHEN 并发数 > 0 "
        + "THEN 并发数 - 1 ELSE 0 END WHERE 主体ID = " + 服务SQL文本(主体)
        + " AND 租户ID = " + 服务SQL文本(租户));
}

函数 校验服务权限(认证值: 整数, 动作: 字符串, 权限: 字符串) : 整数 {
    变量 安全值: 安全上下文 = 安全上下文从句柄(J.获取整数(认证值, "context"));
    如果 (安全上下文具有角色(安全值, "agent_user", 时间.当前毫秒()) == 0
        || 安全上下文具有权限(安全值, 权限, 时间.当前毫秒()) == 0) {
        写服务审计(安全值, 动作, "service", "", 0, "forbidden");
        服务释放安全上下文(安全值);
        J.设置整数(认证值, "ok", 0);
        J.设置整数(认证值, "status", 403);
        J.设置字符串(认证值, "error", "权限不足");
        返回 认证值;
    }
    返回 认证值;
}

函数 占用已授权服务配额(认证值: 整数, 动作: 字符串) : 整数 {
    变量 安全值: 安全上下文 = 安全上下文从句柄(J.获取整数(认证值, "context"));
    变量 配额: 整数 = 占用服务配额(安全值, J.获取整数(认证值, "concurrent_limit"));
    如果 (配额 <= 0) {
        写服务审计(安全值, 动作, "service", "", 0, "quota_exceeded");
        服务释放安全上下文(安全值);
        J.设置整数(认证值, "ok", 0);
        如果 (配额 == 0) { J.设置整数(认证值, "status", 429); J.设置字符串(认证值, "error", "请求配额已用尽"); }
        否则 { J.设置整数(认证值, "status", 500); J.设置字符串(认证值, "error", "配额存储失败"); }
        返回 认证值;
    }
    写服务审计(安全值, 动作, "service", "", 1, "allowed");
    返回 认证值;
}

函数 授权服务请求(认证值: 整数, 动作: 字符串, 权限: 字符串) : 整数 {
    变量 权限结果: 整数 = 校验服务权限(认证值, 动作, 权限);
    如果 (J.获取整数(权限结果, "ok") != 1) { 返回 权限结果; }
    返回 占用已授权服务配额(权限结果, 动作);
}

函数 结束安全请求(配额主体: 字符串, 配额租户: 字符串) {
    释放服务配额(配额主体, 配额租户);
}

函数 安全错误(认证值: 整数) : 响应 {
    变量 状态: 整数 = J.获取整数(认证值, "status");
    变量 消息: 字符串 = J.获取字符串(认证值, "error");
    如果 (状态 == 401) { 返回 错误JSON(401, "Unauthorized", 消息); }
    如果 (状态 == 403) { 返回 错误JSON(403, "Forbidden", 消息); }
    如果 (状态 == 429) { 返回 错误JSON(429, "Too Many Requests", 消息); }
    返回 错误JSON(500, "Internal Server Error", 消息);
}

函数 映射准备错误(状态: 整数, 错误: 字符串) : 响应 {
    如果 (状态 == 400) { 返回 错误JSON(400, "Bad Request", 错误); }
    如果 (状态 == 404) { 返回 错误JSON(404, "Not Found", 错误); }
    如果 (状态 == 409) { 返回 错误JSON(409, "Conflict", 错误); }
    返回 错误JSON(500, "Internal Server Error", 错误);
}

函数 校验服务会话模式(认证值: 整数, 请求对象: 整数) : 响应 {
    如果 (服务会话库 <= 0 && J.获取整数(认证值, "legacy_allowed") != 1) {
        返回 错误JSON(503, "Service Unavailable", "认证服务需要持久会话存储");
    }
    如果 (服务会话库 > 0 && J.是否包含键(请求对象, "会话号") == 1) {
        返回 错误JSON(400, "Bad Request", "持久模式不接受 会话号");
    }
    返回 新建 响应 { 状态码: 0, 状态文本: "", 头部: "", 主体: "" };
}

函数 开始持久运行(会话ID: 字符串, 期望叶: 字符串,
              所有者令牌: 字符串, 栅栏: 整数) : 整数 {
    返回 按写栅栏及期望叶追加会话条目(服务会话库, 会话ID, 期望叶,
        所有者令牌, 栅栏,
        "request.started", "{\"source\":\"service\",\"owner_token\":\""
            + 所有者令牌 + "\",\"fence\":" + 整数转字符串(栅栏) + "}");
}

// POST /chat —— 持久模式使用字符串 会话ID；旧模式才读取整数 会话号。
函数 对话处理器(上下文值: 上下文) : 响应 {
    变量 认证值: 整数 = 认证服务请求(上下文值);
    如果 (J.获取整数(认证值, "ok") != 1) {
        变量 认证响应: 响应 = 安全错误(认证值);
        J.删除(认证值);
        返回 认证响应;
    }
    变量 已认证安全值: 安全上下文 = 安全上下文从句柄(J.获取整数(认证值, "context"));
    变量 主体: 字符串 = 请求主体(上下文值);
    如果 (字符串::字节长度(主体) > 服务最大主体字节) {
        服务释放安全上下文(已认证安全值);
        J.删除(认证值);
        返回 错误JSON(413, "Payload Too Large", "请求体过大");
    }
    变量 o: 整数 = J.解码(主体);
    如果 (o <= 0) {
        服务释放安全上下文(已认证安全值);
        J.删除(认证值);
        返回 错误JSON(400, "Bad Request", "请求体不是合法 JSON");
    }
    变量 模式错误: 响应 = 校验服务会话模式(认证值, o);
    如果 (模式错误.状态码 != 0) {
        J.删除(o);
        服务释放安全上下文(已认证安全值);
        J.删除(认证值);
        返回 模式错误;
    }
    变量 提示: 字符串 = J.获取字符串(o, "提示");
    如果 (字符串::字节长度(提示) == 0) {
        J.删除(o);
        服务释放安全上下文(已认证安全值);
        J.删除(认证值);
        返回 JSON(错误应答("缺少 提示 字段"));
    }
    如果 (字符串::字节长度(提示) > 服务最大提示字节) {
        J.删除(o);
        服务释放安全上下文(已认证安全值);
        J.删除(认证值);
        返回 错误JSON(413, "Payload Too Large", "提示过大");
    }

    变量 入会话ID: 字符串 = J.获取字符串(o, "会话ID");
    变量 动作: 字符串 = "chat";
    变量 权限: 字符串 = "service.chat";
    如果 (服务会话库 > 0 && 字符串::字节长度(入会话ID) == 0) { 动作 = "create"; 权限 = "service.create"; }
    // 已有会话先原子获取会话锁，再占并发配额，确保同会话重叠稳定返回 409。
    变量 后占配额: 整数 = 0;
    如果 (服务会话库 > 0 && 字符串::字节长度(入会话ID) > 0) { 后占配额 = 1; }
    变量 安全准备: 整数 = 0;
    如果 (后占配额 == 1) { 安全准备 = 校验服务权限(认证值, 动作, 权限); }
    否则 { 安全准备 = 授权服务请求(认证值, 动作, 权限); }
    如果 (J.获取整数(安全准备, "ok") != 1) {
        J.删除(o);
        变量 安全响应: 响应 = 安全错误(安全准备);
        J.删除(安全准备);
        返回 安全响应;
    }
    变量 安全值: 安全上下文 = 安全上下文从句柄(J.获取整数(安全准备, "context"));
    变量 配额主体: 字符串 = 安全上下文主体ID(安全值);
    变量 配额租户: 字符串 = 安全上下文租户ID(安全值);
    如果 (后占配额 == 0) {
        服务释放安全上下文(安全值);
        J.删除(安全准备);
    }

    如果 (服务会话库 > 0) {
        变量 准备: 整数 = 准备持久请求(入会话ID, 配额租户);
        J.删除(o);
        如果 (J.获取整数(准备, "ok") != 1) {
            变量 状态: 整数 = J.获取整数(准备, "status");
            变量 错误: 字符串 = J.获取字符串(准备, "error");
            J.删除(准备);
            如果 (后占配额 == 1) {
                如果 (状态 == 409) { 写服务审计(安全值, 动作, "service", "", 0, "session_conflict"); }
                服务释放安全上下文(安全值);
                J.删除(安全准备);
            } 否则 { 结束安全请求(配额主体, 配额租户); }
            返回 映射准备错误(状态, 错误);
        }
        变量 会话ID: 字符串 = J.获取字符串(准备, "session_id");
        变量 runtime: 整数 = J.获取整数(准备, "runtime");
        变量 期望叶: 字符串 = J.获取字符串(准备, "expected_leaf");
        变量 所有者令牌: 字符串 = J.获取字符串(准备, "owner_token");
        变量 栅栏: 整数 = J.获取整数(准备, "fence");
        J.删除(准备);
        如果 (后占配额 == 1) {
            变量 配额准备: 整数 = 占用已授权服务配额(安全准备, 动作);
            如果 (J.获取整数(配额准备, "ok") != 1) {
                底层模型.关闭会话(runtime);
                释放服务会话锁(会话ID, 所有者令牌, 栅栏);
                变量 配额响应: 响应 = 安全错误(配额准备);
                J.删除(配额准备);
                返回 配额响应;
            }
            服务释放安全上下文(安全值);
            J.删除(配额准备);
        }
        变量 持久代理: 代理 = 附加会话写栅栏(
            附加会话存储(创建代理("服务代理", runtime), 服务会话库, 会话ID),
            所有者令牌, 栅栏);
        如果 (恢复持久会话(持久代理) < 0) {
            关闭代理(持久代理);
            释放服务会话锁(会话ID, 所有者令牌, 栅栏);
            结束安全请求(配额主体, 配额租户);
            返回 错误JSON(500, "Internal Server Error", "恢复持久会话失败");
        }
        变量 开始结果: 整数 = 开始持久运行(会话ID, 期望叶, 所有者令牌, 栅栏);
        如果 (开始结果 <= 0) {
            关闭代理(持久代理);
            释放服务会话锁(会话ID, 所有者令牌, 栅栏);
            结束安全请求(配额主体, 配额租户);
            如果 (开始结果 == 0) {
                返回 错误JSON(409, "Conflict", "会话历史已变化，请重试");
            }
            返回 错误JSON(500, "Internal Server Error", "记录会话请求失败");
        }
        如果 (续租服务会话锁(会话ID, 所有者令牌, 栅栏) != 1) {
            关闭代理(持久代理);
            清理活跃服务会话(会话ID, 所有者令牌);
            结束安全请求(配额主体, 配额租户);
            返回 错误JSON(409, "Conflict", "会话租约已被接管，请重试");
        }
        变量 持久回复: 字符串 = "";
        如果 (服务工具数 > 0) {
            持久代理 = 装备服务工具(持久代理);
            持久回复 = 运行(持久代理, 提示);
        } 否则 {
            持久回复 = 简单问(持久代理, 提示);
        }
        关闭代理(持久代理);
        如果 (续租服务会话锁(会话ID, 所有者令牌, 栅栏) != 1) {
            清理活跃服务会话(会话ID, 所有者令牌);
            结束安全请求(配额主体, 配额租户);
            返回 错误JSON(409, "Conflict", "会话租约已被接管，请重试");
        }
        释放服务会话锁(会话ID, 所有者令牌, 栅栏);
        结束安全请求(配额主体, 配额租户);
        返回 JSON(持久应答(会话ID, 持久回复));
    }

    变量 入会话号: 整数 = J.获取整数(o, "会话号");
    J.删除(o);
    变量 会话号: 整数 = 取旧会话(入会话号);
    变量 代理值: 代理 = 创建代理("服务代理", 会话号);
    变量 回复: 字符串 = "";
    如果 (服务工具数 > 0) {
        代理值 = 装备服务工具(代理值);
        回复 = 运行(代理值, 提示);
    } 否则 {
        回复 = 简单问(代理值, 提示);
    }
    结束安全请求(配额主体, 配额租户);
    返回 JSON(应答(会话号, 回复));
}

// POST /json —— 会话协议同 /chat，但始终不装备或执行服务工具。
函数 结构化处理器(上下文值: 上下文) : 响应 {
    变量 认证值: 整数 = 认证服务请求(上下文值);
    如果 (J.获取整数(认证值, "ok") != 1) {
        变量 认证响应: 响应 = 安全错误(认证值);
        J.删除(认证值);
        返回 认证响应;
    }
    变量 已认证安全值: 安全上下文 = 安全上下文从句柄(J.获取整数(认证值, "context"));
    变量 主体: 字符串 = 请求主体(上下文值);
    如果 (字符串::字节长度(主体) > 服务最大主体字节) {
        服务释放安全上下文(已认证安全值);
        J.删除(认证值);
        返回 错误JSON(413, "Payload Too Large", "请求体过大");
    }
    变量 o: 整数 = J.解码(主体);
    如果 (o <= 0) {
        服务释放安全上下文(已认证安全值);
        J.删除(认证值);
        返回 错误JSON(400, "Bad Request", "请求体不是合法 JSON");
    }
    变量 模式错误: 响应 = 校验服务会话模式(认证值, o);
    如果 (模式错误.状态码 != 0) {
        J.删除(o);
        服务释放安全上下文(已认证安全值);
        J.删除(认证值);
        返回 模式错误;
    }
    变量 提示: 字符串 = J.获取字符串(o, "提示");
    变量 字段串: 字符串 = J.获取字符串(o, "字段");
    如果 (字符串::字节长度(提示) == 0) {
        J.删除(o);
        服务释放安全上下文(已认证安全值);
        J.删除(认证值);
        返回 JSON(错误应答("缺少 提示 字段"));
    }
    如果 (字符串::字节长度(提示) > 服务最大提示字节) {
        J.删除(o);
        服务释放安全上下文(已认证安全值);
        J.删除(认证值);
        返回 错误JSON(413, "Payload Too Large", "提示过大");
    }

    变量 入会话ID: 字符串 = J.获取字符串(o, "会话ID");
    变量 后占配额: 整数 = 0;
    如果 (服务会话库 > 0 && 字符串::字节长度(入会话ID) > 0) { 后占配额 = 1; }
    变量 安全准备: 整数 = 0;
    如果 (后占配额 == 1) { 安全准备 = 校验服务权限(认证值, "json", "service.json"); }
    否则 { 安全准备 = 授权服务请求(认证值, "json", "service.json"); }
    如果 (J.获取整数(安全准备, "ok") != 1) {
        J.删除(o);
        变量 安全响应: 响应 = 安全错误(安全准备);
        J.删除(安全准备);
        返回 安全响应;
    }
    变量 安全值: 安全上下文 = 安全上下文从句柄(J.获取整数(安全准备, "context"));
    变量 配额主体: 字符串 = 安全上下文主体ID(安全值);
    变量 配额租户: 字符串 = 安全上下文租户ID(安全值);
    如果 (后占配额 == 0) {
        服务释放安全上下文(安全值);
        J.删除(安全准备);
    }

    // 必需字段列表：把逗号分隔的字段串拆进字符串列表
    变量 字段表: 整数 = 拆字段(字段串);
    如果 (服务会话库 > 0) {
        变量 准备: 整数 = 准备持久请求(入会话ID, 配额租户);
        J.删除(o);
        如果 (J.获取整数(准备, "ok") != 1) {
            变量 状态: 整数 = J.获取整数(准备, "status");
            变量 错误: 字符串 = J.获取字符串(准备, "error");
            J.删除(准备);
            如果 (后占配额 == 1) {
                如果 (状态 == 409) { 写服务审计(安全值, "json", "service", "", 0, "session_conflict"); }
                服务释放安全上下文(安全值);
                J.删除(安全准备);
            } 否则 { 结束安全请求(配额主体, 配额租户); }
            返回 映射准备错误(状态, 错误);
        }
        变量 会话ID: 字符串 = J.获取字符串(准备, "session_id");
        变量 runtime: 整数 = J.获取整数(准备, "runtime");
        变量 期望叶: 字符串 = J.获取字符串(准备, "expected_leaf");
        变量 所有者令牌: 字符串 = J.获取字符串(准备, "owner_token");
        变量 栅栏: 整数 = J.获取整数(准备, "fence");
        J.删除(准备);
        如果 (后占配额 == 1) {
            变量 配额准备: 整数 = 占用已授权服务配额(安全准备, "json");
            如果 (J.获取整数(配额准备, "ok") != 1) {
                底层模型.关闭会话(runtime);
                释放服务会话锁(会话ID, 所有者令牌, 栅栏);
                变量 配额响应: 响应 = 安全错误(配额准备);
                J.删除(配额准备);
                返回 配额响应;
            }
            服务释放安全上下文(安全值);
            J.删除(配额准备);
        }
        变量 持久代理: 代理 = 附加会话写栅栏(
            附加会话存储(创建代理("服务代理", runtime), 服务会话库, 会话ID),
            所有者令牌, 栅栏);
        如果 (恢复持久会话(持久代理) < 0) {
            关闭代理(持久代理);
            释放服务会话锁(会话ID, 所有者令牌, 栅栏);
            结束安全请求(配额主体, 配额租户);
            返回 错误JSON(500, "Internal Server Error", "恢复持久会话失败");
        }
        变量 开始结果: 整数 = 开始持久运行(会话ID, 期望叶, 所有者令牌, 栅栏);
        如果 (开始结果 <= 0) {
            关闭代理(持久代理);
            释放服务会话锁(会话ID, 所有者令牌, 栅栏);
            结束安全请求(配额主体, 配额租户);
            如果 (开始结果 == 0) {
                返回 错误JSON(409, "Conflict", "会话历史已变化，请重试");
            }
            返回 错误JSON(500, "Internal Server Error", "记录会话请求失败");
        }
        如果 (续租服务会话锁(会话ID, 所有者令牌, 栅栏) != 1) {
            关闭代理(持久代理);
            清理活跃服务会话(会话ID, 所有者令牌);
            结束安全请求(配额主体, 配额租户);
            返回 错误JSON(409, "Conflict", "会话租约已被接管，请重试");
        }
        变量 持久结果: 字符串 = 结构化运行(持久代理, 提示, 字段表);
        关闭代理(持久代理);
        如果 (续租服务会话锁(会话ID, 所有者令牌, 栅栏) != 1) {
            清理活跃服务会话(会话ID, 所有者令牌);
            结束安全请求(配额主体, 配额租户);
            返回 错误JSON(409, "Conflict", "会话租约已被接管，请重试");
        }
        释放服务会话锁(会话ID, 所有者令牌, 栅栏);
        结束安全请求(配额主体, 配额租户);
        返回 JSON(持久应答(会话ID, 持久结果));
    }

    变量 入会话号: 整数 = J.获取整数(o, "会话号");
    J.删除(o);
    变量 会话号: 整数 = 取旧会话(入会话号);
    变量 代理值: 代理 = 创建代理("服务代理", 会话号);
    变量 结果值: 字符串 = 结构化运行(代理值, 提示, 字段表);
    结束安全请求(配额主体, 配额租户);
    返回 JSON(应答(会话号, 结果值));
}

// GET /health
函数 健康处理器(上下文值: 上下文) : 响应 {
    变量 出: 整数 = J.创建对象();
    J.设置字符串(出, "状态", "ok");
    J.设置字符串(出, "模型", 服务模型);
    如果 (服务会话库 > 0) {
        J.设置字符串(出, "会话模式", "persistent");
    } 否则如果 (服务认证令牌表 != 0) {
        J.设置字符串(出, "会话模式", "authenticated-fail-closed");
    } 否则 {
        J.设置字符串(出, "会话模式", "anonymous-dev-legacy-runtime-handle");
    }
    变量 s: 字符串 = J.转字符串(出);
    J.删除(出);
    返回 JSON(s);
}

// 逗号分隔字段串 → 标准库.列表 字符串列表句柄（供 结构化运行 的必需字段参数）。
函数 拆字段(字段串: 字符串) : 整数 {
    变量 表: 整数 = 列表库::创建字符串列表();
    变量 段: 整数 = 字符串::分割(字段串, ",");
    变量 n: 整数 = 列表库::字符串列表大小(段);
    变量 i: 整数 = 0;
    当 (i < n) {
        变量 f: 字符串 = 字符串::去空白(列表库::获取字符串(段, i));
        如果 (字符串::字节长度(f) > 0) {
            列表库::添加字符串(表, f);
        }
        i = i + 1;
    }
    返回 表;
}

// 给会话装备服务级工具（若注册过）。
函数 装备服务工具(代理值: 代理) : 代理 {
    如果 (服务工具数 <= 0) {
        返回 代理值;
    }
    变量 i: 整数 = 0;
    当 (i < 服务工具数) {
        变量 t: 工具 = 列表库::获取指针(服务工具表, i);
        代理值 = 添加工具(代理值, t);
        i = i + 1;
    }
    返回 代理值;
}

// 注册一个服务级工具（所有新会话都装备）。启动前调用。
公开 函数 服务注册工具(工具值: 工具) {
    如果 (服务工具表 == 0) {
        服务工具表 = 列表库::创建指针列表();
    }
    列表库::添加指针(服务工具表, 工具值);
    服务工具数 = 服务工具数 + 1;
}

// 启动常驻 agent 服务（阻塞）。
公开 函数 启动代理服务(主机: 字符串, 端口: 整数) {
    如果 (服务认证令牌表 != 0 && 服务会话库 <= 0 && 服务允许匿名开发 != 1) {
        返回;
    }
    如果 (服务安全上下文锁 <= 0) { 服务安全上下文锁 = 同步.创建锁(); }
    如果 (服务活跃会话表 == 0) { 服务活跃会话表 = 哈希表::创建字符串表(); }
    变量 应用值: 应用 = 创建应用();
    应用值 = 配置(应用值, 主机, 端口);
    应用值 = 限制请求大小(应用值, 服务最大主体字节);
    应用值 = 提交(应用值, "/chat", 对话处理器);
    应用值 = 提交(应用值, "/json", 结构化处理器);
    应用值 = 获取(应用值, "/health", 健康处理器);
    运行应用(应用值);
}
