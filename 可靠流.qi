// 可靠流 — DESIGN v2-M1 coordinator over 标准库.大模型 stream-v2 attempts.

包 Harness;

导入 标准库.大模型 作为 底层模型;
导入 标准库.字符串;
导入 标准库.时间;
导入 标准库.随机 作为 随机;
导入 标准库.列表 作为 列表库;
导入 标准库.哈希表 作为 哈希表;
导入 标准库.加密 作为 加密;
导入 标准库.JSON 作为 J;
导入 Harness.代理::{代理, 代理预算句柄};
导入 Harness.运行日志::{创建代理运行, 获取运行租约, 续期运行租约, 释放运行租约,
    获取请求代理运行JSON, 获取代理运行JSON, 列出运行事件, 创建模型尝试,
    更新模型尝试, 追加流运行事件, 终结流运行, 预留运行预算, 结算运行预算,
    保守保留运行预算, 获取运行预算JSON, 恢复终结运行};
导入 Harness.预算::{预留令牌, 结算预留令牌};
导入 Harness.上下文::{估算令牌, 历史令牌估算};
导入 Harness.安全上下文::{安全上下文, 安全会话绑定, 安全上下文未过期, 安全上下文租户ID,
    安全会话绑定有效, 安全会话绑定上下文, 安全会话绑定会话ID};

公开 类型 可靠流配置 { 句柄: 整数 }
公开 类型 取消令牌 { 句柄: 整数 }
公开 类型 流运行结果 { 句柄: 整数 }
公开 类型 可靠流作用域 { 句柄: 整数 }

变量 流表已建: 整数 = 0;
变量 配置有效表: 整数 = 0;
变量 配置首输出表: 整数 = 0;
变量 配置空闲表: 整数 = 0;
变量 配置总超时表: 整数 = 0;
变量 配置最大试次表: 整数 = 0;
变量 配置起始退避表: 整数 = 0;
变量 配置最大退避表: 整数 = 0;
变量 配置预算预留表: 整数 = 0;
变量 取消有效表: 整数 = 0;
变量 取消状态表: 整数 = 0;
变量 取消原因表: 整数 = 0;
变量 作用域代际表: 整数 = 0;
变量 作用域有效表: 整数 = 0;
变量 作用域日志表: 整数 = 0;
变量 作用域安全绑定表: 整数 = 0;
变量 作用域租户表: 整数 = 0;
变量 作用域会话表: 整数 = 0;
变量 结果有效表: 整数 = 0;
变量 结果状态表: 整数 = 0;
变量 结果运行表: 整数 = 0;
变量 结果请求表: 整数 = 0;
变量 结果文本表: 整数 = 0;
变量 结果用量表: 整数 = 0;
变量 结果错误表: 整数 = 0;
变量 结果序号表: 整数 = 0;
变量 作用域句柄跨度: 整数 = 1000000;

函数 新作用域代际(旧代际: 整数) : 整数 {
    变量 代际: 整数 = 随机.生成整数(1000000, 9000000000000);
    当 (代际 == 旧代际) {
        代际 = 随机.生成整数(1000000, 9000000000000);
    }
    返回 代际;
}

函数 确保流表() {
    如果 (流表已建 == 1) { 返回; }
    配置有效表 = 列表库::创建整数列表();
    配置首输出表 = 列表库::创建整数列表();
    配置空闲表 = 列表库::创建整数列表();
    配置总超时表 = 列表库::创建整数列表();
    配置最大试次表 = 列表库::创建整数列表();
    配置起始退避表 = 列表库::创建整数列表();
    配置最大退避表 = 列表库::创建整数列表();
    配置预算预留表 = 列表库::创建整数列表();
    取消有效表 = 列表库::创建整数列表();
    取消状态表 = 列表库::创建整数列表();
    取消原因表 = 哈希表::创建字符串表();
    作用域代际表 = 列表库::创建整数列表();
    作用域有效表 = 列表库::创建整数列表();
    作用域日志表 = 列表库::创建整数列表();
    作用域安全绑定表 = 列表库::创建整数列表();
    作用域租户表 = 哈希表::创建字符串表();
    作用域会话表 = 哈希表::创建字符串表();
    结果有效表 = 列表库::创建整数列表();
    结果状态表 = 哈希表::创建字符串表();
    结果运行表 = 哈希表::创建字符串表();
    结果请求表 = 哈希表::创建字符串表();
    结果文本表 = 哈希表::创建字符串表();
    结果用量表 = 哈希表::创建字符串表();
    结果错误表 = 哈希表::创建字符串表();
    结果序号表 = 列表库::创建整数列表();
    流表已建 = 1;
}

函数 有效索引(表: 整数, 句柄: 整数) : 整数 {
    如果 (句柄 < 0 || 句柄 >= 列表库::整数列表大小(表)) { 返回 0; }
    返回 列表库::获取整数(表, 句柄);
}

公开 函数 默认可靠流配置() : 可靠流配置 {
    确保流表();
    变量 句柄: 整数 = 列表库::整数列表大小(配置有效表);
    列表库::添加整数(配置有效表, 1);
    列表库::添加整数(配置首输出表, 30000);
    列表库::添加整数(配置空闲表, 30000);
    列表库::添加整数(配置总超时表, 120000);
    列表库::添加整数(配置最大试次表, 3);
    列表库::添加整数(配置起始退避表, 100);
    列表库::添加整数(配置最大退避表, 2000);
    列表库::添加整数(配置预算预留表, 4096);
    返回 新建 可靠流配置 { 句柄: 句柄 };
}

公开 函数 配置可靠流预算预留(配置值: 可靠流配置, 预留令牌数: 整数) : 可靠流配置 {
    确保流表();
    如果 (有效索引(配置有效表, 配置值.句柄) == 1 && 预留令牌数 >= 0) {
        列表库::设置整数(配置预算预留表, 配置值.句柄, 预留令牌数);
    }
    返回 配置值;
}

公开 函数 配置可靠流重试(配置值: 可靠流配置, 最大总试次: 整数,
                    起始退避毫秒: 整数, 最大退避毫秒: 整数) : 可靠流配置 {
    确保流表();
    如果 (有效索引(配置有效表, 配置值.句柄) == 0) { 返回 配置值; }
    如果 (最大总试次 > 0) { 列表库::设置整数(配置最大试次表, 配置值.句柄, 最大总试次); }
    如果 (起始退避毫秒 >= 0) { 列表库::设置整数(配置起始退避表, 配置值.句柄, 起始退避毫秒); }
    如果 (最大退避毫秒 >= 0) { 列表库::设置整数(配置最大退避表, 配置值.句柄, 最大退避毫秒); }
    返回 配置值;
}

公开 函数 配置可靠流超时(配置值: 可靠流配置, 首输出超时毫秒: 整数,
                    空闲超时毫秒: 整数, 总超时毫秒: 整数) : 可靠流配置 {
    确保流表();
    如果 (有效索引(配置有效表, 配置值.句柄) == 0) { 返回 配置值; }
    如果 (首输出超时毫秒 > 0) { 列表库::设置整数(配置首输出表, 配置值.句柄, 首输出超时毫秒); }
    如果 (空闲超时毫秒 > 0) { 列表库::设置整数(配置空闲表, 配置值.句柄, 空闲超时毫秒); }
    如果 (总超时毫秒 > 0) { 列表库::设置整数(配置总超时表, 配置值.句柄, 总超时毫秒); }
    返回 配置值;
}

公开 函数 释放可靠流配置(配置值: 可靠流配置) : 整数 {
    确保流表();
    如果 (有效索引(配置有效表, 配置值.句柄) == 0) { 返回 0; }
    列表库::设置整数(配置有效表, 配置值.句柄, 0);
    返回 1;
}

公开 函数 创建取消令牌() : 取消令牌 {
    确保流表();
    变量 句柄: 整数 = 列表库::整数列表大小(取消有效表);
    列表库::添加整数(取消有效表, 1);
    列表库::添加整数(取消状态表, 0);
    哈希表::设置字符串(取消原因表, 整数转字符串(句柄), "");
    返回 新建 取消令牌 { 句柄: 句柄 };
}

公开 函数 请求取消(令牌: 取消令牌, 原因: 字符串) : 整数 {
    确保流表();
    如果 (有效索引(取消有效表, 令牌.句柄) == 0) { 返回 0; }
    列表库::设置整数(取消状态表, 令牌.句柄, 1);
    哈希表::设置字符串(取消原因表, 整数转字符串(令牌.句柄), 原因);
    返回 1;
}

公开 函数 已请求取消(令牌: 取消令牌) : 整数 {
    确保流表();
    如果 (有效索引(取消有效表, 令牌.句柄) == 0) { 返回 0; }
    返回 列表库::获取整数(取消状态表, 令牌.句柄);
}

公开 函数 释放取消令牌(令牌: 取消令牌) : 整数 {
    确保流表();
    如果 (有效索引(取消有效表, 令牌.句柄) == 0) { 返回 0; }
    列表库::设置整数(取消有效表, 令牌.句柄, 0);
    返回 1;
}

函数 空可靠流作用域() : 可靠流作用域 {
    返回 新建 可靠流作用域 { 句柄: 0 };
}

函数 编码作用域句柄(槽位: 整数, 代际: 整数) : 整数 {
    返回 代际 * 作用域句柄跨度 + 槽位 + 1;
}

函数 作用域槽位(句柄: 整数) : 整数 {
    变量 原值: 整数 = 句柄 - 1;
    返回 原值 - (原值 / 作用域句柄跨度) * 作用域句柄跨度;
}

函数 作用域代际(句柄: 整数) : 整数 {
    返回 (句柄 - 1) / 作用域句柄跨度;
}

函数 可靠流作用域有效(作用域值: 可靠流作用域) : 整数 {
    确保流表();
    如果 (作用域值.句柄 <= 作用域句柄跨度) { 返回 0; }
    变量 槽位: 整数 = 作用域槽位(作用域值.句柄);
    如果 (有效索引(作用域有效表, 槽位) == 0
        || 列表库::获取整数(作用域代际表, 槽位) != 作用域代际(作用域值.句柄)) { 返回 0; }
    变量 绑定值: 安全会话绑定 = 新建 安全会话绑定 {
        句柄: 列表库::获取整数(作用域安全绑定表, 槽位),
    };
    变量 现: 整数 = 时间.当前毫秒();
    变量 上下文值: 安全上下文 = 安全会话绑定上下文(绑定值, 现);
    如果 (安全会话绑定有效(绑定值, 现) == 0
        || 字符串::等于(安全上下文租户ID(上下文值),
            哈希表::获取字符串(作用域租户表, 整数转字符串(槽位))) == 0
        || 字符串::等于(安全会话绑定会话ID(绑定值, 现),
            哈希表::获取字符串(作用域会话表, 整数转字符串(槽位))) == 0) { 返回 0; }
    返回 1;
}

函数 可靠流作用域已注册(作用域值: 可靠流作用域) : 整数 {
    确保流表();
    如果 (作用域值.句柄 <= 作用域句柄跨度) { 返回 0; }
    变量 槽位: 整数 = 作用域槽位(作用域值.句柄);
    如果 (有效索引(作用域有效表, 槽位) == 0
        || 列表库::获取整数(作用域代际表, 槽位) != 作用域代际(作用域值.句柄)) { 返回 0; }
    返回 1;
}

// The trusted server adapter supplies the authenticated context and its own session binding.
// Tenant identity is always derived from the context, never accepted as caller text.
公开 函数 创建可靠流作用域(绑定值: 安全会话绑定, 运行日志句柄: 整数) : 可靠流作用域 {
    确保流表();
    变量 现: 整数 = 时间.当前毫秒();
    如果 (运行日志句柄 <= 0 || 安全会话绑定有效(绑定值, 现) == 0) { 返回 空可靠流作用域(); }
    变量 上下文值: 安全上下文 = 安全会话绑定上下文(绑定值, 现);
    变量 租户ID: 字符串 = 安全上下文租户ID(上下文值);
    变量 会话ID: 字符串 = 安全会话绑定会话ID(绑定值, 现);
    如果 (字符串::字节长度(租户ID) == 0 || 字符串::字节长度(会话ID) == 0) { 返回 空可靠流作用域(); }
    变量 槽位: 整数 = 0;
    当 (槽位 < 列表库::整数列表大小(作用域有效表)
        && 列表库::获取整数(作用域有效表, 槽位) == 1) { 槽位 = 槽位 + 1; }
    变量 代际: 整数 = 新作用域代际(0);
    如果 (槽位 == 列表库::整数列表大小(作用域有效表)) {
        列表库::添加整数(作用域代际表, 代际);
        列表库::添加整数(作用域有效表, 1);
        列表库::添加整数(作用域日志表, 运行日志句柄);
        列表库::添加整数(作用域安全绑定表, 绑定值.句柄);
    } 否则 {
        代际 = 新作用域代际(列表库::获取整数(作用域代际表, 槽位));
        列表库::设置整数(作用域代际表, 槽位, 代际);
        列表库::设置整数(作用域有效表, 槽位, 1);
        列表库::设置整数(作用域日志表, 槽位, 运行日志句柄);
        列表库::设置整数(作用域安全绑定表, 槽位, 绑定值.句柄);
    }
    哈希表::设置字符串(作用域租户表, 整数转字符串(槽位), 租户ID);
    哈希表::设置字符串(作用域会话表, 整数转字符串(槽位), 会话ID);
    返回 新建 可靠流作用域 { 句柄: 编码作用域句柄(槽位, 代际) };
}

公开 函数 释放可靠流作用域(作用域值: 可靠流作用域) : 整数 {
    确保流表();
    如果 (可靠流作用域已注册(作用域值) == 0) { 返回 0; }
    变量 槽位: 整数 = 作用域槽位(作用域值.句柄);
    列表库::设置整数(作用域有效表, 槽位, 0);
    列表库::设置整数(作用域日志表, 槽位, 0);
    列表库::设置整数(作用域安全绑定表, 槽位, 0);
    哈希表::设置字符串(作用域租户表, 整数转字符串(槽位), "");
    哈希表::设置字符串(作用域会话表, 整数转字符串(槽位), "");
    返回 1;
}

函数 新结果(状态: 字符串, 运行ID: 字符串, 请求ID: 字符串, 文本: 字符串,
            用量JSON: 字符串, 错误JSON: 字符串, 最后序号: 整数) : 流运行结果 {
    确保流表();
    变量 句柄: 整数 = 列表库::整数列表大小(结果有效表);
    列表库::添加整数(结果有效表, 1);
    列表库::添加整数(结果序号表, 最后序号);
    哈希表::设置字符串(结果状态表, 整数转字符串(句柄), 状态);
    哈希表::设置字符串(结果运行表, 整数转字符串(句柄), 运行ID);
    哈希表::设置字符串(结果请求表, 整数转字符串(句柄), 请求ID);
    哈希表::设置字符串(结果文本表, 整数转字符串(句柄), 文本);
    哈希表::设置字符串(结果用量表, 整数转字符串(句柄), 用量JSON);
    哈希表::设置字符串(结果错误表, 整数转字符串(句柄), 错误JSON);
    返回 新建 流运行结果 { 句柄: 句柄 };
}

公开 函数 流结果状态(结果值: 流运行结果) : 字符串 { 返回 哈希表::获取字符串(结果状态表, 整数转字符串(结果值.句柄)); }
公开 函数 流结果运行ID(结果值: 流运行结果) : 字符串 { 返回 哈希表::获取字符串(结果运行表, 整数转字符串(结果值.句柄)); }
公开 函数 流结果请求ID(结果值: 流运行结果) : 字符串 { 返回 哈希表::获取字符串(结果请求表, 整数转字符串(结果值.句柄)); }
公开 函数 流结果文本(结果值: 流运行结果) : 字符串 { 返回 哈希表::获取字符串(结果文本表, 整数转字符串(结果值.句柄)); }
公开 函数 流结果用量JSON(结果值: 流运行结果) : 字符串 { 返回 哈希表::获取字符串(结果用量表, 整数转字符串(结果值.句柄)); }
公开 函数 流结果错误JSON(结果值: 流运行结果) : 字符串 { 返回 哈希表::获取字符串(结果错误表, 整数转字符串(结果值.句柄)); }
公开 函数 流结果最后序号(结果值: 流运行结果) : 整数 { 返回 列表库::获取整数(结果序号表, 结果值.句柄); }

公开 函数 释放流运行结果(结果值: 流运行结果) : 整数 {
    如果 (有效索引(结果有效表, 结果值.句柄) == 0) { 返回 0; }
    列表库::设置整数(结果有效表, 结果值.句柄, 0);
    返回 1;
}

函数 可靠流首行(文本: 字符串) : 整数 {
    变量 数组值: 整数 = J.解码(文本);
    如果 (数组值 <= 0 || J.数组长度(数组值) == 0) { 返回 0; }
    返回 J.数组获取对象(数组值, 0);
}

函数 错误载荷(代码: 字符串, 消息: 字符串) : 字符串 {
    变量 根: 整数 = J.创建对象();
    J.设置字符串(根, "code", 代码);
    J.设置字符串(根, "message", 消息);
    返回 J.转字符串(根);
}

函数 事件载荷(事件对象: 整数) : 字符串 {
    变量 载荷: 整数 = J.获取对象(事件对象, "payload");
    如果 (载荷 <= 0) { 返回 "{}"; }
    返回 J.转字符串(载荷);
}

函数 事件信封(运行ID: 字符串, 请求ID: 字符串, 会话ID: 字符串,
            尝试ID: 字符串, 序号: 整数, 时间戳: 整数, 事件类型: 字符串,
            载荷JSON: 字符串) : 字符串 {
    变量 根: 整数 = J.创建对象();
    J.设置整数(根, "version", 2);
    J.设置字符串(根, "run_id", 运行ID);
    J.设置字符串(根, "request_id", 请求ID);
    J.设置字符串(根, "session_id", 会话ID);
    J.设置字符串(根, "turn_id", 运行ID);
    J.设置字符串(根, "step_id", "model-0");
    J.设置字符串(根, "attempt_id", 尝试ID);
    J.设置整数(根, "seq", 序号);
    J.设置整数(根, "ts_ms", 时间戳);
    J.设置字符串(根, "type", 事件类型);
    变量 载荷: 整数 = J.解码(载荷JSON);
    如果 (载荷 <= 0) { 载荷 = J.创建对象(); }
    J.设置对象(根, "payload", 载荷);
    返回 J.转字符串(根);
}

函数 回放已有(库: 整数, 行: 整数, 请求ID: 字符串,
            回调: 函数(字符串): 整数) : 流运行结果 {
    变量 运行ID: 字符串 = J.获取字符串(行, "run_id");
    变量 状态: 字符串 = J.获取字符串(行, "status");
    如果 (字符串::等于(状态, "running") == 1) {
        返回 新结果("already_running", 运行ID, 请求ID, "", "", "", J.获取整数(行, "last_seq"));
    }
    变量 事件数组: 整数 = J.解码(列出运行事件(库, 运行ID, 0));
    变量 i: 整数 = 0;
    当 (i < J.数组长度(事件数组)) {
        变量 事件行: 整数 = J.数组获取对象(事件数组, i);
        变量 载荷: 字符串 = J.获取字符串(事件行, "payload_json");
        变量 信封: 字符串 = 事件信封(运行ID, 请求ID, J.获取字符串(行, "session_id"), "",
            J.获取整数(事件行, "seq"), J.获取整数(事件行, "timestamp"),
            J.获取字符串(事件行, "type"), 载荷);
        如果 (回调(信封) != 1) { i = J.数组长度(事件数组); }
        否则 { i = i + 1; }
    }
    返回 新结果(状态, 运行ID, 请求ID, J.获取字符串(行, "final_text"),
        J.获取字符串(行, "usage_json"), J.获取字符串(行, "error_json"),
        J.获取整数(行, "last_seq"));
}

函数 续租(库: 整数, 运行ID: 字符串, 所有者: 字符串, 栅栏: 整数) : 整数 {
    变量 现: 整数 = 时间.当前毫秒();
    返回 续期运行租约(库, 运行ID, 所有者, 栅栏, 现, 现 + 30000);
}

函数 用量令牌(用量JSON: 字符串) : 整数 {
    变量 对象: 整数 = J.解码(用量JSON);
    如果 (对象 <= 0) { 返回 0; }
    变量 总数: 整数 = J.获取整数(对象, "total");
    如果 (总数 <= 0) { 总数 = J.获取整数(对象, "total_tokens"); }
    返回 总数;
}

函数 结算尝试预算(库: 整数, 运行ID: 字符串, 所有者: 字符串, 栅栏: 整数,
            状态: 字符串, 预留ID: 字符串, 预算句柄: 整数, 预留数: 整数,
            用量: 字符串, 已发送: 整数, 请求ID: 字符串, 会话ID: 字符串,
            尝试ID: 字符串, 回调: 函数(字符串): 整数) : 整数 {
    如果 (字符串::字节长度(预留ID) == 0) { 返回 2; }
    变量 已知: 整数 = 0;
    变量 实际: 整数 = 0;
    变量 结算状态: 字符串 = "released";
    变量 使用状态: 字符串 = "not_sent";
    如果 (字符串::字节长度(用量) > 0) {
        已知 = 1;
        实际 = 用量令牌(用量);
        结算状态 = "settled";
        使用状态 = "actual";
    } 否则如果 (已发送 == 1) {
        实际 = 预留数;
        结算状态 = "retained";
        使用状态 = "usage_unknown";
    }
    变量 现: 整数 = 时间.当前毫秒();
    变量 结算值: 整数 = 0;
    如果 (续租(库, 运行ID, 所有者, 栅栏) == 1) {
        结算值 = 结算运行预算(库, 运行ID, 所有者, 栅栏, 状态,
            现, 预留ID, 实际, 0, 结算状态, 使用状态);
    }
    如果 (结算值 <= 0) {
        结算值 = 保守保留运行预算(库, 运行ID, 预留ID, 现);
        如果 (预算句柄 >= 0) {
            结算预留令牌(预算句柄, 预留数, 预留数, 0);
        }
        返回 结算值;
    }
    如果 (结算值 == 1 && 预算句柄 >= 0) {
        如果 (已发送 == 0) { 结算预留令牌(预算句柄, 预留数, 0, 1); }
        否则 { 结算预留令牌(预算句柄, 预留数, 实际, 已知); }
    }
    如果 (结算值 == 1) {
        变量 行: 整数 = 可靠流首行(获取代理运行JSON(库, 运行ID));
        变量 事件类型: 字符串 = "budget.released";
        如果 (字符串::等于(使用状态, "actual") == 1) { 事件类型 = "budget.settled"; }
        否则如果 (字符串::等于(使用状态, "usage_unknown") == 1) { 事件类型 = "budget.usage_unknown"; }
        回调(事件信封(运行ID, 请求ID, 会话ID, 尝试ID, J.获取整数(行, "last_seq"),
            J.获取整数(行, "updated_at"), 事件类型, "{\"tokens\":" + 整数转字符串(实际) + "}"));
    }
    返回 结算值;
}

函数 日志失败结果(库: 整数, 运行ID: 字符串, 请求ID: 字符串,
                    默认文本: 字符串, 默认用量: 字符串, 消息: 字符串) : 流运行结果 {
    变量 行: 整数 = 可靠流首行(获取代理运行JSON(库, 运行ID));
    如果 (行 > 0 && 字符串::等于(J.获取字符串(行, "status"), "running") == 0) {
        返回 新结果(J.获取字符串(行, "status"), 运行ID, 请求ID,
            J.获取字符串(行, "final_text"), J.获取字符串(行, "usage_json"),
            J.获取字符串(行, "error_json"), J.获取整数(行, "last_seq"));
    }
    如果 (行 > 0 && 字符串::等于(J.获取字符串(行, "current_state"), "COMMITTING_FINAL") == 1) {
        返回 新结果("needs_reconciliation", 运行ID, 请求ID, 默认文本, 默认用量,
            错误载荷("needs_reconciliation", 消息), J.获取整数(行, "last_seq"));
    }
    变量 序号: 整数 = 0;
    如果 (行 > 0) { 序号 = J.获取整数(行, "last_seq"); }
    返回 新结果("stale_writer", 运行ID, 请求ID, 默认文本, 默认用量,
        错误载荷("stale_writer", 消息), 序号);
}

// Takes over an expired running run and terminates it from journal state only.
// It never opens a model stream. Repeating recovery replays the existing terminal run.
公开 函数 恢复过期可靠流运行(作用域值: 可靠流作用域, 运行ID: 字符串,
                    当前时间: 整数, 回调: 函数(字符串): 整数) : 流运行结果 {
    确保流表();
    如果 (可靠流作用域有效(作用域值) == 0) {
        返回 新结果("failed", 运行ID, "", "", "", 错误载荷("invalid_scope", "可靠流作用域无效"), 0);
    }
    变量 作用域索引: 整数 = 作用域槽位(作用域值.句柄);
    变量 库: 整数 = 列表库::获取整数(作用域日志表, 作用域索引);
    变量 行: 整数 = 可靠流首行(获取代理运行JSON(库, 运行ID));
    如果 (行 <= 0 || 字符串::等于(J.获取字符串(行, "tenant_id"),
        哈希表::获取字符串(作用域租户表, 整数转字符串(作用域索引))) == 0
        || 字符串::等于(J.获取字符串(行, "session_id"),
        哈希表::获取字符串(作用域会话表, 整数转字符串(作用域索引))) == 0) {
        返回 新结果("failed", 运行ID, "", "", "", 错误载荷("run_not_found", "运行不存在"), 0);
    }
    变量 请求ID: 字符串 = J.获取字符串(行, "request_id");
    如果 (字符串::等于(J.获取字符串(行, "status"), "running") == 0) {
        返回 回放已有(库, 行, 请求ID, 回调);
    }
    变量 所有者: 字符串 = "recovery-" + 随机.UUID();
    变量 栅栏: 整数 = 获取运行租约(库, 运行ID, 所有者, 当前时间, 当前时间 + 30000);
    如果 (栅栏 <= 0) { 返回 新结果("already_running", 运行ID, 请求ID, "", "", "", J.获取整数(行, "last_seq")); }
    行 = 可靠流首行(获取代理运行JSON(库, 运行ID));
    变量 状态: 字符串 = J.获取字符串(行, "current_state");
    变量 预算数组: 整数 = J.解码(获取运行预算JSON(库, 运行ID));
    变量 i: 整数 = 0;
    当 (i < J.数组长度(预算数组)) {
        变量 预算行: 整数 = J.数组获取对象(预算数组, i);
        如果 (字符串::等于(J.获取字符串(预算行, "status"), "reserved") == 1) {
            变量 恢复结算: 整数 = 结算运行预算(库, 运行ID, 所有者, 栅栏, 状态, 当前时间,
                J.获取字符串(预算行, "reservation_id"), J.获取整数(预算行, "reserved_tokens"),
                J.获取整数(预算行, "reserved_cost_micros"), "retained", "usage_unknown");
            如果 (恢复结算 <= 0) {
                保守保留运行预算(库, 运行ID, J.获取字符串(预算行, "reservation_id"), 当前时间);
            } 否则如果 (恢复结算 == 1) {
                变量 预算后行: 整数 = 可靠流首行(获取代理运行JSON(库, 运行ID));
                回调(事件信封(运行ID, 请求ID, J.获取字符串(行, "session_id"), "",
                    J.获取整数(预算后行, "last_seq"), 当前时间, "budget.usage_unknown",
                    "{\"recovered\":true}"));
            }
        }
        i = i + 1;
    }
    变量 终态: 字符串 = "FAILED";
    变量 运行状态: 字符串 = "failed";
    变量 事件类型: 字符串 = "run.failed";
    如果 (J.获取整数(行, "partial_output_committed") == 1) {
        终态 = "INCOMPLETE"; 运行状态 = "incomplete"; 事件类型 = "run.incomplete";
    }
    如果 (字符串::等于(状态, "COMMITTING_FINAL") == 1) {
        终态 = "NEEDS_RECONCILIATION"; 运行状态 = "needs_reconciliation";
        事件类型 = "run.needs_reconciliation";
    }
    变量 错误: 字符串 = 错误载荷("stale_run_recovered", "过期运行已由日志恢复，未再次调用 provider");
    变量 序号: 整数 = 恢复终结运行(库, 运行ID, 所有者, 栅栏, 状态, 当前时间,
        终态, 运行状态, 事件类型, 错误);
    如果 (序号 <= 0) {
        释放运行租约(库, 运行ID, 所有者, 栅栏, 当前时间);
        返回 日志失败结果(库, 运行ID, 请求ID, J.获取字符串(行, "final_text"),
            J.获取字符串(行, "usage_json"), "恢复终态日志提交失败");
    }
    如果 (序号 > 0 && 序号 != 2) {
        回调(事件信封(运行ID, 请求ID, J.获取字符串(行, "session_id"), "", 序号,
            当前时间, 事件类型, 错误));
    }
    释放运行租约(库, 运行ID, 所有者, 栅栏, 当前时间);
    行 = 可靠流首行(获取代理运行JSON(库, 运行ID));
    返回 新结果(J.获取字符串(行, "status"), 运行ID, 请求ID,
        J.获取字符串(行, "final_text"), J.获取字符串(行, "usage_json"),
        J.获取字符串(行, "error_json"), J.获取整数(行, "last_seq"));
}

公开 函数 重放流事件(作用域值: 可靠流作用域, 运行ID: 字符串,
                    之后序号: 整数, 回调: 函数(字符串): 整数) : 整数 {
    确保流表();
    如果 (可靠流作用域有效(作用域值) == 0) { 返回 0 - 1; }
    变量 作用域索引: 整数 = 作用域槽位(作用域值.句柄);
    变量 库: 整数 = 列表库::获取整数(作用域日志表, 作用域索引);
    变量 行: 整数 = 可靠流首行(获取代理运行JSON(库, 运行ID));
    如果 (行 <= 0 || 字符串::等于(J.获取字符串(行, "tenant_id"),
        哈希表::获取字符串(作用域租户表, 整数转字符串(作用域索引))) == 0
        || 字符串::等于(J.获取字符串(行, "session_id"),
        哈希表::获取字符串(作用域会话表, 整数转字符串(作用域索引))) == 0) { 返回 0 - 1; }
    变量 数组值: 整数 = J.解码(列出运行事件(库, 运行ID, 之后序号));
    变量 i: 整数 = 0;
    当 (i < J.数组长度(数组值)) {
        变量 事件行: 整数 = J.数组获取对象(数组值, i);
        变量 信封: 字符串 = 事件信封(运行ID, J.获取字符串(行, "request_id"),
            J.获取字符串(行, "session_id"), "", J.获取整数(事件行, "seq"),
            J.获取整数(事件行, "timestamp"), J.获取字符串(事件行, "type"),
            J.获取字符串(事件行, "payload_json"));
        变量 接受: 整数 = 回调(信封);
        如果 (接受 != 1) { 返回 接受; }
        i = i + 1;
    }
    返回 i;
}

函数 终结并回调(库: 整数, 运行ID: 字符串, 请求ID: 字符串, 会话ID: 字符串,
            所有者: 字符串, 栅栏: 整数, 当前状态: 字符串, 终态: 字符串,
            状态: 字符串, 事件类型: 字符串, 文本: 字符串, 用量: 字符串,
            错误: 字符串, 已输出: 整数, 尝试ID: 字符串,
            回调: 函数(字符串): 整数) : 流运行结果 {
    变量 现: 整数 = 时间.当前毫秒();
    变量 载荷: 字符串 = "{}";
    如果 (字符串::字节长度(错误) > 0) { 载荷 = 错误; }
    变量 序号: 整数 = 终结流运行(库, 运行ID, 所有者, 栅栏, 当前状态, 终态,
        状态, 事件类型, 现, 载荷, 已输出, 文本, 用量, 错误);
    如果 (序号 <= 0) {
        释放运行租约(库, 运行ID, 所有者, 栅栏, 时间.当前毫秒());
        返回 日志失败结果(库, 运行ID, 请求ID, 文本, 用量, "终态日志提交失败");
    }
    回调(事件信封(运行ID, 请求ID, 会话ID, 尝试ID, 序号, 现, 事件类型, 载荷));
    释放运行租约(库, 运行ID, 所有者, 栅栏, 时间.当前毫秒());
    返回 新结果(状态, 运行ID, 请求ID, 文本, 用量, 错误, 序号);
}

函数 可靠流运行时可用() : 整数 {
    如果 (底层模型.能力版本("stream_v2") < 1) { 返回 0; }
    如果 (底层模型.能力版本("stream_v2_timed_poll") < 1) { 返回 0; }
    返回 1;
}

公开 函数 可靠流式运行(作用域值: 可靠流作用域, 代理值: 代理, 提示: 字符串,
                    请求ID: 字符串, 配置值: 可靠流配置, 取消值: 取消令牌,
                    事件回调: 函数(字符串): 整数) : 流运行结果 {
    确保流表();
    如果 (可靠流作用域有效(作用域值) == 0
        || 有效索引(配置有效表, 配置值.句柄) == 0
        || 有效索引(取消有效表, 取消值.句柄) == 0
        || 代理值.会话句柄 <= 0 || 字符串::字节长度(请求ID) == 0) {
        返回 新结果("failed", "", 请求ID, "", "", 错误载荷("invalid_argument", "可靠流参数无效"), 0);
    }
    如果 (可靠流运行时可用() == 0) {
        返回 新结果("failed", "", 请求ID, "", "",
            错误载荷("unsupported_runtime", "runtime 缺少 stream_v2 timed poll"), 0);
    }
    变量 作用域索引: 整数 = 作用域槽位(作用域值.句柄);
    变量 库: 整数 = 列表库::获取整数(作用域日志表, 作用域索引);
    变量 租户ID: 字符串 = 哈希表::获取字符串(作用域租户表, 整数转字符串(作用域索引));
    变量 会话ID: 字符串 = 哈希表::获取字符串(作用域会话表, 整数转字符串(作用域索引));
    变量 请求哈希: 字符串 = 加密.SHA256哈希(会话ID + "\n" + 提示);
    变量 已有: 整数 = 可靠流首行(获取请求代理运行JSON(库, 租户ID, 会话ID, 请求ID));
    如果 (已有 > 0) {
        如果 (字符串::等于(J.获取字符串(已有, "request_hash"), 请求哈希) == 0) {
            返回 新结果("failed", J.获取字符串(已有, "run_id"), 请求ID, "", "",
                错误载荷("idempotency_conflict", "相同 request_id 的请求内容不同"), J.获取整数(已有, "last_seq"));
        }
        返回 回放已有(库, 已有, 请求ID, 事件回调);
    }

    变量 运行ID: 字符串 = 随机.UUID();
    变量 现: 整数 = 时间.当前毫秒();
    变量 创建值: 整数 = 创建代理运行(库, 运行ID, 租户ID, 会话ID, 请求ID, 请求哈希, "NEW", 现);
    如果 (创建值 != 1) {
        已有 = 可靠流首行(获取请求代理运行JSON(库, 租户ID, 会话ID, 请求ID));
        如果 (已有 > 0 && 字符串::等于(J.获取字符串(已有, "request_hash"), 请求哈希) == 1) {
            返回 回放已有(库, 已有, 请求ID, 事件回调);
        }
        返回 新结果("failed", 运行ID, 请求ID, "", "", 错误载荷("journal_conflict", "无法创建运行日志"), 0);
    }
    变量 所有者: 字符串 = "local-placeholder-" + 随机.UUID();
    变量 栅栏: 整数 = 获取运行租约(库, 运行ID, 所有者, 现, 现 + 30000);
    如果 (栅栏 <= 0) { 返回 新结果("already_running", 运行ID, 请求ID, "", "", "", 0); }

    变量 状态: 字符串 = "NEW";
    变量 事件时间: 整数 = 时间.当前毫秒();
    变量 序号: 整数 = 追加流运行事件(库, 运行ID, 所有者, 栅栏, 状态, "ATTEMPT_OPENING",
        "run.started", 事件时间, "{}", 0);
    状态 = "ATTEMPT_OPENING";
    如果 (序号 > 0 && 事件回调(事件信封(运行ID, 请求ID, 会话ID, "", 序号,
        事件时间, "run.started", "{}")) == 0) { 请求取消(取消值, "callback_cancelled"); }

    变量 最大试次: 整数 = 列表库::获取整数(配置最大试次表, 配置值.句柄);
    变量 延迟: 整数 = 列表库::获取整数(配置起始退避表, 配置值.句柄);
    变量 最大延迟: 整数 = 列表库::获取整数(配置最大退避表, 配置值.句柄);
    变量 首输出超时: 整数 = 列表库::获取整数(配置首输出表, 配置值.句柄);
    变量 空闲超时: 整数 = 列表库::获取整数(配置空闲表, 配置值.句柄);
    变量 总超时: 整数 = 列表库::获取整数(配置总超时表, 配置值.句柄);
    变量 试次: 整数 = 1;
    变量 已输出: 整数 = 0;
    变量 文本: 字符串 = "";
    变量 用量: 字符串 = "";
    变量 最后错误: 字符串 = "";
    变量 继续尝试: 整数 = 1;
    变量 开始时间: 整数 = 时间.当前毫秒();
    变量 首次输出时间: 整数 = 0;

    当 (继续尝试 == 1 && 试次 <= 最大试次) {
        如果 (时间.当前毫秒() - 开始时间 >= 总超时) {
            最后错误 = 错误载荷("total_timeout", "可靠流超过总超时");
            返回 终结并回调(库, 运行ID, 请求ID, 会话ID, 所有者, 栅栏, 状态,
                "FAILED", "failed", "run.failed", 文本, 用量, 最后错误, 已输出, "", 事件回调);
        }
        如果 (续租(库, 运行ID, 所有者, 栅栏) != 1) {
            返回 日志失败结果(库, 运行ID, 请求ID, 文本, 用量, "运行租约已丢失");
        }
        如果 (已请求取消(取消值) == 1) {
            返回 终结并回调(库, 运行ID, 请求ID, 会话ID, 所有者, 栅栏, 状态,
                "CANCELLED", "cancelled", "run.cancelled", 文本, 用量,
                错误载荷("cancelled", 哈希表::获取字符串(取消原因表, 整数转字符串(取消值.句柄))),
                已输出, "", 事件回调);
        }
        变量 尝试ID: 字符串 = 随机.UUID();
        如果 (创建模型尝试(库, 运行ID, 所有者, 栅栏, 状态, 时间.当前毫秒(), 尝试ID,
            "model-0", 试次, "opening", "unknown") == 0) {
            返回 日志失败结果(库, 运行ID, 请求ID, 文本, 用量, "无法创建 fenced attempt");
        }
        事件时间 = 时间.当前毫秒();
        序号 = 追加流运行事件(库, 运行ID, 所有者, 栅栏, 状态, "PREFETCHING",
            "attempt.started", 事件时间, "{\"attempt\":" + 整数转字符串(试次) + "}", 已输出);
        状态 = "PREFETCHING";
        如果 (序号 > 0 && 事件回调(事件信封(运行ID, 请求ID, 会话ID, 尝试ID, 序号,
            事件时间, "attempt.started", "{\"attempt\":" + 整数转字符串(试次) + "}")) == 0) {
            请求取消(取消值, "callback_cancelled");
        }

        变量 预留数: 整数 = 列表库::获取整数(配置预算预留表, 配置值.句柄);
        变量 输入估算: 整数 = 历史令牌估算(代理值.会话句柄) + 估算令牌(提示) + 4;
        变量 最大输出: 整数 = 预留数 - 输入估算;
        变量 预留ID: 字符串 = "";
        如果 (最大输出 <= 0) {
            最后错误 = 错误载荷("budget_exceeded", "预算预留不足以容纳估算输入和正数输出上限");
            更新模型尝试(库, 运行ID, 所有者, 栅栏, 状态, 时间.当前毫秒(), 尝试ID,
                "rejected", "", 0, "", "not_sent", 最后错误);
            返回 终结并回调(库, 运行ID, 请求ID, 会话ID, 所有者, 栅栏, 状态,
                "BUDGET_EXCEEDED", "budget_exceeded", "run.budget_exceeded", 文本, 用量,
                最后错误, 已输出, 尝试ID, 事件回调);
        }
        变量 代理预算: 整数 = 代理预算句柄(代理值);
        如果 (代理预算 >= 0) {
            如果 (预留令牌(代理预算, 预留数) == 0) {
                最后错误 = 错误载荷("budget_exceeded", "预算无法为本次 provider attempt 预留容量");
                更新模型尝试(库, 运行ID, 所有者, 栅栏, 状态, 时间.当前毫秒(), 尝试ID,
                    "rejected", "", 0, "", "not_sent", 最后错误);
                返回 终结并回调(库, 运行ID, 请求ID, 会话ID, 所有者, 栅栏, 状态,
                    "BUDGET_EXCEEDED", "budget_exceeded", "run.budget_exceeded", 文本, 用量,
                    最后错误, 已输出, 尝试ID, 事件回调);
            }
        }
        预留ID = 随机.UUID();
        事件时间 = 时间.当前毫秒();
        变量 预留载荷: 字符串 = "{\"tokens\":" + 整数转字符串(预留数) + "}";
        变量 预留结果: 整数 = 预留运行预算(库, 运行ID, 所有者, 栅栏, 状态,
            事件时间, 预留ID, 尝试ID, 租户ID, 预留数, 0, "estimated");
        如果 (预留结果 <= 0) {
            如果 (代理预算 >= 0) {
                结算预留令牌(代理预算, 预留数, 0, 1);
            }
            返回 日志失败结果(库, 运行ID, 请求ID, 文本, 用量,
                "预算预留未通过 fenced journal");
        }
        序号 = J.获取整数(可靠流首行(获取代理运行JSON(库, 运行ID)), "last_seq");
        事件回调(事件信封(运行ID, 请求ID, 会话ID, 尝试ID, 序号, 事件时间,
            "budget.reserved", 预留载荷));

        变量 历史版本: 整数 = 底层模型.历史版本(代理值.会话句柄);
        变量 请求对象: 整数 = J.创建对象();
        J.设置字符串(请求对象, "prompt", 提示);
        J.设置整数(请求对象, "max_tokens", 最大输出);
        // Once open is invoked the request may have reached the provider even if no
        // stream handle is returned, so missing usage must settle conservatively.
        变量 已发送: 整数 = 1;
        变量 尝试开始: 整数 = 时间.当前毫秒();
        变量 最后事件时间: 整数 = 尝试开始;
        变量 流: 整数 = 底层模型.打开流V2(代理值.会话句柄, J.转字符串(请求对象));
        如果 (流 <= 0) {
            最后错误 = 错误载荷("open_failed", "打开 stream_v2 失败: " + 整数转字符串(流));
            更新模型尝试(库, 运行ID, 所有者, 栅栏, 状态, 时间.当前毫秒(), 尝试ID,
                "failed", "", 0, "", "unknown", 最后错误);
            结算尝试预算(库, 运行ID, 所有者, 栅栏, 状态, 预留ID,
                代理预算, 预留数, "", 已发送, 请求ID, 会话ID, 尝试ID, 事件回调);
        } 否则 {
            变量 本次结束: 整数 = 0;
            变量 本次超时: 整数 = 0;
            当 (本次结束 == 0) {
                如果 (已请求取消(取消值) == 1) {
                    底层模型.取消流V2(流, 哈希表::获取字符串(取消原因表, 整数转字符串(取消值.句柄)));
                }
                变量 轮询时间: 整数 = 时间.当前毫秒();
                变量 等待毫秒: 整数 = 总超时 - (轮询时间 - 开始时间);
                如果 (已输出 == 0 && 首输出超时 - (轮询时间 - 尝试开始) < 等待毫秒) {
                    等待毫秒 = 首输出超时 - (轮询时间 - 尝试开始);
                }
                如果 (空闲超时 - (轮询时间 - 最后事件时间) < 等待毫秒) {
                    等待毫秒 = 空闲超时 - (轮询时间 - 最后事件时间);
                }
                如果 (等待毫秒 < 0) { 等待毫秒 = 0; }
                变量 原事件: 字符串 = 底层模型.限时读取流事件V2(流, 等待毫秒);
                如果 (字符串::字节长度(原事件) == 0) {
                    最后错误 = 错误载荷("unexpected_eof", "runtime 事件流未给出终止事件");
                    本次结束 = 1;
                } 否则 {
                    变量 事件对象: 整数 = J.解码(原事件);
                    变量 类型值: 字符串 = J.获取字符串(事件对象, "type");
                    变量 载荷JSON: 字符串 = 事件载荷(事件对象);
                    如果 (字符串::等于(类型值, "poll.timeout") == 1) {
                        变量 超时时间: 整数 = 时间.当前毫秒();
                        变量 超时代码: 字符串 = "";
                        变量 超时消息: 字符串 = "";
                        如果 (超时时间 - 开始时间 >= 总超时) {
                            超时代码 = "total_timeout";
                            超时消息 = "可靠流超过总超时";
                        } 否则如果 (已输出 == 0 && 超时时间 - 尝试开始 >= 首输出超时) {
                            超时代码 = "first_output_timeout";
                            超时消息 = "可靠流首输出超时";
                        } 否则如果 (超时时间 - 最后事件时间 >= 空闲超时) {
                            超时代码 = "idle_timeout";
                            超时消息 = "可靠流空闲超时";
                        }
                        如果 (字符串::字节长度(超时代码) > 0) {
                            最后错误 = 错误载荷(超时代码, 超时消息);
                            底层模型.取消流V2(流, 超时代码);
                            事件时间 = 超时时间;
                            序号 = 追加流运行事件(库, 运行ID, 所有者, 栅栏, 状态, 状态,
                                "attempt.timeout", 事件时间, 最后错误, 已输出);
                            如果 (序号 <= 0) {
                                底层模型.放弃流V2(流); 底层模型.关闭流V2(流);
                                返回 日志失败结果(库, 运行ID, 请求ID, 文本, 用量,
                                    "超时事件提交被新 fence 拒绝");
                            }
                            事件回调(事件信封(运行ID, 请求ID, 会话ID, 尝试ID, 序号,
                                事件时间, "attempt.timeout", 最后错误));
                            本次超时 = 1;
                            本次结束 = 1;
                        }
                    } 否则 {
                    最后事件时间 = 时间.当前毫秒();
                    变量 语义输出: 整数 = 0;
                    如果 (字符串::等于(类型值, "text.delta") == 1 || 字符串::等于(类型值, "tool_call.delta") == 1) {
                        语义输出 = 1;
                    }
                    变量 候选已输出: 整数 = 已输出;
                    如果 (语义输出 == 1) { 候选已输出 = 1; }
                    变量 候选文本: 字符串 = 文本;
                    如果 (字符串::等于(类型值, "text.delta") == 1) {
                        变量 载荷对象: 整数 = J.获取对象(事件对象, "payload");
                        候选文本 = 文本 + J.获取字符串(载荷对象, "text");
                    }
                    如果 (字符串::等于(类型值, "usage") == 1) {
                        变量 用量载荷: 整数 = J.获取对象(事件对象, "payload");
                        如果 (用量载荷 > 0
                            && 字符串::等于(J.获取字符串(用量载荷, "status"), "usage_unknown") == 0) {
                            用量 = 载荷JSON;
                        }
                    }
                    变量 期望事件状态: 字符串 = 状态;
                    变量 新状态: 字符串 = 状态;
                    如果 (语义输出 == 1) { 新状态 = "STREAMING"; }
                    事件时间 = 时间.当前毫秒();
                    序号 = 追加流运行事件(库, 运行ID, 所有者, 栅栏,
                        期望事件状态,
                        新状态, 类型值, 事件时间, 载荷JSON, 候选已输出);
                    如果 (序号 > 0) {
                        状态 = 新状态;
                        如果 (已输出 == 0 && 候选已输出 == 1) { 首次输出时间 = 事件时间; }
                        已输出 = 候选已输出;
                        文本 = 候选文本;
                    }
                    否则 {
                        底层模型.放弃流V2(流); 底层模型.关闭流V2(流);
                        结算尝试预算(库, 运行ID, 所有者, 栅栏, 状态, 预留ID,
                            代理预算, 预留数, 用量, 已发送,
                            请求ID, 会话ID, 尝试ID, 事件回调);
                        返回 日志失败结果(库, 运行ID, 请求ID, 文本, 用量,
                            "事件提交被新 fence 拒绝");
                    }
                    变量 回调值: 整数 = 1;
                    如果 (序号 > 0) { 回调值 = 事件回调(事件信封(运行ID, 请求ID, 会话ID, 尝试ID,
                        序号, 事件时间, 类型值, 载荷JSON)); }
                    如果 (回调值 == 0) {
                        请求取消(取消值, "callback_cancelled");
                        底层模型.取消流V2(流, "callback_cancelled");
                    } 否则如果 (回调值 < 0) {
                        请求取消(取消值, "consumer_failed");
                        底层模型.取消流V2(流, "consumer_failed");
                        最后错误 = 错误载荷("consumer_failed", "事件消费者返回失败");
                    }
                    如果 (字符串::等于(类型值, "response.completed") == 1) {
                        事件时间 = 时间.当前毫秒();
                        变量 提交序号: 整数 = 追加流运行事件(库, 运行ID, 所有者, 栅栏, 状态,
                            "COMMITTING_FINAL", "run.committing_final", 事件时间, "{}", 已输出);
                        如果 (提交序号 <= 0) {
                            底层模型.放弃流V2(流); 底层模型.关闭流V2(流);
                            结算尝试预算(库, 运行ID, 所有者, 栅栏, 状态, 预留ID,
                                代理预算, 预留数, 用量, 已发送,
                                请求ID, 会话ID, 尝试ID, 事件回调);
                            返回 日志失败结果(库, 运行ID, 请求ID, 文本, 用量,
                                "最终提交 fence 已失效");
                        }
                        状态 = "COMMITTING_FINAL";
                        事件回调(事件信封(运行ID, 请求ID, 会话ID, 尝试ID, 提交序号,
                            事件时间, "run.committing_final", "{}"));
                        变量 新版本: 整数 = 底层模型.提交流V2(流, 历史版本);
                        如果 (新版本 > 历史版本) {
                            变量 使用状态: 字符串 = "unknown";
                            如果 (字符串::字节长度(用量) > 0) { 使用状态 = "known"; }
                            更新模型尝试(库, 运行ID, 所有者, 栅栏, 状态, 时间.当前毫秒(), 尝试ID,
                                "completed", "", 首次输出时间, 用量, 使用状态, "");
                            变量 最终结算: 整数 = 结算尝试预算(库, 运行ID, 所有者, 栅栏, 状态, 预留ID,
                                代理预算, 预留数, 用量, 已发送,
                                请求ID, 会话ID, 尝试ID, 事件回调);
                            底层模型.关闭流V2(流);
                            如果 (最终结算 <= 0) {
                                返回 日志失败结果(库, 运行ID, 请求ID, 文本, 用量,
                                    "最终预算结算需要对账");
                            }
                            返回 终结并回调(库, 运行ID, 请求ID, 会话ID, 所有者, 栅栏, 状态,
                                "COMPLETED", "completed", "run.completed", 文本, 用量, "", 已输出,
                                尝试ID, 事件回调);
                        }
                        最后错误 = 错误载荷("history_conflict", "提交历史版本冲突");
                        更新模型尝试(库, 运行ID, 所有者, 栅栏, 状态, 时间.当前毫秒(), 尝试ID,
                            "needs_reconciliation", "", 0, 用量, "unknown", 最后错误);
                        结算尝试预算(库, 运行ID, 所有者, 栅栏, 状态, 预留ID,
                            代理预算, 预留数, 用量, 已发送,
                            请求ID, 会话ID, 尝试ID, 事件回调);
                        底层模型.放弃流V2(流);
                        底层模型.关闭流V2(流);
                        返回 终结并回调(库, 运行ID, 请求ID, 会话ID, 所有者, 栅栏, 状态,
                            "NEEDS_RECONCILIATION", "needs_reconciliation", "run.needs_reconciliation",
                            文本, 用量, 最后错误, 已输出, 尝试ID, 事件回调);
                    } 否则如果 (字符串::等于(类型值, "error") == 1) {
                        最后错误 = 载荷JSON;
                        本次结束 = 1;
                    } 否则如果 (字符串::等于(类型值, "cancelled") == 1) {
                        更新模型尝试(库, 运行ID, 所有者, 栅栏, 状态, 时间.当前毫秒(), 尝试ID,
                            "cancelled", "", 0, 用量, "unknown", 载荷JSON);
                        结算尝试预算(库, 运行ID, 所有者, 栅栏, 状态, 预留ID,
                            代理预算, 预留数, 用量, 已发送,
                            请求ID, 会话ID, 尝试ID, 事件回调);
                        底层模型.放弃流V2(流);
                        底层模型.关闭流V2(流);
                        如果 (字符串::包含(最后错误, "consumer_failed") == 1) {
                            返回 终结并回调(库, 运行ID, 请求ID, 会话ID, 所有者, 栅栏, 状态,
                                "CONSUMER_FAILED", "consumer_failed", "run.consumer_failed", 文本, 用量,
                                最后错误, 已输出, 尝试ID, 事件回调);
                        }
                        返回 终结并回调(库, 运行ID, 请求ID, 会话ID, 所有者, 栅栏, 状态,
                            "CANCELLED", "cancelled", "run.cancelled", 文本, 用量, 载荷JSON,
                            已输出, 尝试ID, 事件回调);
                    }
                    }
                }
            }
            底层模型.放弃流V2(流);
            底层模型.关闭流V2(流);
            变量 尝试状态: 字符串 = "failed";
            如果 (本次超时 == 1) { 尝试状态 = "timed_out"; }
            更新模型尝试(库, 运行ID, 所有者, 栅栏, 状态, 时间.当前毫秒(), 尝试ID,
                尝试状态, "", 首次输出时间, 用量, "unknown", 最后错误);
            结算尝试预算(库, 运行ID, 所有者, 栅栏, 状态, 预留ID,
                代理预算, 预留数, 用量, 已发送,
                请求ID, 会话ID, 尝试ID, 事件回调);
        }

        如果 (已输出 == 1) {
            返回 终结并回调(库, 运行ID, 请求ID, 会话ID, 所有者, 栅栏, 状态,
                "INCOMPLETE", "incomplete", "run.incomplete", 文本, 用量, 最后错误,
                1, 尝试ID, 事件回调);
        }
        如果 (试次 >= 最大试次) {
            返回 终结并回调(库, 运行ID, 请求ID, 会话ID, 所有者, 栅栏, 状态,
                "FAILED", "failed", "run.failed", 文本, 用量, 最后错误, 0,
                尝试ID, 事件回调);
        }
        如果 (时间.当前毫秒() - 开始时间 >= 总超时) {
            最后错误 = 错误载荷("total_timeout", "可靠流超过总超时");
            返回 终结并回调(库, 运行ID, 请求ID, 会话ID, 所有者, 栅栏, 状态,
                "FAILED", "failed", "run.failed", 文本, 用量, 最后错误, 0,
                尝试ID, 事件回调);
        }
        事件时间 = 时间.当前毫秒();
        序号 = 追加流运行事件(库, 运行ID, 所有者, 栅栏, 状态, "ATTEMPT_OPENING",
            "attempt.retrying", 事件时间, 最后错误, 0);
        状态 = "ATTEMPT_OPENING";
        如果 (序号 > 0 && 事件回调(事件信封(运行ID, 请求ID, 会话ID, 尝试ID, 序号,
            事件时间, "attempt.retrying", 最后错误)) == 0) {
            请求取消(取消值, "callback_cancelled");
        }
        变量 剩余总时间: 整数 = 总超时 - (时间.当前毫秒() - 开始时间);
        如果 (延迟 > 剩余总时间) { 延迟 = 剩余总时间; }
        如果 (延迟 > 0) { 时间.睡眠毫秒(延迟); }
        延迟 = 延迟 * 2;
        如果 (延迟 > 最大延迟) { 延迟 = 最大延迟; }
        试次 = 试次 + 1;
    }
    返回 终结并回调(库, 运行ID, 请求ID, 会话ID, 所有者, 栅栏, 状态,
        "FAILED", "failed", "run.failed", 文本, 用量, 最后错误, 已输出, "", 事件回调);
}
