// 命令行 - qi-harness developer CLI 的可测试辅助逻辑

包 Harness;

导入 标准库.数据库;
导入 标准库.字符串;
导入 标准库.操作系统 作为 系统;
导入 标准库.JSON 作为 J;

// 显式参数优先，其次 QI_SESSION_DB，最后使用用户主目录下的单文件数据库。
公开 函数 CLI会话数据库路径(显式路径: 字符串) : 字符串 {
    如果 (字符串::字节长度(显式路径) > 0) { 返回 显式路径; }
    变量 环境路径: 字符串 = 系统.获取环境变量("QI_SESSION_DB");
    如果 (字符串::字节长度(环境路径) > 0) { 返回 环境路径; }
    变量 主目录: 字符串 = 系统.获取环境变量("HOME");
    如果 (字符串::字节长度(主目录) > 0) { 返回 主目录 + "/.qi-harness-sessions.db"; }
    返回 "/tmp/qi-harness-sessions.db";
}

// 支持仓库现有的两套 provider 环境变量约定。
公开 函数 CLI提供商就绪(聊天URL: 字符串, 聊天密钥: 字符串, 聊天模型: 字符串,
                       通用密钥: 字符串, DeepSeek密钥: 字符串) : 整数 {
    如果 (字符串::字节长度(聊天URL) > 0
        && 字符串::字节长度(聊天密钥) > 0
        && 字符串::字节长度(聊天模型) > 0) { 返回 1; }
    如果 (字符串::字节长度(通用密钥) > 0) { 返回 1; }
    如果 (字符串::字节长度(DeepSeek密钥) > 0) { 返回 1; }
    返回 0;
}

公开 函数 CLI嵌入就绪(嵌入URL: 字符串, 嵌入密钥: 字符串, 嵌入模型: 字符串) : 整数 {
    如果 (字符串::字节长度(嵌入URL) > 0
        && 字符串::字节长度(嵌入密钥) > 0
        && 字符串::字节长度(嵌入模型) > 0) { 返回 1; }
    返回 0;
}

公开 函数 CLIMCP就绪(MCP命令: 字符串, MCP网址: 字符串) : 整数 {
    如果 (字符串::字节长度(MCP命令) > 0 || 字符串::字节长度(MCP网址) > 0) { 返回 1; }
    返回 0;
}

函数 配置状态(已配置: 整数) : 字符串 {
    如果 (已配置 == 1) { 返回 "configured"; }
    返回 "unconfigured";
}

// 只输出配置状态和选中的约定，不输出 URL、命令、模型、路径或密钥值。
公开 函数 CLI诊断JSON(聊天URL: 字符串, 聊天密钥: 字符串, 聊天模型: 字符串,
                     通用基址: 字符串, 通用密钥: 字符串, 通用模型: 字符串,
                     DeepSeek密钥: 字符串,
                     嵌入URL: 字符串, 嵌入密钥: 字符串, 嵌入模型: 字符串,
                     MCP命令: 字符串, MCP网址: 字符串,
                     会话数据库可访问: 整数) : 字符串 {
    变量 聊天就绪: 整数 = CLI提供商就绪(聊天URL, 聊天密钥, 聊天模型, 通用密钥, DeepSeek密钥);
    变量 聊天模式: 字符串 = "none";
    如果 (字符串::字节长度(聊天URL) > 0
        && 字符串::字节长度(聊天密钥) > 0
        && 字符串::字节长度(聊天模型) > 0) {
        聊天模式 = "chat";
    } 否则如果 (字符串::字节长度(通用密钥) > 0) {
        聊天模式 = "llm";
    } 否则如果 (字符串::字节长度(DeepSeek密钥) > 0) {
        聊天模式 = "deepseek";
    }

    变量 根: 整数 = J.创建对象();
    变量 聊天: 整数 = J.创建对象();
    J.设置字符串(聊天, "status", 配置状态(聊天就绪));
    J.设置字符串(聊天, "mode", 聊天模式);
    J.设置布尔(聊天, "ready", 聊天就绪);
    J.设置布尔(聊天, "chat_url_configured", 字符串::字节长度(聊天URL) > 0);
    J.设置布尔(聊天, "chat_key_configured", 字符串::字节长度(聊天密钥) > 0);
    J.设置布尔(聊天, "chat_model_configured", 字符串::字节长度(聊天模型) > 0);
    J.设置布尔(聊天, "llm_base_configured", 字符串::字节长度(通用基址) > 0);
    J.设置布尔(聊天, "llm_key_configured", 字符串::字节长度(通用密钥) > 0);
    J.设置布尔(聊天, "llm_model_configured", 字符串::字节长度(通用模型) > 0);
    J.设置布尔(聊天, "deepseek_key_configured", 字符串::字节长度(DeepSeek密钥) > 0);
    J.设置对象(根, "chat", 聊天);

    变量 嵌入: 整数 = J.创建对象();
    变量 嵌入就绪: 整数 = CLI嵌入就绪(嵌入URL, 嵌入密钥, 嵌入模型);
    J.设置字符串(嵌入, "status", 配置状态(嵌入就绪));
    J.设置布尔(嵌入, "ready", 嵌入就绪);
    J.设置布尔(嵌入, "url_configured", 字符串::字节长度(嵌入URL) > 0);
    J.设置布尔(嵌入, "key_configured", 字符串::字节长度(嵌入密钥) > 0);
    J.设置布尔(嵌入, "model_configured", 字符串::字节长度(嵌入模型) > 0);
    J.设置对象(根, "embedding", 嵌入);

    变量 MCP: 整数 = J.创建对象();
    变量 MCP就绪: 整数 = CLIMCP就绪(MCP命令, MCP网址);
    J.设置字符串(MCP, "status", 配置状态(MCP就绪));
    J.设置布尔(MCP, "ready", MCP就绪);
    J.设置布尔(MCP, "command_configured", 字符串::字节长度(MCP命令) > 0);
    J.设置布尔(MCP, "url_configured", 字符串::字节长度(MCP网址) > 0);
    J.设置对象(根, "mcp", MCP);

    变量 会话: 整数 = J.创建对象();
    J.设置字符串(会话, "status", 配置状态(会话数据库可访问));
    J.设置布尔(会话, "accessible", 会话数据库可访问);
    J.设置对象(根, "session_db", 会话);
    返回 J.转字符串(根);
}

// 返回按创建时间排序的会话摘要 JSON。查询不拼接用户输入。
公开 函数 CLI列出会话JSON(库: 整数) : 字符串 {
    如果 (库 <= 0) { 返回 "[]"; }
    返回 数据库.查询(库, "SELECT 会话ID AS session_id, 当前叶 AS leaf_entry_id, "
        + "创建时间戳 AS created_at, "
        + "(SELECT COUNT(*) FROM 会话条目 e WHERE e.会话ID = s.会话ID) AS entry_count "
        + "FROM 持久会话 s ORDER BY 创建时间戳, 会话ID");
}

函数 CLI轮已完成(路径: 整数, 开始索引: 整数, 轮ID: 字符串) : 整数 {
    变量 i: 整数 = 开始索引 + 1;
    当 (i < J.数组长度(路径)) {
        变量 条目: 整数 = J.数组获取对象(路径, i);
        变量 类型值: 字符串 = J.获取字符串(条目, "type");
        如果 (字符串::等于(类型值, "turn.start") == 1) { 返回 0; }
        如果 (字符串::等于(类型值, "turn.complete") == 1) {
            变量 载荷: 整数 = J.解码(J.获取字符串(条目, "payload_json"));
            如果 (载荷 > 0 && 字符串::等于(J.获取字符串(载荷, "turn_id"), 轮ID) == 1) {
                返回 1;
            }
        }
        i = i + 1;
    }
    返回 0;
}

// 与恢复会话到运行时使用相同筛选规则，但只返回元数据，不创建 provider 会话。
公开 函数 CLI恢复信息JSON(会话ID: 字符串, 当前叶: 字符串, 路径JSON: 字符串) : 字符串 {
    变量 路径: 整数 = J.解码(路径JSON);
    如果 (路径 <= 0) { 返回 ""; }
    变量 可恢复: 整数 = J.创建数组();
    变量 当前轮可恢复: 整数 = 1;
    变量 i: 整数 = 0;
    当 (i < J.数组长度(路径)) {
        变量 条目: 整数 = J.数组获取对象(路径, i);
        变量 类型值: 字符串 = J.获取字符串(条目, "type");
        变量 载荷: 整数 = J.解码(J.获取字符串(条目, "payload_json"));
        如果 (字符串::等于(类型值, "turn.start") == 1) {
            当前轮可恢复 = 0;
            如果 (载荷 > 0) {
                当前轮可恢复 = CLI轮已完成(路径, i, J.获取字符串(载荷, "turn_id"));
            }
        } 否则如果 (载荷 > 0 && 当前轮可恢复 == 1) {
            变量 角色: 字符串 = "";
            如果 (字符串::等于(类型值, "message.user") == 1
                || 字符串::等于(类型值, "message.assistant") == 1) {
                角色 = J.获取字符串(载荷, "role");
            } 否则如果 (字符串::等于(类型值, "message.assistant.raw") == 1) {
                角色 = "assistant";
            } 否则如果 (字符串::等于(类型值, "tool.result") == 1) {
                角色 = "tool";
            }
            如果 (字符串::字节长度(角色) > 0) {
                变量 项: 整数 = J.创建对象();
                J.设置字符串(项, "entry_id", J.获取字符串(条目, "entry_id"));
                J.设置字符串(项, "type", 类型值);
                J.设置字符串(项, "role", 角色);
                J.数组添加对象(可恢复, 项);
            }
        }
        i = i + 1;
    }
    变量 根: 整数 = J.创建对象();
    J.设置字符串(根, "session_id", 会话ID);
    J.设置字符串(根, "leaf_entry_id", 当前叶);
    J.设置整数(根, "path_entry_count", J.数组长度(路径));
    J.设置整数(根, "restorable_message_count", J.数组长度(可恢复));
    J.设置数组(根, "restorable_messages", 可恢复);
    返回 J.转字符串(根);
}
